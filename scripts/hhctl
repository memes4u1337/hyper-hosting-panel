#!/usr/bin/env bash
set -Eeuo pipefail

CONF="/etc/hyper-host/hyper-host.conf"
[[ -f "$CONF" ]] || { echo "Config not found: $CONF" >&2; exit 2; }
# shellcheck disable=SC1090
source "$CONF"

PANEL_NAME="${PANEL_NAME:-HYPER-HOST}"
POWERED_BY="${POWERED_BY:-powered by memes4u1337}"
SERVER_IP="${SERVER_IP:-$(hostname -I 2>/dev/null | awk '{print $1}')}"
PANEL_DOMAIN="${PANEL_DOMAIN:-_}"
BASE_DIR="${BASE_DIR:-/opt/hyper-host}"
PANEL_DIR="${PANEL_DIR:-/var/www/hyper-host}"
SITES_DIR="${SITES_DIR:-/var/www/hyper-host-sites}"
BOTS_DIR="${BOTS_DIR:-/var/www/hyper-host-bots}"
FTP_DIR="${FTP_DIR:-/var/www/hyper-host-ftp}"
PHP_FPM_SOCK="${PHP_FPM_SOCK:-}"
PHPMYADMIN_PATH="${PHPMYADMIN_PATH:-/usr/share/phpmyadmin}"
BACKUP_DIR="${BACKUP_DIR:-$BASE_DIR/backups}"
DNS_DIR="${DNS_DIR:-/etc/bind/hyper-host-zones}"
CRON_DIR="/etc/cron.d"
NGINX_AVAILABLE="/etc/nginx/sites-available"
NGINX_ENABLED="/etc/nginx/sites-enabled"

export PANEL_NAME POWERED_BY SERVER_IP PANEL_DOMAIN BASE_DIR PANEL_DIR SITES_DIR BOTS_DIR FTP_DIR PHP_FPM_SOCK PHPMYADMIN_PATH BACKUP_DIR

log() { echo "[hhctl] $*"; }
err() { echo "[hhctl error] $*" >&2; exit 1; }
valid_domain() { [[ "$1" =~ ^([A-Za-z0-9]([A-Za-z0-9-]{0,61}[A-Za-z0-9])?\.)+[A-Za-z]{2,63}$ ]]; }
valid_name() { [[ "$1" =~ ^[A-Za-z0-9_][A-Za-z0-9_-]{1,63}$ ]]; }
valid_folder() { [[ "$1" =~ ^[A-Za-z0-9._-]{1,80}$ ]] && [[ "$1" != "." && "$1" != ".." ]]; }
valid_db_name() { [[ "$1" =~ ^[A-Za-z0-9_]{2,48}$ ]]; }
sql_escape() { printf "%s" "$1" | sed "s/'/''/g"; }
json_escape() { python3 -c 'import json,sys; print(json.dumps(sys.argv[1], ensure_ascii=False))' "$1"; }

ensure_nologin_shell() {
  if [[ -x /usr/sbin/nologin ]] && ! grep -qxF /usr/sbin/nologin /etc/shells 2>/dev/null; then echo /usr/sbin/nologin >> /etc/shells; fi
  if [[ -x /bin/false ]] && ! grep -qxF /bin/false /etc/shells 2>/dev/null; then echo /bin/false >> /etc/shells; fi
}
ensure_dirs() { mkdir -p "$SITES_DIR" "$BOTS_DIR" "$FTP_DIR" "$BACKUP_DIR" "$BASE_DIR/templates" "$BASE_DIR/data"; }
nginx_reload() { nginx -t >/dev/null; systemctl reload nginx; }

fix_web_permissions() {
  local path="$1" user="${2:-}"
  [[ -e "$path" ]] || return 0
  chgrp -R www-data "$path" 2>/dev/null || true
  chmod -R u+rwX,g+rwX,o+rX "$path" 2>/dev/null || true
  find "$path" -type d -exec chmod g+s {} + 2>/dev/null || true
  if command -v setfacl >/dev/null 2>&1; then
    setfacl -R -m u:www-data:rwx,g:www-data:rwx "$path" 2>/dev/null || true
    setfacl -R -d -m u:www-data:rwx,g:www-data:rwx "$path" 2>/dev/null || true
    if [[ -n "$user" ]]; then
      setfacl -R -m u:"$user":rwx "$path" 2>/dev/null || true
      setfacl -R -d -m u:"$user":rwx "$path" 2>/dev/null || true
    fi
  fi
}

php_index_template_file() {
  local title="$1" file="$2"
  mkdir -p "$(dirname "$file")"
  cat > "$file" <<EOPHP
<?php http_response_code(200); ?>
<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1">
  <title>${title} — HYPER-HOST</title>
  <style>:root{color-scheme:dark}*{box-sizing:border-box}body{margin:0;min-height:100vh;display:grid;place-items:center;background:radial-gradient(circle at 20% 20%,#2563eb44,transparent 32%),radial-gradient(circle at 90% 10%,#9333ea44,transparent 30%),linear-gradient(135deg,#070a14,#101827);color:#fff;font-family:Inter,Arial,sans-serif}.box{width:min(860px,92vw);padding:44px;border:1px solid rgba(255,255,255,.14);border-radius:32px;background:rgba(15,23,42,.78);box-shadow:0 40px 120px rgba(0,0,0,.55);backdrop-filter:blur(18px)}.logo{display:inline-flex;gap:10px;align-items:center;padding:10px 14px;border:1px solid rgba(255,255,255,.14);border-radius:999px;background:rgba(255,255,255,.06);color:#93c5fd}h1{margin:18px 0 12px;font-size:clamp(36px,6vw,64px);letter-spacing:-.05em}.muted{color:#b7c2d8;font-size:18px;line-height:1.65}.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin-top:26px}.item{padding:16px;border-radius:18px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1)}code{color:#a7f3d0}.powered{margin-top:24px;color:#a78bfa}</style>
</head>
<body><main class="box"><div class="logo">🚀 HYPER-HOST</div><h1>${title}</h1><p class="muted">Сайт/папка создана. Загрузи файлы через FTP или файловый менеджер и замени этот стартовый экран.</p><div class="grid"><div class="item">Корень: <code>public_html</code></div><div class="item">PHP: <code>работает</code></div><div class="item">Панель: <code>HYPER-HOST</code></div></div><div class="powered">powered by memes4u1337</div></main></body></html>
EOPHP
}

php_sock_for_version() {
  local version="$1"
  if [[ -n "$version" && -S "/run/php/php${version}-fpm.sock" ]]; then echo "/run/php/php${version}-fpm.sock"; return; fi
  echo "$PHP_FPM_SOCK"
}

cmd_create_folder() {
  ensure_dirs
  local name="${1:-}"; [[ -n "$name" ]] || err "Folder name required"; valid_folder "$name" || err "Invalid folder name: $name"
  local root="$SITES_DIR/$name/public_html"
  mkdir -p "$root" "$SITES_DIR/$name/logs"
  [[ -f "$root/index.php" || -f "$root/index.html" ]] || php_index_template_file "$name" "$root/index.php"
  chown -R www-data:www-data "$SITES_DIR/$name" 2>/dev/null || true
  fix_web_permissions "$SITES_DIR/$name"
  log "Folder created: $name -> $root"
}
cmd_delete_folder() { local name="${1:-}"; [[ -n "$name" ]] || err "Folder name required"; valid_folder "$name" || err "Invalid folder name"; rm -rf "$SITES_DIR/$name"; log "Folder deleted: $name"; }

cmd_add_site() {
  ensure_dirs
  local domain="${1:-}" aliases="${2:-}" phpv="${3:-}"
  [[ -n "$domain" ]] || err "Domain required"; valid_domain "$domain" || err "Invalid domain: $domain"
  local root="$SITES_DIR/$domain/public_html" sock; sock="$(php_sock_for_version "$phpv")"
  mkdir -p "$root" "$SITES_DIR/$domain/logs"
  [[ -f "$root/index.php" || -f "$root/index.html" ]] || php_index_template_file "$domain работает" "$root/index.php"
  chown -R www-data:www-data "$SITES_DIR/$domain" 2>/dev/null || true
  fix_web_permissions "$SITES_DIR/$domain"
  local server_names="$domain"
  if [[ -n "$aliases" ]]; then
    IFS=',' read -ra arr <<< "$aliases"
    for a in "${arr[@]}"; do a="$(echo "$a" | xargs)"; [[ -z "$a" ]] && continue; valid_domain "$a" || err "Invalid alias: $a"; server_names="$server_names $a"; done
  fi
  cat > "$NGINX_AVAILABLE/hyper-host-site-$domain.conf" <<EONGINX
server {
    listen 80;
    listen [::]:80;
    server_name ${server_names};
    root ${root};
    index index.php index.html index.htm;
    client_max_body_size 1024M;
    access_log ${SITES_DIR}/${domain}/logs/access.log;
    error_log ${SITES_DIR}/${domain}/logs/error.log;
    location / { try_files \$uri \$uri/ /index.php?\$query_string; }
    location ~ \.php$ { include snippets/fastcgi-php.conf; fastcgi_pass unix:${sock}; }
    location ~ /\. { deny all; }
}
EONGINX
  ln -sf "$NGINX_AVAILABLE/hyper-host-site-$domain.conf" "$NGINX_ENABLED/hyper-host-site-$domain.conf"
  nginx_reload
  log "Site created: $domain -> $root"
}
cmd_delete_site() { local domain="${1:-}" mode="${2:---keep-files}"; [[ -n "$domain" ]] || err "Domain required"; valid_domain "$domain" || err "Invalid domain"; rm -f "$NGINX_ENABLED/hyper-host-site-$domain.conf" "$NGINX_AVAILABLE/hyper-host-site-$domain.conf"; nginx_reload; [[ "$mode" == "--delete-files" ]] && rm -rf "$SITES_DIR/$domain"; log "Site deleted: $domain / $mode"; }
public_ip() {
  curl -4 -fsS --max-time 5 https://api.ipify.org 2>/dev/null || curl -4 -fsS --max-time 5 https://ifconfig.me 2>/dev/null || echo "$SERVER_IP"
}
resolve_domain_ips() {
  local domain="$1"
  { dig +short A "$domain" 2>/dev/null; dig +short AAAA "$domain" 2>/dev/null; } | sed '/^$/d' | sort -u
}
dns_points_here() {
  local domain="$1" pub ips
  pub="$(public_ip)"; ips="$(resolve_domain_ips "$domain")"
  [[ -n "$ips" ]] || return 2
  echo "$ips" | grep -qxF "$pub" && return 0
  echo "$ips" | grep -qxF "$SERVER_IP" && return 0
  return 1
}
cmd_ssl_check_json() {
  local domain="${1:-}"; [[ -n "$domain" ]] || err "Domain required"; valid_domain "$domain" || err "Invalid domain"
  DOMAIN="$domain" SERVER_IP="$SERVER_IP" PUBLIC_IP="$(public_ip)" python3 - <<'PYSSL'
import os,subprocess,json
D=os.environ['DOMAIN']
def dig(t):
    try: return [x.strip() for x in subprocess.check_output(['dig','+short',t,D],text=True,stderr=subprocess.DEVNULL).splitlines() if x.strip()]
    except Exception: return []
a=dig('A'); aaaa=dig('AAAA')
public=os.environ.get('PUBLIC_IP',''); server=os.environ.get('SERVER_IP','')
points=bool(set(a+aaaa) & {public,server})
print(json.dumps({'domain':D,'a':a,'aaaa':aaaa,'server_ip':server,'public_ip':public,'points_here':points,'has_records':bool(a or aaaa)},ensure_ascii=False))
PYSSL
}
cmd_ssl_site() {
  local domain="${1:-}" email="${2:-}"
  [[ -n "$domain" && -n "$email" ]] || err "Domain and email required"
  valid_domain "$domain" || err "Invalid domain"
  local pub ips
  pub="$(public_ip)"; ips="$(resolve_domain_ips "$domain")"
  if [[ -z "$ips" ]]; then
    err "SSL не выпущен: у домена $domain нет публичных A/AAAA записей. Добавь DNS A: $domain -> $pub, подожди обновления DNS и повтори выпуск SSL. Проверка: dig +short $domain"
  fi
  if ! dns_points_here "$domain"; then
    err "SSL не выпущен: DNS $domain сейчас указывает не на этот сервер. Текущие DNS: ${ips//$'\n'/, }. IP сервера: $pub. Исправь A-запись на $pub и повтори."
  fi
  certbot --nginx -d "$domain" --non-interactive --agree-tos -m "$email" --redirect
  nginx_reload
  log "SSL issued for $domain"
}

cmd_site_php() {
  local domain="${1:-}" version="${2:-}"; [[ -n "$domain" && -n "$version" ]] || err "Domain and PHP version required"; valid_domain "$domain" || err "Invalid domain"
  local conf="$NGINX_AVAILABLE/hyper-host-site-$domain.conf" sock; [[ -f "$conf" ]] || err "Nginx config not found: $conf"; sock="$(php_sock_for_version "$version")"; [[ -S "$sock" ]] || err "PHP-FPM socket not found: $sock"
  sed -i -E "s#fastcgi_pass unix:[^;]+;#fastcgi_pass unix:${sock};#" "$conf"
  nginx_reload; log "PHP version for $domain -> $version"
}

cmd_create_ftp() {
  ensure_dirs; ensure_nologin_shell
  local username="${1:-}" password="${2:-}" mode="${3:-common}"
  [[ -n "$username" && -n "$password" ]] || err "Username and password required"; valid_name "$username" || err "Invalid ftp username"
  [[ "$username" == hhftp_* ]] || username="hhftp_${username}"
  local home="$FTP_DIR/$username" common="$home/common" sites="$common/sites" bots="$common/bots"
  mkdir -p "$common" "$sites" "$bots" "$SITES_DIR" "$BOTS_DIR"
  if id "$username" >/dev/null 2>&1; then
    usermod -d "$home" -s /usr/sbin/nologin "$username" || true
    echo "$username:$password" | chpasswd
  else
    useradd -m -d "$home" -s /usr/sbin/nologin "$username"
    echo "$username:$password" | chpasswd
  fi
  usermod -aG www-data "$username" 2>/dev/null || true
  chown root:root "$home"; chmod 0755 "$home"
  chown -R "$username":www-data "$common"; chmod -R u+rwX,g+rwX,o+rX "$common"
  find "$common" -type d -exec chmod g+s {} + 2>/dev/null || true
  # В FTP пользователь видит одну общую папку common/, а внутри common/sites и common/bots.
  for pair in "$SITES_DIR:$sites" "$BOTS_DIR:$bots"; do
    src="${pair%%:*}"; dst="${pair#*:}"
    mkdir -p "$src" "$dst"
    if ! mountpoint -q "$dst"; then mount --bind "$src" "$dst" 2>/dev/null || true; fi
    if mountpoint -q "$dst" && ! grep -qs " $dst " /etc/fstab; then echo "$src $dst none bind 0 0" >> /etc/fstab; fi
  done
  fix_web_permissions "$SITES_DIR" "$username"
  fix_web_permissions "$BOTS_DIR" "$username"
  fix_web_permissions "$common" "$username"
  systemctl restart vsftpd
  log "FTP user ready: $username -> $home/common (sites/bots inside common)"
}
cmd_delete_ftp() {
  local username="${1:-}"; [[ -n "$username" ]] || err "Username required"; valid_name "$username" || err "Invalid username"; [[ "$username" == hhftp_* ]] || username="hhftp_${username}"
  local home="$FTP_DIR/$username"
  for d in "$home/sites" "$home/bots" "$home/site"; do mountpoint -q "$d" && umount "$d" || true; done
  if [[ -f /etc/fstab ]]; then tmp="$(mktemp)"; grep -vF " $home/sites " /etc/fstab | grep -vF " $home/bots " | grep -vF " $home/site " > "$tmp" || true; cat "$tmp" > /etc/fstab; rm -f "$tmp"; fi
  id "$username" >/dev/null 2>&1 && userdel "$username" || true
  rm -rf "$home"; systemctl restart vsftpd || true; log "FTP user deleted: $username"
}
cmd_ftp_password() { local username="${1:-}" password="${2:-}"; [[ -n "$username" && -n "$password" ]] || err "Username and password required"; valid_name "$username" || err "Invalid username"; [[ "$username" == hhftp_* ]] || username="hhftp_${username}"; id "$username" >/dev/null 2>&1 || err "FTP user not found"; echo "$username:$password" | chpasswd; fix_web_permissions "$SITES_DIR" "$username"; log "FTP password updated: $username"; }

cmd_create_db() {
  local db="${1:-}" user="${2:-}" pass="${3:-}" remote="${4:-0}"; [[ -n "$db" && -n "$user" && -n "$pass" ]] || err "DB, user and password required"; valid_db_name "$db" || err "Invalid db name"; valid_db_name "$user" || err "Invalid db user"; epass="$(sql_escape "$pass")"
  mysql <<SQL
CREATE DATABASE IF NOT EXISTS \`${db}\` CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
CREATE USER IF NOT EXISTS '${user}'@'localhost' IDENTIFIED BY '${epass}';
ALTER USER '${user}'@'localhost' IDENTIFIED BY '${epass}';
GRANT ALL PRIVILEGES ON \`${db}\`.* TO '${user}'@'localhost';
SQL
  if [[ "$remote" == "1" ]]; then mysql <<SQL
CREATE USER IF NOT EXISTS '${user}'@'%' IDENTIFIED BY '${epass}';
ALTER USER '${user}'@'%' IDENTIFIED BY '${epass}';
GRANT ALL PRIVILEGES ON \`${db}\`.* TO '${user}'@'%';
SQL
  fi
  mysql -e "FLUSH PRIVILEGES;"; log "Database created: $db / $user / remote=$remote"
}
cmd_delete_db() { local db="${1:-}" user="${2:-}"; [[ -n "$db" && -n "$user" ]] || err "DB and user required"; valid_db_name "$db" || err "Invalid db"; valid_db_name "$user" || err "Invalid user"; mysql -e "DROP DATABASE IF EXISTS \`${db}\`; DROP USER IF EXISTS '${user}'@'localhost'; DROP USER IF EXISTS '${user}'@'%'; FLUSH PRIVILEGES;"; log "Database deleted: $db / $user"; }
cmd_mysql_external() { local state="${1:-}"; [[ "$state" == enable || "$state" == disable ]] || err "Use enable or disable"; local file="/etc/mysql/mariadb.conf.d/50-server.cnf"; [[ -f "$file" ]] || file="/etc/mysql/my.cnf"; cp "$file" "$file.backup.$(date +%s)" || true; if [[ "$state" == enable ]]; then sed -i 's/^\s*bind-address\s*=.*/bind-address = 0.0.0.0/' "$file" || true; grep -q '^bind-address' "$file" || echo 'bind-address = 0.0.0.0' >> "$file"; ufw allow 3306/tcp >/dev/null 2>&1 || true; else sed -i 's/^\s*bind-address\s*=.*/bind-address = 127.0.0.1/' "$file" || true; ufw delete allow 3306/tcp >/dev/null 2>&1 || true; fi; systemctl restart mariadb; log "MySQL external access: $state"; }

ensure_pm2() {
  command -v python3 >/dev/null 2>&1 || apt-get install -y python3
  command -v pip3 >/dev/null 2>&1 || apt-get install -y python3-pip
  command -v node >/dev/null 2>&1 || apt-get install -y nodejs npm
  command -v pm2 >/dev/null 2>&1 || npm install -g pm2
}
make_bot_start_script() {
  local name="$1" runtime="$2" main_file="$3" path="$BOTS_DIR/$name" mem="$4" interp=""
  case "$runtime" in
    python)
      if [[ -x "$path/venv/bin/python" ]]; then interp="$path/venv/bin/python"; else interp="python3"; fi
      cat > "$path/.hyper-start.sh" <<EOS
#!/usr/bin/env bash
set -Eeuo pipefail
cd "$path"
if [[ -f .env ]]; then set -a; source .env; set +a; fi
exec "$interp" "$main_file"
EOS
      ;;
    node)
      cat > "$path/.hyper-start.sh" <<EOS
#!/usr/bin/env bash
set -Eeuo pipefail
cd "$path"
if [[ -f .env ]]; then set -a; source .env; set +a; fi
exec node "$main_file"
EOS
      ;;
    php)
      cat > "$path/.hyper-start.sh" <<EOS
#!/usr/bin/env bash
set -Eeuo pipefail
cd "$path"
if [[ -f .env ]]; then set -a; source .env; set +a; fi
exec php "$main_file"
EOS
      ;;
    custom)
      cat > "$path/.hyper-start.sh" <<EOS
#!/usr/bin/env bash
set -Eeuo pipefail
cd "$path"
if [[ -f .env ]]; then set -a; source .env; set +a; fi
exec bash -lc "$main_file"
EOS
      ;;
  esac
  chmod +x "$path/.hyper-start.sh"
}
bot_install_deps_internal() {
  local name="$1" runtime="${2:-python}" path="$BOTS_DIR/$name"
  [[ -d "$path" ]] || err "Bot folder not found"
  if [[ "$runtime" == "python" && -f "$path/requirements.txt" ]]; then
    python3 -m venv "$path/venv"
    "$path/venv/bin/python" -m pip install --upgrade pip wheel setuptools
    "$path/venv/bin/pip" install -r "$path/requirements.txt"
    log "Python requirements installed in venv for $name"
  elif [[ "$runtime" == "node" && -f "$path/package.json" ]]; then
    (cd "$path" && npm install)
    log "Node packages installed for $name"
  elif [[ "$runtime" == "php" && -f "$path/composer.json" ]]; then
    if command -v composer >/dev/null 2>&1; then (cd "$path" && composer install --no-interaction); fi
    log "PHP dependencies checked for $name"
  else
    log "No dependency file found for $name"
  fi
}
bot_start_pm2() {
  local name="$1" runtime="$2" main_file="$3" mem="${4:-0}" path="$BOTS_DIR/$name"
  ensure_pm2
  make_bot_start_script "$name" "$runtime" "$main_file" "$path" "$mem"
  (cd "$path" && pm2 delete "$name" >/dev/null 2>&1 || true)
  local mem_arg=(); [[ "$mem" =~ ^[0-9]+$ && "$mem" -gt 0 ]] && mem_arg+=(--max-memory-restart "${mem}M")
  (cd "$path" && pm2 start ./.hyper-start.sh --name "$name" --interpreter bash "${mem_arg[@]}")
  pm2 save >/dev/null || true
}
cmd_bot_create() {
  ensure_dirs; ensure_pm2
  local name="${1:-}" runtime="${2:-python}" main_file="${3:-}" mem="${4:-0}" proc_limit="${5:-0}"
  [[ -n "$name" ]] || err "Bot name required"; valid_name "$name" || err "Invalid bot name"; [[ "$runtime" =~ ^(python|node|php|custom)$ ]] || err "Invalid runtime"
  local path="$BOTS_DIR/$name"; mkdir -p "$path"
  if [[ -z "$main_file" ]]; then
    case "$runtime" in python) main_file="bot.py";; node) main_file="index.js";; php) main_file="bot.php";; custom) main_file="start.sh";; esac
  fi
  main_file="${main_file#python3 }"; main_file="${main_file#python }"; main_file="${main_file#node }"; main_file="${main_file#php }"; main_file="$(basename "$main_file")"
  [[ -f "$path/.env" ]] || echo '# BOT_TOKEN=put_token_here' > "$path/.env"
  if [[ "$runtime" == python && ! -f "$path/$main_file" ]]; then cat > "$path/$main_file" <<'PYBOT'
import time
print('HYPER-HOST bot template started', flush=True)
while True:
    time.sleep(60)
PYBOT
  fi
  if [[ "$runtime" == node && ! -f "$path/$main_file" ]]; then echo "setInterval(()=>console.log('HYPER-HOST node bot'),60000);" > "$path/$main_file"; fi
  if [[ "$runtime" == php && ! -f "$path/$main_file" ]]; then echo "<?php while(true){ echo 'HYPER-HOST php bot'.PHP_EOL; sleep(60); }" > "$path/$main_file"; fi
  fix_web_permissions "$path"
  bot_install_deps_internal "$name" "$runtime"
  bot_start_pm2 "$name" "$runtime" "$main_file" "$mem"
  fix_web_permissions "$path"
  log "PM2 bot created: $name / main=$main_file"
}
cmd_bot_deploy() {
  ensure_dirs; ensure_pm2
  local name="${1:-}" runtime="${2:-python}" main_file="${3:-bot.py}" bot_tmp="${4:-}" env_tmp="${5:-}" req_tmp="${6:-}" mem="${7:-0}"
  [[ -n "$name" ]] || err "Bot name required"; valid_name "$name" || err "Invalid bot name"; [[ "$runtime" =~ ^(python|node|php|custom)$ ]] || err "Invalid runtime"
  main_file="${main_file#python3 }"; main_file="${main_file#python }"; main_file="${main_file#node }"; main_file="${main_file#php }"; main_file="$(basename "$main_file")"
  local path="$BOTS_DIR/$name"; mkdir -p "$path"
  if [[ -n "$bot_tmp" && -f "$bot_tmp" ]]; then cp "$bot_tmp" "$path/$main_file"; fi
  if [[ -n "$env_tmp" && -f "$env_tmp" ]]; then cp "$env_tmp" "$path/.env"; elif [[ ! -f "$path/.env" ]]; then echo '# BOT_TOKEN=put_token_here' > "$path/.env"; fi
  if [[ -n "$req_tmp" && -f "$req_tmp" ]]; then
    if [[ "$runtime" == "node" ]]; then cp "$req_tmp" "$path/package.json"; else cp "$req_tmp" "$path/requirements.txt"; fi
  fi
  [[ -f "$path/$main_file" ]] || err "Главный файл бота не найден: $main_file. Загрузи bot.py / index.js / bot.php."
  fix_web_permissions "$path"
  bot_install_deps_internal "$name" "$runtime"
  bot_start_pm2 "$name" "$runtime" "$main_file" "$mem"
  fix_web_permissions "$path"
  log "Bot deployed and started: $name / main=$main_file"
}
cmd_bot_install_requirements() { local name="${1:-}"; [[ -n "$name" ]] || err "Bot name required"; valid_name "$name" || err "Invalid bot"; local runtime="${2:-python}"; bot_install_deps_internal "$name" "$runtime"; fix_web_permissions "$BOTS_DIR/$name"; }
cmd_bot_delete() { local name="${1:-}" mode="${2:---keep-files}"; [[ -n "$name" ]] || err "Bot name required"; valid_name "$name" || err "Invalid bot"; ensure_pm2; pm2 stop "$name" >/dev/null 2>&1 || true; pm2 delete "$name" >/dev/null 2>&1 || true; pm2 save >/dev/null 2>&1 || true; [[ "$mode" == "--delete-files" ]] && rm -rf "$BOTS_DIR/$name"; log "Bot deleted: $name"; }
cmd_bot_action() { local action="${1:-}" name="${2:-}"; [[ "$action" =~ ^(start|stop|restart|status|logs)$ ]] || err "Invalid bot action"; [[ -n "$name" ]] || err "Bot name required"; valid_name "$name" || err "Invalid bot"; ensure_pm2; case "$action" in start|stop|restart) pm2 "$action" "$name"; pm2 save >/dev/null 2>&1 || true;; status) BOTNAME="$name" pm2 jlist | BOTNAME="$name" python3 -c 'import sys,json,os; data=json.load(sys.stdin); name=os.environ.get("BOTNAME",""); print(next((p.get("pm2_env",{}).get("status","") for p in data if p.get("name")==name), "not_found"))';; logs) pm2 logs "$name" --lines 250 --nostream || true;; esac; }
cmd_bot_list_json() {
  ensure_pm2
  pm2 jlist 2>/dev/null | python3 -c 'import sys,json,os
try:
    data=json.load(sys.stdin)
except Exception:
    data=[]
out=[]
for p in data:
    env=p.get("pm2_env",{})
    cwd=env.get("pm_cwd","")
    files=[]
    if cwd and os.path.isdir(cwd):
        for n in ("bot.py","main.py","index.js","bot.php",".env","requirements.txt","package.json"):
            if os.path.exists(os.path.join(cwd,n)): files.append(n)
    out.append({"name":p.get("name",""),"status":env.get("status",""),"restarts":env.get("restart_time",0),"memory":p.get("monit",{}).get("memory",0),"cpu":p.get("monit",{}).get("cpu",0),"cwd":cwd,"files":files})
print(json.dumps(out, ensure_ascii=False))'
}

cmd_backup_run() {
  ensure_dirs
  local target="${1:-all}" ts archive; ts="$(date +%F-%H%M%S)"; mkdir -p "$BACKUP_DIR"; archive="$BACKUP_DIR/hyper-host-${target}-${ts}.tar.gz"
  local paths=(); [[ "$target" == all || "$target" == sites ]] && paths+=("$SITES_DIR"); [[ "$target" == all || "$target" == bots ]] && paths+=("$BOTS_DIR"); [[ "$target" == all || "$target" == panel ]] && paths+=("$BASE_DIR/data" "$PANEL_DIR");
  if [[ "$target" == all || "$target" == db ]]; then
    dump="$BACKUP_DIR/mysql-${ts}.sql"; mysqldump --all-databases > "$dump" 2>/dev/null || true; paths+=("$dump")
  fi
  tar -czf "$archive" "${paths[@]}" 2>/dev/null || true
  [[ -f "${dump:-}" ]] && rm -f "$dump" || true
  log "Backup created: $archive"
}
cmd_backup_schedule() { local name="${1:-}" schedule="${2:-}" target="${3:-all}"; [[ -n "$name" && -n "$schedule" ]] || err "Name and schedule required"; valid_name "$name" || err "Invalid name"; cat > "$CRON_DIR/hyper-host-backup-$name" <<EOCRON
SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
${schedule} root /usr/local/sbin/hyper-host-ctl backup-run ${target} >/var/log/hyper-host-backup-${name}.log 2>&1
EOCRON
chmod 0644 "$CRON_DIR/hyper-host-backup-$name"; systemctl reload cron 2>/dev/null || systemctl reload crond 2>/dev/null || true; log "Backup schedule saved: $name"; }
cmd_backup_delete_schedule() { local name="${1:-}"; valid_name "$name" || err "Invalid name"; rm -f "$CRON_DIR/hyper-host-backup-$name"; log "Backup schedule deleted: $name"; }
cmd_backup_list_json() { python3 - <<PY
import os,json,glob
bd=os.environ.get('BACKUP_DIR','$BACKUP_DIR')
items=[]
for f in sorted(glob.glob(os.path.join(bd,'*.tar.gz')), key=os.path.getmtime, reverse=True)[:80]:
    st=os.stat(f); items.append({'name':os.path.basename(f),'path':f,'size':st.st_size,'mtime':st.st_mtime})
print(json.dumps(items, ensure_ascii=False))
PY
}

cmd_dns_apply() {
  local domain="${1:-}" records_json="${2:-[]}" ns="${3:-ns1.local.}" admin="${4:-admin.local.}"
  valid_domain "$domain" || err "Invalid domain"; mkdir -p "$DNS_DIR"
  local zonefile="$DNS_DIR/db.$domain" serial; serial="$(date +%Y%m%d%H)"
  python3 - "$domain" "$records_json" "$ns" "$admin" "$zonefile" "$serial" <<'PY'
import sys,json
zone,records_json,ns,admin,path,serial=sys.argv[1:]
try: records=json.loads(records_json)
except Exception: records=[]
with open(path,'w',encoding='utf-8') as f:
    f.write(f"$TTL 3600\n@ IN SOA {ns} {admin} ({serial} 3600 1800 1209600 3600)\n")
    f.write(f"@ IN NS {ns}\n")
    for r in records:
        name=r.get('name','@') or '@'; typ=r.get('type','A').upper(); value=r.get('value',''); ttl=int(r.get('ttl',3600) or 3600)
        if not value: continue
        f.write(f"{name} {ttl} IN {typ} {value}\n")
PY
  if [[ -d /etc/bind ]]; then
    touch /etc/bind/named.conf.local
    if ! grep -q "zone \"$domain\"" /etc/bind/named.conf.local; then
      cat >> /etc/bind/named.conf.local <<EOBIND
zone "$domain" { type master; file "$zonefile"; };
EOBIND
    fi
    named-checkzone "$domain" "$zonefile" >/dev/null 2>&1 || true
    systemctl restart bind9 2>/dev/null || true
  fi
  log "DNS zone applied: $domain -> $zonefile"
}
cmd_dns_delete() { local domain="${1:-}"; valid_domain "$domain" || err "Invalid domain"; rm -f "$DNS_DIR/db.$domain"; log "DNS zone file deleted: $domain"; }

cmd_cron_set() { local name="${1:-}" schedule="${2:-}" command="${3:-}"; [[ -n "$name" && -n "$schedule" && -n "$command" ]] || err "Name schedule command required"; valid_name "$name" || err "Invalid name"; cat > "$CRON_DIR/hyper-host-task-$name" <<EOCRON
SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
${schedule} root ${command} >/var/log/hyper-host-cron-${name}.log 2>&1
EOCRON
chmod 0644 "$CRON_DIR/hyper-host-task-$name"; systemctl reload cron 2>/dev/null || true; log "Cron task saved: $name"; }
cmd_cron_delete() { local name="${1:-}"; valid_name "$name" || err "Invalid name"; rm -f "$CRON_DIR/hyper-host-task-$name"; log "Cron task deleted: $name"; }

cmd_site_logs() { local domain="${1:-}" kind="${2:-error}" lines="${3:-200}" filter="${4:-}"; valid_domain "$domain" || err "Invalid domain"; [[ "$kind" == access || "$kind" == error ]] || kind=error; local file="$SITES_DIR/$domain/logs/$kind.log"; [[ -f "$file" ]] || { echo "Log not found: $file"; return 0; }; if [[ -n "$filter" ]]; then tail -n "$lines" "$file" | grep -i -- "$filter" || true; else tail -n "$lines" "$file" || true; fi; }

cmd_ssl_status_json() { python3 - <<'PY'
import os,glob,json,subprocess,datetime
items=[]
for cert in glob.glob('/etc/letsencrypt/live/*/fullchain.pem'):
    domain=cert.split('/')[-2]
    try:
        out=subprocess.check_output(['openssl','x509','-in',cert,'-noout','-enddate'], text=True).strip().split('=',1)[1]
        exp=datetime.datetime.strptime(out, '%b %d %H:%M:%S %Y %Z')
        days=(exp-datetime.datetime.utcnow()).days
        items.append({'domain':domain,'expires':exp.isoformat()+'Z','days_left':days,'status':'ok' if days>14 else 'warning'})
    except Exception as e: items.append({'domain':domain,'error':str(e),'status':'error'})
print(json.dumps(items, ensure_ascii=False))
PY
}
cmd_ssl_renew_all() { certbot renew --quiet; nginx_reload; log "SSL renew checked"; }
cmd_php_list_json() { python3 - <<'PY'
import glob,os,json,re
items=[]
for sock in glob.glob('/run/php/php*-fpm.sock'):
    m=re.search(r'php([0-9.]+)-fpm\.sock', sock)
    if m: items.append({'version':m.group(1),'sock':sock})
print(json.dumps(items, ensure_ascii=False))
PY
}

cmd_stats_json() { python3 - <<'PY'
import os,json,subprocess,shutil
def run(cmd):
    try: return subprocess.check_output(cmd,shell=True,text=True,stderr=subprocess.DEVNULL).strip()
    except Exception: return ''
def service(name): return run(f'systemctl is-active {name}') or 'inactive'
def meminfo():
    data={}
    try:
        for line in open('/proc/meminfo'):
            k,v=line.split(':',1); data[k]=int(v.strip().split()[0])*1024
    except Exception: pass
    t=data.get('MemTotal',0); a=data.get('MemAvailable',0); return t,max(0,t-a),a
def cpu():
    try:
        for l in open('/proc/cpuinfo',encoding='utf-8',errors='ignore'):
            if l.lower().startswith('model name'): return l.split(':',1)[1].strip()
    except Exception: pass
    return run('uname -m') or 'unknown'
def upt():
    try:
        s=int(float(open('/proc/uptime').read().split()[0])); d,s=divmod(s,86400); h,s=divmod(s,3600); m,_=divmod(s,60); return f'{d}д {h}ч {m}м' if d else f'{h}ч {m}м'
    except Exception: return 'unknown'
du=shutil.disk_usage('/'); mt,mu,ma=meminfo(); load=os.getloadavg() if hasattr(os,'getloadavg') else (0,0,0)
php=run("systemctl list-units --type=service --state=running --no-legend 'php*-fpm.service' | awk '{print $1}' | head -n1") or 'php-fpm'
pm2=run('command -v pm2 >/dev/null 2>&1 && pm2 -v || true')
print(json.dumps({'server_ip':os.environ.get('SERVER_IP',''),'panel_domain':os.environ.get('PANEL_DOMAIN',''),'cpu_model':cpu(),'cpu_cores':os.cpu_count() or 0,'load1':load[0],'load5':load[1],'load15':load[2],'uptime':upt(),'disk_total':du.total,'disk_used':du.used,'disk_free':du.free,'mem_total':mt,'mem_used':mu,'mem_available':ma,'pm2_version':pm2,'services':{'nginx':service('nginx'),'mariadb':service('mariadb'),'vsftpd':service('vsftpd'),'php_fpm':service(php),'bind9':service('bind9')},'paths':{'panel':os.environ.get('PANEL_DIR',''),'sites':os.environ.get('SITES_DIR',''),'bots':os.environ.get('BOTS_DIR',''),'ftp':os.environ.get('FTP_DIR',''),'backups':os.environ.get('BACKUP_DIR',''),'phpmyadmin':os.environ.get('PHPMYADMIN_PATH','/usr/share/phpmyadmin')}},ensure_ascii=False))
PY
}

cmd_sync_json() { python3 - <<'PY'
import os,json,glob,pwd,re,subprocess
SITES_DIR=os.environ.get('SITES_DIR','/var/www/hyper-host-sites'); BOTS_DIR=os.environ.get('BOTS_DIR','/var/www/hyper-host-bots'); FTP_DIR=os.environ.get('FTP_DIR','/var/www/hyper-host-ftp'); NGINX_AVAILABLE='/etc/nginx/sites-available'
sites=[]; folders=[]
for public_html in sorted(glob.glob(os.path.join(SITES_DIR,'*','public_html'))):
    name=os.path.basename(os.path.dirname(public_html)); conf=os.path.join(NGINX_AVAILABLE,f'hyper-host-site-{name}.conf')
    if os.path.exists(conf) and re.match(r'^([A-Za-z0-9]([A-Za-z0-9-]{0,61}[A-Za-z0-9])?\.)+[A-Za-z]{2,63}$', name):
        text=open(conf,encoding='utf-8',errors='ignore').read(); aliases=[]; m=re.search(r'server_name\s+([^;]+);', text)
        if m:
            names=[x.strip() for x in m.group(1).split() if x.strip()]; aliases=[x for x in names if x != name]
        ssl=1 if os.path.exists(f'/etc/letsencrypt/live/{name}/fullchain.pem') else 0
        phpm=re.search(r'/run/php/php([0-9.]+)-fpm\.sock', text); phpv=phpm.group(1) if phpm else ''
        sites.append({'domain':name,'aliases':','.join(aliases),'root_path':public_html,'ssl_enabled':ssl,'php_version':phpv})
    else: folders.append({'name':name,'path':public_html})
ftp=[]
for u in pwd.getpwall():
    if u.pw_name.startswith('hhftp_'):
        ftp.append({'username':u.pw_name,'target_path':u.pw_dir,'host':os.environ.get('PANEL_DOMAIN') if os.environ.get('PANEL_DOMAIN','_')!='_' else os.environ.get('SERVER_IP','')})
bots=[]
try:
    data=json.loads(subprocess.check_output('pm2 jlist',shell=True,text=True,stderr=subprocess.DEVNULL))
except Exception: data=[]
for p in data:
    name=p.get('name','')
    if not re.match(r'^[A-Za-z0-9_][A-Za-z0-9_-]{1,63}$', name): continue
    env=p.get('pm2_env',{}); path=env.get('pm_cwd') or os.path.join(BOTS_DIR,name); script=env.get('pm_exec_path',''); interp=env.get('exec_interpreter','') or ''
    runtime='custom'; cmd=os.path.basename(script) if script else ''
    if 'python' in interp or script.endswith('.py'): runtime='python'; cmd='python3 '+cmd
    elif script.endswith('.js') or 'node' in interp: runtime='node'; cmd='node '+cmd
    elif script.endswith('.php') or 'php' in interp: runtime='php'; cmd='php '+cmd
    bots.append({'name':name,'runtime':runtime,'path':path,'start_command':cmd,'memory_limit_mb':0})
databases=[]
try:
    out=subprocess.check_output("mysql -N -B -e \"SELECT Db, User, MAX(Host <> 'localhost') AS remote FROM mysql.db WHERE Db NOT IN ('mysql','performance_schema','information_schema','sys') GROUP BY Db, User ORDER BY Db\"",shell=True,text=True,stderr=subprocess.DEVNULL)
    for line in out.splitlines():
        parts=line.split('\t')
        if len(parts)>=3 and parts[0] and parts[1] and not parts[0].startswith('phpmyadmin'):
            databases.append({'db_name':parts[0],'db_user':parts[1],'remote_allowed':1 if parts[2] in ('1','true','TRUE') else 0})
except Exception: pass
print(json.dumps({'sites':sites,'folders':folders,'ftp':ftp,'databases':databases,'bots':bots},ensure_ascii=False))
PY
}

cmd_repair() {
  ensure_dirs; ensure_nologin_shell
  mkdir -p "$BASE_DIR/data" "$PANEL_DIR" "$SITES_DIR" "$BOTS_DIR" "$FTP_DIR" "$BACKUP_DIR" "$BASE_DIR/templates" /etc/hyper-host
  chown -R www-data:www-data "$PANEL_DIR" "$BASE_DIR/data" 2>/dev/null || true
  chmod 0770 "$BASE_DIR/data" 2>/dev/null || true
  if [[ -f "$BASE_DIR/data/hyperhost.sqlite" ]]; then chown www-data:www-data "$BASE_DIR/data/hyperhost.sqlite" "$BASE_DIR/data/hyperhost.sqlite"-* 2>/dev/null || true; chmod 0660 "$BASE_DIR/data/hyperhost.sqlite" "$BASE_DIR/data/hyperhost.sqlite"-* 2>/dev/null || true; fi
  fix_web_permissions "$SITES_DIR"; fix_web_permissions "$BOTS_DIR"; chmod 0755 "$FTP_DIR" "$BACKUP_DIR" 2>/dev/null || true
  while IFS=: read -r user _ uid gid gecos home shell; do
    [[ "$user" == hhftp_* ]] || continue; [[ -n "$home" && -d "$home" ]] || continue
    usermod -s /usr/sbin/nologin "$user" 2>/dev/null || true; chown root:root "$home" 2>/dev/null || true; chmod 0755 "$home" 2>/dev/null || true; mkdir -p "$home/common" "$home/common/sites" "$home/common/bots"
    chown -R "$user":www-data "$home/common" 2>/dev/null || true; chmod -R u+rwX,g+rwX,o+rX "$home/common" 2>/dev/null || true
    for pair in "$SITES_DIR:$home/common/sites" "$BOTS_DIR:$home/common/bots"; do src="${pair%%:*}"; dst="${pair#*:}"; mkdir -p "$src" "$dst"; if ! mountpoint -q "$dst"; then mount --bind "$src" "$dst" 2>/dev/null || true; fi; if mountpoint -q "$dst" && ! grep -qs " $dst " /etc/fstab; then echo "$src $dst none bind 0 0" >> /etc/fstab; fi; done
    fix_web_permissions "$SITES_DIR" "$user"; fix_web_permissions "$BOTS_DIR" "$user"; fix_web_permissions "$home/common" "$user"
  done < /etc/passwd
  cat > /etc/sudoers.d/hyper-host <<EOSUDO
www-data ALL=(root) NOPASSWD: /usr/local/sbin/hyper-host-ctl *
EOSUDO
  chmod 0440 /etc/sudoers.d/hyper-host; visudo -cf /etc/sudoers.d/hyper-host >/dev/null
  ufw allow 80/tcp >/dev/null 2>&1 || true; ufw allow 443/tcp >/dev/null 2>&1 || true; ufw allow 21/tcp >/dev/null 2>&1 || true; ufw allow 40000:40100/tcp >/dev/null 2>&1 || true
  systemctl restart vsftpd 2>/dev/null || true; systemctl reload nginx 2>/dev/null || systemctl restart nginx 2>/dev/null || true
  log "Repair finished: permissions, ACL, FTP common/sites/bots, sudoers and services checked"
}

case "${1:-}" in
  create-folder) shift; cmd_create_folder "$@" ;;
  delete-folder) shift; cmd_delete_folder "$@" ;;
  add-site) shift; cmd_add_site "$@" ;;
  delete-site) shift; cmd_delete_site "$@" ;;
  ssl-site) shift; cmd_ssl_site "$@" ;;
  site-php) shift; cmd_site_php "$@" ;;
  create-ftp) shift; cmd_create_ftp "$@" ;;
  delete-ftp) shift; cmd_delete_ftp "$@" ;;
  ftp-password) shift; cmd_ftp_password "$@" ;;
  create-db) shift; cmd_create_db "$@" ;;
  delete-db) shift; cmd_delete_db "$@" ;;
  mysql-external) shift; cmd_mysql_external "$@" ;;
  bot-create) shift; cmd_bot_create "$@" ;;
  bot-deploy) shift; cmd_bot_deploy "$@" ;;
  bot-install-requirements) shift; cmd_bot_install_requirements "$@" ;;
  bot-delete) shift; cmd_bot_delete "$@" ;;
  bot) shift; cmd_bot_action "$@" ;;
  bot-list-json) shift; cmd_bot_list_json "$@" ;;
  backup-run) shift; cmd_backup_run "$@" ;;
  backup-schedule) shift; cmd_backup_schedule "$@" ;;
  backup-delete-schedule) shift; cmd_backup_delete_schedule "$@" ;;
  backup-list-json) shift; cmd_backup_list_json "$@" ;;
  dns-apply) shift; cmd_dns_apply "$@" ;;
  dns-delete) shift; cmd_dns_delete "$@" ;;
  cron-set) shift; cmd_cron_set "$@" ;;
  cron-delete) shift; cmd_cron_delete "$@" ;;
  site-logs) shift; cmd_site_logs "$@" ;;
  ssl-status-json) shift; cmd_ssl_status_json "$@" ;;
  ssl-check-json) shift; cmd_ssl_check_json "$@" ;;
  ssl-renew-all) shift; cmd_ssl_renew_all "$@" ;;
  php-list-json) shift; cmd_php_list_json "$@" ;;
  stats-json) shift; cmd_stats_json "$@" ;;
  sync-json) shift; cmd_sync_json "$@" ;;
  repair) shift; cmd_repair "$@" ;;
  *) cat >&2 <<EOHELP
Usage: hyper-host-ctl add-site DOMAIN [ALIASES] [PHP_VERSION]
       hyper-host-ctl create-ftp USER PASS [all-sites]
       hyper-host-ctl bot-create NAME python|node|php|custom MAIN_FILE [MEM_MB]
       hyper-host-ctl bot-deploy NAME python MAIN_FILE TMP_BOT TMP_ENV TMP_REQ [MEM_MB]
       hyper-host-ctl backup-run all|sites|bots|db|panel
       hyper-host-ctl dns-apply DOMAIN RECORDS_JSON [NS] [ADMIN]
       hyper-host-ctl cron-set NAME "* * * * *" COMMAND
       hyper-host-ctl repair
EOHELP
     exit 1 ;;
esac
