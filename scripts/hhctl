#!/usr/bin/env bash
set -Eeuo pipefail

CONF="/etc/hyper-host/hyper-host.conf"
[[ -f "$CONF" ]] || { echo "Config not found: $CONF" >&2; exit 2; }
# shellcheck disable=SC1090
source "$CONF"
export PANEL_NAME POWERED_BY SERVER_IP PANEL_DOMAIN BASE_DIR PANEL_DIR SITES_DIR BOTS_DIR PHP_FPM_SOCK PHPMYADMIN_PATH

NGINX_AVAILABLE="/etc/nginx/sites-available"
NGINX_ENABLED="/etc/nginx/sites-enabled"
BOT_SERVICE_PREFIX="hyperbot"

log() { echo "[hhctl] $*"; }
err() { echo "[hhctl error] $*" >&2; exit 1; }

valid_domain() {
  [[ "$1" =~ ^([A-Za-z0-9]([A-Za-z0-9-]{0,61}[A-Za-z0-9])?\.)+[A-Za-z]{2,63}$ ]]
}

valid_name() {
  [[ "$1" =~ ^[A-Za-z0-9_][A-Za-z0-9_-]{1,63}$ ]]
}

valid_db_name() {
  [[ "$1" =~ ^[A-Za-z0-9_]{2,48}$ ]]
}

shell_quote() {
  printf "%q" "$1"
}

sql_escape() {
  printf "%s" "$1" | sed "s/'/''/g"
}

ensure_dirs() {
  mkdir -p "$SITES_DIR" "$BOTS_DIR" "$BASE_DIR/templates"
}

nginx_reload() {
  nginx -t >/dev/null
  systemctl reload nginx
}

php_index_template() {
  local domain="$1"
  cat > "$SITES_DIR/$domain/public_html/index.php" <<EOPHP
<?php
http_response_code(200);
?>
<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>${domain} — HYPER-HOST</title>
  <style>
    body{margin:0;min-height:100vh;display:flex;align-items:center;justify-content:center;background:#090b12;color:#fff;font-family:Arial,sans-serif}
    .box{max-width:720px;padding:38px;border:1px solid rgba(255,255,255,.12);border-radius:24px;background:linear-gradient(135deg,rgba(99,102,241,.22),rgba(14,165,233,.12));box-shadow:0 30px 90px rgba(0,0,0,.45)}
    h1{margin:0 0 14px;font-size:42px}.muted{color:#aeb8d0}.badge{display:inline-block;margin-top:18px;padding:9px 14px;border-radius:999px;background:#111827;color:#7dd3fc}
  </style>
</head>
<body>
  <div class="box">
    <h1>${domain} работает 🚀</h1>
    <p class="muted">Сайт создан в панели HYPER-HOST. Загрузи свои файлы в public_html.</p>
    <div class="badge">powered by memes4u1337</div>
  </div>
</body>
</html>
EOPHP
}

cmd_add_site() {
  ensure_dirs
  local domain="${1:-}"
  local aliases="${2:-}"
  [[ -n "$domain" ]] || err "Domain required"
  valid_domain "$domain" || err "Invalid domain: $domain"

  local root="$SITES_DIR/$domain/public_html"
  mkdir -p "$root" "$SITES_DIR/$domain/logs"
  if [[ ! -f "$root/index.php" && ! -f "$root/index.html" ]]; then
    php_index_template "$domain"
  fi
  chown -R www-data:www-data "$SITES_DIR/$domain"
  chmod -R u+rwX,g+rwX,o+rX "$SITES_DIR/$domain"

  local server_names="$domain"
  if [[ -n "$aliases" ]]; then
    IFS=',' read -ra arr <<< "$aliases"
    for a in "${arr[@]}"; do
      a="$(echo "$a" | xargs)"
      [[ -z "$a" ]] && continue
      valid_domain "$a" || err "Invalid alias: $a"
      server_names="$server_names $a"
    done
  fi

  cat > "$NGINX_AVAILABLE/hyper-host-site-$domain.conf" <<EONGINX
server {
    listen 80;
    listen [::]:80;
    server_name ${server_names};

    root ${root};
    index index.php index.html index.htm;
    client_max_body_size 256M;

    access_log ${SITES_DIR}/${domain}/logs/access.log;
    error_log ${SITES_DIR}/${domain}/logs/error.log;

    location / {
        try_files \$uri \$uri/ /index.php?\$query_string;
    }

    location ~ \.php$ {
        include snippets/fastcgi-php.conf;
        fastcgi_pass unix:${PHP_FPM_SOCK};
    }

    location ~ /\. {
        deny all;
    }
}
EONGINX

  ln -sf "$NGINX_AVAILABLE/hyper-host-site-$domain.conf" "$NGINX_ENABLED/hyper-host-site-$domain.conf"
  nginx_reload
  log "Site created: $domain -> $root"
}

cmd_delete_site() {
  local domain="${1:-}"
  local mode="${2:---keep-files}"
  [[ -n "$domain" ]] || err "Domain required"
  valid_domain "$domain" || err "Invalid domain: $domain"
  rm -f "$NGINX_ENABLED/hyper-host-site-$domain.conf" "$NGINX_AVAILABLE/hyper-host-site-$domain.conf"
  nginx_reload
  if [[ "$mode" == "--delete-files" ]]; then
    rm -rf "$SITES_DIR/$domain"
    log "Site and files deleted: $domain"
  else
    log "Site config deleted, files kept: $SITES_DIR/$domain"
  fi
}

cmd_ssl_site() {
  local domain="${1:-}"
  local email="${2:-}"
  [[ -n "$domain" && -n "$email" ]] || err "Domain and email required"
  valid_domain "$domain" || err "Invalid domain: $domain"
  certbot --nginx -d "$domain" --non-interactive --agree-tos -m "$email" --redirect
  nginx_reload
  log "SSL issued for $domain"
}

cmd_create_ftp() {
  local username="${1:-}"
  local password="${2:-}"
  local target="${3:-}"
  [[ -n "$username" && -n "$password" && -n "$target" ]] || err "Username, password and target path required"
  valid_name "$username" || err "Invalid ftp username"
  [[ "$username" == hhftp_* ]] || username="hhftp_${username}"
  [[ "$target" == "$SITES_DIR"/* || "$target" == "$BOTS_DIR"/* ]] || err "Target must be inside sites or bots dir"
  mkdir -p "$target"
  if id "$username" >/dev/null 2>&1; then
    echo "$username:$password" | chpasswd
  else
    useradd -d "$target" -s /usr/sbin/nologin "$username"
    echo "$username:$password" | chpasswd
  fi
  chown -R "$username":www-data "$target"
  chmod -R u+rwX,g+rwX,o+rX "$target"
  systemctl restart vsftpd
  log "FTP user ready: $username -> $target"
}

cmd_delete_ftp() {
  local username="${1:-}"
  [[ -n "$username" ]] || err "Username required"
  valid_name "$username" || err "Invalid username"
  [[ "$username" == hhftp_* ]] || username="hhftp_${username}"
  if id "$username" >/dev/null 2>&1; then
    userdel "$username"
  fi
  log "FTP user deleted: $username"
}

cmd_create_db() {
  local db="${1:-}"
  local user="${2:-}"
  local pass="${3:-}"
  local remote="${4:-0}"
  [[ -n "$db" && -n "$user" && -n "$pass" ]] || err "DB, user and password required"
  valid_db_name "$db" || err "Invalid db name"
  valid_db_name "$user" || err "Invalid db user"
  local epass
  epass="$(sql_escape "$pass")"

  mysql <<SQL
CREATE DATABASE IF NOT EXISTS \`${db}\` CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
CREATE USER IF NOT EXISTS '${user}'@'localhost' IDENTIFIED BY '${epass}';
ALTER USER '${user}'@'localhost' IDENTIFIED BY '${epass}';
GRANT ALL PRIVILEGES ON \`${db}\`.* TO '${user}'@'localhost';
SQL

  if [[ "$remote" == "1" ]]; then
    mysql <<SQL
CREATE USER IF NOT EXISTS '${user}'@'%' IDENTIFIED BY '${epass}';
ALTER USER '${user}'@'%' IDENTIFIED BY '${epass}';
GRANT ALL PRIVILEGES ON \`${db}\`.* TO '${user}'@'%';
SQL
  fi
  mysql -e "FLUSH PRIVILEGES;"
  log "Database created: $db / $user / remote=$remote"
}

cmd_delete_db() {
  local db="${1:-}"
  local user="${2:-}"
  [[ -n "$db" && -n "$user" ]] || err "DB and user required"
  valid_db_name "$db" || err "Invalid db name"
  valid_db_name "$user" || err "Invalid db user"
  mysql <<SQL
DROP DATABASE IF EXISTS \`${db}\`;
DROP USER IF EXISTS '${user}'@'localhost';
DROP USER IF EXISTS '${user}'@'%';
FLUSH PRIVILEGES;
SQL
  log "Database deleted: $db / $user"
}

cmd_mysql_external() {
  local state="${1:-}"
  [[ "$state" == "enable" || "$state" == "disable" ]] || err "Use enable or disable"
  local file="/etc/mysql/mariadb.conf.d/50-server.cnf"
  [[ -f "$file" ]] || file="/etc/mysql/my.cnf"
  cp "$file" "$file.backup.$(date +%s)" || true
  if [[ "$state" == "enable" ]]; then
    if grep -qE '^\s*bind-address\s*=' "$file"; then
      sed -i 's/^\s*bind-address\s*=.*/bind-address = 0.0.0.0/' "$file"
    else
      echo "bind-address = 0.0.0.0" >> "$file"
    fi
    ufw allow 3306/tcp >/dev/null 2>&1 || true
  else
    if grep -qE '^\s*bind-address\s*=' "$file"; then
      sed -i 's/^\s*bind-address\s*=.*/bind-address = 127.0.0.1/' "$file"
    else
      echo "bind-address = 127.0.0.1" >> "$file"
    fi
    ufw delete allow 3306/tcp >/dev/null 2>&1 || true
  fi
  systemctl restart mariadb
  log "MySQL external access: $state"
}

cmd_bot_create() {
  local name="${1:-}"
  local runtime="${2:-python}"
  local command="${3:-}"
  [[ -n "$name" && -n "$command" ]] || err "Bot name and command required"
  valid_name "$name" || err "Invalid bot name"
  [[ "$runtime" =~ ^(python|node|php|custom)$ ]] || err "Invalid bot runtime"

  local path="$BOTS_DIR/$name"
  local service="${BOT_SERVICE_PREFIX}-${name}.service"
  mkdir -p "$path"
  if [[ ! -f "$path/README.txt" ]]; then
    cat > "$path/README.txt" <<EOTXT
HYPER-HOST bot folder: ${name}
Put your bot files here and set start command in panel.
EOTXT
  fi
  chown -R hyperbot:www-data "$path"
  chmod -R u+rwX,g+rwX,o+rX "$path"

  local escaped_cmd
  escaped_cmd="$(printf "%s" "$command" | sed "s/'/'\\\\''/g")"
  cat > "/etc/systemd/system/${service}" <<EOSERVICE
[Unit]
Description=HYPER-HOST Telegram Bot ${name}
After=network-online.target mariadb.service
Wants=network-online.target

[Service]
Type=simple
User=hyperbot
Group=www-data
WorkingDirectory=${path}
ExecStart=/bin/bash -lc 'cd ${path} && exec ${escaped_cmd}'
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
EOSERVICE
  systemctl daemon-reload
  systemctl enable "$service" >/dev/null 2>&1 || true
  log "Bot service created: $service"
}

cmd_bot_delete() {
  local name="${1:-}"
  local mode="${2:---keep-files}"
  [[ -n "$name" ]] || err "Bot name required"
  valid_name "$name" || err "Invalid bot name"
  local service="${BOT_SERVICE_PREFIX}-${name}.service"
  systemctl stop "$service" >/dev/null 2>&1 || true
  systemctl disable "$service" >/dev/null 2>&1 || true
  rm -f "/etc/systemd/system/$service"
  systemctl daemon-reload
  if [[ "$mode" == "--delete-files" ]]; then
    rm -rf "$BOTS_DIR/$name"
  fi
  log "Bot deleted: $name"
}

cmd_bot_action() {
  local action="${1:-}"
  local name="${2:-}"
  [[ "$action" =~ ^(start|stop|restart|status|logs)$ ]] || err "Invalid bot action"
  [[ -n "$name" ]] || err "Bot name required"
  valid_name "$name" || err "Invalid bot name"
  local service="${BOT_SERVICE_PREFIX}-${name}.service"
  case "$action" in
    start|stop|restart)
      systemctl "$action" "$service"
      log "Bot $action: $name"
      ;;
    status)
      systemctl is-active "$service" || true
      ;;
    logs)
      journalctl -u "$service" -n 160 --no-pager || true
      ;;
  esac
}


cmd_stats_json() {
  python3 - <<'PY'
import os, json, subprocess, shutil

def run(cmd):
    try:
        return subprocess.check_output(cmd, shell=True, text=True, stderr=subprocess.DEVNULL).strip()
    except Exception:
        return ""

def service(name):
    out = run(f"systemctl is-active {name}")
    return out or "inactive"

def meminfo():
    data = {}
    try:
        with open('/proc/meminfo', 'r', encoding='utf-8') as f:
            for line in f:
                k, v = line.split(':', 1)
                data[k] = int(v.strip().split()[0]) * 1024
    except Exception:
        pass
    total = data.get('MemTotal', 0)
    available = data.get('MemAvailable', 0)
    used = max(0, total - available)
    return total, used, available

def cpu_model():
    try:
        for line in open('/proc/cpuinfo', 'r', encoding='utf-8', errors='ignore'):
            if line.lower().startswith('model name'):
                return line.split(':', 1)[1].strip()
    except Exception:
        pass
    return run('uname -m') or 'unknown'

def uptime_text():
    try:
        sec = int(float(open('/proc/uptime').read().split()[0]))
        d, sec = divmod(sec, 86400)
        h, sec = divmod(sec, 3600)
        m, _ = divmod(sec, 60)
        if d:
            return f"{d}д {h}ч {m}м"
        return f"{h}ч {m}м"
    except Exception:
        return "unknown"

du = shutil.disk_usage('/')
mt, mu, ma = meminfo()
load = os.getloadavg() if hasattr(os, 'getloadavg') else (0,0,0)
php_units = run("systemctl list-units --type=service --state=running --no-legend 'php*-fpm.service' | awk '{print $1}' | head -n1")
php_service = php_units or 'php-fpm'

result = {
    'server_ip': os.environ.get('SERVER_IP', ''),
    'panel_domain': os.environ.get('PANEL_DOMAIN', ''),
    'cpu_model': cpu_model(),
    'cpu_cores': os.cpu_count() or 0,
    'load1': load[0], 'load5': load[1], 'load15': load[2],
    'uptime': uptime_text(),
    'disk_total': du.total, 'disk_used': du.used, 'disk_free': du.free,
    'mem_total': mt, 'mem_used': mu, 'mem_available': ma,
    'services': {
        'nginx': service('nginx'),
        'mariadb': service('mariadb'),
        'vsftpd': service('vsftpd'),
        'php_fpm': service(php_service),
    },
    'paths': {
        'panel': os.environ.get('PANEL_DIR', ''),
        'sites': os.environ.get('SITES_DIR', ''),
        'bots': os.environ.get('BOTS_DIR', ''),
        'phpmyadmin': os.environ.get('PHPMYADMIN_PATH', '/usr/share/phpmyadmin'),
    }
}
print(json.dumps(result, ensure_ascii=False))
PY
}

cmd_sync_json() {
  python3 - <<'PY'
import os, json, glob, pwd, re, subprocess

SITES_DIR=os.environ.get('SITES_DIR','/var/www/hyper-host-sites')
BOTS_DIR=os.environ.get('BOTS_DIR','/var/www/hyper-host-bots')
NGINX_AVAILABLE='/etc/nginx/sites-available'

sites=[]
for public_html in sorted(glob.glob(os.path.join(SITES_DIR, '*', 'public_html'))):
    domain=os.path.basename(os.path.dirname(public_html))
    if not re.match(r'^([A-Za-z0-9]([A-Za-z0-9-]{0,61}[A-Za-z0-9])?\.)+[A-Za-z]{2,63}$', domain):
        continue
    aliases=[]
    conf=os.path.join(NGINX_AVAILABLE, f'hyper-host-site-{domain}.conf')
    if os.path.exists(conf):
        text=open(conf, encoding='utf-8', errors='ignore').read()
        m=re.search(r'server_name\s+([^;]+);', text)
        if m:
            names=[x.strip() for x in m.group(1).split() if x.strip()]
            aliases=[x for x in names if x != domain]
    ssl=1 if os.path.exists(f'/etc/letsencrypt/live/{domain}/fullchain.pem') else 0
    sites.append({'domain':domain,'aliases':','.join(aliases),'root_path':public_html,'ssl_enabled':ssl})

ftp=[]
for u in pwd.getpwall():
    if u.pw_name.startswith('hhftp_'):
        ftp.append({'username':u.pw_name,'target_path':u.pw_dir})

bots=[]
for svc in sorted(glob.glob('/etc/systemd/system/hyperbot-*.service')):
    name=os.path.basename(svc)[len('hyperbot-'):-len('.service')]
    if not re.match(r'^[A-Za-z0-9_][A-Za-z0-9_-]{1,63}$', name):
        continue
    text=open(svc, encoding='utf-8', errors='ignore').read()
    mpath=re.search(r'^WorkingDirectory=(.+)$', text, re.M)
    mcmd=re.search(r"^ExecStart=/bin/bash -lc 'cd [^']+ && exec (.*)'$", text, re.M)
    path=mpath.group(1).strip() if mpath else os.path.join(BOTS_DIR,name)
    cmd=mcmd.group(1).strip() if mcmd else ''
    runtime='custom'
    if cmd.startswith('python') or 'python' in cmd: runtime='python'
    elif cmd.startswith('node') or 'node ' in cmd: runtime='node'
    elif cmd.startswith('php') or 'php ' in cmd: runtime='php'
    bots.append({'name':name,'runtime':runtime,'path':path,'start_command':cmd})

databases=[]
try:
    out=subprocess.check_output("mysql -N -B -e \"SELECT Db, User, MAX(Host <> 'localhost') AS remote FROM mysql.db WHERE Db NOT IN ('mysql','performance_schema','information_schema','sys') GROUP BY Db, User ORDER BY Db\"", shell=True, text=True, stderr=subprocess.DEVNULL)
    for line in out.splitlines():
        parts=line.split('\t')
        if len(parts) >= 3:
            db,user,remote=parts[0],parts[1],parts[2]
            if db and user and not db.startswith('phpmyadmin'):
                databases.append({'db_name':db,'db_user':user,'remote_allowed':1 if remote in ('1','true','TRUE') else 0})
except Exception:
    pass

print(json.dumps({'sites':sites,'ftp':ftp,'databases':databases,'bots':bots}, ensure_ascii=False))
PY
}

cmd_repair() {
  ensure_dirs
  mkdir -p "$BASE_DIR/data" "$PANEL_DIR" "$SITES_DIR" "$BOTS_DIR" "$BASE_DIR/templates" /etc/hyper-host
  chown -R www-data:www-data "$PANEL_DIR" "$BASE_DIR/data"
  chown www-data:www-data "$SITES_DIR" 2>/dev/null || true
  chmod 0755 "$PANEL_DIR" "$SITES_DIR" "$BOTS_DIR"
  chmod 0770 "$BASE_DIR/data"
  if [[ -f "$BASE_DIR/data/hyperhost.sqlite" ]]; then
    chown www-data:www-data "$BASE_DIR/data/hyperhost.sqlite" "$BASE_DIR/data/hyperhost.sqlite"-* 2>/dev/null || true
    chmod 0660 "$BASE_DIR/data/hyperhost.sqlite" "$BASE_DIR/data/hyperhost.sqlite"-* 2>/dev/null || true
  fi
  if ! id hyperbot >/dev/null 2>&1; then
    useradd --system --home "$BOTS_DIR" --shell /usr/sbin/nologin hyperbot
  fi
  chown -R hyperbot:www-data "$BOTS_DIR"
  chmod -R u+rwX,g+rwX,o+rX "$BOTS_DIR"
  while IFS=: read -r user _ uid gid gecos home shell; do
    [[ "$user" == hhftp_* ]] || continue
    [[ -n "$home" && -d "$home" ]] || continue
    chown -R "$user":www-data "$home" 2>/dev/null || true
    chmod -R u+rwX,g+rwX,o+rX "$home" 2>/dev/null || true
  done < /etc/passwd
  cat > /etc/sudoers.d/hyper-host <<EOSUDO
www-data ALL=(root) NOPASSWD: /usr/local/sbin/hyper-host-ctl *
EOSUDO
  chmod 0440 /etc/sudoers.d/hyper-host
  visudo -cf /etc/sudoers.d/hyper-host >/dev/null
  ufw allow 80/tcp >/dev/null 2>&1 || true
  ufw allow 443/tcp >/dev/null 2>&1 || true
  ufw allow 21/tcp >/dev/null 2>&1 || true
  ufw allow 40000:40100/tcp >/dev/null 2>&1 || true
  systemctl restart vsftpd 2>/dev/null || true
  systemctl reload nginx 2>/dev/null || systemctl restart nginx 2>/dev/null || true
  log "Repair finished: permissions, sudoers, FTP ports and services checked"
}

case "${1:-}" in
  add-site) shift; cmd_add_site "$@" ;;
  delete-site) shift; cmd_delete_site "$@" ;;
  ssl-site) shift; cmd_ssl_site "$@" ;;
  create-ftp) shift; cmd_create_ftp "$@" ;;
  delete-ftp) shift; cmd_delete_ftp "$@" ;;
  create-db) shift; cmd_create_db "$@" ;;
  delete-db) shift; cmd_delete_db "$@" ;;
  mysql-external) shift; cmd_mysql_external "$@" ;;
  bot-create) shift; cmd_bot_create "$@" ;;
  bot-delete) shift; cmd_bot_delete "$@" ;;
  bot) shift; cmd_bot_action "$@" ;;
  stats-json) shift; cmd_stats_json "$@" ;;
  sync-json) shift; cmd_sync_json "$@" ;;
  repair) shift; cmd_repair "$@" ;;
  *)
    cat >&2 <<EOHELP
Usage:
  hyper-host-ctl add-site DOMAIN [ALIASES_COMMA]
  hyper-host-ctl delete-site DOMAIN [--keep-files|--delete-files]
  hyper-host-ctl ssl-site DOMAIN EMAIL
  hyper-host-ctl create-ftp USER PASS TARGET_PATH
  hyper-host-ctl delete-ftp USER
  hyper-host-ctl create-db DB USER PASS [0|1]
  hyper-host-ctl delete-db DB USER
  hyper-host-ctl mysql-external enable|disable
  hyper-host-ctl bot-create NAME python|node|php|custom COMMAND
  hyper-host-ctl bot-delete NAME [--keep-files|--delete-files]
  hyper-host-ctl bot start|stop|restart|status|logs NAME
  hyper-host-ctl stats-json
  hyper-host-ctl sync-json
  hyper-host-ctl repair
EOHELP
    exit 1
    ;;
esac
