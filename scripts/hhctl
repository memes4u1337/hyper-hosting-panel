#!/usr/bin/env bash
set -Eeo pipefail

CONF="/etc/hyper-host/hyper-host.conf"
[[ -f "$CONF" ]] || { echo "Config not found: $CONF" >&2; exit 2; }
# shellcheck disable=SC1090
source "$CONF"

# HYPER-HOST v53: фиксированный сетевой профиль и реальный FTP/MySQL connectivity fix.
FIXED_INTERNAL_IP="${HYPER_FIXED_INTERNAL_IP:-192.168.0.179}"
FIXED_PUBLIC_IP="${HYPER_FIXED_PUBLIC_IP:-90.189.208.25}"

PANEL_NAME="${PANEL_NAME:-HYPER-HOST}"
POWERED_BY="${POWERED_BY:-powered by memes4u1337}"
CONFIGURED_SERVER_IP="${SERVER_IP:-}"
detect_internal_ipv4_bootstrap() {
  printf '%s\n' "$FIXED_INTERNAL_IP"
}

DETECTED_INTERNAL_IP="$FIXED_INTERNAL_IP"
SERVER_IP="$FIXED_INTERNAL_IP"
PUBLIC_IP="$FIXED_PUBLIC_IP"
PUBLIC_IP_MODE="manual"
PANEL_DOMAIN="${PANEL_DOMAIN:-_}"
BASE_DIR="${BASE_DIR:-/opt/hyper-host}"
PANEL_DIR="${PANEL_DIR:-/var/www/hyper-host}"
SITES_DIR="${SITES_DIR:-/var/www/hyper-host-sites}"
BOTS_DIR="${BOTS_DIR:-/var/www/hyper-host-bots}"
FTP_DIR="${FTP_DIR:-/var/www/hyper-host-ftp}"
PHP_FPM_SOCK="${PHP_FPM_SOCK:-}"
PHPMYADMIN_PATH="${PHPMYADMIN_PATH:-/usr/share/phpmyadmin}"
BACKUP_DIR="${BACKUP_DIR:-$BASE_DIR/backups}"
DNS_DIR="${DNS_DIR:-/etc/bind/hyper-host-zones}"
CRON_DIR="/etc/cron.d"
NGINX_AVAILABLE="/etc/nginx/sites-available"
NGINX_ENABLED="/etc/nginx/sites-enabled"
# v59: если /etc/nginx доступен только для чтения, рабочая копия конфигов
# хранится в /opt и bind-mount'ится поверх /etc/nginx.
# Никаких записей в /usr/lib/systemd или /etc/systemd: текущий unit живёт в /run,
# а восстановление после reboot выполняет root crontab из writable /var.
NGINX_RUNTIME_DIR="${NGINX_RUNTIME_DIR:-$BASE_DIR/runtime/nginx}"
NGINX_BOOT_SCRIPT="${NGINX_BOOT_SCRIPT:-$BASE_DIR/bin/hyper-host-nginx-runtime}"
NGINX_RUNTIME_UNIT="${NGINX_RUNTIME_UNIT:-/run/systemd/system/hyper-host-nginx-runtime.service}"
NGINX_REBOOT_MARKER="HYPER-HOST-NGINX-RUNTIME"
NGINX_RUNTIME_LOG="${NGINX_RUNTIME_LOG:-$BASE_DIR/logs/nginx-runtime-boot.log}"
# v69: неизвестные домены больше не открывают панель. Старые panel-конфиги
# с server_name _ отключаются, панель закрепляется только за точным доменом/IP,
# а каждый сайт обслуживается из собственного public_html.
NGINX_DEFAULT_ROOT="${NGINX_DEFAULT_ROOT:-$BASE_DIR/default-site}"
NGINX_DEFAULT_TLS_DIR="${NGINX_DEFAULT_TLS_DIR:-$BASE_DIR/data/nginx-default-tls}"
NGINX_DEFAULT_TLS_CERT="${NGINX_DEFAULT_TLS_CERT:-$NGINX_DEFAULT_TLS_DIR/fullchain.pem}"
NGINX_DEFAULT_TLS_KEY="${NGINX_DEFAULT_TLS_KEY:-$NGINX_DEFAULT_TLS_DIR/privkey.pem}"

# v62: один FTP/FTPS-движок ProFTPD; учётные записи и конфиг хранятся в /opt.
FTP_GUEST_USER="${FTP_GUEST_USER:-www-data}"
FTP_USER_CONF_DIR="${FTP_USER_CONF_DIR:-$BASE_DIR/ftp/user_conf}"
FTP_AUTH_TXT="${FTP_AUTH_TXT:-$BASE_DIR/data/vsftpd_virtual_users.txt}"
FTP_AUTH_DB_BASE="${FTP_AUTH_DB_BASE:-$BASE_DIR/data/vsftpd_virtual_users}"
FTP_AUTH_DB="${FTP_AUTH_DB:-$FTP_AUTH_DB_BASE.db}"
# v67: два независимых ProFTPD-инстанса.
# LAN-клиенты остаются на TCP 21 и получают LAN PASV-IP.
# Внешние клиенты приходят с роутера на TCP 21 и перенаправляются iptables на
# внутренний WAN-backend TCP 2121, который отдаёт публичный PASV-IP.
FTP_PORT="${FTP_PORT:-21}"
FTP_LAN_PORT="${FTP_LAN_PORT:-21}"
FTP_WAN_PORT="${FTP_WAN_PORT:-2121}"
FTP_LAN_PASV_MIN="${FTP_LAN_PASV_MIN:-40000}"
FTP_LAN_PASV_MAX="${FTP_LAN_PASV_MAX:-40049}"
FTP_WAN_PASV_MIN="${FTP_WAN_PASV_MIN:-40050}"
FTP_WAN_PASV_MAX="${FTP_WAN_PASV_MAX:-40100}"
FTP_PASV_MIN="$FTP_LAN_PASV_MIN"
FTP_PASV_MAX="$FTP_WAN_PASV_MAX"
FTP_LAN_CIDR="${FTP_LAN_CIDR:-192.168.0.0/24}"
FTP_RUNTIME_SCRIPT="${FTP_RUNTIME_SCRIPT:-$BASE_DIR/bin/hyper_ftp_runtime.py}"
FTP_RUNTIME_VENV="${FTP_RUNTIME_VENV:-$BASE_DIR/venv-ftp}"
FTP_RUNTIME_RUN_DIR="${FTP_RUNTIME_RUN_DIR:-$BASE_DIR/run}"
FTP_RUNTIME_LOG_DIR="${FTP_RUNTIME_LOG_DIR:-$BASE_DIR/logs}"

# v62: один промышленный FTP/FTPS-движок ProFTPD. Конфиг, auth и runtime
# находятся в /opt; PAM, Berkeley DB и запись конфигов FTP в /etc не нужны.
PROFTPD_DIR="${PROFTPD_DIR:-$BASE_DIR/proftpd}"
PROFTPD_CONFIG_LAN="${PROFTPD_CONFIG_LAN:-$PROFTPD_DIR/proftpd-lan.conf}"
PROFTPD_CONFIG_WAN="${PROFTPD_CONFIG_WAN:-$PROFTPD_DIR/proftpd-wan.conf}"
# Совместимость со старым кодом: основной конфиг указывает на LAN-инстанс.
PROFTPD_CONFIG="${PROFTPD_CONFIG:-$PROFTPD_CONFIG_LAN}"
PROFTPD_PASSWD="${PROFTPD_PASSWD:-$PROFTPD_DIR/auth/users.passwd}"
PROFTPD_GROUP="${PROFTPD_GROUP:-$PROFTPD_DIR/auth/groups}"
PROFTPD_RUN_DIR="${PROFTPD_RUN_DIR:-$PROFTPD_DIR/run}"
PROFTPD_LOG_DIR="${PROFTPD_LOG_DIR:-$BASE_DIR/logs/proftpd}"
PROFTPD_AUTH_BUILDER="${PROFTPD_AUTH_BUILDER:-$BASE_DIR/bin/proftpd_auth_sync.py}"
PROFTPD_BIN="${PROFTPD_BIN:-/usr/sbin/proftpd}"
PROFTPD_MODULE_DIR="${PROFTPD_MODULE_DIR:-/usr/lib/proftpd}"

# v60: writable ACME/Certbot storage and FTPS certificate storage.
# /etc on this server can be read-only, therefore Let's Encrypt state must live in /opt.
ACME_WEBROOT="${ACME_WEBROOT:-$BASE_DIR/acme-webroot}"
LE_CONFIG_DIR="${LE_CONFIG_DIR:-$BASE_DIR/letsencrypt}"
LE_WORK_DIR="${LE_WORK_DIR:-$BASE_DIR/letsencrypt-work}"
LE_LOGS_DIR="${LE_LOGS_DIR:-$BASE_DIR/logs/letsencrypt}"
FTP_TLS_DIR="${FTP_TLS_DIR:-$BASE_DIR/data/ftp-tls}"
FTP_TLS_CERT_FALLBACK="${FTP_TLS_CERT_FALLBACK:-$FTP_TLS_DIR/fullchain.pem}"
FTP_TLS_KEY_FALLBACK="${FTP_TLS_KEY_FALLBACK:-$FTP_TLS_DIR/privkey.pem}"

export PANEL_NAME POWERED_BY CONFIGURED_SERVER_IP DETECTED_INTERNAL_IP SERVER_IP PUBLIC_IP PUBLIC_IP_MODE PANEL_DOMAIN BASE_DIR PANEL_DIR SITES_DIR BOTS_DIR FTP_DIR PHP_FPM_SOCK PHPMYADMIN_PATH BACKUP_DIR FTP_GUEST_USER FTP_USER_CONF_DIR FTP_AUTH_TXT FTP_AUTH_DB_BASE FTP_AUTH_DB FTP_PORT FTP_PASV_MIN FTP_PASV_MAX FTP_LAN_PORT FTP_WAN_PORT FTP_LAN_PASV_MIN FTP_LAN_PASV_MAX FTP_WAN_PASV_MIN FTP_WAN_PASV_MAX FTP_RUNTIME_SCRIPT FTP_RUNTIME_VENV FTP_RUNTIME_RUN_DIR FTP_RUNTIME_LOG_DIR PROFTPD_DIR PROFTPD_CONFIG PROFTPD_PASSWD PROFTPD_GROUP PROFTPD_RUN_DIR PROFTPD_LOG_DIR PROFTPD_AUTH_BUILDER PROFTPD_BIN PROFTPD_MODULE_DIR NGINX_RUNTIME_DIR NGINX_BOOT_SCRIPT NGINX_RUNTIME_UNIT NGINX_REBOOT_MARKER NGINX_RUNTIME_LOG NGINX_DEFAULT_ROOT NGINX_DEFAULT_TLS_DIR NGINX_DEFAULT_TLS_CERT NGINX_DEFAULT_TLS_KEY ACME_WEBROOT LE_CONFIG_DIR LE_WORK_DIR LE_LOGS_DIR FTP_TLS_DIR FTP_TLS_CERT_FALLBACK FTP_TLS_KEY_FALLBACK
export FTP_LAN_CIDR PROFTPD_CONFIG_LAN PROFTPD_CONFIG_WAN
BOT_USER="${BOT_USER:-hyperbot}"
PM2_HOME_DIR="${PM2_HOME_DIR:-$BOTS_DIR/.pm2}"
NODE_MAJOR_MIN="${NODE_MAJOR_MIN:-18}"

log() { echo "[hhctl] $*"; }
warn() { echo "[hhctl warning] $*" >&2; }
err() { echo "[hhctl error] $*" >&2; exit 1; }
valid_domain() { [[ "$1" =~ ^([A-Za-z0-9]([A-Za-z0-9-]{0,61}[A-Za-z0-9])?\.)+[A-Za-z]{2,63}$ ]]; }
valid_name() { [[ "$1" =~ ^[A-Za-z0-9_][A-Za-z0-9_-]{1,63}$ ]]; }
valid_folder() { [[ "$1" =~ ^[A-Za-z0-9._-]{1,80}$ ]] && [[ "$1" != "." && "$1" != ".." ]]; }
valid_db_name() { [[ "$1" =~ ^[A-Za-z0-9_]{2,48}$ ]]; }
sql_escape() { printf '%s' "$1" | sed -e 's/\\/\\\\/g' -e "s/'/''/g"; }
json_escape() { python3 -c 'import json,sys; print(json.dumps(sys.argv[1], ensure_ascii=False))' "$1"; }

ensure_nologin_shell() {
  # v42: read-only /etc/shells не должен ронять FTP-операции.
  if [[ -x /usr/sbin/nologin ]] && ! grep -qxF /usr/sbin/nologin /etc/shells 2>/dev/null; then echo /usr/sbin/nologin >> /etc/shells 2>/dev/null || true; fi
  if [[ -x /bin/false ]] && ! grep -qxF /bin/false /etc/shells 2>/dev/null; then echo /bin/false >> /etc/shells 2>/dev/null || true; fi
}
ensure_dirs() { mkdir -p "$SITES_DIR" "$BOTS_DIR" "$FTP_DIR" "$BACKUP_DIR" "$BASE_DIR/templates" "$BASE_DIR/data" "$BASE_DIR/ftp" "$FTP_USER_CONF_DIR" "$ACME_WEBROOT/.well-known/acme-challenge" "$LE_CONFIG_DIR" "$LE_WORK_DIR" "$LE_LOGS_DIR" "$FTP_TLS_DIR" "$PROFTPD_DIR/auth" "$PROFTPD_RUN_DIR" "$PROFTPD_LOG_DIR"; }

sql_quote() { sql_escape "$1"; }

configure_php_limits() {
  local dir fpm
  for dir in /etc/php/*/fpm/conf.d /etc/php/*/cli/conf.d; do
    [[ -d "$dir" ]] || continue
    cat > "$dir/99-hyper-host-limits.ini" <<'EOINI'
; HYPER-HOST upload/export limits
file_uploads = On
upload_max_filesize = 1024M
post_max_size = 1024M
memory_limit = 1024M
max_execution_time = 600
max_input_time = 600
max_file_uploads = 100
max_input_vars = 10000
EOINI
  done
  for fpm in php*-fpm; do systemctl restart "$fpm" >/dev/null 2>&1 || true; done
}

cmd_php_install_all() {
  export DEBIAN_FRONTEND=noninteractive
  apt-get update -y
  apt-get install -y software-properties-common apt-transport-https lsb-release >/dev/null 2>&1 || true
  if ! apt-cache show php8.4-fpm >/dev/null 2>&1; then
    add-apt-repository -y ppa:ondrej/php >/dev/null 2>&1 && apt-get update -y || true
  fi
  local v pkgs
  for v in 8.1 8.2 8.3 8.4; do
    pkgs=("php${v}-fpm" "php${v}-cli" "php${v}-mysql" "php${v}-sqlite3" "php${v}-curl" "php${v}-mbstring" "php${v}-xml" "php${v}-zip" "php${v}-gd" "php${v}-intl" "php${v}-bcmath" "php${v}-soap" "php${v}-readline")
    if apt-cache show "php${v}-fpm" >/dev/null 2>&1; then
      apt-get install -y "${pkgs[@]}" || true
      systemctl enable "php${v}-fpm" >/dev/null 2>&1 || true
      systemctl restart "php${v}-fpm" >/dev/null 2>&1 || true
    fi
  done
  configure_php_limits
  nginx_reload || true
  log "PHP versions installed/checked"
}

configure_phpmyadmin_storage() {
  mkdir -p /etc/phpmyadmin/conf.d /var/lib/phpmyadmin/tmp /etc/hyper-host
  chown -R www-data:www-data /var/lib/phpmyadmin/tmp 2>/dev/null || true
  chmod 0770 /var/lib/phpmyadmin/tmp 2>/dev/null || true
  local pass secret_file sqlpass create_sql
  secret_file=/etc/hyper-host/phpmyadmin-control.secret
  if [[ -f "$secret_file" ]]; then pass="$(cat "$secret_file" 2>/dev/null || true)"; fi
  if [[ -z "${pass:-}" ]]; then pass="$(openssl rand -base64 30 | tr -d '\n')"; printf '%s' "$pass" > "$secret_file"; chmod 0600 "$secret_file"; fi
  sqlpass="$(sql_quote "$pass")"
  mysql --protocol=socket -uroot <<EOSQL >/dev/null 2>&1 || true
CREATE DATABASE IF NOT EXISTS phpmyadmin DEFAULT CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
CREATE USER IF NOT EXISTS 'pma'@'localhost' IDENTIFIED BY '${sqlpass}';
ALTER USER 'pma'@'localhost' IDENTIFIED BY '${sqlpass}';
GRANT SELECT, INSERT, UPDATE, DELETE ON phpmyadmin.* TO 'pma'@'localhost';
FLUSH PRIVILEGES;
EOSQL
  create_sql="/usr/share/phpmyadmin/sql/create_tables.sql"
  [[ -f "$create_sql" ]] && mysql --protocol=socket -uroot phpmyadmin < "$create_sql" >/dev/null 2>&1 || true
  {
  cat > /etc/phpmyadmin/conf.d/hyper-host-storage.php <<EOPMASTORE
<?php
\$cfg['TempDir'] = '/var/lib/phpmyadmin/tmp';
\$cfg['UploadDir'] = '';
\$cfg['SaveDir'] = '';
\$cfg['ExecTimeLimit'] = 0;
\$cfg['MemoryLimit'] = '1024M';
if (isset(\$i) && isset(\$cfg['Servers'][\$i])) {
    \$cfg['Servers'][\$i]['pmadb'] = 'phpmyadmin';
    \$cfg['Servers'][\$i]['controlhost'] = 'localhost';
    \$cfg['Servers'][\$i]['controluser'] = 'pma';
    \$cfg['Servers'][\$i]['controlpass'] = '${pass}';
    \$cfg['Servers'][\$i]['bookmarktable'] = 'pma__bookmark';
    \$cfg['Servers'][\$i]['relation'] = 'pma__relation';
    \$cfg['Servers'][\$i]['table_info'] = 'pma__table_info';
    \$cfg['Servers'][\$i]['table_coords'] = 'pma__table_coords';
    \$cfg['Servers'][\$i]['pdf_pages'] = 'pma__pdf_pages';
    \$cfg['Servers'][\$i]['column_info'] = 'pma__column_info';
    \$cfg['Servers'][\$i]['history'] = 'pma__history';
    \$cfg['Servers'][\$i]['table_uiprefs'] = 'pma__table_uiprefs';
    \$cfg['Servers'][\$i]['tracking'] = 'pma__tracking';
    \$cfg['Servers'][\$i]['userconfig'] = 'pma__userconfig';
    \$cfg['Servers'][\$i]['recent'] = 'pma__recent';
    \$cfg['Servers'][\$i]['favorite'] = 'pma__favorite';
    \$cfg['Servers'][\$i]['users'] = 'pma__users';
    \$cfg['Servers'][\$i]['usergroups'] = 'pma__usergroups';
    \$cfg['Servers'][\$i]['navigationhiding'] = 'pma__navigationhiding';
    \$cfg['Servers'][\$i]['savedsearches'] = 'pma__savedsearches';
    \$cfg['Servers'][\$i]['central_columns'] = 'pma__central_columns';
    \$cfg['Servers'][\$i]['designer_settings'] = 'pma__designer_settings';
    \$cfg['Servers'][\$i]['export_templates'] = 'pma__export_templates';
}
EOPMASTORE
  } 2>/dev/null || warn "Не удалось записать /etc/phpmyadmin/conf.d/hyper-host-storage.php (read-only /etc?) — phpMyAdmin storage relations могут быть недоступны, панель это не остановит."
  chmod 0644 /etc/phpmyadmin/conf.d/hyper-host-storage.php 2>/dev/null || true
}

cmd_phpmyadmin_status_json() {
  local ready=0 db=0 tables=0 conf=0 upload="" post="" mem=""
  mysql --protocol=socket -uroot -NBe "SHOW DATABASES LIKE 'phpmyadmin'" 2>/dev/null | grep -qx phpmyadmin && db=1 || true
  tables=$(mysql --protocol=socket -uroot -NBe "SELECT COUNT(*) FROM information_schema.tables WHERE table_schema='phpmyadmin' AND table_name LIKE 'pma\\_\\_%'" 2>/dev/null || echo 0)
  [[ -f /etc/phpmyadmin/conf.d/hyper-host-storage.php ]] && conf=1
  [[ "$db" == 1 && "${tables:-0}" -gt 5 && "$conf" == 1 ]] && ready=1
  upload=$(php -r 'echo ini_get("upload_max_filesize");' 2>/dev/null || true)
  post=$(php -r 'echo ini_get("post_max_size");' 2>/dev/null || true)
  mem=$(php -r 'echo ini_get("memory_limit");' 2>/dev/null || true)
  READY="$ready" DB="$db" TABLES="${tables:-0}" CONF="$conf" UPLOAD="$upload" POST="$post" MEM="$mem" python3 - <<'PYST'
import os,json
print(json.dumps({
 'ready': os.environ.get('READY')=='1',
 'database': os.environ.get('DB')=='1',
 'tables': int(os.environ.get('TABLES') or 0),
 'config': os.environ.get('CONF')=='1',
 'upload_max_filesize': os.environ.get('UPLOAD',''),
 'post_max_size': os.environ.get('POST',''),
 'memory_limit': os.environ.get('MEM',''),
}, ensure_ascii=False))
PYST
}

nginx_write_probe() {
  local probe="/etc/nginx/.hyper-host-write-test-$$"
  if ( : > "$probe" ) 2>/dev/null; then
    rm -f "$probe" 2>/dev/null || true
    return 0
  fi
  return 1
}

install_nginx_runtime_bootstrap() {
  mkdir -p "$BASE_DIR/bin" "$BASE_DIR/logs" /run/systemd/system

  cat > "$NGINX_BOOT_SCRIPT" <<'EOSCRIPT'
#!/usr/bin/env bash
set -Eeuo pipefail
RUNTIME="/opt/hyper-host/runtime/nginx"
TARGET="/etc/nginx"
LOG="/opt/hyper-host/logs/nginx-runtime-boot.log"
mkdir -p "$RUNTIME/sites-available" "$RUNTIME/sites-enabled" "$(dirname "$LOG")"
exec >>"$LOG" 2>&1
printf '[%s] nginx runtime bootstrap start\n' "$(date -Is)"
if command -v flock >/dev/null 2>&1; then
  exec 9>/run/hyper-host-nginx-runtime.lock
  flock -x 9
fi
probe="$TARGET/.hyper-host-write-test-$$"
if ( : > "$probe" ) 2>/dev/null; then
  rm -f "$probe" 2>/dev/null || true
else
  mount --bind "$RUNTIME" "$TARGET"
  mount -o remount,bind,rw "$TARGET" >/dev/null 2>&1 || true
fi
probe="$TARGET/.hyper-host-write-test-$$"
( : > "$probe" ) 2>/dev/null || { echo 'ERROR: /etc/nginx remains read-only'; exit 1; }
rm -f "$probe" 2>/dev/null || true
nginx -t
systemctl reload nginx >/dev/null 2>&1 || systemctl restart nginx
printf '[%s] nginx runtime bootstrap ready\n' "$(date -Is)"
EOSCRIPT
  chmod 0755 "$NGINX_BOOT_SCRIPT"

  cat > "$NGINX_RUNTIME_UNIT" <<EOUNIT
[Unit]
Description=HYPER-HOST writable Nginx runtime
After=local-fs.target

[Service]
Type=oneshot
ExecStart=$NGINX_BOOT_SCRIPT
RemainAfterExit=yes
EOUNIT
  chmod 0644 "$NGINX_RUNTIME_UNIT"
  systemctl daemon-reload >/dev/null 2>&1 || true

  command -v crontab >/dev/null 2>&1 || err "crontab не найден — невозможно восстановить Nginx runtime после перезагрузки"
  local cron_tmp
  cron_tmp="$(mktemp /tmp/hyper-host-nginx-cron.XXXXXX)"
  crontab -l 2>/dev/null | grep -v "$NGINX_REBOOT_MARKER" > "$cron_tmp" || true
  printf '%s\n' "@reboot sleep 8 && $NGINX_BOOT_SCRIPT # $NGINX_REBOOT_MARKER" >> "$cron_tmp"
  crontab "$cron_tmp" || { rm -f "$cron_tmp"; err "Не удалось сохранить root @reboot для Nginx runtime"; }
  rm -f "$cron_tmp"
}

ensure_nginx_runtime_overlay() {
  if command -v flock >/dev/null 2>&1; then
    exec 8>/run/hyper-host-nginx-overlay.lock
    flock -x 8
  fi

  command -v mount >/dev/null 2>&1 || err "Команда mount не найдена — невозможно подключить writable Nginx runtime"
  mkdir -p "$NGINX_RUNTIME_DIR"

  if [[ ! -f "$NGINX_RUNTIME_DIR/.hyper-host-runtime-ready" ]]; then
    cp -a /etc/nginx/. "$NGINX_RUNTIME_DIR/" 2>/dev/null || err "Не удалось скопировать действующий /etc/nginx в $NGINX_RUNTIME_DIR"
    touch "$NGINX_RUNTIME_DIR/.hyper-host-runtime-ready"
  else
    cp -an /etc/nginx/. "$NGINX_RUNTIME_DIR/" 2>/dev/null || true
  fi
  mkdir -p "$NGINX_RUNTIME_DIR/sites-available" "$NGINX_RUNTIME_DIR/sites-enabled" "$BASE_DIR/logs"

  if ! nginx_write_probe; then
    mount --bind "$NGINX_RUNTIME_DIR" /etc/nginx 2>/dev/null || err "Не удалось подключить $NGINX_RUNTIME_DIR поверх /etc/nginx"
    mount -o remount,bind,rw /etc/nginx >/dev/null 2>&1 || true
  fi
  nginx_write_probe || err "Nginx runtime подключён, но /etc/nginx всё ещё read-only"

  install_nginx_runtime_bootstrap
  log "Nginx runtime ready: $NGINX_RUNTIME_DIR -> /etc/nginx"
}

nginx_repair_duplicate_panel_name() {
  # v59: старый panel-конфиг при PANEL_DOMAIN=_ содержал два server_name _.
  # Меняем только первое вхождение; default server с _ остаётся без изменений.
  local conf="$NGINX_AVAILABLE/hyper-host-panel.conf"
  [[ -f "$conf" ]] || return 0
  python3 - "$conf" <<'PYNGINXPANEL'
import pathlib, sys
path = pathlib.Path(sys.argv[1])
text = path.read_text(encoding='utf-8', errors='ignore')
needle = 'server_name _;'
if text.count(needle) >= 2:
    text = text.replace(needle, 'server_name hyper-host-panel.invalid;', 1)
    path.write_text(text, encoding='utf-8')
PYNGINXPANEL
}

nginx_repair_log_paths() {
  # v59: nginx открывает access_log/error_log уже на этапе `nginx -t`.
  # Если каталог сайта был создан не полностью или остался старый конфиг,
  # отсутствующий logs/ ронял создание всех следующих сайтов.
  local conf kind path dir
  shopt -s nullglob
  for conf in "$NGINX_ENABLED"/*.conf "$NGINX_ENABLED"/*; do
    [[ -f "$conf" || -L "$conf" ]] || continue
    while IFS=$'\t' read -r kind path; do
      [[ -n "$path" && "$path" == /* ]] || continue
      dir="$(dirname "$path")"
      mkdir -p "$dir" || err "Не удалось создать каталог логов Nginx: $dir"
      touch "$path" || err "Не удалось создать файл лога Nginx: $path"
      chown www-data:adm "$path" 2>/dev/null || chown www-data:www-data "$path" 2>/dev/null || true
      chmod 0755 "$dir" 2>/dev/null || true
      chmod 0640 "$path" 2>/dev/null || true
    done < <(
      awk '
        /^[[:space:]]*(access_log|error_log)[[:space:]]+/ {
          kind=$1; path=$2; gsub(/;/, "", path);
          if (path ~ /^\//) print kind "\t" path
        }
      ' "$conf" 2>/dev/null || true
    )
  done
  shopt -u nullglob
}

prepare_site_runtime_dirs() {
  local domain="$1" site_dir="$SITES_DIR/$domain" log_dir="$SITES_DIR/$domain/logs"
  mkdir -p "$site_dir/public_html" "$log_dir" || err "Не удалось создать каталоги сайта: $site_dir"
  touch "$log_dir/access.log" "$log_dir/error.log" || err "Не удалось создать логи сайта: $log_dir"
  chown -R www-data:www-data "$site_dir" 2>/dev/null || true
  chmod 2775 "$log_dir" 2>/dev/null || true
  chmod 0664 "$log_dir/access.log" "$log_dir/error.log" 2>/dev/null || true
  [[ -d "$log_dir" && -f "$log_dir/access.log" && -f "$log_dir/error.log" ]] \
    || err "Каталог логов сайта не готов: $log_dir"
}

cmd_nginx_runtime_fix() {
  ensure_nginx_runtime_overlay
  nginx_repair_duplicate_panel_name
  nginx_repair_log_paths
  nginx -t >/dev/null
  systemctl reload nginx >/dev/null 2>&1 || systemctl restart nginx >/dev/null 2>&1
  log "Nginx writable config OK: /etc/nginx -> $NGINX_RUNTIME_DIR"
}

nginx_reload() {
  ensure_nginx_runtime_overlay
  write_nginx_default_catchall
  nginx_repair_site_vhosts
  if [[ -n "${PANEL_DOMAIN:-}" && "${PANEL_DOMAIN:-_}" != "_" ]] && valid_domain "$PANEL_DOMAIN"; then
    panel_domain_conflict_cleanup "$PANEL_DOMAIN"
  fi
  nginx_pin_panel_to_exact_names
  nginx_disable_legacy_panel_catchalls
  nginx_remove_other_defaults
  ln -sfn "$NGINX_AVAILABLE/hyper-host-default.conf" "$NGINX_ENABLED/00-hyper-host-default.conf"
  ln -sfn "$NGINX_AVAILABLE/hyper-host-panel.conf" "$NGINX_ENABLED/10-hyper-host-panel.conf"
  nginx_repair_log_paths
  nginx -t >/dev/null
  systemctl reload nginx
  # Reload у Nginx graceful: старые workers могут короткое время принимать
  # запросы. Даём новому поколению workers подняться до проверки vhost.
  sleep 0.35
}

nginx_verify_site_vhost() {
  # Проверяет не только наличие файла конфига, а реальную маршрутизацию Host
  # в public_html. Используем LAN IP сервера, а не 127.0.0.1: некоторые
  # конфиги слушают только адрес интерфейса. Повторяем запрос во время
  # graceful reload Nginx.
  local domain="$1" root="$2" token probe body i
  [[ -n "$domain" && -d "$root" ]] || return 1
  command -v curl >/dev/null 2>&1 || return 0
  token="HYPER-HOST-VHOST-$domain-$(date +%s)-$$-$RANDOM"
  probe="$root/.hyper-host-vhost-probe-$$-$RANDOM.txt"
  printf '%s' "$token" > "$probe" || return 1
  chown www-data:www-data "$probe" 2>/dev/null || true
  chmod 0644 "$probe" 2>/dev/null || true
  for i in $(seq 1 30); do
    body="$(curl --noproxy '*' -fsS --max-time 4       --resolve "$domain:80:$SERVER_IP"       "http://$domain/${probe##*/}" 2>/dev/null || true)"
    if [[ "$body" == "$token" ]]; then
      rm -f "$probe"
      return 0
    fi
    sleep 0.2
  done
  rm -f "$probe"
  return 1
}


ensure_writable_parent_for() {
  local target="$1" parent probe
  parent="$(dirname "$target")"
  mkdir -p "$parent" 2>/dev/null || true
  probe="$parent/.hyper-host-write-test-$$"
  if ! ( : > "$probe" ) 2>/dev/null; then
    mount -o remount,rw / >/dev/null 2>&1 || true
    mount -o remount,rw "$parent" >/dev/null 2>&1 || true
  else
    rm -f "$probe" 2>/dev/null || true
  fi
}

safe_replace_file() {
  local target="$1" tmp="$2"
  [[ -f "$tmp" ]] || err "Temp file not found: $tmp"
  ensure_writable_parent_for "$target"
  if ! cat "$tmp" > "$target" 2>/tmp/hyper-host-safe-write.err; then
    mount -o remount,rw / >/dev/null 2>&1 || true
    mount -o remount,rw "$(dirname "$target")" >/dev/null 2>&1 || true
    cat "$tmp" > "$target" 2>/tmp/hyper-host-safe-write.err || {
      cat /tmp/hyper-host-safe-write.err >&2 || true
      err "Не удалось записать $target. Файловая система всё ещё read-only: проверь dmesg, диск и mount."
    }
  fi
}
safe_write_file_optional() {
  # Читает содержимое из stdin. Если /etc read-only — предупреждает, но не ломает создание FTP.
  local target="$1" tmp
  tmp="$(mktemp)"
  cat > "$tmp"
  ensure_writable_parent_for "$target"
  if ! cat "$tmp" > "$target" 2>/tmp/hyper-host-optional-write.err; then
    mount -o remount,rw / >/dev/null 2>&1 || true
    mount -o remount,rw "$(dirname "$target")" >/dev/null 2>&1 || true
    if ! cat "$tmp" > "$target" 2>/tmp/hyper-host-optional-write.err; then
      warn "Не удалось записать $target: filesystem read-only. Если FTP ещё не был настроен, после ремонта диска выполни sudo hyper ftp fix"
      rm -f "$tmp" /tmp/hyper-host-optional-write.err 2>/dev/null || true
      return 1
    fi
  fi
  rm -f "$tmp" /tmp/hyper-host-optional-write.err 2>/dev/null || true
  return 0
}


ensure_acme_webroot() {
  mkdir -p "$ACME_WEBROOT/.well-known/acme-challenge"
  chown -R www-data:www-data "$ACME_WEBROOT" 2>/dev/null || true
  chmod 0755 "$ACME_WEBROOT" "$ACME_WEBROOT/.well-known" "$ACME_WEBROOT/.well-known/acme-challenge" 2>/dev/null || true
}

ensure_acme_location_for_conf() {
  # v60: challenge хранится в одном writable webroot под /opt.
  local conf="$1" _site_root="${2:-}"
  [[ -f "$conf" ]] || return 0
  ensure_acme_webroot
  python3 - "$conf" "$ACME_WEBROOT" <<'PYACME'
import sys, pathlib, re
conf = pathlib.Path(sys.argv[1])
webroot = sys.argv[2]
text = conf.read_text(encoding='utf-8', errors='ignore')
block = '\n'.join([
    '',
    '    # HYPER-HOST ACME CHALLENGE',
    '    location ^~ /.well-known/acme-challenge/ {',
    '        root %s;' % webroot,
    '        default_type "text/plain";',
    '        try_files $uri =404;',
    '        allow all;',
    '        access_log off;',
    '        log_not_found off;',
    '    }',
    ''
])
text = re.sub(
    r'\n\s*# HYPER-HOST ACME CHALLENGE\n\s*location \^~ /\.well-known/acme-challenge/ \{.*?\n\s*\}\n',
    '\n', text, flags=re.S
)
needle = '    location ~ /\\. { deny all; }'
if needle in text:
    text = text.replace(needle, block + '\n' + needle, 1)
else:
    pos = text.rfind('\n}')
    if pos < 0:
        raise SystemExit('cannot find closing server brace in %s' % conf)
    text = text[:pos] + block + text[pos:]
conf.write_text(text, encoding='utf-8')
PYACME
}

ensure_acme_location_for_domain() {
  local domain="$1" root="$2"
  local conf="$NGINX_AVAILABLE/hyper-host-site-$domain.conf"
  local enabled="$NGINX_ENABLED/hyper-host-site-$domain.conf"
  ensure_nginx_runtime_overlay
  ensure_acme_webroot
  if [[ -f "$conf" ]]; then
    ensure_acme_location_for_conf "$conf" "$root"
    ln -sfn "$conf" "$enabled"
  elif [[ -f "$enabled" ]]; then
    ensure_acme_location_for_conf "$enabled" "$root"
  fi
}

ensure_acme_locations_all() {
  local conf domain root
  ensure_acme_webroot
  shopt -s nullglob
  for conf in "$NGINX_AVAILABLE"/hyper-host-site-*.conf; do
    domain="${conf##*/hyper-host-site-}"; domain="${domain%.conf}"
    root="$(awk '/^[[:space:]]*root[[:space:]]+/ {gsub(";", "", $2); print $2; exit}' "$conf" 2>/dev/null || true)"
    [[ -n "$root" ]] || root="$SITES_DIR/$domain/public_html"
    ensure_acme_location_for_domain "$domain" "$root"
  done
  shopt -u nullglob
}

ensure_nginx_default_tls() {
  mkdir -p "$NGINX_DEFAULT_TLS_DIR" "$NGINX_DEFAULT_ROOT"
  if [[ ! -s "$NGINX_DEFAULT_TLS_CERT" || ! -s "$NGINX_DEFAULT_TLS_KEY" ]]; then
    local cn="hyper-host-default.invalid" san="DNS:hyper-host-default.invalid,IP:${SERVER_IP},IP:${FIXED_PUBLIC_IP}"
    if ! openssl req -x509 -nodes -newkey rsa:2048 -sha256 -days 825 \
        -keyout "$NGINX_DEFAULT_TLS_KEY" -out "$NGINX_DEFAULT_TLS_CERT" \
        -subj "/CN=$cn" -addext "subjectAltName=$san" >/dev/null 2>&1; then
      openssl req -x509 -nodes -newkey rsa:2048 -sha256 -days 825 \
        -keyout "$NGINX_DEFAULT_TLS_KEY" -out "$NGINX_DEFAULT_TLS_CERT" \
        -subj "/CN=$cn" >/dev/null 2>&1 || err "Не удалось создать fallback TLS-сертификат Nginx"
    fi
  fi
  chmod 0600 "$NGINX_DEFAULT_TLS_KEY" 2>/dev/null || true
  chmod 0644 "$NGINX_DEFAULT_TLS_CERT" 2>/dev/null || true
  if [[ ! -f "$NGINX_DEFAULT_ROOT/index.html" ]]; then
    cat > "$NGINX_DEFAULT_ROOT/index.html" <<'EOFDEFAULTSITE'
<!doctype html><html lang="ru"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Домен не настроен</title></head><body style="font-family:Arial,sans-serif;background:#07101f;color:#fff;display:grid;place-items:center;min-height:100vh;margin:0"><main style="max-width:720px;padding:36px;border:1px solid #ffffff24;border-radius:24px;background:#0f1b31"><h1>Домен не настроен</h1><p>Создай сайт в HYPER-HOST или проверь DNS и имя домена.</p></main></body></html>
EOFDEFAULTSITE
  fi
  chmod -R a+rX "$NGINX_DEFAULT_ROOT" 2>/dev/null || true
}

write_nginx_default_catchall() {
  ensure_nginx_runtime_overlay
  ensure_nginx_default_tls
  mkdir -p "$NGINX_AVAILABLE" "$NGINX_ENABLED"
  local conf="$NGINX_AVAILABLE/hyper-host-default.conf"
  cat > "$conf" <<EODEFAULTNGINX
server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name _;
    root ${NGINX_DEFAULT_ROOT};
    index index.html;
    location ^~ /.well-known/acme-challenge/ {
        root ${ACME_WEBROOT};
        default_type "text/plain";
        try_files \$uri =404;
        allow all;
        access_log off;
        log_not_found off;
    }
    location / { try_files \$uri /index.html =404; }
}
server {
    listen 443 ssl default_server;
    listen [::]:443 ssl default_server;
    server_name _;
    ssl_certificate ${NGINX_DEFAULT_TLS_CERT};
    ssl_certificate_key ${NGINX_DEFAULT_TLS_KEY};
    root ${NGINX_DEFAULT_ROOT};
    index index.html;
    location / { try_files \$uri /index.html =404; }
}
EODEFAULTNGINX
  # Отключаем стандартную заглушку Ubuntu, чтобы default_server был ровно один.
  rm -f "$NGINX_ENABLED/default" 2>/dev/null || true
  ln -sfn "$conf" "$NGINX_ENABLED/00-hyper-host-default.conf"
}

nginx_repair_site_vhosts() {
  ensure_nginx_default_tls
  local conf
  shopt -s nullglob
  for conf in "$NGINX_AVAILABLE"/hyper-host-site-*.conf; do
    python3 - "$conf" "$NGINX_DEFAULT_TLS_CERT" "$NGINX_DEFAULT_TLS_KEY" <<'PYVHOST'
import pathlib,re,sys
p=pathlib.Path(sys.argv[1]); cert=sys.argv[2]; key=sys.argv[3]
text=p.read_text(encoding='utf-8',errors='ignore')
# Uploaded index.html must win over the generated placeholder index.php.
text=re.sub(r'index\s+index\.php\s+index\.html\s+index\.htm\s*;', 'index index.html index.htm index.php;', text)
text=re.sub(r'index\s+index\.php\s+index\.html\s*;', 'index index.html index.php;', text)
# Old HTTP-only sites were falling through to the panel on HTTPS. Give every
# HYPER-HOST site an exact HTTPS vhost using the shared fallback certificate.
if not re.search(r'listen\s+(?:\[::\]:)?443\b', text):
    marker='    listen [::]:80;'
    addition=(marker+'\n    listen 443 ssl;\n    listen [::]:443 ssl;\n'
              f'    ssl_certificate {cert};\n'
              f'    ssl_certificate_key {key};')
    if marker in text:
        text=text.replace(marker, addition, 1)
    else:
        marker='    listen 80;'
        addition=(marker+'\n    listen 443 ssl;\n'
                  f'    ssl_certificate {cert};\n'
                  f'    ssl_certificate_key {key};')
        text=text.replace(marker, addition, 1)
p.write_text(text,encoding='utf-8')
PYVHOST
    ln -sfn "$conf" "$NGINX_ENABLED/${conf##*/}"
  done
  shopt -u nullglob
}

panel_exact_server_names() {
  local domain="${PANEL_DOMAIN:-_}"
  if [[ -n "$domain" && "$domain" != "_" ]] && valid_domain "$domain"; then
    printf '%s\n' "$domain"
  else
    # Если домен панели не настроен, панель доступна только по известным IP,
    # но никогда не становится catch-all для чужих доменов.
    printf '%s %s localhost\n' "$SERVER_IP" "$FIXED_PUBLIC_IP"
  fi
}

nginx_pin_panel_to_exact_names() {
  local conf="$NGINX_AVAILABLE/hyper-host-panel.conf" names
  names="$(panel_exact_server_names)"
  if [[ ! -f "$conf" ]]; then
    write_panel_nginx_conf "${PANEL_DOMAIN:-_}"
  fi
  [[ -f "$conf" ]] || err "Не найден конфиг панели Nginx: $conf"
  python3 - "$conf" "$names" <<'PYPINPANEL'
import pathlib,re,sys
p=pathlib.Path(sys.argv[1]); names=sys.argv[2].strip()
text=p.read_text(encoding='utf-8',errors='ignore')
# Панель никогда не должна быть default_server и не должна иметь server_name _.
text=re.sub(r'(listen\s+(?:\[::\]:)?(?:80|443)(?:\s+ssl)?)[^;]*\bdefault_server\b([^;]*;)', r'\1\2', text)
text=re.sub(r'(^\s*server_name\s+)[^;]+;', lambda m: m.group(1)+names+';', text, flags=re.M)
p.write_text(text,encoding='utf-8')
PYPINPANEL
  rm -f "$NGINX_ENABLED/00-hyper-host-panel.conf" "$NGINX_ENABLED/hyper-host-panel.conf" 2>/dev/null || true
  ln -sfn "$conf" "$NGINX_ENABLED/10-hyper-host-panel.conf"
}

nginx_disable_legacy_panel_catchalls() {
  local path real base
  shopt -s nullglob
  for path in "$NGINX_ENABLED"/*; do
    base="${path##*/}"
    [[ "$base" == "00-hyper-host-default.conf" || "$base" == "10-hyper-host-panel.conf" ]] && continue
    real="$(readlink -f "$path" 2>/dev/null || echo "$path")"
    [[ -f "$real" ]] || continue
    # Любой старый server_name _ конкурирует с единственным нейтральным
    # 00-hyper-host-default.conf и может отправить новый домен в панель.
    if python3 - "$real" <<'PYLEGACYPANEL'
import pathlib,re,sys
text=pathlib.Path(sys.argv[1]).read_text(encoding='utf-8',errors='ignore')
is_legacy_catch=bool(re.search(r'(^|\s)server_name\s+_[^;]*;',text,re.M))
raise SystemExit(0 if is_legacy_catch else 1)
PYLEGACYPANEL
    then
      rm -f "$path" 2>/dev/null || true
    fi
  done
  shopt -u nullglob
}

nginx_remove_other_defaults() {
  local path real
  shopt -s nullglob
  for path in "$NGINX_ENABLED"/*; do
    [[ "${path##*/}" == "00-hyper-host-default.conf" ]] && continue
    real="$(readlink -f "$path" 2>/dev/null || echo "$path")"
    [[ -f "$real" ]] || continue
    python3 - "$real" <<'PYDEFAULT'
import pathlib,re,sys
p=pathlib.Path(sys.argv[1]); text=p.read_text(encoding='utf-8',errors='ignore')
text=re.sub(r'(listen\s+(?:\[::\]:)?(?:80|443)(?:\s+ssl)?)[^;]*\bdefault_server\b([^;]*;)', r'\1\2', text)
p.write_text(text,encoding='utf-8')
PYDEFAULT
  done
  shopt -u nullglob
}

cmd_nginx_site_routing_fix() {
  ensure_nginx_runtime_overlay
  ensure_acme_webroot
  write_nginx_default_catchall
  nginx_repair_site_vhosts
  if [[ -n "${PANEL_DOMAIN:-}" && "${PANEL_DOMAIN:-_}" != "_" ]] && valid_domain "$PANEL_DOMAIN"; then
    panel_domain_conflict_cleanup "$PANEL_DOMAIN"
  fi
  nginx_pin_panel_to_exact_names
  nginx_disable_legacy_panel_catchalls
  nginx_remove_other_defaults
  # После удаления старых catch-all ещё раз гарантируем единственные ссылки.
  ln -sfn "$NGINX_AVAILABLE/hyper-host-default.conf" "$NGINX_ENABLED/00-hyper-host-default.conf"
  ln -sfn "$NGINX_AVAILABLE/hyper-host-panel.conf" "$NGINX_ENABLED/10-hyper-host-panel.conf"
  nginx_repair_log_paths
  nginx -t >/dev/null
  systemctl reload nginx >/dev/null 2>&1 || systemctl restart nginx >/dev/null 2>&1
  log "Nginx site routing fixed: panel pinned to exact domain/IP; sites serve their own public_html"
}

write_panel_nginx_conf() {
  ensure_nginx_runtime_overlay
  write_nginx_default_catchall
  local domain="${1:-$PANEL_DOMAIN}" named_domain
  [[ -n "$domain" ]] || domain="_"
  named_domain="$domain"
  # Без настроенного домена панель привязывается только к IP/localhost,
  # но не перехватывает произвольные Host-заголовки.
  if [[ -z "$named_domain" || "$named_domain" == "_" ]] || ! valid_domain "$named_domain"; then
    named_domain="$SERVER_IP $FIXED_PUBLIC_IP localhost"
  fi
  mkdir -p /etc/nginx/sites-available /etc/nginx/sites-enabled "$PANEL_DIR/public/.well-known/acme-challenge"
  chown -R www-data:www-data "$PANEL_DIR/public/.well-known" 2>/dev/null || true
  chmod -R a+rX "$PANEL_DIR/public/.well-known" 2>/dev/null || true
  {
  cat > /etc/nginx/sites-available/hyper-host-panel.conf <<EOPANELNGINX
server {
    listen 80;
    listen [::]:80;
    server_name ${named_domain};

    root ${PANEL_DIR}/public;
    index index.php index.html;
    client_max_body_size 1024M;

    access_log /var/log/nginx/hyper-host-panel.access.log;
    error_log /var/log/nginx/hyper-host-panel.error.log;

    # HYPER-HOST PANEL ACME CHALLENGE
    location ^~ /.well-known/acme-challenge/ {
        root ${PANEL_DIR}/public;
        default_type "text/plain";
        try_files \$uri =404;
        allow all;
    }

    location / {
        try_files \$uri \$uri/ /index.php?\$query_string;
    }

    location /phpmyadmin {
        alias /usr/share/phpmyadmin/;
        index index.php index.html;
    }

    location ~ ^/phpmyadmin/(.+\.php)$ {
        alias /usr/share/phpmyadmin/\$1;
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME /usr/share/phpmyadmin/\$1;
        fastcgi_read_timeout 600;
        fastcgi_send_timeout 600;
        fastcgi_connect_timeout 60;
        fastcgi_pass unix:${PHP_FPM_SOCK};
    }

    location ~ ^/phpmyadmin/(.+)$ {
        alias /usr/share/phpmyadmin/\$1;
    }

    location ~ \.php$ {
        include snippets/fastcgi-php.conf;
        fastcgi_read_timeout 600;
        fastcgi_send_timeout 600;
        fastcgi_connect_timeout 60;
        fastcgi_pass unix:${PHP_FPM_SOCK};
    }

    location ~ /\. {
        deny all;
    }
}

EOPANELNGINX
  } 2>/dev/null || warn "Не удалось записать /etc/nginx/sites-available/hyper-host-panel.conf (read-only /etc?) — конфиг nginx для домена панели не обновлён."
  # Панель открывается только по точному PANEL_DOMAIN. Default vhost теперь
  # отдельный и никогда не показывает интерфейс панели для нового домена.
  rm -f /etc/nginx/sites-enabled/00-hyper-host-panel.conf /etc/nginx/sites-enabled/hyper-host-panel.conf 2>/dev/null || true
  ln -sf /etc/nginx/sites-available/hyper-host-panel.conf /etc/nginx/sites-enabled/10-hyper-host-panel.conf 2>/dev/null || true
}

panel_domain_conflict_cleanup() {
  local domain="$1" path real target
  # Disable the exact HYPER-HOST site config for the panel domain.
  local site_conf="$NGINX_AVAILABLE/hyper-host-site-$domain.conf" enabled_conf="$NGINX_ENABLED/hyper-host-site-$domain.conf"
  [[ -e "$enabled_conf" || -L "$enabled_conf" ]] && rm -f "$enabled_conf"
  [[ -f "$site_conf" ]] && mv -f "$site_conf" "$site_conf.disabled-for-panel" 2>/dev/null || true

  # Disable any other enabled nginx config that contains this exact server_name, except panel config.
  shopt -s nullglob
  for path in "$NGINX_ENABLED"/*; do
    [[ -e "$path" || -L "$path" ]] || continue
    [[ "${path##*/}" == "00-hyper-host-default.conf" || "${path##*/}" == "00-hyper-host-panel.conf" || "${path##*/}" == "10-hyper-host-panel.conf" || "${path##*/}" == "hyper-host-panel.conf" ]] && continue
    real="$(readlink -f "$path" 2>/dev/null || echo "$path")"
    [[ -f "$real" ]] || continue
    if python3 - "$real" "$domain" <<'PYCHECK'
import re,sys,pathlib
text=pathlib.Path(sys.argv[1]).read_text(errors='ignore')
d=sys.argv[2]
found=False
for m in re.finditer(r'server_name\s+([^;]+);', text):
    names=m.group(1).split()
    if d in names:
        found=True
        break
sys.exit(0 if found else 1)
PYCHECK
    then
      rm -f "$path" 2>/dev/null || true
      case "$real" in
        "$NGINX_AVAILABLE"/*) mv -f "$real" "$real.disabled-for-panel" 2>/dev/null || true ;;
      esac
    fi
  done
  shopt -u nullglob
}

update_panel_domain_in_app_config() {
  local domain="$1" cfg="$PANEL_DIR/app/config.php"
  [[ -f "$cfg" ]] || return 0
  python3 - "$cfg" "$domain" <<'PYCFG'
import re,sys,pathlib
p=pathlib.Path(sys.argv[1]); d=sys.argv[2]
text=p.read_text(encoding='utf-8',errors='ignore')
text=re.sub(r"('panel_domain'\s*=>\s*)'[^']*'", r"\1'"+d.replace("'","\\'")+"'", text)
p.write_text(text,encoding='utf-8')
PYCFG
}


path_is_mount_target() {
  local target="${1:-}"
  [[ -n "$target" ]] || return 1
  awk '{print $5}' /proc/self/mountinfo 2>/dev/null | sed 's/\\040/ /g' | grep -Fxq "$target"
}

safe_fstab_filter_file() {
  # v42: FTP больше не пишет /etc/fstab.
  # Это убирает ошибки вида: /etc/fstab: Read-only file system.
  local tmp="${1:-}"
  [[ -n "$tmp" ]] && rm -f "$tmp" 2>/dev/null || true
  return 0
}

safe_fstab_remove_ftp_paths() {
  local pattern_file="${1:-}"
  [[ -n "$pattern_file" ]] && rm -f "$pattern_file" 2>/dev/null || true
  return 0
}

safe_fstab_append_bind() {
  # v55: FTP bind-mounts are runtime-only. /etc/fstab is intentionally never
  # touched because /etc may be mounted read-only on this server.
  return 0
}

ftp_remove_fstab_target() {
  # v55: there are no persistent FTP entries in /etc/fstab.
  return 0
}

ftp_make_path_visible() {
  # Делает каталог читаемым/открываемым для FTP-пользователей, не ломая владельцев сайта.
  local path="${1:-}" user="${2:-}"
  [[ -n "$path" && -e "$path" ]] || return 0
  chgrp -R www-data "$path" 2>/dev/null || true
  find "$path" -xdev -type d -exec chmod u+rwx,g+rwx,o+rx {} + 2>/dev/null || true
  find "$path" -xdev -type f -exec chmod u+rw,g+rw,o+r {} + 2>/dev/null || true
  if command -v setfacl >/dev/null 2>&1; then
    setfacl -R -m g:www-data:rwx "$path" 2>/dev/null || true
    setfacl -R -d -m g:www-data:rwx "$path" 2>/dev/null || true
    if [[ -n "$user" ]]; then
      setfacl -R -m u:"$user":rwx "$path" 2>/dev/null || true
      setfacl -R -d -m u:"$user":rwx "$path" 2>/dev/null || true
    fi
  fi
}

cleanup_hyper_host_mounts() {
  # v38: чистим только реально сломанные циклические bind-mount'ы.
  # ВАЖНО: больше не снимаем нормальные FTP bind-mount'ы вида:
  #   /var/www/hyper-host-ftp/<user>/sites
  #   /var/www/hyper-host-ftp/<user>/bots
  #   /var/www/hyper-host-ftp/<user>/backups
  # Именно из-за старой слишком широкой чистки FileZilla подключалась, но каталог был пустой.
  local mp pass tmp
  for pass in 1 2 3 4 5; do
    mapfile -t _hh_bad_mounts < <(
      awk '{print $5}' /proc/self/mountinfo 2>/dev/null \
        | sed 's/\\040/ /g' \
        | while read -r mp; do
            case "$mp" in
              */public_html/common|*/public_html/common/*|*/public_html/sites|*/public_html/sites/*|*/public_html/bots|*/public_html/bots/*|*/public_html/site|*/public_html/site/*|*/common/sites/common|*/common/sites/common/*|*/common/bots/common|*/common/bots/common/*|*/site/common|*/site/common/*)
                printf '%s\n' "$mp" ;;
            esac
          done \
        | sort -r || true
    )
    [[ ${#_hh_bad_mounts[@]} -eq 0 ]] && break
    for mp in "${_hh_bad_mounts[@]}"; do
      case "$mp" in
        "/"|"/var"|"/var/www"|"$SITES_DIR"|"$BOTS_DIR"|"$FTP_DIR") continue ;;
      esac
      umount -lf "$mp" 2>/dev/null || true
    done
  done
  if [[ -f /etc/fstab ]]; then
    tmp="$(mktemp)"
    awk '
      /public_html\/(common|sites|bots|site)/ {next}
      /common\/sites\/common/ {next}
      /common\/bots\/common/ {next}
      /site\/common/ {next}
      {print}
    ' /etc/fstab > "$tmp" || true
    safe_fstab_filter_file "$tmp"
    rm -f "$tmp"
  fi
}

safe_chown_tree() {
  local owner="$1" path="$2"
  [[ -e "$path" ]] || return 0
  cleanup_hyper_host_mounts
  find "$path" -xdev -exec chown -h "$owner" {} + 2>/dev/null || true
}

safe_chmod_tree() {
  local mode="$1" path="$2"
  [[ -e "$path" ]] || return 0
  cleanup_hyper_host_mounts
  find "$path" -xdev -exec chmod "$mode" {} + 2>/dev/null || true
}
fix_web_permissions() {
  local path="$1" user="${2:-}"
  [[ -e "$path" ]] || return 0
  cleanup_hyper_host_mounts
  find "$path" -xdev -exec chgrp www-data {} + 2>/dev/null || true
  find "$path" -xdev -exec chmod u+rwX,g+rwX,o+rX {} + 2>/dev/null || true
  find "$path" -xdev -type d -exec chmod g+s {} + 2>/dev/null || true
  if command -v setfacl >/dev/null 2>&1; then
    setfacl -R -m u:www-data:rwx,g:www-data:rwx "$path" 2>/dev/null || true
    setfacl -R -d -m u:www-data:rwx,g:www-data:rwx "$path" 2>/dev/null || true
    if [[ -n "$user" ]]; then
      setfacl -R -m u:"$user":rwx "$path" 2>/dev/null || true
      setfacl -R -d -m u:"$user":rwx "$path" 2>/dev/null || true
    fi
  fi
}

php_index_template_file() {
  local title="$1" file="$2"
  mkdir -p "$(dirname "$file")"
  cat > "$file" <<EOPHP
<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1">
  <title>${title} — HYPER-HOST</title>
  <style>:root{color-scheme:dark}*{box-sizing:border-box}body{margin:0;min-height:100vh;display:grid;place-items:center;background:radial-gradient(circle at 20% 20%,#2563eb44,transparent 32%),radial-gradient(circle at 90% 10%,#9333ea44,transparent 30%),linear-gradient(135deg,#070a14,#101827);color:#fff;font-family:Inter,Arial,sans-serif}.box{width:min(860px,92vw);padding:44px;border:1px solid rgba(255,255,255,.14);border-radius:32px;background:rgba(15,23,42,.78);box-shadow:0 40px 120px rgba(0,0,0,.55);backdrop-filter:blur(18px)}.logo{display:inline-flex;gap:10px;align-items:center;padding:10px 14px;border:1px solid rgba(255,255,255,.14);border-radius:999px;background:rgba(255,255,255,.06);color:#93c5fd}h1{margin:18px 0 12px;font-size:clamp(36px,6vw,64px);letter-spacing:-.05em}.muted{color:#b7c2d8;font-size:18px;line-height:1.65}.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin-top:26px}.item{padding:16px;border-radius:18px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1)}code{color:#a7f3d0}.powered{margin-top:24px;color:#a78bfa}</style>
</head>
<body><main class="box"><div class="logo">🚀 HYPER-HOST</div><h1>${title}</h1><p class="muted">Сайт/папка создана. Загрузи файлы через FTP или файловый менеджер и замени этот стартовый экран.</p><div class="grid"><div class="item">Корень: <code>public_html</code></div><div class="item">PHP: <code>работает</code></div><div class="item">Панель: <code>HYPER-HOST</code></div></div><div class="powered">powered by memes4u1337</div></main></body></html>
EOPHP
}

php_sock_for_version() {
  local version="$1"
  if [[ -n "$version" && -S "/run/php/php${version}-fpm.sock" ]]; then echo "/run/php/php${version}-fpm.sock"; return; fi
  echo "$PHP_FPM_SOCK"
}

cmd_create_folder() {
  ensure_dirs
  local name="${1:-}"; [[ -n "$name" ]] || err "Folder name required"; valid_folder "$name" || err "Invalid folder name: $name"
  local root="$SITES_DIR/$name/public_html"
  mkdir -p "$root" "$SITES_DIR/$name/logs"
  [[ -f "$root/index.php" || -f "$root/index.html" ]] || php_index_template_file "$name" "$root/index.html"
  chown -R www-data:www-data "$SITES_DIR/$name" 2>/dev/null || true
  fix_web_permissions "$SITES_DIR/$name"
  log "Folder created: $name -> $root"
}
cmd_delete_folder() { local name="${1:-}"; [[ -n "$name" ]] || err "Folder name required"; valid_folder "$name" || err "Invalid folder name"; rm -rf "$SITES_DIR/$name"; log "Folder deleted: $name"; }

cmd_add_site() {
  ensure_dirs
  ensure_nginx_runtime_overlay
  local domain="${1:-}" aliases="${2:-}" phpv="${3:-}"
  [[ -n "$domain" ]] || err "Domain required"; valid_domain "$domain" || err "Invalid domain: $domain"
  if [[ -n "$PANEL_DOMAIN" && "$PANEL_DOMAIN" != "_" && "$domain" == "$PANEL_DOMAIN" ]]; then
    err "Этот домен закреплён за панелью: $domain. Используй другой домен для сайта или сначала смени panel-domain."
  fi
  local root="$SITES_DIR/$domain/public_html" sock conf enabled
  sock="$(php_sock_for_version "$phpv")"
  conf="$NGINX_AVAILABLE/hyper-host-site-$domain.conf"
  enabled="$NGINX_ENABLED/hyper-host-site-$domain.conf"

  # ВАЖНО: сначала создаём public_html + logs + сами log-файлы,
  # и только потом публикуем конфиг. Иначе nginx -t падает на open(access.log).
  prepare_site_runtime_dirs "$domain"
  [[ -f "$root/index.php" || -f "$root/index.html" ]] || php_index_template_file "$domain работает" "$root/index.html"
  chown -R www-data:www-data "$SITES_DIR/$domain" 2>/dev/null || true
  fix_web_permissions "$SITES_DIR/$domain"
  prepare_site_runtime_dirs "$domain"
  ensure_acme_webroot
  ensure_nginx_default_tls
  local server_names="$domain"
  if [[ -n "$aliases" ]]; then
    IFS=',' read -ra arr <<< "$aliases"
    for a in "${arr[@]}"; do a="$(echo "$a" | xargs)"; [[ -z "$a" ]] && continue; valid_domain "$a" || err "Invalid alias: $a"; server_names="$server_names $a"; done
  fi
  {
  cat > "$conf" <<EONGINX
server {
    listen 80;
    listen [::]:80;
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name ${server_names};
    ssl_certificate ${NGINX_DEFAULT_TLS_CERT};
    ssl_certificate_key ${NGINX_DEFAULT_TLS_KEY};
    root ${root};
    index index.html index.htm index.php;
    client_max_body_size 1024M;
    access_log ${SITES_DIR}/${domain}/logs/access.log;
    error_log ${SITES_DIR}/${domain}/logs/error.log;
    location / { try_files \$uri \$uri/ /index.php?\$query_string; }
    # HYPER-HOST ACME CHALLENGE
    location ^~ /.well-known/acme-challenge/ {
        root ${ACME_WEBROOT};
        default_type "text/plain";
        try_files \$uri =404;
        allow all;
        access_log off;
        log_not_found off;
    }
    location ~ \.php$ { include snippets/fastcgi-php.conf; fastcgi_read_timeout 600; fastcgi_send_timeout 600; fastcgi_connect_timeout 60; fastcgi_pass unix:${sock}; }
    location ~ /\. { deny all; }
}
EONGINX
  } 2>/dev/null || err "Не удалось записать конфиг nginx для $domain (read-only /etc/nginx?) — сайт не создан."
  ln -sf "$conf" "$enabled"
  if ! nginx_reload; then
    rm -f "$enabled" "$conf" 2>/dev/null || true
    nginx_reload >/dev/null 2>&1 || true
    err "Конфиг сайта $domain не прошёл nginx -t; конфиг откатан, файлы сайта сохранены"
  fi
  if ! nginx_verify_site_vhost "$domain" "$root"; then
    rm -f "$enabled" "$conf" 2>/dev/null || true
    nginx_reload >/dev/null 2>&1 || true
    err "Nginx загрузил конфиг, но Host $domain не попал в $root; конфиг откатан, файлы сайта сохранены"
  fi
  log "Site created and verified: $domain -> $root"
}
cmd_delete_site() { local domain="${1:-}" mode="${2:---keep-files}"; [[ -n "$domain" ]] || err "Domain required"; valid_domain "$domain" || err "Invalid domain"; ensure_nginx_runtime_overlay; rm -f "$NGINX_ENABLED/hyper-host-site-$domain.conf" "$NGINX_AVAILABLE/hyper-host-site-$domain.conf"; nginx_reload; [[ "$mode" == "--delete-files" ]] && rm -rf "$SITES_DIR/$domain"; log "Site deleted: $domain / $mode"; }
is_private_ipv4() {
  local ip="$1"
  [[ "$ip" =~ ^10\. ]] && return 0
  [[ "$ip" =~ ^192\.168\. ]] && return 0
  [[ "$ip" =~ ^172\.(1[6-9]|2[0-9]|3[0-1])\. ]] && return 0
  [[ "$ip" =~ ^127\. ]] && return 0
  return 1
}

detect_internal_ipv4() {
  detect_internal_ipv4_bootstrap
}

default_gateway_ipv4() {
  ip -4 route show default 2>/dev/null | awk '/default/ {print $3; exit}' || true
}

default_interface() {
  ip -4 route show default 2>/dev/null | awk '/default/ {print $5; exit}' || true
}

valid_public_ipv4() {
  local ip="${1:-}"
  [[ "$ip" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]] || return 1
  python3 - "$ip" <<'PYIPVALID' >/dev/null 2>&1
import ipaddress,sys
ip=ipaddress.ip_address(sys.argv[1])
raise SystemExit(0 if ip.version == 4 and ip.is_global else 1)
PYIPVALID
}

outbound_public_ip() {
  printf '%s\n' "$FIXED_PUBLIC_IP"
}

configured_public_ip() {
  printf '%s\n' "$FIXED_PUBLIC_IP"
}

public_ip() {
  printf '%s\n' "$FIXED_PUBLIC_IP"
}


persist_runtime_ips() {
  local internal="$FIXED_INTERNAL_IP" external="$FIXED_PUBLIC_IP" app_cfg="$PANEL_DIR/app/config.php"
  mkdir -p /etc/hyper-host
  printf '%s\n' "$internal" > /etc/hyper-host/internal_ip 2>/dev/null || true
  printf '%s\n' "$external" > /etc/hyper-host/public_ip 2>/dev/null || true
  rm -f /run/hyper-host-public-ip.cache 2>/dev/null || true
  if [[ -f "$CONF" ]]; then
    INTERNAL="$internal" EXTERNAL="$external" python3 - "$CONF" <<'PYPERSISTCONF'
from pathlib import Path
import os,re,sys
p=Path(sys.argv[1]); text=p.read_text(errors='ignore')
def put(key,val):
    global text
    line=f'{key}="{val}"'
    if re.search(rf'^{re.escape(key)}=', text, re.M):
        text=re.sub(rf'^{re.escape(key)}=.*$', line, text, flags=re.M)
    else:
        text += ('\n' if text and not text.endswith('\n') else '') + line + '\n'
put('SERVER_IP',os.environ['INTERNAL'])
put('PUBLIC_IP',os.environ['EXTERNAL'])
put('PUBLIC_IP_MODE','manual')
p.write_text(text)
PYPERSISTCONF
  fi
  if [[ -f "$app_cfg" ]]; then
    INTERNAL="$internal" EXTERNAL="$external" python3 - "$app_cfg" <<'PYPERSISTAPP'
from pathlib import Path
import os,re,sys
p=Path(sys.argv[1]); text=p.read_text(errors='ignore')
for key,env in [('server_ip','INTERNAL'),('public_ip','EXTERNAL')]:
    val=os.environ[env]
    text=re.sub(rf"('{re.escape(key)}'\s*=>\s*)'[^']*'", rf"\1'{val}'", text, count=1)
p.write_text(text)
PYPERSISTAPP
  fi
}


cmd_ip_info_json() {
  local internal external configured gateway iface panel panel_a nat=0
  internal="$(detect_internal_ipv4)"
  external="$(outbound_public_ip)"
  configured="$(configured_public_ip)"
  [[ -z "$external" ]] && external="$configured"
  gateway="$(default_gateway_ipv4)"
  iface="$(default_interface)"
  panel="${PANEL_DOMAIN:-_}"
  panel_a=""
  [[ -n "$panel" && "$panel" != "_" ]] && panel_a="$(resolve_domain_a_public "$panel" | head -n1 || true)"
  [[ -n "$internal" ]] && is_private_ipv4 "$internal" && nat=1
  INTERNAL="$internal" EXTERNAL="$external" CONFIGURED="$configured" GATEWAY="$gateway" IFACE="$iface" PANEL="$panel" PANEL_A="$panel_a" NAT="$nat" PUBLIC_IP_MODE="${PUBLIC_IP_MODE:-auto}" python3 - <<'PYIPINFO'
import json,os
internal=os.environ.get('INTERNAL',''); external=os.environ.get('EXTERNAL','')
print(json.dumps({
  'internal_ip': internal,
  'external_ip': external,
  'configured_public_ip': os.environ.get('CONFIGURED',''),
  'public_ip_mode': os.environ.get('PUBLIC_IP_MODE','auto'),
  'gateway': os.environ.get('GATEWAY',''),
  'interface': os.environ.get('IFACE',''),
  'panel_domain': os.environ.get('PANEL',''),
  'panel_domain_ip': os.environ.get('PANEL_A',''),
  'nat': os.environ.get('NAT') == '1',
  'nat_mode': os.environ.get('NAT') == '1',
  'ftp_lan': f'{internal}:21' if internal else '',
  'ftp_lan_endpoint': f'{internal}:21' if internal else '',
  'ftp_external': f'{external}:21' if external else '',
  'ftp_external_endpoint': f'{external}:21' if external else '',
  'ftp_passive_ports': {'lan':'40000-40049','internet':'40050-40100'},
  'mysql_local': '127.0.0.1:3306',
  'mysql_local_endpoint': '127.0.0.1:3306',
  'mysql_lan': f'{internal}:3306' if internal else '',
  'mysql_lan_endpoint': f'{internal}:3306' if internal else '',
  'mysql_external': f'{external}:3306' if external else '',
  'mysql_external_endpoint': f'{external}:3306' if external else '',
  'phpmyadmin_lan': f'http://{internal}/phpmyadmin/' if internal else '',
  'phpmyadmin_external': f'http://{external}/phpmyadmin/' if external else '',
  'phpmyadmin_url': f'http://{internal}/phpmyadmin/' if internal else '',
}, ensure_ascii=False))
PYIPINFO
}

cmd_ip_detect() {
  local mode="${1:---apply}" old_external
  old_external="$(tr -d '[:space:]' </etc/hyper-host/public_ip 2>/dev/null || true)"
  if [[ "$mode" == "--apply" || "$mode" == "apply" || "$mode" == "fix" ]]; then
    persist_runtime_ips "$FIXED_INTERNAL_IP" "$FIXED_PUBLIC_IP"
    SERVER_IP="$FIXED_INTERNAL_IP"; PUBLIC_IP="$FIXED_PUBLIC_IP"; PUBLIC_IP_MODE="manual"
    export SERVER_IP PUBLIC_IP PUBLIC_IP_MODE
    configure_phpmyadmin_label || true
    ensure_vsftpd_external_access || true
    open_server_ports || true
    if [[ -n "$old_external" && "$old_external" != "$FIXED_PUBLIC_IP" && -d "$DNS_DIR" ]]; then
      grep -rl "IN A $old_external" "$DNS_DIR"/db.* 2>/dev/null | while read -r z; do
        sed -i "s/IN A ${old_external//./\.}$/IN A $FIXED_PUBLIC_IP/g; s/ip4:${old_external//./\.} /ip4:$FIXED_PUBLIC_IP /g" "$z" 2>/dev/null || true
      done
      systemctl restart bind9 2>/dev/null || true
    fi
    log "Fixed IP profile applied: LAN=$FIXED_INTERNAL_IP WAN=$FIXED_PUBLIC_IP"
  fi
  cmd_ip_info_json
}


resolve_domain_ips_public() {
  # HYPER-HOST v16: проверяем DNS через публичные резолверы, а не через локальный bind/hosts.
  # Иначе сервер может сам себе отдавать 192.168.x.x и SSL/панель думают, что DNS неправильный.
  local domain="$1" ns
  for ns in 1.1.1.1 8.8.8.8 9.9.9.9; do
    { dig +time=2 +tries=1 +short @"$ns" A "$domain" 2>/dev/null; dig +time=2 +tries=1 +short @"$ns" AAAA "$domain" 2>/dev/null; }
  done | sed '/^$/d' | sort -u
}

resolve_domain_a_public() {
  local domain="$1" ns
  for ns in 1.1.1.1 8.8.8.8 9.9.9.9; do
    dig +time=2 +tries=1 +short @"$ns" A "$domain" 2>/dev/null
  done | sed '/^$/d' | sort -u
}

resolve_domain_ips() {
  local domain="$1"
  # Важно: для SSL/DNS нельзя брать локальный bind/resolv.conf, иначе панель видит 192.168.x.x.
  # Проверяем только публичные резолверы. Локальная зона показывается отдельно в dns-status.
  resolve_domain_ips_public "$domain"
}

resolve_domain_a() {
  local domain="$1"
  # Только публичный DNS. Без fallback на локальный resolver.
  resolve_domain_a_public "$domain"
}

resolve_domain_a_local() {
  local domain="$1"
  dig +time=1 +tries=1 +short @127.0.0.1 A "$domain" 2>/dev/null | sed '/^$/d' | sort -u || true
}

choose_ssl_expected_ip() {
  local domain="$1" cfg arec first_a out
  cfg="$(public_ip)"
  [[ -n "$cfg" ]] && { echo "$cfg"; return; }
  arec="$(resolve_domain_a "$domain")"
  first_a="$(printf '%s\n' "$arec" | head -n1)"
  # Если сервер за NAT и DNS уже смотрит на публичный IP роутера — считаем его ожидаемым.
  if [[ -n "$first_a" && -n "$SERVER_IP" ]] && is_private_ipv4 "$SERVER_IP"; then echo "$first_a"; return; fi
  if [[ -n "$SERVER_IP" ]] && ! is_private_ipv4 "$SERVER_IP"; then echo "$SERVER_IP"; return; fi
  out="$(outbound_public_ip)"
  [[ -n "$out" ]] && { echo "$out"; return; }
  echo "$SERVER_IP"
}

dns_points_here() {
  local domain="$1" expected ips
  expected="$(choose_ssl_expected_ip "$domain")"
  ips="$(resolve_domain_ips "$domain")"
  [[ -n "$ips" ]] || return 2
  if [[ -n "$expected" ]] && echo "$ips" | grep -qxF "$expected"; then return 0; fi
  # Для локального сервера за NAT разрешаем A-запись на публичный IP роутера,
  # даже если outbound IP отличается. Главное — чтобы порты 80/443 были проброшены.
  if [[ -z "$(configured_public_ip)" && -n "$SERVER_IP" ]] && is_private_ipv4 "$SERVER_IP" && [[ -n "$(resolve_domain_a "$domain")" ]]; then return 0; fi
  [[ -n "$SERVER_IP" ]] && echo "$ips" | grep -qxF "$SERVER_IP" && return 0
  return 1
}

site_root_for_domain() {
  local domain="$1" conf="$NGINX_AVAILABLE/hyper-host-site-$domain.conf" root=""
  if [[ -f "$conf" ]]; then
    root="$(awk '/^[[:space:]]*root[[:space:]]+/ {gsub(";", "", $2); print $2; exit}' "$conf" 2>/dev/null || true)"
  fi
  [[ -n "$root" ]] || root="$SITES_DIR/$domain/public_html"
  echo "$root"
}

nginx_domains_for_site() {
  local domain="$1" conf="$NGINX_AVAILABLE/hyper-host-site-$domain.conf"
  if [[ -f "$conf" ]]; then
    awk '/^[[:space:]]*server_name[[:space:]]+/ {for(i=2;i<=NF;i++){gsub(";", "", $i); print $i}}' "$conf" 2>/dev/null | sort -u
  else
    echo "$domain"
  fi
}

local_http_challenge_check() {
  local domain="$1" root="$2" token body
  [[ -d "$root" ]] || return 2
  ensure_acme_location_for_domain "$domain" "$root"
  ensure_acme_webroot
  nginx_reload >/dev/null 2>&1 || return 1
  token="hyper-host-ssl-test-$(date +%s)-$$"
  printf 'ok-%s' "$token" > "$ACME_WEBROOT/.well-known/acme-challenge/$token"
  chown www-data:www-data "$ACME_WEBROOT/.well-known/acme-challenge/$token" 2>/dev/null || true
  chmod 0644 "$ACME_WEBROOT/.well-known/acme-challenge/$token" 2>/dev/null || true
  body="$(curl --noproxy '*' -fsS --connect-timeout 2 --max-time 5 \
      --resolve "$domain:80:127.0.0.1" \
      "http://$domain/.well-known/acme-challenge/$token" 2>/dev/null || true)"
  rm -f "$ACME_WEBROOT/.well-known/acme-challenge/$token" 2>/dev/null || true
  [[ "$body" == "ok-$token" ]]
}

ssl_preflight_json() {
  local domain="$1" root pub configured outbound expected arec aaaarec ips dns_status nginx_ok http_ok has_site certbot_ready problem required_a nat_mode warning
  root="$(site_root_for_domain "$domain")"
  configured="$(configured_public_ip)"
  outbound="$(outbound_public_ip)"
  expected="$(choose_ssl_expected_ip "$domain")"
  pub="$expected"
  arec="$(resolve_domain_a_public "$domain")"
  aaaarec="$(for ns in 1.1.1.1 8.8.8.8 9.9.9.9; do dig +time=2 +tries=1 +short @"$ns" AAAA "$domain" 2>/dev/null; done | sed '/^$/d' | sort -u || true)"
  ips="$(printf '%s\n%s\n' "$arec" "$aaaarec" | sed '/^$/d' | sort -u)"
  dns_status="bad"
  nat_mode=0
  [[ -n "$SERVER_IP" ]] && is_private_ipv4 "$SERVER_IP" && nat_mode=1
  if [[ -z "$ips" ]]; then
    dns_status="missing"
  elif dns_points_here "$domain"; then
    dns_status="ok"
  else
    dns_status="wrong_ip"
  fi
  nginx_ok=0; nginx -t >/dev/null 2>&1 && nginx_ok=1
  has_site=0; [[ -f "$NGINX_AVAILABLE/hyper-host-site-$domain.conf" || -d "$root" ]] && has_site=1
  http_ok=0; [[ "$nginx_ok" == 1 ]] && local_http_challenge_check "$domain" "$root" && http_ok=1
  certbot_ready=0; [[ "$dns_status" == ok && "$nginx_ok" == 1 && "$http_ok" == 1 && "$has_site" == 1 ]] && certbot_ready=1
  problem=""; warning=""
  required_a="A    $domain    $expected"
  if [[ "$nat_mode" == 1 ]]; then warning=""; fi
  if [[ "$dns_status" == missing ]]; then problem="У домена нет публичных A/AAAA записей. Добавь запись: $required_a"; fi
  if [[ "$dns_status" == wrong_ip ]]; then problem="DNS домена указывает не на нужный IP. Сейчас: ${ips//$'\n'/, }. Нужно: $required_a"; fi
  if [[ "$nginx_ok" != 1 ]]; then problem="Nginx config не проходит проверку: sudo nginx -t"; fi
  if [[ "$has_site" != 1 ]]; then problem="Сайт не найден в HYPER-HOST. Сначала создай сайт: $domain"; fi
  if [[ "$http_ok" != 1 && "$dns_status" == ok && "$nginx_ok" == 1 ]]; then problem="Nginx локально не отдаёт /.well-known/acme-challenge для Host: $domain. Проверь root сайта и конфиг."; fi
  DOMAIN="$domain" ROOT="$root" PUBLIC_IP="$pub" CONFIGURED_PUBLIC_IP="$configured" OUTBOUND_PUBLIC_IP="$outbound" EXPECTED_PUBLIC_IP="$expected" SERVER_IP="$SERVER_IP" A_RECORDS="$arec" AAAA_RECORDS="$aaaarec" DNS_STATUS="$dns_status" NGINX_OK="$nginx_ok" HTTP_OK="$http_ok" HAS_SITE="$has_site" CERTBOT_READY="$certbot_ready" PROBLEM="$problem" WARNING="$warning" REQUIRED_A="$required_a" NAT_MODE="$nat_mode" python3 - <<'PYSSL'
import os,json
split=lambda s:[x for x in s.splitlines() if x.strip()]
print(json.dumps({
 'domain':os.environ['DOMAIN'],
 'root':os.environ['ROOT'],
 'server_ip':os.environ.get('SERVER_IP',''),
 'public_ip':os.environ.get('PUBLIC_IP',''),
 'expected_public_ip':os.environ.get('EXPECTED_PUBLIC_IP',''),
 'configured_public_ip':os.environ.get('CONFIGURED_PUBLIC_IP',''),
 'outbound_public_ip':os.environ.get('OUTBOUND_PUBLIC_IP',''),
 'nat_mode':os.environ.get('NAT_MODE')=='1',
 'a':split(os.environ.get('A_RECORDS','')),
 'aaaa':split(os.environ.get('AAAA_RECORDS','')),
 'dns_status':os.environ.get('DNS_STATUS'),
 'points_here':os.environ.get('DNS_STATUS')=='ok',
 'nginx_ok':os.environ.get('NGINX_OK')=='1',
 'http_challenge_ok':os.environ.get('HTTP_OK')=='1',
 'site_exists':os.environ.get('HAS_SITE')=='1',
 'certbot_ready':os.environ.get('CERTBOT_READY')=='1',
 'required_a':os.environ.get('REQUIRED_A',''),
 'problem':os.environ.get('PROBLEM',''),
 'warning':os.environ.get('WARNING',''),
}, ensure_ascii=False))
PYSSL
}

cmd_ssl_check_json() {
  local domain="${1:-}"
  [[ -n "$domain" ]] || err "Domain required"
  valid_domain "$domain" || err "Invalid domain"
  ssl_preflight_json "$domain"
}

cmd_public_ip() {
  local action="${1:-get}" requested="${2:-}"
  case "$action" in
    get)
      echo "$FIXED_PUBLIC_IP"
      ;;
    set)
      if [[ -n "$requested" && "$requested" != "$FIXED_PUBLIC_IP" ]]; then
        warn "Этот сервер закреплён за $FIXED_PUBLIC_IP; адрес $requested проигнорирован"
      fi
      persist_runtime_ips "$FIXED_INTERNAL_IP" "$FIXED_PUBLIC_IP"
      PUBLIC_IP_MODE="manual"; PUBLIC_IP="$FIXED_PUBLIC_IP"; SERVER_IP="$FIXED_INTERNAL_IP"
      export PUBLIC_IP_MODE PUBLIC_IP SERVER_IP
      configure_phpmyadmin_label || true
      ensure_vsftpd_external_access || true
      log "Fixed public IP saved: $FIXED_PUBLIC_IP"
      ;;
    clear)
      persist_runtime_ips "$FIXED_INTERNAL_IP" "$FIXED_PUBLIC_IP"
      log "Сброс отключён: восстановлен фиксированный IP $FIXED_PUBLIC_IP"
      ;;
    *) err "Use: public-ip get|set 90.189.208.25|clear" ;;
  esac
}


cmd_ip_autofix() {
  # Cron только восстанавливает заданный профиль и никогда не определяет IP через интернет.
  local quiet="${1:-}" old
  old="$(tr -d '[:space:]' </etc/hyper-host/public_ip 2>/dev/null || true)"
  persist_runtime_ips "$FIXED_INTERNAL_IP" "$FIXED_PUBLIC_IP"
  SERVER_IP="$FIXED_INTERNAL_IP"; PUBLIC_IP="$FIXED_PUBLIC_IP"; PUBLIC_IP_MODE="manual"
  export SERVER_IP PUBLIC_IP PUBLIC_IP_MODE
  if [[ -n "$old" && "$old" != "$FIXED_PUBLIC_IP" && -d "$DNS_DIR" ]]; then
    grep -rl "IN A $old" "$DNS_DIR"/db.* 2>/dev/null | while read -r zonefile; do
      sed -i "s/IN A ${old//./\.}$/IN A $FIXED_PUBLIC_IP/g; s/ip4:${old//./\.} /ip4:$FIXED_PUBLIC_IP /g" "$zonefile" 2>/dev/null || true
    done
    systemctl restart bind9 2>/dev/null || true
  fi
  ensure_vsftpd_external_access >/dev/null 2>&1 || true
  configure_phpmyadmin_label >/dev/null 2>&1 || true
  [[ "$quiet" == "--quiet" ]] || log "Fixed IP profile OK: LAN=$FIXED_INTERNAL_IP WAN=$FIXED_PUBLIC_IP"
}


cmd_ssl_ip_selfsigned() {
  ensure_nginx_runtime_overlay
  local ip="${1:-$SERVER_IP}"
  [[ "$ip" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]] || err "Invalid IP: $ip"
  local dir="/etc/ssl/hyper-host-ip-$ip" key="$dir/privkey.pem" crt="$dir/fullchain.pem" conf="$dir/openssl.cnf" nginx_conf="/etc/nginx/sites-available/hyper-host-ip-$ip.conf"
  mkdir -p "$dir" "$PANEL_DIR/public"
  cat > "$conf" <<EOFIP
[req]
default_bits = 2048
prompt = no
default_md = sha256
distinguished_name = dn
x509_extensions = v3_req
[dn]
CN = $ip
[v3_req]
subjectAltName = @alt_names
[alt_names]
IP.1 = $ip
EOFIP
  openssl req -x509 -nodes -days 825 -newkey rsa:2048 -keyout "$key" -out "$crt" -config "$conf" >/dev/null 2>&1
  chmod 0600 "$key"; chmod 0644 "$crt"
  cat > "$nginx_conf" <<EOFIPNGINX
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name $ip;

    ssl_certificate $crt;
    ssl_certificate_key $key;

    root ${PANEL_DIR}/public;
    index index.php index.html;
    client_max_body_size 1024M;

    access_log /var/log/nginx/hyper-host-ip-$ip.access.log;
    error_log /var/log/nginx/hyper-host-ip-$ip.error.log;

    location / { try_files \$uri \$uri/ /index.php?\$query_string; }

    location /phpmyadmin {
        alias /usr/share/phpmyadmin/;
        index index.php index.html;
    }

    location ~ ^/phpmyadmin/(.+\.php)$ {
        alias /usr/share/phpmyadmin/\$1;
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME /usr/share/phpmyadmin/\$1;
        fastcgi_read_timeout 600;
        fastcgi_send_timeout 600;
        fastcgi_connect_timeout 60;
        fastcgi_pass unix:${PHP_FPM_SOCK};
    }

    location ~ \.php$ {
        include snippets/fastcgi-php.conf;
        fastcgi_read_timeout 600;
        fastcgi_send_timeout 600;
        fastcgi_connect_timeout 60;
        fastcgi_pass unix:${PHP_FPM_SOCK};
    }
}
EOFIPNGINX
  ln -sf "$nginx_conf" "/etc/nginx/sites-enabled/hyper-host-ip-$ip.conf"
  ufw allow 443/tcp >/dev/null 2>&1 || true
  nginx -t >/dev/null && systemctl reload nginx || nginx -t
  log "Self-signed IP SSL enabled: https://$ip -> HYPER-HOST panel"
  echo "WARNING: это self-signed сертификат для IP. Браузер будет предупреждать о недоверенном сертификате. Для нормального зелёного SSL используй домен panel.hyper-host.pw."
}




cmd_ssl_fix_site() {
  local domain="${1:-}"
  [[ -n "$domain" ]] || err "Domain required"
  valid_domain "$domain" || err "Invalid domain"
  local root="$(site_root_for_domain "$domain")"
  ensure_acme_location_for_domain "$domain" "$root"
  ensure_acme_webroot
  nginx_reload
  local_http_challenge_check "$domain" "$root" || err "ACME local check failed for $domain"
  log "SSL ACME location fixed for $domain -> $ACME_WEBROOT"
}

cmd_ssl_site() {
  local domain="${1:-}" email="${2:-}"
  [[ -n "$domain" && -n "$email" ]] || err "Domain and email required"
  valid_domain "$domain" || err "Invalid domain"
  cleanup_hyper_host_mounts
  ensure_dirs
  ufw allow 80/tcp >/dev/null 2>&1 || true
  ufw allow 443/tcp >/dev/null 2>&1 || true

  local check ready problem root log_file d candidates=() cert_domains=() args=()
  root="$(site_root_for_domain "$domain")"
  ensure_acme_location_for_domain "$domain" "$root"
  nginx_reload >/dev/null 2>&1 || true
  check="$(ssl_preflight_json "$domain")"
  ready="$(printf '%s' "$check" | python3 -c 'import sys,json; print(1 if json.load(sys.stdin).get("certbot_ready") else 0)' 2>/dev/null || echo 0)"
  if [[ "$ready" != 1 ]]; then
    problem="$(printf '%s' "$check" | python3 -c 'import sys,json; print(json.load(sys.stdin).get("problem","SSL preflight failed"))' 2>/dev/null || echo "SSL preflight failed")"
    echo "$check" >&2
    err "SSL не выпущен: $problem"
  fi

  root="$(site_root_for_domain "$domain")"
  while read -r d; do
    [[ -z "$d" ]] && continue
    valid_domain "$d" || continue
    if dns_points_here "$d" && local_http_challenge_check "$d" "$root"; then
      candidates+=("$d")
    fi
  done < <(nginx_domains_for_site "$domain")
  candidates+=("$domain")
  mapfile -t cert_domains < <(printf '%s\n' "${candidates[@]}" | sed '/^$/d' | sort -u)
  [[ ${#cert_domains[@]} -gt 0 ]] || cert_domains=("$domain")

  ensure_acme_webroot
  mkdir -p "$LE_CONFIG_DIR" "$LE_WORK_DIR" "$LE_LOGS_DIR"
  log_file="$LE_LOGS_DIR/hyper-host-${domain}-$(date +%F-%H%M%S).log"
  args=(certbot --config-dir "$LE_CONFIG_DIR" --work-dir "$LE_WORK_DIR" --logs-dir "$LE_LOGS_DIR" --nginx --non-interactive --agree-tos --email "$email" --no-eff-email --keep-until-expiring --expand --redirect --preferred-challenges http --cert-name "$domain")
  for d in "${cert_domains[@]}"; do args+=(-d "$d"); done

  log "SSL preflight OK: ${cert_domains[*]} -> $root"
  if ! "${args[@]}" >"$log_file" 2>&1; then
    tail -n 120 "$log_file" >&2 || true
    err "SSL не выпущен: Certbot вернул ошибку. Лог: $log_file. Проверь DNS, 80/443 порты и что домен доступен из интернета."
  fi
  nginx_reload
  mkdir -p "$FTP_TLS_DIR"
  printf '%s\n' "$domain" > "$FTP_TLS_DIR/preferred-domain"
  cmd_ftp_fix_all >/dev/null 2>&1 || warn "SSL выпущен, но FTP TLS не удалось перезапустить автоматически"
  log "SSL issued for ${cert_domains[*]} / log: $log_file"
}

cmd_site_php() {
  ensure_nginx_runtime_overlay
  local domain="${1:-}" version="${2:-}"
  [[ -n "$domain" && -n "$version" ]] || err "Domain and PHP version required"
  valid_domain "$domain" || err "Invalid domain"
  local conf="$NGINX_AVAILABLE/hyper-host-site-$domain.conf" sock tmp
  [[ -f "$conf" ]] || err "Nginx config not found: $conf"
  sock="$(php_sock_for_version "$version")"
  [[ -S "$sock" ]] || err "PHP-FPM socket not found: $sock. Запусти: sudo hyper php install"
  tmp="$(mktemp /tmp/hyper-host-site-php.XXXXXX)"
  python3 - "$conf" "$sock" "$tmp" <<'PYSITEPHP'
import sys, re, pathlib
conf, sock, tmp = sys.argv[1:]
p = pathlib.Path(conf)
text = p.read_text(encoding='utf-8', errors='ignore')
new, n = re.subn(r'fastcgi_pass\s+unix:[^;]+;', 'fastcgi_pass unix:%s;' % sock, text)
if n < 1:
    raise SystemExit('В nginx-конфиге не найден fastcgi_pass unix:...;')
pathlib.Path(tmp).write_text(new, encoding='utf-8')
PYSITEPHP
  safe_replace_file "$conf" "$tmp"
  rm -f "$tmp" 2>/dev/null || true
  nginx_reload
  log "PHP version for $domain -> $version"
}

ftp_shell_path() {
  if [[ -x /usr/sbin/nologin ]]; then echo /usr/sbin/nologin; else echo /bin/false; fi
}

ftp_alias_for() {
  local username="${1:-}"
  if [[ "$username" == hhftp_* ]]; then
    printf '%s' "${username#hhftp_}"
  else
    printf 'hhftp_%s' "$username"
  fi
}

ftp_user_variants() {
  local username="${1:-}" alias_user lower lower_alias seen="" u
  alias_user="$(ftp_alias_for "$username")"
  lower="$(printf '%s' "$username" | tr '[:upper:]' '[:lower:]')"
  lower_alias="$(ftp_alias_for "$lower")"
  for u in "$username" "$alias_user" "$lower" "$lower_alias"; do
    [[ -n "$u" ]] || continue
    [[ "$seen" == *"|$u|"* ]] && continue
    valid_name "$u" || continue
    printf '%s\n' "$u"
    seen="$seen|$u|"
  done
}

ftp_scope_normalize() {
  local mode="${1:-all}"
  case "$mode" in
    all|all-sites|common|root|everything) echo all ;;
    sites|www|web) echo sites ;;
    site|single-site) echo site ;;
    bots|pm2) echo bots ;;
    backups|backup) echo backups ;;
    files|ftp|uploads|own) echo files ;;
    *) err "Неверный режим FTP-доступа: $mode" ;;
  esac
}

ftp_scope_label() {
  local mode="${1:-all}" target="${2:-}"
  mode="$(ftp_scope_normalize "$mode")"
  case "$mode" in
    all) echo "всё: sites, bots, backups, uploads" ;;
    sites) echo "все сайты" ;;
    site) echo "сайт ${target:-не выбран}" ;;
    bots) echo "боты" ;;
    backups) echo "backup" ;;
    files) echo "личная FTP-папка uploads" ;;
  esac
}

ftp_link_path() {
  # Для chroot ProFTPD нужны реальные bind-mount: symlink наружу chroot не работает.
  local src="${1:-}" dst="${2:-}"
  [[ -n "$src" && -n "$dst" ]] || return 1
  mkdir -p "$src" "$(dirname "$dst")"
  if [[ -L "$dst" ]]; then rm -f "$dst"; fi
  mkdir -p "$dst"
  if path_is_mount_target "$dst"; then umount -lf "$dst" 2>/dev/null || true; fi
  mount --bind "$src" "$dst"
  safe_fstab_append_bind "$src" "$dst"
}

ftp_bind_mount() {
  # имя оставлено для совместимости старых вызовов
  ftp_link_path "$@"
}

ftp_umount_scope_mounts() {
  local home="${1:-}" mp
  [[ -n "$home" && "$home" == "$FTP_DIR"/* ]] || return 0
  for mp in "$home/site" "$home/sites" "$home/bots" "$home/backups" "$home/common/sites" "$home/common/bots" "$home/common/backups"; do
    path_is_mount_target "$mp" && umount -lf "$mp" 2>/dev/null || true
    ftp_remove_fstab_target "$mp"
    [[ -L "$mp" ]] && rm -f "$mp" 2>/dev/null || true
  done
}

ftp_prepare_scope() {
  local username="${1:-}" mode="${2:-all}" target="${3:-}" home="${4:-}" local_root label
  mode="$(ftp_scope_normalize "$mode")"
  [[ -n "$username" && -n "$home" ]] || err "FTP scope: empty username/home"
  [[ "$home" == "$FTP_DIR"/* ]] || err "Unsafe FTP home: $home"
  mkdir -p "$home"
  ftp_umount_scope_mounts "$home"

  case "$mode" in
    all)
      mkdir -p "$home/sites" "$home/bots" "$home/backups" "$home/uploads"
      ftp_bind_mount "$SITES_DIR" "$home/sites"
      ftp_bind_mount "$BOTS_DIR" "$home/bots"
      ftp_bind_mount "$BACKUP_DIR" "$home/backups"
      local_root="$home"
      ;;
    sites)
      mkdir -p "$home/sites"
      ftp_bind_mount "$SITES_DIR" "$home/sites"
      local_root="$home/sites"
      ;;
    site)
      [[ -n "$target" ]] || err "Для режима site укажи домен сайта"
      valid_domain "$target" || err "Invalid site domain: $target"
      mkdir -p "$SITES_DIR/$target/public_html" "$home/site"
      ftp_bind_mount "$SITES_DIR/$target/public_html" "$home/site"
      local_root="$home/site"
      ;;
    bots)
      mkdir -p "$home/bots"
      ftp_bind_mount "$BOTS_DIR" "$home/bots"
      local_root="$home/bots"
      ;;
    backups)
      mkdir -p "$home/backups"
      ftp_bind_mount "$BACKUP_DIR" "$home/backups"
      local_root="$home/backups"
      ;;
    files)
      mkdir -p "$home/uploads"
      local_root="$home/uploads"
      ;;
  esac
  [[ -n "$local_root" ]] || err "FTP local_root не определён"
  cat > "$home/README_FTP.txt" <<EOFTPREADME 2>/dev/null || true
HYPER-HOST FTP
Режим доступа: $(ftp_scope_label "$mode" "$target")

Если папка открывается пустой после перезагрузки сервера, выполни:
sudo hyper ftp fix
EOFTPREADME
  echo "$local_root"
}

ensure_ftp_virtual_dirs() {
  ensure_dirs
  mkdir -p "$BASE_DIR/data" "$BASE_DIR/ftp" "$FTP_USER_CONF_DIR" "$FTP_DIR"
  chown -R "$FTP_GUEST_USER":"$FTP_GUEST_USER" "$BASE_DIR/ftp" 2>/dev/null || chown -R www-data:www-data "$BASE_DIR/ftp" 2>/dev/null || true
  chmod 0755 "$BASE_DIR" "$BASE_DIR/data" "$BASE_DIR/ftp" "$FTP_USER_CONF_DIR" "$FTP_DIR" 2>/dev/null || true
  touch "$FTP_AUTH_TXT" 2>/dev/null || true
  chmod 0600 "$FTP_AUTH_TXT" 2>/dev/null || true
}

ftp_auth_rebuild_db() {
  # v62: this canonical text file remains the panel source of FTP credentials.
  # ProFTPD receives an atomic SHA-512 AuthUserFile built under /opt; no PAM,
  # Berkeley DB, /etc/fstab or writable /etc are required.
  ensure_ftp_virtual_dirs
  local tmp
  tmp="$(mktemp "${FTP_AUTH_TXT}.tmp.XXXXXX")"
  if ! python3 - "$FTP_AUTH_TXT" "$tmp" <<'PYFTPAUTHNORMALIZE'
from pathlib import Path
import sys

source = Path(sys.argv[1])
target = Path(sys.argv[2])
try:
    raw = source.read_text(encoding="utf-8", errors="surrogateescape")
except FileNotFoundError:
    raw = ""

# Repair the malformed v53/v55 form containing literal backslash+n tokens.
if "\\n" in raw and raw.count("\n") <= 1:
    raw = raw.replace("\\r\\n", "\n").replace("\\n", "\n")

lines = raw.splitlines()
pairs = []
seen = set()
for index in range(0, len(lines) - 1, 2):
    username = lines[index].strip()
    password = lines[index + 1]
    if not username or not password or username in seen:
        continue
    seen.add(username)
    pairs.append((username, password))

text = "".join(f"{username}\n{password}\n" for username, password in pairs)
target.write_text(text, encoding="utf-8", errors="surrogateescape")
PYFTPAUTHNORMALIZE
  then
    rm -f "$tmp" 2>/dev/null || true
    err "Не удалось нормализовать FTP auth-файл"
  fi
  chmod 0600 "$tmp" 2>/dev/null || true
  chown root:root "$tmp" 2>/dev/null || true
  mv -f "$tmp" "$FTP_AUTH_TXT"
  chmod 0600 "$FTP_AUTH_TXT" 2>/dev/null || true
  chown root:root "$FTP_AUTH_TXT" 2>/dev/null || true
  # Remove obsolete PAM/Berkeley output from old versions. Failure is harmless.
  rm -f "$FTP_AUTH_DB" "$FTP_AUTH_DB_BASE" 2>/dev/null || true
  if declare -F proftpd_auth_rebuild >/dev/null 2>&1 && [[ -x "$PROFTPD_AUTH_BUILDER" ]]; then
    proftpd_auth_rebuild || return 1
    proftpd_reload_quiet
  fi
  return 0
}

ftp_auth_set_password_for_variants() {
  local password="${1:-}"; shift || true
  [[ -n "$password" ]] || return 1
  ensure_ftp_virtual_dirs
  ftp_auth_rebuild_db
  python3 - "$FTP_AUTH_TXT" "$password" "$@" <<'PYFTPAUTHSET'
import sys, pathlib
path=pathlib.Path(sys.argv[1]); password=sys.argv[2]; users=[u for u in sys.argv[3:] if u]
items=[]
try:
    lines=path.read_text(encoding='utf-8', errors='ignore').splitlines()
except FileNotFoundError:
    lines=[]
i=0
skip=set(users)
while i < len(lines):
    u=lines[i].strip(); p=lines[i+1] if i+1 < len(lines) else ''
    if u and u not in skip:
        items.extend([u,p])
    i += 2
for u in users:
    items.extend([u,password])
path.parent.mkdir(parents=True, exist_ok=True)
path.write_text('\n'.join(items)+'\n', encoding='utf-8')
PYFTPAUTHSET
  ftp_auth_rebuild_db
}

ftp_auth_remove_variants() {
  ensure_ftp_virtual_dirs
  ftp_auth_rebuild_db
  python3 - "$FTP_AUTH_TXT" "$@" <<'PYFTPAUTHRM'
import sys, pathlib
path=pathlib.Path(sys.argv[1]); users=set([u for u in sys.argv[2:] if u])
try:
    lines=path.read_text(encoding='utf-8', errors='ignore').splitlines()
except FileNotFoundError:
    lines=[]
out=[]; i=0
while i < len(lines):
    u=lines[i].strip(); p=lines[i+1] if i+1 < len(lines) else ''
    if u and u not in users:
        out.extend([u,p])
    i += 2
path.parent.mkdir(parents=True, exist_ok=True)
path.write_text(('\n'.join(out)+'\n') if out else '', encoding='utf-8')
PYFTPAUTHRM
  ftp_auth_rebuild_db
}

ensure_single_ftp_os_user() {
  # Имя функции оставлено для совместимости. Linux-пользователи не создаются:
  # виртуальные учётные записи ProFTPD собираются в AuthUserFile под /opt.
  local username="${1:-}" password="${2:-}" home="${3:-}"
  [[ -n "$username" && -n "$password" && -n "$home" ]] || return 1
  valid_name "$username" || return 1
  ftp_auth_set_password_for_variants "$password" "$username"
  return 0
}

write_ftp_user_conf() {
  local username="${1:-}" local_root="${2:-}"
  [[ -n "$username" && -n "$local_root" ]] || return 0
  ensure_ftp_virtual_dirs
  cat > "$FTP_USER_CONF_DIR/$username" <<EOFUSERCONF
local_root=$local_root
write_enable=YES
EOFUSERCONF
  chmod 0644 "$FTP_USER_CONF_DIR/$username" 2>/dev/null || true
}

cmd_create_ftp() {
  ensure_dirs
  cleanup_hyper_host_mounts
  local username="${1:-}" password="${2:-}" mode="${3:-all}" target="${4:-}" variants=() u owner="" alias_note="" home local_root guest
  [[ -n "$username" && -n "$password" ]] || err "Username and password required"
  valid_name "$username" || err "Invalid ftp username"
  mode="$(ftp_scope_normalize "$mode")"
  guest="$FTP_GUEST_USER"
  id "$guest" >/dev/null 2>&1 || guest="www-data"
  id "$guest" >/dev/null 2>&1 || err "Нет системного гостевого пользователя для FTP: www-data. Установи nginx/apache или создай www-data."

  mapfile -t variants < <(ftp_user_variants "$username")
  [[ ${#variants[@]} -gt 0 ]] || err "Invalid ftp username"

  home="$FTP_DIR/$username"
  local_root="$(ftp_prepare_scope "$username" "$mode" "$target" "$home")"

  find "$home" -xdev -exec chown -h "$guest":"$guest" {} + 2>/dev/null || true
  chmod 0755 "$home" 2>/dev/null || true

  for u in "${variants[@]}"; do
    ensure_single_ftp_os_user "$u" "$password" "$home" || err "Не удалось записать виртуального FTP-пользователя: $u"
    write_ftp_user_conf "$u" "$local_root"
  done
  owner="$guest"

  mkdir -p "$home/uploads"
  chown -R "$owner":"$owner" "$home/uploads" 2>/dev/null || true
  chmod -R u+rwX,g+rwX,o+rX "$home/uploads" 2>/dev/null || true
  find "$home/uploads" -type d -exec chmod 2775 {} + 2>/dev/null || true

  ftp_make_path_visible "$SITES_DIR" "$guest"
  ftp_make_path_visible "$BOTS_DIR" "$guest"
  ftp_make_path_visible "$BACKUP_DIR" "$guest"
  ftp_make_path_visible "$home/uploads" "$guest"

  local_root="$(ftp_prepare_scope "$username" "$mode" "$target" "$home")"
  for u in "${variants[@]}"; do write_ftp_user_conf "$u" "$local_root"; done

  if [[ "${HYPER_FTP_BATCH:-0}" != 1 ]]; then
    ensure_vsftpd_external_access
    assert_hyper_ftp_ready
  fi
  alias_note="$(printf '%s ' "${variants[@]}" | sed 's/[[:space:]]*$//')"
  log "FTP user ready: $username -> $local_root / scope=$(ftp_scope_label "$mode" "$target") / aliases: $alias_note"
}

cmd_delete_ftp() {
  local username="${1:-}" variants=() u
  [[ -n "$username" ]] || err "Username required"
  valid_name "$username" || err "Invalid username"
  mapfile -t variants < <(ftp_user_variants "$username")
  local home
  home="$FTP_DIR/$username"
  ftp_umount_scope_mounts "$home"
  for d in "$home/common/sites" "$home/common/bots" "$home/common/backups" "$home/sites" "$home/bots" "$home/backups" "$home/site"; do
    path_is_mount_target "$d" && umount -lf "$d" 2>/dev/null || true
  done
  ftp_auth_remove_variants "${variants[@]}"
  for u in "${variants[@]}"; do rm -f "$FTP_USER_CONF_DIR/$u" 2>/dev/null || true; done
  [[ "$home" == "$FTP_DIR"/* ]] && rm -rf --one-file-system "$home" 2>/dev/null || true
  # AuthUserFile уже пересобран; HUP применяет удаление к следующим входам.
  log "FTP user deleted: $username"
}

cmd_ftp_password() {
  local username="${1:-}" password="${2:-}" mode="${3:-all}" target="${4:-}" variants=() u owner="" home="" local_root="" guest
  [[ -n "$username" && -n "$password" ]] || err "Username and password required"
  valid_name "$username" || err "Invalid username"
  mode="$(ftp_scope_normalize "$mode")"
  guest="$FTP_GUEST_USER"
  id "$guest" >/dev/null 2>&1 || guest="www-data"
  id "$guest" >/dev/null 2>&1 || err "Нет системного гостевого пользователя для FTP: www-data."
  mapfile -t variants < <(ftp_user_variants "$username")
  [[ ${#variants[@]} -gt 0 ]] || err "Invalid ftp username"
  home="$FTP_DIR/$username"
  mkdir -p "$home"
  local_root="$(ftp_prepare_scope "$username" "$mode" "$target" "$home")"
  find "$home" -xdev -exec chown -h "$guest":"$guest" {} + 2>/dev/null || true
  chmod 0755 "$home" 2>/dev/null || true

  for u in "${variants[@]}"; do
    ensure_single_ftp_os_user "$u" "$password" "$home" || err "Не удалось записать виртуального FTP-пользователя: $u"
    write_ftp_user_conf "$u" "$local_root"
  done
  owner="$guest"

  mkdir -p "$home/uploads"
  chown -R "$owner":"$owner" "$home/uploads" 2>/dev/null || true
  chmod -R u+rwX,g+rwX,o+rX "$home/uploads" 2>/dev/null || true
  find "$home/uploads" -type d -exec chmod 2775 {} + 2>/dev/null || true

  ftp_make_path_visible "$SITES_DIR" "$guest"
  ftp_make_path_visible "$BOTS_DIR" "$guest"
  ftp_make_path_visible "$BACKUP_DIR" "$guest"
  ftp_make_path_visible "$home/uploads" "$guest"

  local_root="$(ftp_prepare_scope "$username" "$mode" "$target" "$home")"
  for u in "${variants[@]}"; do write_ftp_user_conf "$u" "$local_root"; done
  if [[ "${HYPER_FTP_BATCH:-0}" != 1 ]]; then
    ensure_vsftpd_external_access
    assert_hyper_ftp_ready
  fi
  log "FTP password/login repaired: $username / root=$local_root / scope=$(ftp_scope_label "$mode" "$target") / aliases: $(printf '%s ' "${variants[@]}" | sed 's/[[:space:]]*$//')"
}

cmd_ftp_test_login() {
  local username="${1:-}" password="${2:-}" host="${3:-127.0.0.1}" port="${4:-21}"
  [[ -n "$username" && -n "$password" ]] || err "Используй: sudo hyper ftp test LOGIN PASSWORD [HOST] [PORT]"
  [[ "$port" =~ ^[0-9]{1,5}$ ]] || err "Некорректный FTP port: $port"
  python3 - "$host" "$username" "$password" "$port" <<'PYFTPTEST'
import ftplib, io, secrets, ssl, sys
host,user,pw,port=sys.argv[1],sys.argv[2],sys.argv[3],int(sys.argv[4])
name='.hyper-host-ftp-test-' + secrets.token_hex(5) + '.txt'
payload=('HYPER-HOST FTP OK ' + secrets.token_hex(12)).encode()
ftp=None
try:
    ctx=ssl._create_unverified_context()
    ctx.minimum_version=ssl.TLSVersion.TLSv1_2
    ctx.maximum_version=ssl.TLSVersion.TLSv1_2
    ftp=ftplib.FTP_TLS(context=ctx, timeout=10)
    ftp.connect(host,port,timeout=10)
    banner=getattr(ftp,'welcome','')
    ftp.auth()
    ftp.login(user,pw)
    ftp.prot_p()
    ftp.set_pasv(True)
    ftp.storbinary('STOR ' + name, io.BytesIO(payload))
    received=bytearray()
    ftp.retrbinary('RETR ' + name, received.extend)
    if bytes(received) != payload:
        raise RuntimeError('upload/download content mismatch')
    ftp.delete(name)
    items=ftp.nlst()
    ftp.quit(); ftp=None
    print('OK: FTP login + passive upload/download/delete work')
    print('endpoint:', f'{host}:{port}')
    print('user:', user)
    print('banner:', banner)
    print('items:', ', '.join(items[:50]) if items else '(empty)')
except Exception as e:
    if ftp is not None:
        try: ftp.delete(name)
        except Exception: pass
        try: ftp.close()
        except Exception: pass
    print('ERROR:', type(e).__name__, str(e))
    sys.exit(1)
PYFTPTEST
}


cmd_ftp_test_saved_json() {
  local dbfile="${BASE_DIR}/data/hyperhost.sqlite"
  DBFILE="$dbfile" python3 - <<'PYFTPSTORED'
import ftplib, io, json, os, secrets, sqlite3, ssl
path=os.environ.get('DBFILE','')
result={'accounts':[], 'tested':0, 'passed':0, 'failed':0, 'ok':True,
        'endpoints':[{'name':'FTP','host':'127.0.0.1','port':21}]}
if not path or not os.path.exists(path):
    print(json.dumps(result, ensure_ascii=False)); raise SystemExit
try:
    con=sqlite3.connect(path)
    cols={r[1] for r in con.execute('pragma table_info(ftp_accounts)')}
    if not {'username','password_plain'} <= cols:
        print(json.dumps(result, ensure_ascii=False)); raise SystemExit
    rows=con.execute("select username,coalesce(password_plain,'') from ftp_accounts order by id limit 20").fetchall()
finally:
    try: con.close()
    except Exception: pass
for user,pw in rows:
    if not user or not pw: continue
    item={'username':str(user),'checks':[],'ok':True}
    result['tested']+=1
    name='.hyper-host-v56-test-'+secrets.token_hex(5)+'.txt'
    payload=('HYPER-HOST FTP STORED TEST '+secrets.token_hex(12)).encode()
    ftp=None; check={'name':'FTP','host':'127.0.0.1','port':21,'passive':True,'ok':False,'error':''}
    try:
        ctx=ssl._create_unverified_context(); ctx.minimum_version=ssl.TLSVersion.TLSv1_2; ctx.maximum_version=ssl.TLSVersion.TLSv1_2
        ftp=ftplib.FTP_TLS(context=ctx, timeout=8); ftp.connect('127.0.0.1',21,timeout=8); ftp.auth(); ftp.login(str(user),str(pw)); ftp.prot_p(); ftp.set_pasv(True)
        ftp.storbinary('STOR '+name, io.BytesIO(payload))
        got=bytearray(); ftp.retrbinary('RETR '+name, got.extend)
        if bytes(got)!=payload: raise RuntimeError('upload/download content mismatch')
        ftp.delete(name); ftp.quit(); ftp=None; check['ok']=True
    except Exception as exc:
        check['error']=f'{type(exc).__name__}: {exc}'; item['ok']=False
        if ftp is not None:
            try: ftp.delete(name)
            except Exception: pass
            try: ftp.close()
            except Exception: pass
    item['checks'].append(check)
    if item['ok']: result['passed']+=1
    else: result['failed']+=1; result['ok']=False
    result['accounts'].append(item)
print(json.dumps(result, ensure_ascii=False))
PYFTPSTORED
}


cmd_create_db() {
  local db="${1:-}" user="${2:-}" pass="${3:-}" remote="${4:-0}" host_pattern="${5:-}"
  [[ -n "$db" && -n "$user" && -n "$pass" ]] || err "DB, user and password required"
  valid_db_name "$db" || err "Invalid db name"
  valid_db_name "$user" || err "Invalid db user"
  local epass; epass="$(sql_escape "$pass")"
  [[ -z "$host_pattern" ]] && { [[ "$remote" == "1" ]] && host_pattern="%" || host_pattern="localhost"; }
  validate_mysql_host_pattern "$host_pattern"
  mysql <<SQL
CREATE DATABASE IF NOT EXISTS \`${db}\` CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
CREATE USER IF NOT EXISTS '${user}'@'localhost' IDENTIFIED BY '${epass}';
ALTER USER '${user}'@'localhost' IDENTIFIED BY '${epass}';
GRANT ALL PRIVILEGES ON \`${db}\`.* TO '${user}'@'localhost';
SQL
  # v44 fix: phpMyAdmin в этой панели всегда ходит в MySQL по TCP на 127.0.0.1
  # (см. configure_phpmyadmin_label: $cfg['Servers'][$i]['host'] = '127.0.0.1').
  # А MySQL/MariaDB считает 'user'@'localhost' и 'user'@'127.0.0.1' РАЗНЫМИ учётками:
  # 'localhost' match'ится только для подключения через unix-сокет. Из-за этого
  # "Войти" в phpMyAdmin падал с Access denied, даже если логин/пароль верные.
  # Поэтому всегда дополнительно создаём аккаунт на 127.0.0.1, независимо от чекбокса remote.
  mysql <<SQL
CREATE USER IF NOT EXISTS '${user}'@'127.0.0.1' IDENTIFIED BY '${epass}';
ALTER USER '${user}'@'127.0.0.1' IDENTIFIED BY '${epass}';
GRANT ALL PRIVILEGES ON \`${db}\`.* TO '${user}'@'127.0.0.1';
SQL
  if [[ "$remote" == "1" ]]; then mysql <<SQL
CREATE USER IF NOT EXISTS '${user}'@'${host_pattern}' IDENTIFIED BY '${epass}';
ALTER USER '${user}'@'${host_pattern}' IDENTIFIED BY '${epass}';
GRANT ALL PRIVILEGES ON \`${db}\`.* TO '${user}'@'${host_pattern}';
SQL
  fi
  mysql -e "FLUSH PRIVILEGES;"
  log "Database created: $db / $user / remote=$remote host=$host_pattern (localhost + 127.0.0.1 for phpMyAdmin)"
}

cmd_delete_db() {
  local db="${1:-}" user="${2:-}"
  [[ -n "$db" && -n "$user" ]] || err "DB and user required"
  valid_db_name "$db" || err "Invalid db"
  valid_db_name "$user" || err "Invalid user"
  mysql -e "DROP DATABASE IF EXISTS \`${db}\`; DROP USER IF EXISTS '${user}'@'localhost'; DROP USER IF EXISTS '${user}'@'%'; FLUSH PRIVILEGES;"
  mysql -N -B -e "SELECT Host FROM mysql.user WHERE User='$(sql_escape "$user")'" 2>/dev/null | while read -r h; do [[ -n "$h" ]] && mysql -e "DROP USER IF EXISTS '${user}'@'${h}';" || true; done
  mysql -e "FLUSH PRIVILEGES;"
  log "Database deleted: $db / $user"
}

validate_mysql_host_pattern() {
  local h="${1:-}"
  [[ "$h" == "localhost" || "$h" == "%" ]] && return 0
  [[ "$h" =~ ^[0-9]{1,3}(\.[0-9]{1,3}){3}$ ]] && return 0
  [[ "$h" =~ ^[A-Za-z0-9._%-]{1,128}$ ]] && return 0
  err "Invalid MySQL host pattern: $h"
}

cmd_create_mysql_account() {
  local user="${1:-}" pass="${2:-}" host="${3:-localhost}" db="${4:-}" priv="${5:-ALL}"
  [[ -n "$user" && -n "$pass" ]] || err "User and password required"
  valid_db_name "$user" || err "Invalid MySQL user"
  validate_mysql_host_pattern "$host"
  [[ -z "$db" || "$db" == "*" || "$db" == "*.*" || "$db" =~ ^[A-Za-z0-9_]{2,48}$ ]] || err "Invalid db name"
  [[ "$priv" =~ ^(ALL|SELECT|READ)$ ]] || priv="ALL"
  local epass; epass="$(sql_escape "$pass")"
  # v44 fix: phpMyAdmin подключается к MySQL по TCP на 127.0.0.1, а не через unix-сокет
  # localhost, поэтому если аккаунт создан только на 'localhost', кнопка "Войти" в
  # phpMyAdmin отдаёт Access denied даже с правильным паролем. Всегда добавляем 127.0.0.1
  # к списку хостов аккаунта, в дополнение к выбранному в форме host.
  local hosts=("$host")
  [[ "$host" != "127.0.0.1" ]] && hosts+=("127.0.0.1")
  [[ "$host" != "localhost" ]] && hosts+=("localhost")
  local h
  for h in "${hosts[@]}"; do
    mysql <<SQL
CREATE USER IF NOT EXISTS '${user}'@'${h}' IDENTIFIED BY '${epass}';
ALTER USER '${user}'@'${h}' IDENTIFIED BY '${epass}';
SQL
    if [[ -n "$db" && "$db" != "*" && "$db" != "*.*" ]]; then
      mysql -e "CREATE DATABASE IF NOT EXISTS \`${db}\` CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;"
      if [[ "$priv" == "SELECT" || "$priv" == "READ" ]]; then
        mysql -e "GRANT SELECT, SHOW VIEW ON \`${db}\`.* TO '${user}'@'${h}';"
      else
        mysql -e "GRANT ALL PRIVILEGES ON \`${db}\`.* TO '${user}'@'${h}';"
      fi
    elif [[ "$db" == "*" || "$db" == "*.*" ]]; then
      mysql -e "GRANT ALL PRIVILEGES ON *.* TO '${user}'@'${h}' WITH GRANT OPTION;"
    else
      mysql -e "GRANT USAGE ON *.* TO '${user}'@'${h}';"
    fi
  done
  mysql -e "FLUSH PRIVILEGES;"
  log "MySQL/phpMyAdmin account ready: ${user}@(${hosts[*]}) db=${db:-usage}"
}

cmd_delete_mysql_account() {
  local user="${1:-}" host="${2:-localhost}"
  [[ -n "$user" ]] || err "User required"
  valid_db_name "$user" || err "Invalid MySQL user"
  validate_mysql_host_pattern "$host"
  mysql -e "DROP USER IF EXISTS '${user}'@'${host}'; FLUSH PRIVILEGES;"
  log "MySQL account deleted: ${user}@${host}"
}

cmd_mysql_repair_accounts() {
  local dbfile="${BASE_DIR}/data/hyperhost.sqlite" sqltmp
  [[ -f "$dbfile" ]] || { warn "SQLite панели не найден: $dbfile"; return 0; }
  sqltmp="$(mktemp)"
  python3 - "$dbfile" "$FIXED_PUBLIC_IP" > "$sqltmp" <<'PYMYSQLREPAIR'
import sqlite3,sys
path,pub=sys.argv[1],sys.argv[2]
con=sqlite3.connect(path)
def cols(t):
    try:return {r[1] for r in con.execute(f'pragma table_info({t})')}
    except:return set()
def esc(s): return str(s or '').replace('\\','\\\\').replace("'","''")
def ident(s): return str(s or '').replace('`','``')
items={}
if {'db_name','db_user','db_password_plain'} <= cols('databases'):
    for db,u,p in con.execute("select db_name,db_user,coalesce(db_password_plain,'') from databases"):
        if db and u and p: items[(u,p,db)]='ALL'
if {'username','password_plain','db_name','privileges'} <= cols('mysql_accounts'):
    for u,p,db,pr in con.execute("select username,coalesce(password_plain,''),coalesce(db_name,''),coalesce(privileges,'ALL') from mysql_accounts"):
        if u and p and db and db not in ('*','*.*'): items[(u,p,db)]=pr or 'ALL'
for (u,p,db),pr in items.items():
    for host in ('localhost','127.0.0.1','192.168.0.%','%'):
        print(f"CREATE USER IF NOT EXISTS '{esc(u)}'@'{host}' IDENTIFIED BY '{esc(p)}';")
        print(f"ALTER USER '{esc(u)}'@'{host}' IDENTIFIED BY '{esc(p)}';")
        if str(pr).upper() in ('SELECT','READ'):
            print(f"GRANT SELECT, SHOW VIEW ON `{ident(db)}`.* TO '{esc(u)}'@'{host}';")
        else:
            print(f"GRANT ALL PRIVILEGES ON `{ident(db)}`.* TO '{esc(u)}'@'{host}';")
print('FLUSH PRIVILEGES;')
try:
    if {'remote_allowed','db_host'} <= cols('databases'):
        con.execute('update databases set remote_allowed=1, db_host=?',(pub,))
    if {'remote_allowed','host_pattern'} <= cols('mysql_accounts'):
        con.execute("update mysql_accounts set remote_allowed=1, host_pattern='%'")
    con.commit()
finally: con.close()
PYMYSQLREPAIR
  if [[ -s "$sqltmp" ]]; then mysql --protocol=socket -uroot < "$sqltmp"; fi
  rm -f "$sqltmp"
  log "MySQL-пользователи панели восстановлены для localhost, 127.0.0.1, LAN и Internet (%)"
}

cmd_mysql_external() {
  local state="${1:-}" value common_file="/etc/mysql/conf.d/99-hyper-host-network.cnf" file
  [[ "$state" == enable || "$state" == disable ]] || err "Use enable or disable"
  value="127.0.0.1"; [[ "$state" == enable ]] && value="0.0.0.0"

  # /etc/mysql/conf.d читается и MariaDB, и Oracle MySQL в Debian/Ubuntu.
  # Дополнительно дублируем в vendor-specific каталог, если он существует.
  mkdir -p /etc/mysql/conf.d
  for file in "$common_file" /etc/mysql/mariadb.conf.d/99-hyper-host-network.cnf /etc/mysql/mysql.conf.d/99-hyper-host-network.cnf; do
    [[ "$file" == "$common_file" || -d "$(dirname "$file")" ]] || continue
    cat > "$file" <<EOMYSQLNET
# Managed by HYPER-HOST. Do not edit manually.
[mysqld]
bind-address = $value
skip-networking = 0
EOMYSQLNET
    chmod 0644 "$file" 2>/dev/null || true
  done

  if [[ "$state" == enable ]]; then
    open_server_ports
  else
    ufw delete allow 3306/tcp >/dev/null 2>&1 || true
  fi
  if systemctl list-unit-files mariadb.service >/dev/null 2>&1; then
    systemctl restart mariadb
  else
    systemctl restart mysql
  fi
  sleep 1
  systemctl is-active mariadb >/dev/null 2>&1 || systemctl is-active mysql >/dev/null 2>&1 || err "MariaDB/MySQL не запустилась после изменения bind-address. Проверь: journalctl -u mariadb -n 100"
  listen_port_tcp 3306 || err "MariaDB запущена, но порт 3306 не слушается"
  if [[ "$state" == enable ]]; then
    mysql_listens_external || {
      ss -H -ltnp 'sport = :3306' >&2 2>/dev/null || true
      err "MariaDB слушает 3306 только локально. Проверь конфликтующие bind-address: grep -Rni '^[[:space:]]*bind-address' /etc/mysql"
    }
    cmd_mysql_repair_accounts
  fi
  configure_phpmyadmin_label || true
  local ext lan
  ext="$(public_ip)"; lan="$(detect_internal_ipv4)"
  log "MySQL external access: $state / bind=$value / LAN=${lan}:3306 / Internet=${ext}:3306"
}
cmd_mysql_status_json() {
  local external internal configured panel panel_ip
  external="$(public_ip)"; internal="$(detect_internal_ipv4)"; configured="$(configured_public_ip)"; panel="${PANEL_DOMAIN:-_}"; panel_ip=""
  [[ -n "$panel" && "$panel" != "_" ]] && panel_ip="$(resolve_domain_a_public "$panel" | head -n1 || true)"
  EXTERNAL_IP="$external" INTERNAL_IP="$internal" CONFIGURED_IP="$configured" PANEL="$panel" PANEL_IP="$panel_ip" python3 - <<'PYIN'
import json, subprocess, re, os

def sh(cmd):
    try: return subprocess.check_output(cmd, shell=True, text=True, stderr=subprocess.DEVNULL).strip()
    except Exception: return ''
bind=''
for f in ['/etc/mysql/my.cnf','/etc/mysql/mariadb.conf.d/50-server.cnf','/etc/mysql/mysql.conf.d/mysqld.cnf','/etc/mysql/conf.d/99-hyper-host-network.cnf','/etc/mysql/mariadb.conf.d/99-hyper-host-network.cnf','/etc/mysql/mysql.conf.d/99-hyper-host-network.cnf']:
    if os.path.exists(f):
        txt=open(f,errors='ignore').read(); m=re.findall(r'^\s*bind-address\s*=\s*(\S+)', txt, re.M)
        if m: bind=m[-1]
listen=bool(sh("ss -H -lnt 'sport = :3306' | head -n1"))
service=sh('systemctl is-active mariadb || systemctl is-active mysql || true')
users=[]
raw=sh("mysql -N -B -e \"SELECT User,Host FROM mysql.user WHERE User NOT IN ('root','mariadb.sys','mysql','debian-sys-maint') ORDER BY User,Host\" 2>/dev/null || true")
for line in raw.splitlines():
    p=line.split('\t')
    if len(p)>=2: users.append({'user':p[0], 'host':p[1]})
external=os.environ.get('EXTERNAL_IP',''); internal=os.environ.get('INTERNAL_IP',''); panel=os.environ.get('PANEL','')
print(json.dumps({
  'bind_address': bind or 'default',
  'listen_3306': listen,
  'service': service,
  'external_enabled': bind in ('0.0.0.0','::','*'),
  'external_host': external,
  'external_endpoint': f'{external}:3306' if external else '',
  'public_ip': external,
  'configured_public_ip': os.environ.get('CONFIGURED_IP',''),
  'lan_host': internal,
  'lan_endpoint': f'{internal}:3306' if internal else '',
  'internal_host': '127.0.0.1',
  'local_endpoint': '127.0.0.1:3306',
  'panel_domain': panel,
  'panel_domain_ip': os.environ.get('PANEL_IP',''),
  'phpmyadmin_sql_host': '127.0.0.1',
  'phpmyadmin_display_host': external or internal or '127.0.0.1',
  'port': '3306',
  'users': users,
}, ensure_ascii=False))
PYIN
}
cmd_mysql_doctor_json() {
  local external internal
  external="$(public_ip)"; internal="$(detect_internal_ipv4)"
  EXTERNAL_IP="$external" INTERNAL_IP="$internal" python3 - <<'PYDOC'
import json, os, socket, subprocess, re

def sh(cmd):
    try: return subprocess.check_output(cmd, shell=True, text=True, stderr=subprocess.DEVNULL).strip()
    except Exception: return ''
def tcp(host, port, timeout=2):
    if not host: return False
    try:
        with socket.create_connection((host,int(port)), timeout=timeout): return True
    except Exception: return False
external=os.environ.get('EXTERNAL_IP',''); internal=os.environ.get('INTERNAL_IP','')
listen=bool(sh("ss -H -lnt 'sport = :3306' | head -n1"))
local_tcp=tcp('127.0.0.1',3306)
lan_tcp=tcp(internal,3306)
external_tcp=tcp(external,3306)
bind=''
for f in ['/etc/mysql/my.cnf','/etc/mysql/mariadb.conf.d/50-server.cnf','/etc/mysql/mysql.conf.d/mysqld.cnf','/etc/mysql/conf.d/99-hyper-host-network.cnf','/etc/mysql/mariadb.conf.d/99-hyper-host-network.cnf','/etc/mysql/mysql.conf.d/99-hyper-host-network.cnf']:
    if os.path.exists(f):
        txt=open(f,errors='ignore').read(); m=re.findall(r'^\s*bind-address\s*=\s*(\S+)', txt, re.M)
        if m: bind=m[-1]
external_enabled=bind in ('0.0.0.0','::','*')
remote_users=[]
raw=sh("mysql -N -B -e \"SELECT User,Host FROM mysql.user WHERE Host NOT IN ('localhost','127.0.0.1','::1') AND User NOT IN ('root','mariadb.sys','mysql','debian-sys-maint') ORDER BY User,Host\" 2>/dev/null || true")
for line in raw.splitlines():
    p=line.split('\t')
    if len(p)>=2: remote_users.append({'user':p[0],'host':p[1]})
problem=''
if not listen or not local_tcp:
    problem='MariaDB не слушает 3306. Выполни: sudo hyper db external enable'
elif not external_enabled:
    problem='Внешний SQL выключен. Выполни: sudo hyper db external enable'
elif not remote_users:
    problem='Порт открыт, но нет MySQL-пользователя для внешнего входа. Создай: sudo hyper db user USER PASS DB %'
print(json.dumps({
  'service': sh('systemctl is-active mariadb || systemctl is-active mysql || true'),
  'bind_address': bind or 'default',
  'external_enabled': external_enabled,
  'listen_3306': listen,
  'local_127_0_0_1': local_tcp,
  'lan_host': internal,
  'lan_3306': lan_tcp,
  'external_host': external,
  'external_3306_from_server': external_tcp,
  'remote_users': remote_users,
  'router_rule': f'TCP 3306 -> {internal}:3306' if internal else '',
  'note': f'phpMyAdmin работает через 127.0.0.1. Из LAN используй {internal}:3306. Из интернета используй {external}:3306 и проброс TCP 3306 на роутере.',
  'problem': problem,
}, ensure_ascii=False))
PYDOC
}
cmd_mysql_test() {
  local host="${1:-127.0.0.1}" user="${2:-}" pass="${3:-}" db="${4:-}" client
  [[ -n "$user" && -n "$pass" ]] || err "Use: mysql-test HOST USER PASSWORD [DB]"
  client="$(command -v mariadb || command -v mysql || true)"
  [[ -n "$client" ]] || err "Не найден клиент mariadb/mysql"
  local opt_db=(); [[ -n "$db" ]] && opt_db=("$db")
  MYSQL_PWD="$pass" "$client" --protocol=tcp -h "$host" -P 3306 -u "$user" -e "SELECT 'ok' AS hyper_host_mysql_test, USER() AS mysql_user, CURRENT_USER() AS grants_user, VERSION() AS version;" "${opt_db[@]}"
}


cmd_mysql_test_saved_json() {
  local dbfile="${BASE_DIR}/data/hyperhost.sqlite"
  DBFILE="$dbfile" MYSQL_BIN="$(command -v mariadb || command -v mysql || true)" python3 - <<'PYMYSQLSTORED'
import json, os, sqlite3, subprocess
path=os.environ.get('DBFILE',''); binary=os.environ.get('MYSQL_BIN','')
result={'accounts':[], 'tested':0, 'passed':0, 'failed':0, 'ok':True}
if not path or not os.path.exists(path) or not binary:
    if not binary:
        result.update(ok=False,failed=1,error='mariadb/mysql client not found')
    print(json.dumps(result,ensure_ascii=False)); raise SystemExit
con=sqlite3.connect(path)
try:
    cols={r[1] for r in con.execute('pragma table_info(databases)')}
    if not {'db_name','db_user','db_password_plain'} <= cols:
        print(json.dumps(result,ensure_ascii=False)); raise SystemExit
    rows=con.execute("select db_name,db_user,coalesce(db_password_plain,'') from databases order by id limit 5").fetchall()
finally: con.close()
for db,user,pw in rows:
    if not db or not user or not pw: continue
    item={'database':str(db),'username':str(user),'hosts':[],'ok':True}
    result['tested']+=1
    for host in ('127.0.0.1','192.168.0.179','90.189.208.25'):
        env=os.environ.copy(); env['MYSQL_PWD']=str(pw)
        cp=subprocess.run([binary,'--protocol=tcp','-h',host,'-P','3306','-u',str(user),str(db),'-NBe','SELECT 1'],env=env,text=True,stdout=subprocess.PIPE,stderr=subprocess.PIPE,timeout=6)
        ok=cp.returncode==0 and cp.stdout.strip()=='1'
        item['hosts'].append({'host':host,'ok':ok,'error':cp.stderr.strip()[-400:] if not ok else ''})
        if not ok: item['ok']=False
    if item['ok']: result['passed']+=1
    else: result['failed']+=1; result['ok']=False
    result['accounts'].append(item)
print(json.dumps(result,ensure_ascii=False))
PYMYSQLSTORED
}


configure_phpmyadmin_label() {
  mkdir -p /etc/phpmyadmin/conf.d
  local external internal pma_label
  external="$(public_ip)"; internal="$(detect_internal_ipv4)"
  pma_label="HYPER-HOST SQL | Internet ${external:-unknown}:3306 | LAN ${internal:-unknown}:3306"
  {
  cat > /etc/phpmyadmin/conf.d/hyper-host-server.php <<EOPMA
<?php
// HYPER-HOST: phpMyAdmin соединяется с локальной MariaDB через 127.0.0.1,
// а в названии показывает реальные адреса для внешних клиентов.
if (isset(\$i)) {
    \$cfg['Servers'][\$i]['verbose'] = '${pma_label}';
    \$cfg['Servers'][\$i]['host'] = '127.0.0.1';
    \$cfg['Servers'][\$i]['port'] = '3306';
    \$cfg['Servers'][\$i]['connect_type'] = 'tcp';
    \$cfg['Servers'][\$i]['auth_type'] = 'cookie';
    \$cfg['Servers'][\$i]['AllowNoPassword'] = false;
}
EOPMA
  } 2>/dev/null || warn "Не удалось записать /etc/phpmyadmin/conf.d/hyper-host-server.php (read-only /etc?)"
  chmod 0644 /etc/phpmyadmin/conf.d/hyper-host-server.php 2>/dev/null || true
}
cmd_phpmyadmin_fix() {
  configure_phpmyadmin_label
  configure_php_limits
  configure_phpmyadmin_storage
  log "phpMyAdmin fixed: internal SQL=127.0.0.1:3306 / external SQL=$(public_ip):3306 / LAN SQL=$(detect_internal_ipv4):3306"
}

ensure_bot_user() {
  id "$BOT_USER" >/dev/null 2>&1 || useradd --system --home "$BOTS_DIR" --shell /usr/sbin/nologin "$BOT_USER"
  usermod -d "$BOTS_DIR" -s /usr/sbin/nologin "$BOT_USER" 2>/dev/null || true
  usermod -aG www-data "$BOT_USER" 2>/dev/null || true
  mkdir -p "$BOTS_DIR" "$PM2_HOME_DIR"
  # Не делаем chown -R по всем ботам на каждом открытии вкладки — это сильно тормозит панель.
  chown "$BOT_USER":www-data "$BOTS_DIR" "$PM2_HOME_DIR" 2>/dev/null || true
  find "$PM2_HOME_DIR" -xdev -maxdepth 2 -exec chown -h "$BOT_USER":www-data {} + 2>/dev/null || true
  chmod 2775 "$BOTS_DIR" "$PM2_HOME_DIR" 2>/dev/null || true
}
node_major() { node -v 2>/dev/null | sed 's/^v//' | cut -d. -f1 | grep -E '^[0-9]+$' || echo 0; }
ensure_node_runtime() {
  # v50 fix: раньше apt-get update -y (по ВСЕМ репозиториям: ubuntu x4, nodesource,
  # ondrej/php PPA) запускался БЕЗУСЛОВНО при каждом создании/деплое бота — даже
  # когда Node.js уже стоит нужной версии. На домашнем интернете это легко давало
  # 10-60+ секунд ожидания на пустом месте при КАЖДОМ боте. Теперь если Node.js уже
  # нужной версии и npm есть — вообще ничего не трогаем и выходим сразу.
  local major; major="$(node_major)"
  if [[ "$major" -ge "$NODE_MAJOR_MIN" ]] && command -v npm >/dev/null 2>&1; then
    return 0
  fi
  apt-get update -y >/dev/null 2>&1 || true
  apt-get install -y curl ca-certificates gnupg >/dev/null 2>&1 || true
  dpkg --configure -a >/tmp/hyper-host-dpkg-configure.log 2>&1 || true
  apt-get -f install -y >/tmp/hyper-host-apt-fix.log 2>&1 || true
  if [[ "$major" -lt "$NODE_MAJOR_MIN" ]]; then
    log "Node.js слишком старый или сломан: $(node -v 2>/dev/null || echo none). Чищу старые node/npm/libnode-dev и ставлю Node.js 20.x."
    apt-get remove -y npm nodejs libnode-dev node-gyp nodejs-doc >/tmp/hyper-host-node-remove.log 2>&1 || true
    apt-get autoremove -y >/tmp/hyper-host-node-autoremove.log 2>&1 || true
    rm -f /etc/apt/sources.list.d/nodesource*.list /etc/apt/keyrings/nodesource.gpg 2>/dev/null || true
    curl -fsSL https://deb.nodesource.com/setup_20.x | bash - >/tmp/hyper-host-nodesource.log 2>&1 || true
    apt-get update -y >/dev/null 2>&1 || true
    apt-get install -y nodejs >/tmp/hyper-host-node-install.log 2>&1 || apt-get install -y nodejs npm || true
  fi
  command -v npm >/dev/null 2>&1 || apt-get install -y npm || true
}
ensure_pm2() {
  command -v python3 >/dev/null 2>&1 || apt-get install -y python3
  command -v pip3 >/dev/null 2>&1 || apt-get install -y python3-pip
  python3 -m venv --help >/dev/null 2>&1 || apt-get install -y python3-venv
  ensure_node_runtime
  if ! command -v pm2 >/dev/null 2>&1; then npm install -g pm2@latest; fi
  ensure_bot_user
  pm2_as_bot ping >/dev/null 2>&1 || true
  pm2_as_bot save --force >/dev/null 2>&1 || pm2_as_bot save >/dev/null 2>&1 || true
  install_hyperbot_pm2_service
}
pm2_as_bot() {
  sudo -u "$BOT_USER" -H env HOME="$BOTS_DIR" PM2_HOME="$PM2_HOME_DIR" PATH="/usr/local/bin:/usr/bin:/bin" pm2 "$@"
}
run_as_bot() {
  sudo -u "$BOT_USER" -H env HOME="$BOTS_DIR" PM2_HOME="$PM2_HOME_DIR" PATH="/usr/local/bin:/usr/bin:/bin" "$@"
}

install_hyperbot_pm2_service() {
  # HYPER-HOST v13: боты должны жить 24/7 независимо от открытой консоли/панели.
  # Поэтому PM2 запускается как systemd-сервис от пользователя hyperbot и поднимает сохранённый dump.pm2 после reboot.
  #
  # v49 fix: раньше тут стоял голый `cat > /etc/systemd/system/hyperbot-pm2.service <<EOSVC`.
  # На системах с read-only /etc/systemd/system (контейнер/урезанные права) эта запись
  # падала с "Read-only file system", а так как весь скрипт запущен с `set -Eeo pipefail`,
  # ЭТО ПАДЕНИЕ УБИВАЛО ВЕСЬ ЗАПУЩЕННЫЙ КОМАНДОЙ ПРОЦЕСС ЦЕЛИКОМ — включая создание бота,
  # которое вызывает ensure_pm2 первым делом, ДО того как бот вообще создаётся и стартует.
  # Отсюда "не могу создать новых ботов": падало на PM2-автозапуске, а не на самом боте.
  # Теперь пишем во временный файл и переносим в /etc/systemd/system только если это
  # реально получилось; если нет — просто пропускаем systemd-автозапуск (сам PM2-процесс
  # это не затрагивает, боты всё равно стартуют и работают, просто без автоподъёма после
  # полной перезагрузки сервера) и пробуем более лёгкий fallback через cron @reboot.
  ensure_bot_user
  # v50 fix: раньше systemd-юнит перезаписывался и перезапускался (daemon-reload +
  # enable + start) на КАЖДОЕ создание бота — лишние секунды на пустом месте, когда
  # сервис и так уже активен и корректно настроен. Теперь если он уже active — выходим.
  if systemctl is-active hyperbot-pm2.service >/dev/null 2>&1; then
    return 0
  fi
  local pm2_bin
  pm2_bin="$(command -v pm2 || true)"
  [[ -n "$pm2_bin" ]] || return 0
  mkdir -p "$PM2_HOME_DIR"
  chown "$BOT_USER":www-data "$BOTS_DIR" "$PM2_HOME_DIR" 2>/dev/null || true
  chmod 2775 "$BOTS_DIR" "$PM2_HOME_DIR" 2>/dev/null || true

  local tmp_unit="/tmp/hyperbot-pm2.service.$$"
  cat > "$tmp_unit" <<EOSVC
[Unit]
Description=HYPER-HOST PM2 24/7 bots runtime
Documentation=https://github.com/memes4u1337/hyper-hosting-panel
After=network-online.target
Wants=network-online.target

[Service]
Type=forking
User=${BOT_USER}
LimitNOFILE=infinity
LimitNPROC=infinity
LimitCORE=infinity
Environment=HOME=${BOTS_DIR}
Environment=PM2_HOME=${PM2_HOME_DIR}
Environment=PATH=/usr/local/bin:/usr/bin:/bin
PIDFile=${PM2_HOME_DIR}/pm2.pid
ExecStart=/bin/bash -lc '${pm2_bin} resurrect || ${pm2_bin} ping'
ExecReload=/bin/bash -lc '${pm2_bin} reload all || true'
ExecStop=/bin/bash -lc '${pm2_bin} save --force || ${pm2_bin} save || true'
ExecStop=/bin/bash -lc '${pm2_bin} kill || true'
Restart=on-failure
RestartSec=5
TimeoutStartSec=120
TimeoutStopSec=60
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
EOSVC

  if cat "$tmp_unit" > /etc/systemd/system/hyperbot-pm2.service 2>/dev/null; then
    rm -f "$tmp_unit" 2>/dev/null || true
    systemctl daemon-reload >/dev/null 2>&1 || true
    systemctl enable hyperbot-pm2.service >/dev/null 2>&1 || true
    systemctl start hyperbot-pm2.service >/dev/null 2>&1 || true
  else
    rm -f "$tmp_unit" 2>/dev/null || true
    log "PM2 systemd-автозапуск недоступен (read-only /etc/systemd/system) — боты продолжают работать через сам PM2-процесс, но не переживут полную перезагрузку сервера без cron-фолбэка ниже."
    # Лёгкий fallback: поднять сохранённый dump.pm2 через cron @reboot, если /etc/cron.d доступен на запись.
    local cron_tmp="/tmp/hyperbot-pm2-reboot.$$"
    cat > "$cron_tmp" <<EOCRON
SHELL=/bin/bash
PATH=/usr/local/bin:/usr/bin:/bin
@reboot ${BOT_USER} HOME=${BOTS_DIR} PM2_HOME=${PM2_HOME_DIR} ${pm2_bin} resurrect >>/var/log/hyper-host-pm2-reboot.log 2>&1
EOCRON
    if cat "$cron_tmp" > "$CRON_DIR/hyper-host-pm2-reboot" 2>/dev/null; then
      chmod 0644 "$CRON_DIR/hyper-host-pm2-reboot" 2>/dev/null || true
      systemctl reload cron 2>/dev/null || true
    fi
    rm -f "$cron_tmp" 2>/dev/null || true
  fi
}

pm2_persist() {
  # Сохраняем текущий список PM2 и включаем автоподъём через systemd.
  ensure_bot_user
  mkdir -p "$PM2_HOME_DIR"
  chown "$BOT_USER":www-data "$BOTS_DIR" "$PM2_HOME_DIR" 2>/dev/null || true
  pm2_as_bot save --force >/dev/null 2>&1 || pm2_as_bot save >/dev/null 2>&1 || true
  install_hyperbot_pm2_service
}

cmd_pm2_persist() {
  ensure_pm2
  pm2_persist
  log "PM2 24/7 autostart enabled for $BOT_USER. Боты продолжат работать после закрытия панели/SSH и поднимутся после перезагрузки."
}
make_bot_start_script() {
  local name="$1" runtime="$2" main_file="$3" path="$BOTS_DIR/$name" mem="${4:-0}"
  mkdir -p "$path"
  main_file="$(basename "$main_file")"

  # HYPER-HOST v24: раньше .hyper-start.sh мог получить пустой interpreter и падал:
  #   .hyper-start.sh: line 4: : No such file or directory
  # Теперь стартовый файл сам находит interpreter внутри папки бота и пишет понятную ошибку.
  cat > "$path/.hyper-start.sh" <<EOS
#!/usr/bin/env bash
set -Eeuo pipefail
cd "\$(cd "\$(dirname "\${BASH_SOURCE[0]}")" && pwd)"
LOCK=".hyper-bot.lock"
exec 9>"\$LOCK"
if ! flock -n 9; then
  echo "HYPER-HOST: bot ${name} уже запущен, дубль остановлен"
  exit 0
fi
if [[ -f .env ]]; then
  set -a
  # shellcheck disable=SC1091
  source .env
  set +a
fi
MAIN_FILE="${main_file}"
if [[ ! -f "\$MAIN_FILE" ]]; then
  echo "HYPER-HOST ERROR: главный файл не найден: \$(pwd)/\$MAIN_FILE"
  echo "Проверь поле 'Главный файл' в панели и загруженные файлы бота."
  exit 127
fi
case "${runtime}" in
  python)
    if [[ -x ./venv/bin/python ]]; then exec ./venv/bin/python "\$MAIN_FILE"; fi
    if command -v python3 >/dev/null 2>&1; then exec python3 "\$MAIN_FILE"; fi
    if command -v python >/dev/null 2>&1; then exec python "\$MAIN_FILE"; fi
    echo "HYPER-HOST ERROR: python3 не найден. Выполни: sudo apt install -y python3 python3-venv python3-pip"
    exit 127
    ;;
  node)
    if command -v node >/dev/null 2>&1; then exec node "\$MAIN_FILE"; fi
    echo "HYPER-HOST ERROR: node не найден. Выполни: sudo apt install -y nodejs npm"
    exit 127
    ;;
  php)
    if command -v php >/dev/null 2>&1; then exec php "\$MAIN_FILE"; fi
    echo "HYPER-HOST ERROR: php-cli не найден. Выполни: sudo apt install -y php-cli"
    exit 127
    ;;
  custom)
    exec bash -lc "./\$MAIN_FILE"
    ;;
  *)
    echo "HYPER-HOST ERROR: неизвестный runtime: ${runtime}"
    exit 2
    ;;
esac
EOS
  chmod +x "$path/.hyper-start.sh"
  chown "$BOT_USER":www-data "$path/.hyper-start.sh" 2>/dev/null || true
}
bot_install_deps_internal() {
  local name="$1" runtime="${2:-python}" path="$BOTS_DIR/$name"
  [[ -d "$path" ]] || err "Bot folder not found"
  ensure_bot_user
  chown -R "$BOT_USER":www-data "$path" 2>/dev/null || true
  fix_web_permissions "$path" "$BOT_USER"
  if [[ "$runtime" == "python" && -f "$path/requirements.txt" ]]; then
    run_as_bot python3 -m venv "$path/venv"
    run_as_bot "$path/venv/bin/python" -m pip install --upgrade pip wheel setuptools
    run_as_bot "$path/venv/bin/pip" install -r "$path/requirements.txt"
    log "Python requirements installed in venv for $name"
  elif [[ "$runtime" == "node" && -f "$path/package.json" ]]; then
    (cd "$path" && run_as_bot npm install)
    log "Node packages installed for $name"
  elif [[ "$runtime" == "php" && -f "$path/composer.json" ]]; then
    if command -v composer >/dev/null 2>&1; then (cd "$path" && run_as_bot composer install --no-interaction); fi
    log "PHP dependencies checked for $name"
  else
    log "No dependency file found for $name"
  fi
  fix_web_permissions "$path" "$BOT_USER"
}
bot_token_from_path() {
  local path="$1"
  [[ -d "$path" ]] || return 0
  grep -RhoE '[0-9]{8,12}:[A-Za-z0-9_-]{25,}' "$path" 2>/dev/null | head -n1 || true
}

telegram_delete_webhook_for_token() {
  local token="$1"
  [[ -n "$token" ]] || return 0
  curl -fsS --max-time 6 "https://api.telegram.org/bot${token}/deleteWebhook?drop_pending_updates=true" >/dev/null 2>&1 || true
}

bot_stop_same_token_local() {
  local name="$1" path="$2" token other other_name
  token="$(bot_token_from_path "$path")"
  [[ -n "$token" ]] || return 0
  telegram_delete_webhook_for_token "$token"
  shopt -s nullglob
  for other in "$BOTS_DIR"/*; do
    [[ -d "$other" ]] || continue
    [[ "$other" == "$path" ]] && continue
    if grep -RqsF "$token" "$other" 2>/dev/null; then
      other_name="$(basename "$other")"
      pm2_as_bot stop "$other_name" >/dev/null 2>&1 || true
      pm2_as_bot delete "$other_name" >/dev/null 2>&1 || true
      pm2 stop "$other_name" >/dev/null 2>&1 || true
      pm2 delete "$other_name" >/dev/null 2>&1 || true
      pkill -f "$other" >/dev/null 2>&1 || true
    fi
  done
  shopt -u nullglob
}

bot_stop_duplicates() {
  local name="$1" path="$BOTS_DIR/$name"
  # TelegramConflictError возникает, когда один и тот же токен запущен в двух процессах.
  # Перед стартом нового бота гасим старые локальные копии с таким же именем/папкой в PM2 root и PM2 hyperbot.
  pm2_as_bot stop "$name" >/dev/null 2>&1 || true
  pm2_as_bot delete "$name" >/dev/null 2>&1 || true
  if command -v pm2 >/dev/null 2>&1; then
    PM2_HOME=/root/.pm2 pm2 stop "$name" >/dev/null 2>&1 || true
    PM2_HOME=/root/.pm2 pm2 delete "$name" >/dev/null 2>&1 || true
    pm2 stop "$name" >/dev/null 2>&1 || true
    pm2 delete "$name" >/dev/null 2>&1 || true
  fi
  systemctl stop "hyperbot-$name.service" >/dev/null 2>&1 || true
  systemctl disable "hyperbot-$name.service" >/dev/null 2>&1 || true
  # Убиваем только процессы, которые запущены из папки конкретного бота.
  if [[ -d "$path" ]]; then
    pkill -f "$path/.*(bot\.py|main\.py|index\.py|\.hyper-start\.sh)" >/dev/null 2>&1 || true
  fi
}

bot_start_pm2() {
  local name="$1" runtime="$2" main_file="$3" mem="${4:-0}" path="$BOTS_DIR/$name"
  ensure_pm2
  [[ -f "$path/$main_file" ]] || err "Главный файл не найден: $path/$main_file"
  bot_stop_duplicates "$name"
  make_bot_start_script "$name" "$runtime" "$main_file" "$mem"
  local mem_arg=(); [[ "$mem" =~ ^[0-9]+$ && "$mem" -gt 0 ]] && mem_arg+=(--max-memory-restart "${mem}M")
  (cd "$path" && pm2_as_bot start ./.hyper-start.sh --name "$name" --interpreter bash "${mem_arg[@]}")
  pm2_persist
  log "PM2 started: $name (user=$BOT_USER, PM2_HOME=$PM2_HOME_DIR, autostart=systemd)"
}
normalize_main_file() {
  local runtime="$1" main_file="${2:-}"
  if [[ -z "$main_file" ]]; then
    case "$runtime" in python) main_file="bot.py";; node) main_file="index.js";; php) main_file="bot.php";; custom) main_file="start.sh";; esac
  fi
  main_file="${main_file#python3 }"; main_file="${main_file#python }"; main_file="${main_file#node }"; main_file="${main_file#php }"; basename "$main_file"
}
cmd_bot_create() {
  ensure_dirs; ensure_pm2
  local name="${1:-}" runtime="${2:-python}" main_file="${3:-}" mem="${4:-0}" proc_limit="${5:-0}"
  [[ -n "$name" ]] || err "Bot name required"; valid_name "$name" || err "Invalid bot name"; [[ "$runtime" =~ ^(python|node|php|custom)$ ]] || err "Invalid runtime"
  main_file="$(normalize_main_file "$runtime" "$main_file")"
  local path="$BOTS_DIR/$name"; mkdir -p "$path"
  [[ -f "$path/.env" ]] || echo '# BOT_TOKEN=put_token_here' > "$path/.env"
  if [[ "$runtime" == python && ! -f "$path/$main_file" ]]; then cat > "$path/$main_file" <<'PYBOT'
import time
print('HYPER-HOST bot template started', flush=True)
while True:
    time.sleep(60)
PYBOT
  fi
  if [[ "$runtime" == node && ! -f "$path/$main_file" ]]; then echo "setInterval(()=>console.log('HYPER-HOST node bot'),60000);" > "$path/$main_file"; fi
  if [[ "$runtime" == php && ! -f "$path/$main_file" ]]; then echo "<?php while(true){ echo 'HYPER-HOST php bot'.PHP_EOL; sleep(60); }" > "$path/$main_file"; fi
  chown -R "$BOT_USER":www-data "$path" 2>/dev/null || true
  fix_web_permissions "$path" "$BOT_USER"
  bot_install_deps_internal "$name" "$runtime"
  bot_start_pm2 "$name" "$runtime" "$main_file" "$mem"
  fix_web_permissions "$path" "$BOT_USER"
  log "PM2 bot created: $name / main=$main_file"
}
cmd_bot_deploy() {
  ensure_dirs; ensure_pm2
  local name="${1:-}" runtime="${2:-python}" main_file="${3:-bot.py}" bot_tmp="${4:-}" env_tmp="${5:-}" req_tmp="${6:-}" mem="${7:-0}"
  [[ -n "$name" ]] || err "Bot name required"; valid_name "$name" || err "Invalid bot name"; [[ "$runtime" =~ ^(python|node|php|custom)$ ]] || err "Invalid runtime"
  main_file="$(normalize_main_file "$runtime" "$main_file")"
  local path="$BOTS_DIR/$name"; mkdir -p "$path"
  if [[ -n "$bot_tmp" && -f "$bot_tmp" ]]; then cp "$bot_tmp" "$path/$main_file"; fi
  if [[ -n "$env_tmp" && -f "$env_tmp" ]]; then cp "$env_tmp" "$path/.env"; elif [[ ! -f "$path/.env" ]]; then echo '# BOT_TOKEN=put_token_here' > "$path/.env"; fi
  if [[ -n "$req_tmp" && -f "$req_tmp" ]]; then
    if [[ "$runtime" == "node" ]]; then cp "$req_tmp" "$path/package.json"; else cp "$req_tmp" "$path/requirements.txt"; fi
  fi
  [[ -f "$path/$main_file" ]] || err "Главный файл бота не найден: $main_file. Загрузи bot.py / index.js / bot.php."
  chown -R "$BOT_USER":www-data "$path" 2>/dev/null || true
  fix_web_permissions "$path" "$BOT_USER"
  bot_install_deps_internal "$name" "$runtime"
  bot_start_pm2 "$name" "$runtime" "$main_file" "$mem"
  fix_web_permissions "$path" "$BOT_USER"
  log "Bot deployed and started: $name / main=$main_file"
}
cmd_bot_install_requirements() { local name="${1:-}"; [[ -n "$name" ]] || err "Bot name required"; valid_name "$name" || err "Invalid bot"; local runtime="${2:-python}"; ensure_pm2; bot_install_deps_internal "$name" "$runtime"; fix_web_permissions "$BOTS_DIR/$name" "$BOT_USER"; }
cmd_bot_delete() {
  local name="${1:-}" mode="${2:---keep-files}"
  [[ -n "$name" ]] || err "Bot name required"; valid_name "$name" || err "Invalid bot"
  ensure_pm2
  pm2_as_bot stop "$name" >/dev/null 2>&1 || true
  pm2_as_bot delete "$name" >/dev/null 2>&1 || true
  pm2_persist
  if [[ "$mode" == "--delete-files" || "$mode" == "--purge" ]]; then
    local bot_path="$BOTS_DIR/$name"
    if [[ -d "$bot_path" && "$bot_path" == "$BOTS_DIR/"* ]]; then
      rm -rf --one-file-system "$bot_path"
    fi
    log "Bot deleted: $name / files removed"
  else
    log "Bot deleted from PM2 only: $name / files kept"
  fi
}
cmd_bot_action() {
  local action="${1:-}" name="${2:-}"
  [[ "$action" =~ ^(start|stop|restart|status|logs|kill-conflicts)$ ]] || err "Invalid bot action"
  [[ -n "$name" ]] || err "Bot name required"; valid_name "$name" || err "Invalid bot"
  ensure_pm2
  case "$action" in
    start|restart)
      # HYPER-HOST v24: всегда пересобираем .hyper-start.sh перед стартом,
      # чтобы старые битые start-файлы с пустым interpreter не ломали запуск.
      local bot_dir="$BOTS_DIR/$name" runtime="python" main_file=""
      [[ -d "$bot_dir" ]] || err "Папка бота не найдена: $bot_dir"
      if [[ -f "$bot_dir/bot.py" ]]; then runtime="python"; main_file="bot.py";
      elif [[ -f "$bot_dir/main.py" ]]; then runtime="python"; main_file="main.py";
      elif [[ -f "$bot_dir/index.py" ]]; then runtime="python"; main_file="index.py";
      elif [[ -f "$bot_dir/index.js" ]]; then runtime="node"; main_file="index.js";
      elif [[ -f "$bot_dir/bot.php" ]]; then runtime="php"; main_file="bot.php";
      elif [[ -f "$bot_dir/start.sh" ]]; then runtime="custom"; main_file="start.sh";
      else
        err "Не найден главный файл бота. Нужен bot.py, main.py, index.py, index.js, bot.php или start.sh в $bot_dir"
      fi
      make_bot_start_script "$name" "$runtime" "$main_file" 0
      bot_stop_duplicates "$name"
      (cd "$bot_dir" && pm2_as_bot start ./.hyper-start.sh --name "$name" --interpreter bash)
      pm2_persist
      ;;
    stop)
      pm2_as_bot stop "$name" || true
      pm2_persist
      ;;
    kill-conflicts)
      bot_stop_duplicates "$name"
      pm2_persist
      log "Local duplicate bot processes killed: $name"
      ;;
    status)
      BOTNAME="$name" pm2_as_bot jlist | BOTNAME="$name" python3 -c 'import sys,json,os; data=json.load(sys.stdin); name=os.environ.get("BOTNAME",""); print(next((p.get("pm2_env",{}).get("status","") for p in data if p.get("name")==name), "not_found"))'
      ;;
    logs)
      pm2_as_bot logs "$name" --lines 250 --nostream || true
      ;;
  esac
}
cmd_bot_list_json() {
  # v50 fix: эта команда дёргается панелью КАЖДЫЕ 4 СЕКУНДЫ для live-обновления
  # статистики ботов (RAM/CPU/uptime без перезагрузки страницы). Раньше она вызывала
  # полновесный ensure_pm2() на каждый опрос — это python3/pip3/venv/node проверки,
  # sudo su к hyperbot, "pm2 ping", "pm2 save" (запись dump-файла на диск!) и проверку
  # systemd-юнита. При таком расходе на один просто-статус-запрос реальный интервал
  # обновления мог растягиваться до многих секунд, а при таймауте (8с в PHP) —
  # обновление вообще пропускало такт. Теперь для простого чтения списка достаточно
  # проверить, что pm2 бинарь вообще есть, и сразу спросить jlist — это не пишет
  # ничего на диск и не трогает python/node/systemd.
  if ! command -v pm2 >/dev/null 2>&1; then echo '[]'; return 0; fi
  pm2_as_bot jlist 2>/dev/null | python3 -c 'import sys,json,os,time
try:
    data=json.load(sys.stdin)
except Exception:
    data=[]

def rss_from_pid(pid):
    try:
        pid=int(pid or 0)
        if pid <= 0: return 0
        with open(f"/proc/{pid}/status", encoding="utf-8", errors="ignore") as f:
            for line in f:
                if line.startswith("VmRSS:"):
                    return int(line.split()[1]) * 1024
    except Exception:
        pass
    return 0

def uptime_text(ms):
    try:
        sec=max(0, int((time.time()*1000 - int(ms or 0)) / 1000))
        d,sec=divmod(sec,86400); h,sec=divmod(sec,3600); m,_=divmod(sec,60)
        return f"{d}д {h}ч {m}м" if d else (f"{h}ч {m}м" if h else f"{m}м")
    except Exception:
        return "—"

out=[]
for p in data:
    env=p.get("pm2_env",{}) or {}
    cwd=env.get("pm_cwd","") or ""
    files=[]
    if cwd and os.path.isdir(cwd):
        for n in ("bot.py","main.py","index.py","index.js","bot.php",".env","requirements.txt","package.json",".hyper-start.sh"):
            if os.path.exists(os.path.join(cwd,n)): files.append(n)
    pid=p.get("pid") or env.get("pid") or 0
    memory=int((p.get("monit",{}) or {}).get("memory",0) or 0)
    if memory <= 0:
        memory = rss_from_pid(pid)
    cpu=float((p.get("monit",{}) or {}).get("cpu",0) or 0)
    status=env.get("status","") or "unknown"
    created=env.get("pm_uptime") or 0
    out.append({"name":p.get("name","") or "","pm_id":env.get("pm_id", p.get("pm_id", "")),"pid":pid,"status":status,"restarts":int(env.get("restart_time",0) or 0),"unstable_restarts":int(env.get("unstable_restarts",0) or 0),"memory":memory,"memory_mb":round(memory/1024/1024,1),"cpu":cpu,"cpu_percent":round(cpu,1),"cwd":cwd,"files":files,"uptime":uptime_text(created),"pm_uptime":created,"updated_at":int(time.time()),"pm2_home":os.environ.get("PM2_HOME","")})
print(json.dumps(out, ensure_ascii=False))'
}

cmd_bot_doctor() {
  ensure_pm2
  echo "=== HYPER-HOST BOT DOCTOR ==="
  echo "python: $(python3 --version 2>&1 || true)"
  echo "pip: $(pip3 --version 2>&1 || true)"
  echo "node: $(node -v 2>&1 || true)"
  echo "npm: $(npm -v 2>&1 || true)"
  echo "pm2: $(pm2 -v 2>&1 || true)"
  echo "bot_user: $BOT_USER"
  echo "bots_dir: $BOTS_DIR"
  echo "pm2_home: $PM2_HOME_DIR"
  echo "pm2_systemd: $(systemctl is-enabled hyperbot-pm2.service 2>/dev/null || echo disabled) / $(systemctl is-active hyperbot-pm2.service 2>/dev/null || echo inactive)"
  echo "pm2_dump: $PM2_HOME_DIR/dump.pm2"
  echo "--- pm2 list ---"
  pm2_as_bot list || true
}
cmd_backup_run() {
  ensure_dirs
  local target="${1:-all}" ts archive; ts="$(date +%F-%H%M%S)"; mkdir -p "$BACKUP_DIR"; archive="$BACKUP_DIR/hyper-host-${target}-${ts}.tar.gz"
  local paths=(); [[ "$target" == all || "$target" == sites ]] && paths+=("$SITES_DIR"); [[ "$target" == all || "$target" == bots ]] && paths+=("$BOTS_DIR"); [[ "$target" == all || "$target" == panel ]] && paths+=("$BASE_DIR/data" "$PANEL_DIR");
  if [[ "$target" == all || "$target" == db ]]; then
    dump="$BACKUP_DIR/mysql-${ts}.sql"; mysqldump --all-databases > "$dump" 2>/dev/null || true; paths+=("$dump")
  fi
  tar -czf "$archive" "${paths[@]}" 2>/dev/null || true
  [[ -f "${dump:-}" ]] && rm -f "$dump" || true
  log "Backup created: $archive"
}
cmd_backup_schedule() { local name="${1:-}" schedule="${2:-}" target="${3:-all}"; [[ -n "$name" && -n "$schedule" ]] || err "Name and schedule required"; valid_name "$name" || err "Invalid name"; cat > "$CRON_DIR/hyper-host-backup-$name" <<EOCRON
SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
${schedule} root /usr/local/sbin/hyper-host-ctl backup-run ${target} >/var/log/hyper-host-backup-${name}.log 2>&1
EOCRON
chmod 0644 "$CRON_DIR/hyper-host-backup-$name"; systemctl reload cron 2>/dev/null || systemctl reload crond 2>/dev/null || true; log "Backup schedule saved: $name"; }
cmd_backup_delete_schedule() { local name="${1:-}"; valid_name "$name" || err "Invalid name"; rm -f "$CRON_DIR/hyper-host-backup-$name"; log "Backup schedule deleted: $name"; }
cmd_backup_list_json() { python3 - <<PY
import os,json,glob
bd=os.environ.get('BACKUP_DIR','$BACKUP_DIR')
items=[]
for f in sorted(glob.glob(os.path.join(bd,'*.tar.gz')), key=os.path.getmtime, reverse=True)[:80]:
    st=os.stat(f); items.append({'name':os.path.basename(f),'path':f,'size':st.st_size,'mtime':st.st_mtime})
print(json.dumps(items, ensure_ascii=False))
PY
}

cmd_dns_apply() {
  local domain="${1:-}" records_json="${2:-[]}" ns="${3:-}" admin="${4:-}" ns_host="${5:-}"
  valid_domain "$domain" || err "Invalid domain"
  mkdir -p "$DNS_DIR"
  write_bind_authoritative_defaults
  [[ -n "$ns_host" ]] || ns_host="$domain"
  [[ -n "$ns" ]] || ns="ns1.$ns_host."
  [[ -n "$admin" ]] || admin="admin.$domain."
  [[ "$ns" == *. ]] || ns="$ns."
  [[ "$admin" == *. ]] || admin="$admin."
  local zonefile="$DNS_DIR/db.$domain" serial
  serial="$(date +%Y%m%d%H)"
  DOMAIN="$domain" RECORDS_JSON="$records_json" NS="$ns" ADMIN="$admin" ZONEFILE="$zonefile" SERIAL="$serial" NS_HOST="$ns_host" python3 - <<'PYDNSWRITE'
import os, json, re, ipaddress, pathlib, sys
zone=os.environ['DOMAIN'].strip('.').lower()
records_json=os.environ.get('RECORDS_JSON','[]')
ns=os.environ.get('NS') or ('ns1.%s.' % zone)
admin=os.environ.get('ADMIN') or ('admin.%s.' % zone)
ns_host=(os.environ.get('NS_HOST') or zone).strip('.').lower()
path=pathlib.Path(os.environ['ZONEFILE'])
serial=os.environ.get('SERIAL','1')
try:
    records=json.loads(records_json)
except Exception:
    records=[]
if not isinstance(records, list):
    records=[]

def fqdn(v):
    v=str(v or '').strip()
    if not v: return ''
    return v if v.endswith('.') else v+'.'

def qtxt(v):
    v=str(v or '').strip()
    if not v: return ''
    if v.startswith('"') and v.endswith('"'): return v
    return '"'+v.replace('"','\\"')+'"'

def rr_name(v):
    v=str(v or '@').strip()
    if not v or v == zone or v == zone+'.': return '@'
    if v.endswith('.'+zone) or v.endswith('.'+zone+'.'):
        v=v.replace('.'+zone+'.','').replace('.'+zone,'')
    if v.endswith('.'):
        return fqdn(v)
    if not re.match(r'^(\*\.)?[A-Za-z0-9_@.-]+$', v):
        raise SystemExit('bad DNS record name: '+v)
    return v

def rr_value(typ, value):
    value=str(value or '').strip()
    if not value: return ''
    typ=typ.upper()
    if typ == 'A':
        ipaddress.IPv4Address(value); return value
    if typ == 'AAAA':
        ipaddress.IPv6Address(value); return value
    if typ in ('CNAME','NS','PTR'):
        return fqdn(value)
    if typ == 'MX':
        parts=value.split()
        if len(parts) == 1:
            return '10 '+fqdn(parts[0])
        return parts[0]+' '+fqdn(parts[1])
    if typ == 'TXT':
        return qtxt(value)
    if typ == 'CAA':
        return value
    return value

clean=[]
seen=set()
for r in records:
    if not isinstance(r, dict):
        continue
    typ=str(r.get('type','A') or 'A').upper().strip()
    if typ not in {'A','AAAA','CNAME','MX','TXT','NS','CAA','SRV'}:
        continue
    name=rr_name(r.get('name','@'))
    try:
        ttl=int(r.get('ttl',3600) or 3600)
    except Exception:
        ttl=3600
    ttl=max(60, min(ttl, 86400))
    val=rr_value(typ, r.get('value',''))
    if not val:
        continue
    key=(name,typ,val)
    if key in seen:
        continue
    seen.add(key)
    clean.append((name, ttl, typ, val))

# Обязательные NS для делегации домена на эту панель.
# v46 fix: раньше тут всегда стояло 'ns1.%s.'%zone/'ns2.%s.'%zone — то есть КАЖДЫЙ домен
# получал свою уникальную пару NS-имён, и для каждого нового домена нужно было отдельно
# заводить glue-записи у ЕГО регистратора. Теперь используется ns_host (по умолчанию —
# домен панели), и один и тот же ns1./ns2.<домен-панели> можно прописывать у любого
# количества доменов без отдельного glue на каждый из них.
for name, ttl, typ, val in [('@',3600,'NS','ns1.%s.'%ns_host),('@',3600,'NS','ns2.%s.'%ns_host)]:
    key=(name,typ,val)
    if key not in seen:
        clean.insert(0,(name,ttl,typ,val)); seen.add(key)

with path.open('w', encoding='utf-8') as f:
    f.write('$TTL 300\n')
    f.write('@ IN SOA %s %s (%s 300 180 1209600 300)\n' % (fqdn(ns), fqdn(admin), serial))
    for name, ttl, typ, val in clean:
        f.write('%s %s IN %s %s\n' % (name, ttl, typ, val))
PYDNSWRITE
  named-checkzone "$domain" "$zonefile" >/tmp/hyper-host-named-checkzone.log 2>&1 || { cat /tmp/hyper-host-named-checkzone.log >&2; err "DNS zone is invalid: $domain"; }
  touch /etc/bind/named.conf.local
  python3 - "$domain" "$zonefile" <<'PYBINDLOCAL'
import sys,re,pathlib
zone,zonefile=sys.argv[1:]
p=pathlib.Path('/etc/bind/named.conf.local')
text=p.read_text(encoding='utf-8', errors='ignore') if p.exists() else ''
block='zone "%s" { type master; file "%s"; allow-transfer { none; }; };' % (zone, zonefile)
pat=re.compile(r'zone\s+"%s"\s*\{[^}]*\};\s*' % re.escape(zone), re.S)
if pat.search(text):
    text=pat.sub(block+'\n', text)
else:
    text=text.rstrip()+'\n'+block+'\n'
p.write_text(text, encoding='utf-8')
PYBINDLOCAL
  open_server_ports
  systemctl enable bind9 >/dev/null 2>&1 || true
  systemctl restart bind9 2>/dev/null || systemctl restart named 2>/dev/null || true
  systemctl is-active bind9 >/dev/null 2>&1 || err "bind9 не запустился после применения DNS-зоны"
  log "DNS zone applied: $domain -> $zonefile"
}

cmd_dns_delete() {
  local domain="${1:-}"
  valid_domain "$domain" || err "Invalid domain"
  rm -f "$DNS_DIR/db.$domain"
  if [[ -f /etc/bind/named.conf.local ]]; then
    python3 - "$domain" <<'PYBINDDEL'
import sys,re,pathlib
zone=sys.argv[1]
p=pathlib.Path('/etc/bind/named.conf.local')
text=p.read_text(encoding='utf-8', errors='ignore') if p.exists() else ''
text=re.sub(r'zone\s+"%s"\s*\{[^}]*\};\s*' % re.escape(zone), '', text, flags=re.S)
p.write_text(text, encoding='utf-8')
PYBINDDEL
    systemctl restart bind9 2>/dev/null || true
  fi
  log "DNS zone deleted: $domain"
}


cmd_cron_set() { local name="${1:-}" schedule="${2:-}" command="${3:-}"; [[ -n "$name" && -n "$schedule" && -n "$command" ]] || err "Name schedule command required"; valid_name "$name" || err "Invalid name"; cat > "$CRON_DIR/hyper-host-task-$name" <<EOCRON
SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
${schedule} root ${command} >/var/log/hyper-host-cron-${name}.log 2>&1
EOCRON
chmod 0644 "$CRON_DIR/hyper-host-task-$name"; systemctl reload cron 2>/dev/null || true; log "Cron task saved: $name"; }
cmd_cron_delete() { local name="${1:-}"; valid_name "$name" || err "Invalid name"; rm -f "$CRON_DIR/hyper-host-task-$name"; log "Cron task deleted: $name"; }

cmd_site_logs() { local domain="${1:-}" kind="${2:-error}" lines="${3:-200}" filter="${4:-}"; valid_domain "$domain" || err "Invalid domain"; [[ "$kind" == access || "$kind" == error ]] || kind=error; local file="$SITES_DIR/$domain/logs/$kind.log"; [[ -f "$file" ]] || { echo "Log not found: $file"; return 0; }; if [[ -n "$filter" ]]; then tail -n "$lines" "$file" | grep -i -- "$filter" || true; else tail -n "$lines" "$file" || true; fi; }

cmd_ssl_status_json() { python3 - <<'PY'
import os,glob,json,subprocess,datetime
items=[]; seen=set()
roots=[os.path.join(os.environ.get('LE_CONFIG_DIR','/opt/hyper-host/letsencrypt'),'live'), '/etc/letsencrypt/live']
for root in roots:
  for cert in glob.glob(os.path.join(root,'*','fullchain.pem')):
    real=os.path.realpath(cert)
    if real in seen: continue
    seen.add(real); domain=cert.split('/')[-2]
    try:
        out=subprocess.check_output(['openssl','x509','-in',cert,'-noout','-enddate'], text=True).strip().split('=',1)[1]
        exp=datetime.datetime.strptime(out, '%b %d %H:%M:%S %Y %Z')
        days=(exp-datetime.datetime.utcnow()).days
        items.append({'domain':domain,'expires':exp.isoformat()+'Z','days_left':days,'status':'ok' if days>14 else 'warning'})
    except Exception as e: items.append({'domain':domain,'error':str(e),'status':'error'})
print(json.dumps(items, ensure_ascii=False))
PY
}
