write_bind_authoritative_defaults() {
  mkdir -p /etc/bind/hyper-host-zones /var/cache/bind 2>/dev/null || true
  {
  cat > /etc/bind/named.conf.options <<'EOBINDOPT'
options {
    directory "/var/cache/bind";
    listen-on { any; };
    listen-on-v6 { any; };
    allow-query { any; };
    allow-recursion { none; };
    recursion no;
    dnssec-validation auto;
    auth-nxdomain no;
    minimal-responses yes;
};
EOBINDOPT
  } 2>/dev/null || warn "Не удалось записать /etc/bind/named.conf.options (read-only /etc?) — DNS-зоны могут не примениться."
  touch /etc/bind/named.conf.local 2>/dev/null || true
}


extract_ipv4() {
  printf '%s' "${1:-}" | grep -Eo '([0-9]{1,3}\.){3}[0-9]{1,3}' | head -n1 || true
}

listen_port_tcp() {
  local port="$1"
  # Надёжная проверка локального прослушивания порта. Старый awk иногда брал не ту колонку ss.
  ss -H -ltn 2>/dev/null | awk -v p=":$port" '{print $4}' | grep -Eq "(^|[:\]])${port}$|:${port}$" && return 0
  ss -H -ltn "sport = :$port" 2>/dev/null | grep -q .
}

listen_port_udp() {
  local port="$1"
  ss -H -lun 2>/dev/null | awk -v p=":$port" '{print $5}' | grep -Eq "(^|[:\]])${port}$|:${port}$" && return 0
  ss -H -lun "sport = :$port" 2>/dev/null | grep -q .
}

open_server_ports() {
  # Открываем именно firewall Ubuntu. Роутер/NAT всё равно пробрасывается отдельно.
  local tcp_ports=(21 22 53 80 443 3306)
  local p
  if command -v ufw >/dev/null 2>&1; then
    ufw allow 21/tcp >/dev/null 2>&1 || true
    ufw allow 40000:40100/tcp >/dev/null 2>&1 || true
    ufw allow 22/tcp >/dev/null 2>&1 || true
    ufw allow 53/tcp >/dev/null 2>&1 || true
    ufw allow 53/udp >/dev/null 2>&1 || true
    ufw allow 80/tcp >/dev/null 2>&1 || true
    ufw allow 443/tcp >/dev/null 2>&1 || true
    ufw allow 3306/tcp >/dev/null 2>&1 || true
  fi
  if command -v firewall-cmd >/dev/null 2>&1 && firewall-cmd --state >/dev/null 2>&1; then
    firewall-cmd --permanent --add-port=21/tcp >/dev/null 2>&1 || true
    firewall-cmd --permanent --add-port=40000-40100/tcp >/dev/null 2>&1 || true
    firewall-cmd --permanent --add-port=22/tcp >/dev/null 2>&1 || true
    firewall-cmd --permanent --add-port=53/tcp >/dev/null 2>&1 || true
    firewall-cmd --permanent --add-port=53/udp >/dev/null 2>&1 || true
    firewall-cmd --permanent --add-port=80/tcp >/dev/null 2>&1 || true
    firewall-cmd --permanent --add-port=443/tcp >/dev/null 2>&1 || true
    firewall-cmd --permanent --add-port=3306/tcp >/dev/null 2>&1 || true
    firewall-cmd --reload >/dev/null 2>&1 || true
  fi
  if command -v iptables >/dev/null 2>&1; then
    for p in "${tcp_ports[@]}"; do
      iptables -C INPUT -p tcp --dport "$p" -j ACCEPT 2>/dev/null || iptables -I INPUT -p tcp --dport "$p" -j ACCEPT 2>/dev/null || true
    done
    iptables -C INPUT -p udp --dport 53 -j ACCEPT 2>/dev/null || iptables -I INPUT -p udp --dport 53 -j ACCEPT 2>/dev/null || true
    iptables -C INPUT -p tcp --dport 40000:40100 -j ACCEPT 2>/dev/null || iptables -I INPUT -p tcp --dport 40000:40100 -j ACCEPT 2>/dev/null || true
  fi
  if command -v nft >/dev/null 2>&1; then
    nft list ruleset >/dev/null 2>&1 || true
    nft add table inet hyper_host 2>/dev/null || true
    nft 'add chain inet hyper_host input { type filter hook input priority -100; policy accept; }' 2>/dev/null || true
    nft add rule inet hyper_host input tcp dport '{ 21, 22, 53, 80, 443, 3306 }' accept 2>/dev/null || true
    nft add rule inet hyper_host input tcp dport 40000-40100 accept 2>/dev/null || true
    nft add rule inet hyper_host input udp dport 53 accept 2>/dev/null || true
  fi
}

is_private_ipv4_simple() {
  local ip="${1:-}"
  [[ "$ip" =~ ^10\. ]] && return 0
  [[ "$ip" =~ ^192\.168\. ]] && return 0
  [[ "$ip" =~ ^172\.(1[6-9]|2[0-9]|3[0-1])\. ]] && return 0
  [[ "$ip" =~ ^127\. ]] && return 0
  [[ "$ip" =~ ^169\.254\. ]] && return 0
  return 1
}

ftp_passive_address() {
  local ip
  ip="$(extract_ipv4 "$(configured_public_ip)")"
  [[ -z "$ip" ]] && ip="$(extract_ipv4 "$(public_ip)")"
  [[ -z "$ip" ]] && ip="$(extract_ipv4 "${PUBLIC_IP:-}")"
  if [[ -n "$ip" ]] && ! is_private_ipv4_simple "$ip"; then
    echo "$ip"
  fi
}


resolve_hyper_ftp_bin() {
  # Ищем FTP-сервер не только в /usr/local/sbin: если /etc или /usr/local временно read-only,
  # можно запускать прямо из репозитория после git pull.
  local b="${HYPER_FTP_BIN:-}" alt
  if [[ -n "$b" && -x "$b" ]]; then echo "$b"; return 0; fi
  for alt in \
    "$PANEL_DIR/scripts/hyper_ftp_server.py" \
    "$BASE_DIR/scripts/hyper_ftp_server.py" \
    "$BASE_DIR/panel/scripts/hyper_ftp_server.py" \
    "$(pwd)/scripts/hyper_ftp_server.py" \
    "/root/hyper-hosting-panel/scripts/hyper_ftp_server.py"; do
    if [[ -n "$alt" && -x "$alt" ]]; then echo "$alt"; return 0; fi
  done
  return 1
}

start_hyper_ftp_runtime() {
  local bin pid oldpid
  bin="$(resolve_hyper_ftp_bin)" || err "Не найден HYPER-HOST FTP server. Запусти установку из папки проекта: sudo bash install.sh"
  mkdir -p "$BASE_DIR/run" /var/log
  if [[ -f "$HYPER_FTP_PID" ]]; then
    oldpid="$(cat "$HYPER_FTP_PID" 2>/dev/null || true)"
    [[ -n "$oldpid" ]] && kill "$oldpid" >/dev/null 2>&1 || true
    rm -f "$HYPER_FTP_PID" 2>/dev/null || true
  fi
  pkill -f "hyper_ftp_server.py|hyper-host-ftp-server" >/dev/null 2>&1 || true
  nohup "$bin" --host 0.0.0.0 --port 21 --passive-min 40000 --passive-max 40100 >>/var/log/hyper-host-ftp.log 2>&1 &
  pid=$!
  echo "$pid" > "$HYPER_FTP_PID" 2>/dev/null || true
}

hyper_ftp_is_active() {
  listen_port_tcp 21 && pgrep -af "hyper_ftp_server.py|hyper-host-ftp-server" >/dev/null 2>&1
}

assert_hyper_ftp_ready() {
  local i
  for i in 1 2 3 4 5; do
    if listen_port_tcp 21; then return 0; fi
    sleep 1
  done
  tail -n 120 /var/log/hyper-host-ftp.log >&2 2>/dev/null || true
  err "FTP не поднялся на порту 21. Выполни: sudo ss -ltnp | grep ':21' && sudo tail -n 120 /var/log/hyper-host-ftp.log"
}

ensure_vsftpd_external_access() {
  # v44: используется встроенный FTP-сервер HYPER-HOST, не vsftpd.
  # Поэтому создание FTP не зависит от /etc/passwd, /etc/fstab, PAM и systemd.
  ensure_ftp_virtual_dirs
  mkdir -p "$BASE_DIR/run" "$FTP_DIR" "$FTP_USER_CONF_DIR" /var/log
  chmod 0755 "$FTP_DIR" "$FTP_USER_CONF_DIR" 2>/dev/null || true
  ftp_auth_rebuild_db || true

  resolve_hyper_ftp_bin >/dev/null || err "Не найден HYPER-HOST FTP server. Запусти: sudo bash install.sh"

  # Освобождаем 21 порт от старого vsftpd, но не считаем его отсутствие ошибкой.
  # v45 fix: раньше vsftpd только останавливался и disable'ился. Но "disable" не мешает
  # ручному "systemctl restart vsftpd" (например в старых deploy-скриптах) снова
  # поднять vsftpd на порту 21 — он начинает драться за порт с hyper-host-ftp.service
  # (у обоих Restart=always), и FileZilla то коннектится, то нет, то видит не те
  # аккаунты. "mask" полностью блокирует запуск vsftpd, пока его явно не "unmask".
  systemctl stop vsftpd >/dev/null 2>&1 || true
  systemctl disable vsftpd >/dev/null 2>&1 || true
  systemctl mask vsftpd >/dev/null 2>&1 || true

  open_server_ports

  # Если systemd доступен на запись — ставим автозапуск. Если /etc read-only — молча запускаем runtime.
  if [[ -d /etc/systemd/system && -w /etc/systemd/system ]]; then
    local bin
    bin="$(resolve_hyper_ftp_bin)" || err "Не найден HYPER-HOST FTP server"
    cat > /tmp/hyper-host-ftp.service.$$ <<EOSVC
[Unit]
Description=HYPER-HOST FTP server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
Environment=HYPER_HOST_CONF=$CONF
ExecStart=$bin --host 0.0.0.0 --port 21 --passive-min 40000 --passive-max 40100
Restart=always
RestartSec=2
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
EOSVC
    if cat /tmp/hyper-host-ftp.service.$$ > /etc/systemd/system/hyper-host-ftp.service 2>/dev/null; then
      rm -f /tmp/hyper-host-ftp.service.$$ 2>/dev/null || true
      systemctl daemon-reload >/dev/null 2>&1 || true
      systemctl enable hyper-host-ftp.service >/dev/null 2>&1 || true
      systemctl restart hyper-host-ftp.service >/dev/null 2>&1 || true
    else
      rm -f /tmp/hyper-host-ftp.service.$$ 2>/dev/null || true
      start_hyper_ftp_runtime
    fi
  else
    start_hyper_ftp_runtime
  fi

  sleep 1
  if ! listen_port_tcp 21; then
    start_hyper_ftp_runtime
  fi
  assert_hyper_ftp_ready
}


cmd_ftp_fix_all() {
  # v41: ftp fix теперь не только правит vsftpd, но и восстанавливает bind-mount'ы аккаунтов из базы панели.
  ensure_vsftpd_external_access
  local db="${BASE_DIR}/data/hyperhost.sqlite" line username password scope target
  if [[ -f "$db" ]]; then
    while IFS=$'\t' read -r username password scope target; do
      [[ -n "$username" ]] || continue
      scope="$(ftp_scope_normalize "${scope:-all}")"
      if [[ -n "$password" && ${#password} -ge 8 ]]; then
        cmd_ftp_password "$username" "$password" "$scope" "${target:-}" >/dev/null 2>&1 || warn "Не удалось восстановить FTP $username"
      else
        home="$FTP_DIR/$username"
        mkdir -p "$home"
        ftp_prepare_scope "$username" "$scope" "${target:-}" "$home" >/dev/null || warn "Не удалось восстановить mount'ы FTP $username"
      fi
    done < <(python3 - "$db" <<'PYFTPROWS'
import sqlite3, sys
path=sys.argv[1]
try:
    con=sqlite3.connect(path)
    cur=con.execute("SELECT username, COALESCE(password_plain,''), COALESCE(access_scope,'all'), COALESCE(access_target,'') FROM ftp_accounts ORDER BY id")
    for r in cur:
        print('\t'.join(str(x or '') for x in r))
except Exception:
    pass
PYFTPROWS
)
  fi
  ensure_vsftpd_external_access
  log "FTP исправлен: FileZilla, passive-порты и папки аккаунтов восстановлены"
}

cmd_ftp_doctor_json() {
  local pub listen21 local_banner lan_banner service users_count auth_fail_users ufw_status ftp21_fw pasv_fw issue hint proc port21_owner vsftpd_active outbound_ip ip_mismatch
  pub="$(ftp_passive_address)"
  listen21=0; listen_port_tcp 21 && listen21=1
  local_banner="$(timeout 3 bash -c 'head -c 120 < /dev/tcp/127.0.0.1/21' 2>/dev/null | tr -d '\\r' | head -n1 || true)"
  lan_banner=""
  [[ -n "${SERVER_IP:-}" ]] && lan_banner="$(timeout 3 bash -c "head -c 120 < /dev/tcp/${SERVER_IP}/21" 2>/dev/null | tr -d '\\r' | head -n1 || true)"
  service="$(systemctl is-active hyper-host-ftp.service 2>/dev/null || true)"
  proc="$(pgrep -af 'hyper_ftp_server.py|hyper-host-ftp-server' 2>/dev/null | head -n1 || true)"
  # v46: сравниваем настроенный публичный IP с тем, что реально видно из интернета
  # (curl ifconfig.me и т.п.). Если они не совпадают — почти наверняка сервер за CGNAT
  # (двойной NAT у провайдера) и настроенный IP снаружи вообще недостижим ни на каком
  # порту, сколько бы портов ты ни пробрасывал на своём роутере — этот IP просто не твой.
  outbound_ip="$(outbound_public_ip)"
  ip_mismatch=0
  [[ -n "$outbound_ip" && -n "$pub" && "$outbound_ip" != "$pub" ]] && ip_mismatch=1
  # v45: кто реально держит порт 21 — если это не наш процесс (например ожил vsftpd
  # после ручного "systemctl restart vsftpd"), FileZilla будет коннектиться то к
  # старому серверу, то к новому, и логины/пароли не будут совпадать.
  port21_owner="$(ss -H -ltnp 'sport = :21' 2>/dev/null | grep -oE 'users:\(\("[^"]+"' | head -n1 | sed -E 's/users:\(\("//;s/"//' || true)"
  vsftpd_active="$(systemctl is-active vsftpd 2>/dev/null || true)"
  users_count="$(awk 'NF{c++} END{print int(c/2)}' "$FTP_AUTH_TXT" 2>/dev/null || echo 0)"
  auth_fail_users="$(grep -E 'login failed user=' /var/log/hyper-host-ftp.log 2>/dev/null | tail -n 50 | sed -E 's/.*login failed user=([^ ]+).*/\1/' | sort | uniq -c | sort -rn | head -n 6 | awk '{print $2 "(" $1 ")"}' | paste -sd, - || true)"
  ufw_status="$(ufw status 2>/dev/null | head -n1 | sed 's/^Status: //' || true)"
  ftp21_fw="$(ufw status numbered 2>/dev/null | grep -E '(^| )21/tcp' | head -n1 || true)"
  pasv_fw="$(ufw status numbered 2>/dev/null | grep -E '40000:40100|40000-40100' | head -n1 || true)"
  issue=""; hint=""
  if [[ "$ip_mismatch" == 1 ]]; then
    issue="настроенный публичный IP ($pub) не совпадает с тем, что реально видно из интернета ($outbound_ip)"
    hint="Чаще всего это просто смена IP у провайдера (динамический IP) — с v47 это чинится само в течение 5 минут (cron hyper-host-ip-watch) либо сразу командой: sudo hyper network ip-fix. Если IP снова быстро откатывается на старый — уточни у провайдера, статический ли у тебя IP, и нет ли CGNAT."
  fi
  if [[ -z "$issue" && -n "$port21_owner" && "$port21_owner" != "python3" && "$vsftpd_active" == "active" ]]; then
    issue="порт 21 занят другим сервисом ($port21_owner), похоже ожил vsftpd и дерётся за порт с hyper-host-ftp"
    hint="sudo systemctl stop vsftpd; sudo systemctl mask vsftpd; sudo hyper ftp fix"
  fi
  if [[ -z "$issue" ]] && ! resolve_hyper_ftp_bin >/dev/null; then issue="не найден встроенный FTP-сервер"; hint="sudo bash install.sh"; fi
  if [[ -z "$issue" && "$listen21" != 1 ]]; then issue="порт 21 не слушается локально"; hint="sudo hyper ftp fix"; fi
  if [[ -z "$issue" && -z "$local_banner" ]]; then issue="локальный FTP banner не отвечает"; hint="sudo tail -n 120 /var/log/hyper-host-ftp.log"; fi
  if [[ -z "$issue" && "${users_count:-0}" == "0" ]]; then issue="FTP работает, но FTP-пользователей нет"; hint="Создай FTP в панели или выполни: sudo hyper ftp user LOGIN PASSWORD all"; fi
  if [[ -z "$issue" ]]; then issue="локально FTP исправен"; hint="FileZilla: FTP, plain, passive, порт 21. Для внешнего интернета пробрось TCP 21 и 40000-40100."; fi
  SERVER_IP="$SERVER_IP" PUBLIC_IP="$(public_ip)" CONFIGURED_PUBLIC_IP="$(configured_public_ip)" LISTEN21="$listen21" LOCAL_BANNER="$local_banner" LAN_BANNER="$lan_banner" SERVICE="$service" PROC="$proc" USERS_COUNT="$users_count" AUTH_FAIL_USERS="$auth_fail_users" UFW_STATUS="$ufw_status" FTP21_FW="$ftp21_fw" PASV_FW="$pasv_fw" ISSUE="$issue" HINT="$hint" PORT21_OWNER="$port21_owner" VSFTPD_ACTIVE="$vsftpd_active" OUTBOUND_IP="$outbound_ip" IP_MISMATCH="$ip_mismatch" python3 - <<'PYFTP'
import os,json
print(json.dumps({
 'server_ip': os.environ.get('SERVER_IP',''),
 'public_ip': os.environ.get('PUBLIC_IP',''),
 'configured_public_ip': os.environ.get('CONFIGURED_PUBLIC_IP',''),
 'outbound_ip': os.environ.get('OUTBOUND_IP',''),
 'ip_mismatch_cgnat_suspected': os.environ.get('IP_MISMATCH') == '1',
 'ftp_service': os.environ.get('SERVICE',''),
 'ftp_process': os.environ.get('PROC',''),
 'port21_owner': os.environ.get('PORT21_OWNER',''),
 'vsftpd_active': os.environ.get('VSFTPD_ACTIVE',''),
 'ftp_backend': 'hyper-host-ftp',
 'listen_21': os.environ.get('LISTEN21') == '1',
 'local_banner': os.environ.get('LOCAL_BANNER',''),
 'lan_banner': os.environ.get('LAN_BANNER',''),
 'passive_range': '40000-40100',
 'pasv_address': '',
 'pasv_expected': os.environ.get('PUBLIC_IP',''),
 'ftp_users': int(os.environ.get('USERS_COUNT','0') or 0),
 'recent_failed_logins': os.environ.get('AUTH_FAIL_USERS',''),
 'config_test': 'ok',
 'ufw_status': os.environ.get('UFW_STATUS',''),
 'ufw_rules': {'ftp_21': os.environ.get('FTP21_FW',''), 'passive': os.environ.get('PASV_FW','')},
 'issue': os.environ.get('ISSUE',''),
 'hint': os.environ.get('HINT',''),
}, ensure_ascii=False))
PYFTP
}

cmd_access_fix() {
  # Включает доступ к серверу с другого ПК: SSH, FTP, HTTP/HTTPS и MySQL-порт в firewall Ubuntu.
  open_server_ports
  ensure_vsftpd_external_access
  if command -v systemctl >/dev/null 2>&1; then
    systemctl enable ssh >/dev/null 2>&1 || systemctl enable sshd >/dev/null 2>&1 || true
    systemctl restart ssh >/dev/null 2>&1 || systemctl restart sshd >/dev/null 2>&1 || true
  fi
  log "External access fixed: SSH 22, FTP 21/passive 40000-40100, HTTP 80, HTTPS 443, MySQL 3306 opened on Ubuntu. На роутере пробрось нужные порты на $SERVER_IP."
}


cmd_access_doctor_json() {
  local pub cfg out server ufw ssh ftp http https mysql dns_tcp dns_udp nginx mariadb ftp_service sshsvc bind9
  server="$SERVER_IP"; cfg="$(configured_public_ip)"; pub="$(public_ip)"; out="$(outbound_public_ip)"
  ufw="$(ufw status 2>/dev/null | head -n1 | sed 's/^Status: //')"
  ssh=0; listen_port_tcp 22 && ssh=1
  ftp=0; listen_port_tcp 21 && ftp=1
  http=0; listen_port_tcp 80 && http=1
  https=0; listen_port_tcp 443 && https=1
  mysql=0; listen_port_tcp 3306 && mysql=1
  dns_tcp=0; listen_port_tcp 53 && dns_tcp=1
  dns_udp=0; listen_port_udp 53 && dns_udp=1
  nginx="$(systemctl is-active nginx 2>/dev/null || true)"
  mariadb="$(systemctl is-active mariadb 2>/dev/null || systemctl is-active mysql 2>/dev/null || true)"
  ftp_service="$(systemctl is-active hyper-host-ftp.service 2>/dev/null || true)"
  sshsvc="$(systemctl is-active ssh 2>/dev/null || systemctl is-active sshd 2>/dev/null || true)"
  bind9="$(systemctl is-active bind9 2>/dev/null || true)"
  SERVER_IP="$server" PUBLIC_IP="$pub" CONFIGURED_PUBLIC_IP="$cfg" OUTBOUND_PUBLIC_IP="$out" UFW="$ufw" SSH="$ssh" FTP="$ftp" HTTP="$http" HTTPS="$https" MYSQL="$mysql" DNS_TCP="$dns_tcp" DNS_UDP="$dns_udp" NGINX="$nginx" MARIADB="$mariadb" FTP_SERVICE="$ftp_service" SSHSVC="$sshsvc" BIND9="$bind9" python3 - <<'PYACCESS'
import os,json
server=os.environ.get('SERVER_IP','')
public=os.environ.get('PUBLIC_IP','')
ports={
 'ssh_22': os.environ.get('SSH')=='1',
 'ftp_21': os.environ.get('FTP')=='1',
 'http_80': os.environ.get('HTTP')=='1',
 'https_443': os.environ.get('HTTPS')=='1',
 'mysql_3306': os.environ.get('MYSQL')=='1',
 'dns_tcp_53': os.environ.get('DNS_TCP')=='1',
 'dns_udp_53': os.environ.get('DNS_UDP')=='1',
}
router=[]
if server:
    router=[
      {'service':'HTTP sites + SSL','rule':'TCP 80 -> %s:80' % server},
      {'service':'HTTPS sites','rule':'TCP 443 -> %s:443' % server},
      {'service':'SSH/SFTP','rule':'TCP 22 -> %s:22' % server},
      {'service':'FTP','rule':'TCP 21 -> %s:21 and TCP 40000-40100 -> %s:40000-40100' % (server, server)},
      {'service':'MySQL external','rule':'TCP 3306 -> %s:3306' % server},
      {'service':'Own DNS','rule':'TCP/UDP 53 -> %s:53' % server},
    ]
missing=[]
for key, ok in ports.items():
    if not ok: missing.append(key)
print(json.dumps({
  'server_ip': server,
  'public_ip': public,
  'configured_public_ip': os.environ.get('CONFIGURED_PUBLIC_IP',''),
  'outbound_public_ip': os.environ.get('OUTBOUND_PUBLIC_IP',''),
  'ufw_status': os.environ.get('UFW',''),
  'services': {'nginx':os.environ.get('NGINX',''), 'mariadb':os.environ.get('MARIADB',''), 'ftp':os.environ.get('FTP_SERVICE',''), 'ssh':os.environ.get('SSHSVC',''), 'bind9':os.environ.get('BIND9','')},
  'listen_ports': ports,
  'missing_server_ports': missing,
  'router_forwarding_needed': router,
  'ok_for_lan': bool(ports['http_80'] and ports['ssh_22']),
  'note': 'Ubuntu firewall чинится командой sudo hyper access fix. Роутер нужно пробросить вручную на внутренний IP сервера.'
}, ensure_ascii=False))
PYACCESS
}

cmd_access_guide() {
  local pub; pub="$(configured_public_ip)"; [[ -z "$pub" || "$pub" == "_" ]] && pub="$(public_ip)"
  cat <<EOACCESS
HYPER-HOST: подключение к серверу с любого ПК/интернета

Схема:
  сервер Ubuntu внутри сети: ${SERVER_IP}
  публичный IP роутера:      ${pub}

1) На сервере включить доступ:
   sudo hyper access fix
   sudo hyper access doctor

2) На роутере Keenetic: Сетевые правила -> Переадресация портов.
   Создай правила:
   TCP 80          -> ${SERVER_IP}:80        сайты и выпуск SSL
   TCP 443         -> ${SERVER_IP}:443       HTTPS
   TCP 22          -> ${SERVER_IP}:22        SSH/SFTP с другого ПК
   TCP 21          -> ${SERVER_IP}:21        FTP
   TCP 40000-40100 -> ${SERVER_IP}:40000-40100 passive FTP
   TCP 3306        -> ${SERVER_IP}:3306      MySQL извне, если нужно
   TCP/UDP 53      -> ${SERVER_IP}:53        свои NS/DNS, если переносишь домены

3) Как подключаться:
   Из домашней сети:
     панель:  http://${SERVER_IP}/ или https://${SERVER_IP}/
     SSH:     ssh root@${SERVER_IP}
     FTP:     host=${SERVER_IP}, port=21
     MySQL:   host=${SERVER_IP}, port=3306

   Из интернета:
     панель:  https://panel.hyper-host.pw или http://${pub}/
     SSH:     ssh root@${pub}
     FTP:     host=${pub}, port=21
     MySQL:   host=panel.hyper-host.pw или ${pub}, port=3306

4) Важно:
   Если из Wi-Fi не открывается внешний IP ${pub}, а с мобильного интернета открывается — это NAT Loopback.
   Для домашнего ПК можно прописать hosts:
     ${SERVER_IP} panel.hyper-host.pw
     ${SERVER_IP} hyper-host.pw

5) Проверка:
   sudo hyper network doctor hyper-host.pw
   sudo hyper ssl check hyper-host.pw
   sudo ss -lntp | grep -E ':22|:80|:443|:3306|:21'
EOACCESS
}

cmd_disk_doctor_json() {
  python3 - <<'PYDISK'
import json, subprocess, shutil, os

def sh(cmd):
    try:
        return subprocess.check_output(cmd, shell=True, text=True, stderr=subprocess.DEVNULL).strip()
    except Exception:
        return ''

def hb(n):
    try: n=float(n)
    except Exception: n=0
    for u in ['B','KB','MB','GB','TB']:
        if n < 1024 or u == 'TB': return f'{n:.1f} {u}' if u!='B' else f'{n:.0f} {u}'
        n/=1024

def real(path):
    try: return os.path.realpath(path)
    except Exception: return path

usage=shutil.disk_usage('/')
root_source=sh('findmnt -n -o SOURCE /')
root_fstype=sh('findmnt -n -o FSTYPE /')
root_realpath=real(root_source)
lsblk=sh('lsblk -b -o NAME,SIZE,TYPE,FSTYPE,MOUNTPOINTS')
lvs=sh('lvs --noheadings --units b --nosuffix -o lv_path,vg_name,lv_size 2>/dev/null')
pvs=sh('pvs --noheadings --units b --nosuffix -o pv_name,vg_name,pv_size,pv_free 2>/dev/null')
vgs=sh('vgs --noheadings --units b --nosuffix -o vg_name,vg_size,vg_free 2>/dev/null')
root_lv=''
vg=''
lv_size=''
for line in lvs.splitlines():
    parts=line.split()
    if len(parts) < 3:
        continue
    lv_path, vg_name, size = parts[0], parts[1], parts[2]
    lv_real=real(lv_path)
    if lv_path == root_source or lv_real == root_realpath or os.path.basename(lv_path) == os.path.basename(root_source):
        root_lv=lv_path
        vg=vg_name
        lv_size=size
        break
# fallback for Ubuntu mapper naming: /dev/mapper/ubuntu--vg-ubuntu--lv -> VG ubuntu-vg
if not vg and root_source.startswith('/dev/mapper/'):
    encoded=os.path.basename(root_source)
    # lvs raw knows the actual lv path; compare by realpath first, then derive if possible
    for line in lvs.splitlines():
        parts=line.split()
        if len(parts) >= 3 and real(parts[0]) == root_realpath:
            root_lv, vg, lv_size = parts[0], parts[1], parts[2]
            break
pv_candidates=[]
vg_free=0
vg_size=0
if vg:
    for line in vgs.splitlines():
        parts=line.split()
        if len(parts)>=3 and parts[0]==vg:
            vg_size=float(parts[1]); vg_free=float(parts[2])
    for line in pvs.splitlines():
        parts=line.split()
        if len(parts)>=4 and parts[1]==vg:
            pv_candidates.append({'pv':parts[0], 'vg':parts[1], 'size_bytes':float(parts[2]), 'free_bytes':float(parts[3]), 'size':hb(parts[2]), 'free':hb(parts[3])})
can_lvm=bool(vg and root_lv)
print(json.dumps({
  'root_source': root_source,
  'root_realpath': root_realpath,
  'root_lv_path': root_lv,
  'root_fstype': root_fstype,
  'root_total_bytes': usage.total,
  'root_used_bytes': usage.used,
  'root_free_bytes': usage.free,
  'root_total': hb(usage.total),
  'root_used': hb(usage.used),
  'root_free': hb(usage.free),
  'root_used_percent': round(usage.used*100/usage.total,2) if usage.total else 0,
  'lvm_detected': can_lvm,
  'root_vg': vg,
  'vg_size_bytes': vg_size,
  'vg_free_bytes': vg_free,
  'vg_size': hb(vg_size),
  'vg_free': hb(vg_free),
  'pv_candidates': pv_candidates,
  'vgs_raw': vgs,
  'lvs_raw': lvs,
  'pvs_raw': pvs,
  'lsblk_raw': lsblk,
  'recommended_command': 'sudo hyper disk expand' if can_lvm else 'Нужна ручная проверка: lsblk; pvs; vgs; lvs',
}, ensure_ascii=False))
PYDISK
}

cmd_disk_expand() {
  [[ "${EUID}" -eq 0 ]] || err "Запусти: sudo hyper disk expand"
  if ! command -v pvresize >/dev/null 2>&1; then
    apt-get update
    apt-get install -y lvm2
  fi

  local root_src root_real lv_path vg pv vg_free
  root_src="$(findmnt -n -o SOURCE /)"
  root_real="$(readlink -f "$root_src" 2>/dev/null || echo "$root_src")"

  lv_path=""
  vg=""
  while read -r lp vgname; do
    [[ -z "$lp" || -z "$vgname" ]] && continue
    if [[ "$lp" == "$root_src" || "$(readlink -f "$lp" 2>/dev/null || echo "$lp")" == "$root_real" ]]; then
      lv_path="$lp"
      vg="$vgname"
      break
    fi
  done < <(lvs --noheadings -o lv_path,vg_name 2>/dev/null | awk '{print $1" "$2}')

  # fallback: try direct lvs on the original mapper path before failing
  if [[ -z "$vg" ]]; then
    vg="$(lvs --noheadings -o vg_name "$root_src" 2>/dev/null | head -n1 | xargs || true)"
    lv_path="$root_src"
  fi
  if [[ -z "$vg" ]]; then
    vg="$(lvs --noheadings -o vg_name "$root_real" 2>/dev/null | head -n1 | xargs || true)"
    lv_path="$root_real"
  fi
  [[ -n "$vg" ]] || err "Root раздел не похож на LVM. Пришли вывод: lsblk; pvs; vgs; lvs"

  pv="$(pvs --noheadings -o pv_name --select "vg_name=$vg" 2>/dev/null | head -n1 | xargs || true)"
  [[ -n "$pv" ]] || err "Не нашёл physical volume для VG=$vg. Пришли вывод: pvs; vgs; lvs"

  vg_free="$(vgs --noheadings --units g --nosuffix -o vg_free "$vg" 2>/dev/null | head -n1 | xargs || echo 0)"

  echo "[HYPER-HOST] Root source: $root_src"
  echo "[HYPER-HOST] Root real:   $root_real"
  echo "[HYPER-HOST] Root LV:     $lv_path"
  echo "[HYPER-HOST] VG:          $vg"
  echo "[HYPER-HOST] PV:          $pv"
  echo "[HYPER-HOST] VG free:     ${vg_free}G"
  echo
  echo "[HYPER-HOST] Расширяю PV до размера диска..."
  pvresize "$pv"
  echo
  echo "[HYPER-HOST] Расширяю root LV на всё свободное место..."
  lvextend -r -l +100%FREE "$lv_path"
  echo
  echo "[HYPER-HOST] Готово. Новый размер root:"
  df -hT /
  echo
  lsblk
}

cmd_disk_guide() {
  cat <<'EODISKGUIDE'
HYPER-HOST: расширение диска Ubuntu/LVM

У тебя диск физически примерно 1ТБ, а root показывает около 98ГБ — это типичная ситуация после установки Ubuntu с LVM: диск большой, но logical volume root не расширен.

Проверка:
  sudo hyper disk doctor
  lsblk
  df -hT /
  sudo pvs
  sudo vgs
  sudo lvs

Автоматическое расширение на весь свободный объём:
  sudo hyper disk expand

Ручной вариант для твоей типовой схемы /dev/sda3 -> ubuntu-vg -> ubuntu-lv:
  sudo apt update
  sudo apt install -y lvm2
  sudo pvresize /dev/sda3
  sudo lvextend -r -l +100%FREE /dev/mapper/ubuntu--vg-ubuntu--lv
  df -hT /
  lsblk

Если команда выдаст ошибку — не повторяй вслепую, пришли вывод:
  lsblk
  sudo pvs
  sudo vgs
  sudo lvs
EODISKGUIDE
}

ensure_nginx_public_listen() {
  systemctl enable nginx >/dev/null 2>&1 || true
  nginx_force_listen_all
  nginx -t >/dev/null 2>&1 || nginx -t
  systemctl restart nginx 2>/dev/null || systemctl reload nginx 2>/dev/null || true
}

nginx_force_listen_all() {
  # HYPER-HOST не должен биндиться на 90.x.x.x, если сервер за роутером.
  # Внешний IP находится на роутере, а nginx на Ubuntu должен слушать 0.0.0.0:80/443.
  local conf
  shopt -s nullglob
  for conf in /etc/nginx/sites-available/hyper-host-*.conf; do
    python3 - "$conf" <<'PYNGINXALL'
import sys,re,pathlib
p=pathlib.Path(sys.argv[1])
text=p.read_text(encoding='utf-8', errors='ignore')
text=re.sub(r'listen\s+\d+\.\d+\.\d+\.\d+:80\s*;', 'listen 80;', text)
text=re.sub(r'listen\s+\d+\.\d+\.\d+\.\d+:443\s+ssl([^;]*);', r'listen 443 ssl\1;', text)
text=re.sub(r'listen\s+\d+\.\d+\.\d+\.\d+:443\s*;', 'listen 443 ssl;', text)
p.write_text(text, encoding='utf-8')
PYNGINXALL
  done
  shopt -u nullglob
}

cmd_network_fix() {
  local domain="${1:-}" pub="${2:-}" zonefile=""
  pub="$(extract_ipv4 "$pub")"
  [[ -n "$pub" ]] || pub="$(extract_ipv4 "$(configured_public_ip)")"
  [[ -n "$pub" ]] || pub="$(extract_ipv4 "$(choose_ssl_expected_ip "${domain:-example.com}")")"
  [[ -n "$pub" ]] || err "Не смог определить публичный IP. Используй: sudo hyper network fix DOMAIN 90.189.208.25"
  [[ -z "$domain" || "$domain" == "_" ]] || valid_domain "$domain" || err "Invalid domain: $domain"

  cmd_public_ip set "$pub" >/dev/null 2>&1 || true
  open_server_ports
  ensure_vsftpd_external_access
  ensure_acme_locations_all
  ensure_nginx_public_listen

  if [[ -n "$domain" && "$domain" != "_" ]]; then
    local root; root="$(site_root_for_domain "$domain")"
    ensure_acme_location_for_domain "$domain" "$root"
    # Если домен уже обслуживается нашим bind9, принудительно обновляем зону на публичный IP.
    zonefile="$DNS_DIR/db.$domain"
    if [[ -f "$zonefile" ]] || grep -Fq "zone \"$domain\"" /etc/bind/named.conf.local 2>/dev/null; then
      cmd_dns_wizard "$domain" "$pub" panel >/dev/null 2>&1 || true
    fi
  fi

  write_bind_authoritative_defaults
  systemctl enable bind9 >/dev/null 2>&1 || true
  systemctl restart bind9 2>/dev/null || true
  nginx -t >/dev/null && systemctl reload nginx || nginx -t
  log "Network fixed: nginx=0.0.0.0, server ports 80/443/53 opened, public_ip=$pub"
  echo "OK: серверная часть открыта. Если с телефона всё равно не грузит — на роутере пробрось TCP 80/443 -> $SERVER_IP и проверь, что у домена A=$pub."
}

cmd_network_doctor_json() {
  local domain="${1:-}" pub cfg out server nginx_ok bind_ok ufw_status l80 l443 l53 dns_a dns_a_local dns_status local_http local_acme root problem hint
  server="$SERVER_IP"; cfg="$(configured_public_ip)"; pub="$(public_ip)"; out="$(outbound_public_ip)"
  nginx_ok=0; nginx -t >/dev/null 2>&1 && nginx_ok=1
  bind_ok=0; systemctl is-active bind9 >/dev/null 2>&1 && bind_ok=1
  ufw_status="$(ufw status 2>/dev/null | head -n1 | sed 's/^Status: //')"
  l80=0; listen_port_tcp 80 && l80=1
  l443=0; listen_port_tcp 443 && l443=1
  l53=0; listen_port_udp 53 && l53=1
  dns_a=""; dns_a_local=""; dns_status="not_checked"; local_http=0; local_acme=0; problem=""; hint=""
  if [[ -n "$domain" ]]; then
    valid_domain "$domain" || err "Invalid domain"
    dns_a="$(resolve_domain_a_public "$domain")"
    dns_a_local="$(resolve_domain_a_local "$domain")"
    dns_status="bad"
    if [[ -z "$dns_a" ]]; then
      dns_status="missing"
      problem="Публичная DNS A-запись не найдена. У регистратора/в DNS должно быть: A $domain $pub"
    elif printf '%s\n' "$dns_a" | grep -qxF "$pub"; then
      dns_status="ok"
    else
      problem="Публичная DNS A-запись смотрит не туда. Сейчас: ${dns_a//$'\n'/, }. Нужно: $pub"
    fi
    curl -fsS --connect-timeout 1 --max-time 2 -H "Host: $domain" "http://127.0.0.1/" >/dev/null 2>&1 && local_http=1 || true
    root="$(site_root_for_domain "$domain")"
    local_http_challenge_check "$domain" "$root" && local_acme=1 || true
    if [[ "$l80" != 1 || "$l443" != 1 ]]; then problem="На Ubuntu nginx не слушает 80/443. Выполни отдельной строкой: sudo hyper network fix $domain $pub"; fi
    if [[ "$local_acme" != 1 ]]; then problem="Локально не проходит ACME challenge. Выполни отдельной строкой: sudo hyper ssl fix $domain"; fi
  fi
  if [[ -n "$server" ]] && is_private_ipv4 "$server"; then
    hint="Сервер за роутером/NAT. На Ubuntu порты открывает sudo hyper network fix, а на роутере вручную пробрось TCP 80/443 на $server. Если из Wi‑Fi внешний IP не открывается — это NAT Loopback, проверяй через мобильный интернет."
  fi
  DOMAIN="$domain" SERVER_IP="$server" PUBLIC_IP="$pub" CONFIGURED_PUBLIC_IP="$cfg" OUTBOUND_PUBLIC_IP="$out" DNS_A="$dns_a" DNS_A_LOCAL="$dns_a_local" DNS_STATUS="$dns_status" NGINX_OK="$nginx_ok" BIND_OK="$bind_ok" UFW_STATUS="$ufw_status" L80="$l80" L443="$l443" L53="$l53" LOCAL_HTTP="$local_http" LOCAL_ACME="$local_acme" PROBLEM="$problem" HINT="$hint" python3 - <<'PYNET'
import os,json
lines=lambda x:[i for i in x.splitlines() if i.strip()]
print(json.dumps({
 'domain': os.environ.get('DOMAIN',''),
 'server_ip': os.environ.get('SERVER_IP',''),
 'public_ip': os.environ.get('PUBLIC_IP',''),
 'configured_public_ip': os.environ.get('CONFIGURED_PUBLIC_IP',''),
 'outbound_public_ip': os.environ.get('OUTBOUND_PUBLIC_IP',''),
 'nat_mode': os.environ.get('SERVER_IP','').startswith(('192.168.','10.','172.16.','172.17.','172.18.','172.19.','172.20.','172.21.','172.22.','172.23.','172.24.','172.25.','172.26.','172.27.','172.28.','172.29.','172.30.','172.31.')),
 'dns_a': lines(os.environ.get('DNS_A','')),
 'dns_a_local': lines(os.environ.get('DNS_A_LOCAL','')),
 'dns_status': os.environ.get('DNS_STATUS',''),
 'nginx_ok': os.environ.get('NGINX_OK') == '1',
 'bind9_ok': os.environ.get('BIND_OK') == '1',
 'ufw_status': os.environ.get('UFW_STATUS',''),
 'listen_80': os.environ.get('L80') == '1',
 'listen_443': os.environ.get('L443') == '1',
 'listen_dns_53': os.environ.get('L53') == '1',
 'local_http_ok': os.environ.get('LOCAL_HTTP') == '1',
 'local_acme_ok': os.environ.get('LOCAL_ACME') == '1',
 'server_ports_ok': os.environ.get('L80') == '1' and os.environ.get('L443') == '1',
 'dns_ready': os.environ.get('DNS_STATUS','') == 'ok',
 'problem': os.environ.get('PROBLEM',''),
 'hint': os.environ.get('HINT',''),
}, ensure_ascii=False))
PYNET
}
ensure_panel_ns_zone() {
  # v46: единая точка входа для "своих" NS-серверов панели. Если у панели настроен
  # PANEL_DOMAIN (Настройки -> Домен панели), заводим для НЕГО собственную зону с
  # ns1.<домен-панели> / ns2.<домен-панели> (если такой зоны ещё нет). Это единственный
  # домен, которому нужен отдельный glue у регистратора — все остальные домены дальше
  # используют эти же ns1/ns2, без повторной настройки glue на каждый домен.
  local pub="${1:-}"
  [[ -n "${PANEL_DOMAIN:-}" && "${PANEL_DOMAIN:-_}" != "_" ]] || return 0
  valid_domain "$PANEL_DOMAIN" || return 0
  [[ -n "$pub" ]] || pub="$(extract_ipv4 "$(configured_public_ip)")"
  [[ -n "$pub" ]] || return 0
  local zonefile="$DNS_DIR/db.$PANEL_DOMAIN"
  if [[ -f "$zonefile" ]] && grep -qi '^ns1[[:space:]].*IN[[:space:]]*A' "$zonefile" 2>/dev/null; then
    return 0
  fi
  mkdir -p "$DNS_DIR"
  write_bind_authoritative_defaults
  local records
  records="$(PUB="$pub" python3 - <<'PYREC'
import json, os
pub=os.environ['PUB']
print(json.dumps([
 {'name':'@','type':'A','value':pub,'ttl':300},
 {'name':'www','type':'A','value':pub,'ttl':300},
 {'name':'ns1','type':'A','value':pub,'ttl':300},
 {'name':'ns2','type':'A','value':pub,'ttl':300},
], ensure_ascii=False))
PYREC
)"
  cmd_dns_apply "$PANEL_DOMAIN" "$records" "ns1.$PANEL_DOMAIN." "admin.$PANEL_DOMAIN." "$PANEL_DOMAIN"
  log "Базовая зона панели создана: $PANEL_DOMAIN (ns1/ns2.$PANEL_DOMAIN -> $pub)"
}

cmd_dns_wizard() {
  local domain="${1:-}" pub="${2:-}" panel_sub="${3:-panel}" ns_mode="${4:-auto}"
  [[ -n "$domain" ]] || err "Domain required"
  valid_domain "$domain" || err "Invalid domain: $domain"
  [[ -n "$pub" ]] || pub="$(extract_ipv4 "$(configured_public_ip)")"
  [[ -n "$pub" ]] || pub="$(extract_ipv4 "$(public_ip)")"
  [[ "$pub" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]] || err "Invalid public IPv4: $pub"
  [[ "$panel_sub" =~ ^[A-Za-z0-9][A-Za-z0-9-]{0,61}$ ]] || panel_sub="panel"
  cmd_public_ip set "$pub" >/dev/null 2>&1 || true
  mkdir -p "$DNS_DIR"
  write_bind_authoritative_defaults

  # v46: по умолчанию используем ОБЩИЕ NS панели (ns1/ns2.<домен-панели>) для любого нового
  # домена — раньше каждый домен получал свою пару ns1.<домен>/ns2.<домен>, что требовало
  # отдельной настройки glue-записей у регистратора КАЖДОГО домена. ns_mode=own сохраняет
  # старое поведение (например для самого домена панели).
  local ns_host="$domain"
  if [[ "$ns_mode" != "own" && -n "${PANEL_DOMAIN:-}" && "${PANEL_DOMAIN:-_}" != "_" && "$PANEL_DOMAIN" != "$domain" ]]; then
    ns_host="$PANEL_DOMAIN"
    ensure_panel_ns_zone "$pub"
  fi

  local ns1="ns1.$ns_host." admin="admin.$domain." records
  records="$(DOMAIN="$domain" PUB="$pub" PANEL_SUB="$panel_sub" python3 - <<'PYREC'
import json, os
pub=os.environ['PUB']; panel=os.environ.get('PANEL_SUB','panel') or 'panel'
records=[
 {'name':'@','type':'A','value':pub,'ttl':300},
 {'name':'www','type':'A','value':pub,'ttl':300},
 {'name':panel,'type':'A','value':pub,'ttl':300},
 {'name':'ns1','type':'A','value':pub,'ttl':300},
 {'name':'ns2','type':'A','value':pub,'ttl':300},
 {'name':'mail','type':'A','value':pub,'ttl':3600},
 {'name':'@','type':'MX','value':'10 mail.%s.' % os.environ['DOMAIN'], 'ttl':3600},
 {'name':'@','type':'TXT','value':'v=spf1 a mx ip4:%s ~all' % pub,'ttl':3600},
]
print(json.dumps(records, ensure_ascii=False))
PYREC
)"
  cmd_dns_apply "$domain" "$records" "$ns1" "$admin" "$ns_host"
  open_server_ports
  systemctl restart bind9 2>/dev/null || true
  cat <<EOF
DNS зона готова: $domain
NS: ns1.$ns_host / ns2.$ns_host
Glue: ns1.$ns_host -> $pub, ns2.$ns_host -> $pub
Проверка: dig @$pub $domain A
EOF
}


cmd_dns_status_json() {
  local domain="${1:-}" pub zonefile a_local a_public bind_ok named_ok udp53 tcp53 ns_local serial problem
  [[ -n "$domain" ]] || err "Domain required"
  valid_domain "$domain" || err "Invalid domain"
  pub="$(extract_ipv4 "$(configured_public_ip)")"
  [[ -z "$pub" ]] && pub="$(extract_ipv4 "$(public_ip)")"
  zonefile="$DNS_DIR/db.$domain"
  bind_ok=0; systemctl is-active bind9 >/dev/null 2>&1 && bind_ok=1
  named_ok=0; [[ -f "$zonefile" ]] && named-checkzone "$domain" "$zonefile" >/dev/null 2>&1 && named_ok=1
  udp53=0; listen_port_udp 53 && udp53=1
  tcp53=0; listen_port_tcp 53 && tcp53=1
  a_local="$(dig +short @127.0.0.1 "$domain" A 2>/dev/null | sed '/^$/d' | sort -u || true)"
  ns_local="$(dig +short @127.0.0.1 "$domain" NS 2>/dev/null | sed '/^$/d' | sort -u || true)"
  a_public="$(resolve_domain_a_public "$domain")"
  serial="$(awk '/SOA/ {getline; print $1; exit}' "$zonefile" 2>/dev/null || true)"
  problem=""
  [[ "$bind_ok" == 1 ]] || problem="bind9 не запущен"
  [[ "$named_ok" == 1 ]] || problem="zone-файл не прошёл named-checkzone"
  [[ "$udp53" == 1 && "$tcp53" == 1 ]] || problem="порт 53 TCP/UDP не слушает"
  DOMAIN="$domain" PUBLIC_IP="$pub" ZONEFILE="$zonefile" BIND_OK="$bind_ok" NAMED_OK="$named_ok" UDP53="$udp53" TCP53="$tcp53" A_LOCAL="$a_local" A_PUBLIC="$a_public" NS_LOCAL="$ns_local" SERIAL="$serial" PROBLEM="$problem" python3 - <<'PYDNS'
import os,json
lines=lambda x:[i for i in x.splitlines() if i.strip()]
domain=os.environ['DOMAIN']
public_ip=os.environ.get('PUBLIC_IP','')
local_a=lines(os.environ.get('A_LOCAL',''))
public_a=lines(os.environ.get('A_PUBLIC',''))
ns_local=lines(os.environ.get('NS_LOCAL',''))
print(json.dumps({
 'domain': domain,
 'public_ip': public_ip,
 'zonefile': os.environ.get('ZONEFILE',''),
 'zone_exists': os.path.exists(os.environ.get('ZONEFILE','')),
 'bind9_ok': os.environ.get('BIND_OK')=='1',
 'zone_ok': os.environ.get('NAMED_OK')=='1',
 'listen_53_udp': os.environ.get('UDP53')=='1',
 'listen_53_tcp': os.environ.get('TCP53')=='1',
 'local_a': local_a,
 'local_ns': ns_local,
 'public_a': public_a,
 'serial': os.environ.get('SERIAL',''),
 'registrar_ns_required': ['ns1.'+domain, 'ns2.'+domain],
 'glue_required': {'ns1.'+domain: public_ip, 'ns2.'+domain: public_ip},
 'ready_on_server': os.environ.get('BIND_OK')=='1' and os.environ.get('NAMED_OK')=='1' and os.environ.get('UDP53')=='1' and os.environ.get('TCP53')=='1',
 'delegated_publicly': bool(public_ip and public_ip in public_a),
 'problem': os.environ.get('PROBLEM',''),
}, ensure_ascii=False))
PYDNS
}

cmd_dns_inspect_json() {
  local domain="${1:-}" pub raw public_ns public_a public_aaaa public_mx public_txt public_cname soa ptr
  [[ -n "$domain" ]] || err "Domain required"
  valid_domain "$domain" || err "Invalid domain"
  pub="$(extract_ipv4 "$(configured_public_ip)")"
  [[ -z "$pub" ]] && pub="$(extract_ipv4 "$(public_ip)")"
  command -v whois >/dev/null 2>&1 || apt-get install -y whois >/dev/null 2>&1 || true
  raw="$(timeout 12 whois "$domain" 2>/dev/null | tr -d '\r' | head -c 24000 || true)"
  public_ns="$(dig +time=2 +tries=1 +short NS "$domain" 2>/dev/null | sed 's/\.$//' | sort -u || true)"
  public_a="$(resolve_domain_a_public "$domain")"
  public_aaaa="$(for ns in 1.1.1.1 8.8.8.8 9.9.9.9; do dig +time=2 +tries=1 +short @"$ns" AAAA "$domain" 2>/dev/null; done | sed '/^$/d' | sort -u || true)"
  public_mx="$(dig +time=2 +tries=1 +short MX "$domain" 2>/dev/null | sort -u || true)"
  public_txt="$(dig +time=2 +tries=1 +short TXT "$domain" 2>/dev/null | head -n 8 || true)"
  public_cname="$(dig +time=2 +tries=1 +short CNAME "$domain" 2>/dev/null | sed 's/\.$//' | sort -u || true)"
  soa="$(dig +time=2 +tries=1 +short SOA "$domain" 2>/dev/null | head -n1 || true)"
  ptr=""
  if [[ -n "$public_a" ]]; then
    local first_ip; first_ip="$(printf '%s\n' "$public_a" | head -n1)"
    ptr="$(dig +time=2 +tries=1 +short -x "$first_ip" 2>/dev/null | sed 's/\.$//' | head -n1 || true)"
  fi
  DOMAIN="$domain" PUBLIC_IP="$pub" WHOIS_RAW="$raw" PUBLIC_NS="$public_ns" PUBLIC_A="$public_a" PUBLIC_AAAA="$public_aaaa" PUBLIC_MX="$public_mx" PUBLIC_TXT="$public_txt" PUBLIC_CNAME="$public_cname" SOA="$soa" PTR="$ptr" python3 - <<'PYINSPECT'
import os,json,re
raw=os.environ.get('WHOIS_RAW','')
domain=os.environ.get('DOMAIN','')
public_ip=os.environ.get('PUBLIC_IP','')
def lines(v): return [x.strip().rstrip('.') for x in (v or '').splitlines() if x.strip()]
def first(keys):
    for line in raw.splitlines():
        l=line.strip()
        for k in keys:
            if l.lower().startswith(k.lower()+':'):
                return l.split(':',1)[1].strip()
    return ''
registrar=first(['Registrar','Sponsoring Registrar','Registrar Name'])
whois_server=first(['Registrar WHOIS Server','Whois Server'])
creation=first(['Creation Date','Created On','Created'])
updated=first(['Updated Date','Updated On','Last Updated On'])
expiry=first(['Registry Expiry Date','Expiration Date','Expiry Date','Registrar Registration Expiration Date','paid-till'])
ns=lines(os.environ.get('PUBLIC_NS',''))
a=lines(os.environ.get('PUBLIC_A',''))
aaaa=lines(os.environ.get('PUBLIC_AAAA',''))
mx=lines(os.environ.get('PUBLIC_MX',''))
txt=lines(os.environ.get('PUBLIC_TXT',''))
cname=lines(os.environ.get('PUBLIC_CNAME',''))
soa=os.environ.get('SOA','').strip()
ptr=os.environ.get('PTR','').strip()
required=['ns1.'+domain, 'ns2.'+domain]
ns_low={x.lower().rstrip('.') for x in ns}
if all(x.lower() in ns_low for x in required):
    delegation='on_hyper_host'; label='NS уже указывают на HYPER-HOST'
elif ns:
    delegation='external_ns'; label='NS пока у другого провайдера'
else:
    delegation='no_ns'; label='NS не найдены'
# Hosting guess: current panel IP wins, then PTR/NS/SOA hints.
hints=' '.join(ns+[soa,ptr]).lower()
if public_ip and public_ip in a:
    hosting='HYPER-HOST / этот сервер'
elif ptr:
    hosting=ptr
elif 'cloudflare' in hints:
    hosting='Cloudflare DNS/proxy'
elif 'beget' in hints:
    hosting='Beget'
elif 'timeweb' in hints:
    hosting='Timeweb'
elif 'reg.ru' in hints or 'reg.ru' in raw.lower():
    hosting='REG.RU'
elif ns:
    hosting=', '.join(ns[:2])
else:
    hosting=''
print(json.dumps({
 'domain':domain,
 'registrar':registrar,
 'whois_server':whois_server,
 'creation_date':creation,
 'updated_date':updated,
 'expiry_date':expiry,
 'public_ns':ns,
 'public_a':a,
 'public_aaaa':aaaa,
 'public_mx':mx,
 'public_txt':txt,
 'public_cname':cname,
 'soa':soa,
 'ptr':ptr,
 'hosting_guess':hosting,
 'panel_public_ip':public_ip,
 'required_ns':required,
 'glue_required':{'ns1.'+domain:public_ip,'ns2.'+domain:public_ip},
 'delegation_status':delegation,
 'delegation_label':label,
}, ensure_ascii=False))
PYINSPECT
}


cmd_panel_domain() {
  local action="${1:-get}" domain="${2:-}"
  case "$action" in
    get) echo "$PANEL_DOMAIN" ;;
    set|bind)
      [[ -n "$domain" ]] || err "Domain required"
      valid_domain "$domain" || err "Invalid domain"
      mkdir -p /etc/hyper-host
      if [[ -f "$CONF" ]]; then
        if grep -q '^PANEL_DOMAIN=' "$CONF"; then sed -i "s#^PANEL_DOMAIN=.*#PANEL_DOMAIN="$domain"#" "$CONF"; else echo "PANEL_DOMAIN="$domain"" >> "$CONF"; fi
      fi
      PANEL_DOMAIN="$domain"
      panel_domain_conflict_cleanup "$domain"
      write_panel_nginx_conf "$domain"
      update_panel_domain_in_app_config "$domain"
      # Если зона обслуживается нашим DNS, добавляем/обновляем panel A на публичный IP.
      local apex="${domain#panel.}" pub="$(public_ip)"
      if [[ "$apex" != "$domain" && -f "$DNS_DIR/db.$apex" ]]; then
        cmd_dns_wizard "$apex" "$pub" panel >/dev/null 2>&1 || true
      fi
      nginx_reload
      log "Panel domain bound: $domain -> $PANEL_DIR/public. Старые vhost не подключаются; файлы одноимённого сайта сохранены."
      ;;
    *) err "Use: panel-domain get|set DOMAIN" ;;
  esac
}


ensure_cli_links() {
  local self_path hyper_src
  self_path="/usr/local/sbin/hyper-host-ctl"
  hyper_src="/usr/local/bin/hyper"

  # Если скрипт запущен из репозитория, а бинарей ещё нет — устанавливаем их.
  if [[ ! -x "$self_path" && -f "/root/hyper-hosting-panel/scripts/hhctl" ]]; then
    install -m 0755 "/root/hyper-hosting-panel/scripts/hhctl" "$self_path" 2>/dev/null || true
  fi
  if [[ ! -x "$hyper_src" && -f "/root/hyper-hosting-panel/scripts/hyper" ]]; then
    install -m 0755 "/root/hyper-hosting-panel/scripts/hyper" "$hyper_src" 2>/dev/null || true
  fi

  # Дублируем в /usr/bin, чтобы Telegram-боты и разные PATH точно находили команды.
  [[ -x "$self_path" ]] && ln -sf "$self_path" /usr/bin/hyper-host-ctl 2>/dev/null || true
  [[ -x "$hyper_src" ]] && ln -sf "$hyper_src" /usr/bin/hyper 2>/dev/null || true
  chmod 0755 "$self_path" "$hyper_src" /usr/bin/hyper-host-ctl /usr/bin/hyper 2>/dev/null || true
}

cmd_panel_ssl() {
  local domain="${1:-$PANEL_DOMAIN}" email="${2:-}"
  [[ -n "$domain" && "$domain" != "_" ]] || err "Panel domain required. Use: sudo hyper panel domain panel.example.com"
  [[ -n "$email" ]] || err "Email required"
  valid_domain "$domain" || err "Invalid domain"
  cmd_panel_domain set "$domain" >/dev/null
  ufw allow 80/tcp >/dev/null 2>&1 || true
  ufw allow 443/tcp >/dev/null 2>&1 || true
  mkdir -p /opt/hyper-host/acme-webroot/.well-known/acme-challenge /var/log/letsencrypt
  local token body expected check_ip log_file
  token="hyper-host-panel-ssl-test-$(date +%s)-$$"
  printf 'ok-%s' "$token" > "/opt/hyper-host/acme-webroot/.well-known/acme-challenge/$token"
  body="$(curl --noproxy '*' -fsS --connect-timeout 2 --max-time 5 -H "Host: $domain" "http://127.0.0.1/.well-known/acme-challenge/$token" 2>/dev/null || true)"
  rm -f "/opt/hyper-host/acme-webroot/.well-known/acme-challenge/$token" 2>/dev/null || true
  [[ "$body" == "ok-$token" ]] || err "Панель локально не отдаёт ACME для $domain"
  expected="$(public_ip)"
  check_ip="$(resolve_domain_a_public "$domain" | head -n1)"
  if [[ -n "$expected" && "$check_ip" != "$expected" ]]; then
    err "DNS панели смотрит не туда: $domain -> ${check_ip:-нет A}. Нужно: A $domain $expected"
  fi
  log_file="/var/log/letsencrypt/hyper-host-panel-${domain}-$(date +%F-%H%M%S).log"
  if ! certbot certonly --webroot -w /opt/hyper-host/acme-webroot --non-interactive --agree-tos --email "$email" --no-eff-email --keep-until-expiring --preferred-challenges http --cert-name "$domain" -d "$domain" >"$log_file" 2>&1; then
    tail -n 120 "$log_file" >&2 || true
    err "SSL панели не выпущен. Лог: $log_file"
  fi
  nginx_reload
  log "Panel SSL issued: https://$domain / log: $log_file"
}

cmd_repair() {
  configure_phpmyadmin_label # v26
  configure_php_limits
  configure_phpmyadmin_storage
  ensure_cli_links; ensure_dirs; ensure_nologin_shell; ensure_bot_user; cleanup_hyper_host_mounts; ensure_acme_locations_all
  if [[ -n "${PANEL_DOMAIN:-}" && "${PANEL_DOMAIN:-_}" != "_" ]]; then
    panel_domain_conflict_cleanup "$PANEL_DOMAIN"
    write_panel_nginx_conf "$PANEL_DOMAIN"
    update_panel_domain_in_app_config "$PANEL_DOMAIN"
  fi
  mkdir -p "$BASE_DIR/data" "$PANEL_DIR" "$SITES_DIR" "$BOTS_DIR" "$FTP_DIR" "$BACKUP_DIR" "$BASE_DIR/templates" /etc/hyper-host
  safe_chown_tree www-data:www-data "$PANEL_DIR"
  safe_chown_tree www-data:www-data "$BASE_DIR/data"
  chmod 0770 "$BASE_DIR/data" 2>/dev/null || true
  if [[ -f "$BASE_DIR/data/hyperhost.sqlite" ]]; then chown www-data:www-data "$BASE_DIR/data/hyperhost.sqlite" "$BASE_DIR/data/hyperhost.sqlite"-* 2>/dev/null || true; chmod 0660 "$BASE_DIR/data/hyperhost.sqlite" "$BASE_DIR/data/hyperhost.sqlite"-* 2>/dev/null || true; fi
  fix_web_permissions "$SITES_DIR"; fix_web_permissions "$BOTS_DIR" "$BOT_USER"; chmod 0755 "$FTP_DIR" "$BACKUP_DIR" 2>/dev/null || true

  # Убираем только старые циклические bind-mount'ы. Нормальные FTP mount'ы не трогаем, иначе каталог в FileZilla становится пустым.
  cleanup_hyper_host_mounts


  while IFS=: read -r user _ uid gid gecos old_home shell; do
    [[ "$user" == hhftp_* ]] || continue
    home="$FTP_DIR/$user"; common="$home/common"; sites="$common/sites"; bots="$common/bots"
    mkdir -p "$common" "$sites" "$bots"
    usermod -d "$home" -s /usr/sbin/nologin "$user" 2>/dev/null || true
    chown root:root "$home" 2>/dev/null || true; chmod 0755 "$home" 2>/dev/null || true
    chown -R "$user":www-data "$common" 2>/dev/null || true; chmod -R u+rwX,g+rwX,o+rX "$common" 2>/dev/null || true
    mountpoint -q "$sites" || mount --bind "$SITES_DIR" "$sites" 2>/dev/null || true
    mountpoint -q "$bots" || mount --bind "$BOTS_DIR" "$bots" 2>/dev/null || true
    fix_web_permissions "$SITES_DIR" "$user"; fix_web_permissions "$BOTS_DIR" "$user"; fix_web_permissions "$common" "$user"
  done < /etc/passwd

  if command -v pm2 >/dev/null 2>&1; then
    pm2_persist
  fi

  {
  cat > /etc/sudoers.d/hyper-host <<EOSUDO
www-data ALL=(root) NOPASSWD: /usr/local/sbin/hyper-host-ctl *
EOSUDO
  } 2>/dev/null || warn "Не удалось записать /etc/sudoers.d/hyper-host (read-only /etc?) — панели может не хватать прав на sudo-команды."
  if [[ -f /etc/sudoers.d/hyper-host ]]; then
    chmod 0440 /etc/sudoers.d/hyper-host 2>/dev/null || true
    visudo -cf /etc/sudoers.d/hyper-host >/dev/null 2>&1 || warn "visudo не смог проверить /etc/sudoers.d/hyper-host"
  fi
  open_server_ports
  ensure_nginx_public_listen
  ensure_vsftpd_external_access; systemctl reload nginx 2>/dev/null || systemctl restart nginx 2>/dev/null || true
  # v47: гарантируем, что вотчер смены публичного IP стоит в cron даже на уже
  # развёрнутых панелях, обновлённых через git pull без повторного install.sh.
  if [[ ! -f /etc/cron.d/hyper-host-ip-watch ]]; then
    { cat > /etc/cron.d/hyper-host-ip-watch <<EOIPWATCH
SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
*/5 * * * * root /usr/local/sbin/hyper-host-ctl ip-autofix --quiet >/var/log/hyper-host-ip-watch.log 2>&1
EOIPWATCH
    } 2>/dev/null || warn "Не удалось записать /etc/cron.d/hyper-host-ip-watch (read-only /etc?) — автообновление IP при смене адреса не встанет, почини IP вручную: sudo hyper network ip-fix"
    chmod 0644 /etc/cron.d/hyper-host-ip-watch 2>/dev/null || true
    systemctl reload cron 2>/dev/null || true
  fi
  log "Repair finished: permissions, ACL, FTP safe homes, PM2 hyperbot and services checked"
}


deploy_center_python() {
  local py="$DEPLOY_CENTER_DIR/venv/bin/python"
  [[ -x "$py" ]] || py="$(command -v python3 || true)"
  [[ -n "$py" ]] || err "python3 не найден"
  [[ -f "$DEPLOY_CENTER_PY" ]] || err "Deploy Center manager не установлен: $DEPLOY_CENTER_PY"
  "$py" "$DEPLOY_CENTER_PY" "$@"
}

cmd_deploy_center_install() {
  ensure_dirs; ensure_bot_user; ensure_pm2
  mkdir -p "$DEPLOY_CENTER_DIR" /var/www/hyper-host-deploy/master /var/www/hyper-host-deploy/template /var/www/hyper-host-managed-bots
  if [[ ! -x "$DEPLOY_CENTER_DIR/venv/bin/python" ]]; then
    python3 -m venv "$DEPLOY_CENTER_DIR/venv"
  fi
  "$DEPLOY_CENTER_DIR/venv/bin/python" -m pip install --upgrade pip wheel setuptools >/dev/null
  "$DEPLOY_CENTER_DIR/venv/bin/pip" install 'PyMySQL>=1.1,<2' >/dev/null
  chown -R "$BOT_USER":www-data /var/www/hyper-host-deploy /var/www/hyper-host-managed-bots "$BOTS_DIR" 2>/dev/null || true
  chmod 2775 /var/www/hyper-host-deploy /var/www/hyper-host-deploy/master /var/www/hyper-host-deploy/template /var/www/hyper-host-managed-bots 2>/dev/null || true
  deploy_center_python install
}

cmd_deploy_center_config() {
  local mode="${1:-show}"; shift || true
  if [[ "$mode" == save ]]; then
    local host="${1:-}" port="${2:-3306}" user="${3:-}" pass="${4:-}" db="${5:-}"
    deploy_center_python config --save --db-host "$host" --db-port "$port" --db-user "$user" --db-pass "$pass" --db-name "$db"
  else
    deploy_center_python config
  fi
}
cmd_deploy_center_sync() { deploy_center_python sync; }
cmd_deploy_center_doctor() { deploy_center_python doctor; }
cmd_deploy_center_template_install() { deploy_center_python template-install --bot-file "${1:-}" --requirements-file "${2:-}"; }
cmd_deploy_center_master_install() { deploy_center_python master-install --bot-file "${1:-}" --env-file "${2:-}" --requirements-file "${3:-}"; }
cmd_deploy_center_master_action() { deploy_center_python master-action "${1:-}"; }
cmd_deploy_center_project_action() {
  # Не объединять эти присваивания в один local: Bash вычисляет args до того,
  # как локальные project_id/action получают значения, и передаёт в argparse "".
  local project_id="${1:-0}"
  local action="${2:-}"
  local delete_files="${3:-0}"
  local -a args

  [[ "$project_id" =~ ^[0-9]+$ ]] && (( project_id > 0 )) \
    || err "Некорректный project_id: ${project_id:-пусто}"
  case "$action" in
    deploy|start|stop|restart|logs|delete) ;;
    *) err "Некорректное действие проекта: ${action:-пусто}" ;;
  esac

  args=(project-action "$project_id" "$action")
  [[ "$delete_files" == 1 ]] && args+=(--delete-files)
  deploy_center_python "${args[@]}"
}
cmd_ssl_audit_json() {
  [[ -f "$SSL_TRUTH_PY" ]] || err "SSL truth checker не установлен: $SSL_TRUTH_PY"
  SERVER_IP="$SERVER_IP" PUBLIC_IP="$(get_public_ip 2>/dev/null || true)" python3 "$SSL_TRUTH_PY" audit
}
cmd_ssl_restore_existing() {
  [[ -f "$SSL_TRUTH_PY" ]] || err "SSL truth checker не установлен: $SSL_TRUTH_PY"
  SERVER_IP="$SERVER_IP" PUBLIC_IP="$(get_public_ip 2>/dev/null || true)" python3 "$SSL_TRUTH_PY" restore
}

