#!/usr/bin/env bash
set -Eeo pipefail

CONF="/etc/hyper-host/hyper-host.conf"
[[ -f "$CONF" ]] || { echo "Config not found: $CONF" >&2; exit 2; }
# shellcheck disable=SC1090
source "$CONF"

PANEL_NAME="${PANEL_NAME:-HYPER-HOST}"
POWERED_BY="${POWERED_BY:-powered by memes4u1337}"
SERVER_IP="${SERVER_IP:-$(hostname -I 2>/dev/null | awk '{print $1}')}"
PUBLIC_IP="${PUBLIC_IP:-${SERVER_PUBLIC_IP:-}}"
PANEL_DOMAIN="${PANEL_DOMAIN:-_}"
BASE_DIR="${BASE_DIR:-/opt/hyper-host}"
PANEL_DIR="${PANEL_DIR:-/var/www/hyper-host}"
SITES_DIR="${SITES_DIR:-/var/www/hyper-host-sites}"
BOTS_DIR="${BOTS_DIR:-/var/www/hyper-host-bots}"
FTP_DIR="${FTP_DIR:-/var/www/hyper-host-ftp}"
PHP_FPM_SOCK="${PHP_FPM_SOCK:-}"
PHPMYADMIN_PATH="${PHPMYADMIN_PATH:-/usr/share/phpmyadmin}"
BACKUP_DIR="${BACKUP_DIR:-$BASE_DIR/backups}"
DNS_DIR="${DNS_DIR:-/etc/bind/hyper-host-zones}"
CRON_DIR="/etc/cron.d"
NGINX_AVAILABLE="/etc/nginx/sites-available"
NGINX_ENABLED="/etc/nginx/sites-enabled"

export PANEL_NAME POWERED_BY SERVER_IP PUBLIC_IP PANEL_DOMAIN BASE_DIR PANEL_DIR SITES_DIR BOTS_DIR FTP_DIR PHP_FPM_SOCK PHPMYADMIN_PATH BACKUP_DIR
BOT_USER="${BOT_USER:-hyperbot}"
PM2_HOME_DIR="${PM2_HOME_DIR:-$BOTS_DIR/.pm2}"
NODE_MAJOR_MIN="${NODE_MAJOR_MIN:-18}"

log() { echo "[hhctl] $*"; }
err() { echo "[hhctl error] $*" >&2; exit 1; }
valid_domain() { [[ "$1" =~ ^([A-Za-z0-9]([A-Za-z0-9-]{0,61}[A-Za-z0-9])?\.)+[A-Za-z]{2,63}$ ]]; }
valid_name() { [[ "$1" =~ ^[A-Za-z0-9_][A-Za-z0-9_-]{1,63}$ ]]; }
valid_folder() { [[ "$1" =~ ^[A-Za-z0-9._-]{1,80}$ ]] && [[ "$1" != "." && "$1" != ".." ]]; }
valid_db_name() { [[ "$1" =~ ^[A-Za-z0-9_]{2,48}$ ]]; }
sql_escape() { printf "%s" "$1" | sed "s/'/''/g"; }
json_escape() { python3 -c 'import json,sys; print(json.dumps(sys.argv[1], ensure_ascii=False))' "$1"; }

ensure_nologin_shell() {
  if [[ -x /usr/sbin/nologin ]] && ! grep -qxF /usr/sbin/nologin /etc/shells 2>/dev/null; then echo /usr/sbin/nologin >> /etc/shells; fi
  if [[ -x /bin/false ]] && ! grep -qxF /bin/false /etc/shells 2>/dev/null; then echo /bin/false >> /etc/shells; fi
}
ensure_dirs() { mkdir -p "$SITES_DIR" "$BOTS_DIR" "$FTP_DIR" "$BACKUP_DIR" "$BASE_DIR/templates" "$BASE_DIR/data"; }
nginx_reload() { nginx -t >/dev/null; systemctl reload nginx; }

ensure_acme_location_for_conf() {
  # Добавляет явное разрешение /.well-known/acme-challenge/ перед запретом dot-папок.
  # Без этого nginx правило "location ~ /\." может блокировать Let's Encrypt challenge.
  local conf="$1" root_path="$2"
  [[ -f "$conf" ]] || return 0
  grep -q 'HYPER-HOST ACME CHALLENGE' "$conf" && return 0
  python3 - "$conf" "$root_path" <<'PYACME'
import sys, pathlib
conf = pathlib.Path(sys.argv[1])
root = sys.argv[2]
text = conf.read_text(encoding='utf-8', errors='ignore')
block = '''
    # HYPER-HOST ACME CHALLENGE
    location ^~ /.well-known/acme-challenge/ {
        root %s;
        default_type "text/plain";
        try_files $uri =404;
        allow all;
    }
''' % root
needle = '    location ~ /\\. { deny all; }'
if needle in text:
    text = text.replace(needle, block + '\n' + needle, 1)
else:
    pos = text.rfind('}')
    if pos != -1:
        text = text[:pos] + block + text[pos:]
conf.write_text(text, encoding='utf-8')
PYACME
}

ensure_acme_location_for_domain() {
  local domain="$1" root="$2" conf="$NGINX_AVAILABLE/hyper-host-site-$domain.conf"
  ensure_acme_location_for_conf "$conf" "$root"
}

ensure_acme_locations_all() {
  local conf domain root
  shopt -s nullglob
  for conf in "$NGINX_AVAILABLE"/hyper-host-site-*.conf; do
    domain="${conf##*/hyper-host-site-}"; domain="${domain%.conf}"
    root="$(awk '/^[[:space:]]*root[[:space:]]+/ {gsub(";", "", $2); print $2; exit}' "$conf" 2>/dev/null || true)"
    [[ -n "$root" ]] || root="$SITES_DIR/$domain/public_html"
    ensure_acme_location_for_conf "$conf" "$root"
  done
  shopt -u nullglob
}

write_panel_nginx_conf() {
  local domain="${1:-$PANEL_DOMAIN}"
  [[ -n "$domain" ]] || domain="_"
  mkdir -p /etc/nginx/sites-available /etc/nginx/sites-enabled "$PANEL_DIR/public/.well-known/acme-challenge"
  chown -R www-data:www-data "$PANEL_DIR/public/.well-known" 2>/dev/null || true
  chmod -R a+rX "$PANEL_DIR/public/.well-known" 2>/dev/null || true
  cat > /etc/nginx/sites-available/hyper-host-panel.conf <<EOPANELNGINX
server {
    listen 80;
    listen [::]:80;
    server_name ${domain};

    root ${PANEL_DIR}/public;
    index index.php index.html;
    client_max_body_size 256M;

    access_log /var/log/nginx/hyper-host-panel.access.log;
    error_log /var/log/nginx/hyper-host-panel.error.log;

    # HYPER-HOST PANEL ACME CHALLENGE
    location ^~ /.well-known/acme-challenge/ {
        root ${PANEL_DIR}/public;
        default_type "text/plain";
        try_files \$uri =404;
        allow all;
    }

    location / {
        try_files \$uri \$uri/ /index.php?\$query_string;
    }

    location /phpmyadmin {
        alias /usr/share/phpmyadmin/;
        index index.php index.html;
    }

    location ~ ^/phpmyadmin/(.+\.php)$ {
        alias /usr/share/phpmyadmin/\$1;
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME /usr/share/phpmyadmin/\$1;
        fastcgi_pass unix:${PHP_FPM_SOCK};
    }

    location ~ ^/phpmyadmin/(.+)$ {
        alias /usr/share/phpmyadmin/\$1;
    }

    location ~ \.php$ {
        include snippets/fastcgi-php.conf;
        fastcgi_pass unix:${PHP_FPM_SOCK};
    }

    location ~ /\. {
        deny all;
    }
}

server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name _;

    root ${PANEL_DIR}/public;
    index index.php index.html;
    client_max_body_size 256M;

    location ^~ /.well-known/acme-challenge/ {
        root ${PANEL_DIR}/public;
        default_type "text/plain";
        try_files \$uri =404;
        allow all;
    }

    location / { try_files \$uri \$uri/ /index.php?\$query_string; }
    location /phpmyadmin { alias /usr/share/phpmyadmin/; index index.php index.html; }
    location ~ ^/phpmyadmin/(.+\.php)$ { alias /usr/share/phpmyadmin/\$1; include fastcgi_params; fastcgi_param SCRIPT_FILENAME /usr/share/phpmyadmin/\$1; fastcgi_pass unix:${PHP_FPM_SOCK}; }
    location ~ \.php$ { include snippets/fastcgi-php.conf; fastcgi_pass unix:${PHP_FPM_SOCK}; }
}
EOPANELNGINX
  # Load panel config first. If panel.hyper-host.pw was accidentally created as a site,
  # this plus duplicate cleanup makes the exact domain open the panel, not site stub.
  ln -sf /etc/nginx/sites-available/hyper-host-panel.conf /etc/nginx/sites-enabled/00-hyper-host-panel.conf
  rm -f /etc/nginx/sites-enabled/hyper-host-panel.conf 2>/dev/null || true
}

panel_domain_conflict_cleanup() {
  local domain="$1" path real target
  # Disable the exact HYPER-HOST site config for the panel domain.
  local site_conf="$NGINX_AVAILABLE/hyper-host-site-$domain.conf" enabled_conf="$NGINX_ENABLED/hyper-host-site-$domain.conf"
  [[ -e "$enabled_conf" || -L "$enabled_conf" ]] && rm -f "$enabled_conf"
  [[ -f "$site_conf" ]] && mv -f "$site_conf" "$site_conf.disabled-for-panel" 2>/dev/null || true

  # Disable any other enabled nginx config that contains this exact server_name, except panel config.
  shopt -s nullglob
  for path in "$NGINX_ENABLED"/*; do
    [[ -e "$path" || -L "$path" ]] || continue
    [[ "${path##*/}" == "00-hyper-host-panel.conf" || "${path##*/}" == "hyper-host-panel.conf" ]] && continue
    real="$(readlink -f "$path" 2>/dev/null || echo "$path")"
    [[ -f "$real" ]] || continue
    if python3 - "$real" "$domain" <<'PYCHECK'
import re,sys,pathlib
text=pathlib.Path(sys.argv[1]).read_text(errors='ignore')
d=sys.argv[2]
found=False
for m in re.finditer(r'server_name\s+([^;]+);', text):
    names=m.group(1).split()
    if d in names:
        found=True
        break
sys.exit(0 if found else 1)
PYCHECK
    then
      rm -f "$path" 2>/dev/null || true
      case "$real" in
        "$NGINX_AVAILABLE"/*) mv -f "$real" "$real.disabled-for-panel" 2>/dev/null || true ;;
      esac
    fi
  done
  shopt -u nullglob
}

update_panel_domain_in_app_config() {
  local domain="$1" cfg="$PANEL_DIR/app/config.php"
  [[ -f "$cfg" ]] || return 0
  python3 - "$cfg" "$domain" <<'PYCFG'
import re,sys,pathlib
p=pathlib.Path(sys.argv[1]); d=sys.argv[2]
text=p.read_text(encoding='utf-8',errors='ignore')
text=re.sub(r"('panel_domain'\s*=>\s*)'[^']*'", r"\1'"+d.replace("'","\\'")+"'", text)
p.write_text(text,encoding='utf-8')
PYCFG
}

cleanup_hyper_host_mounts() {
  # Безопасно снимает старые/сломанные bind-mount'ы HYPER-HOST, особенно те,
  # которые попали внутрь public_html и создают циклы common/sites/.../common/bots.
  local mp pass
  for pass in 1 2 3 4 5; do
    mapfile -t _hh_bad_mounts < <(
      awk '{print $5}' /proc/self/mountinfo 2>/dev/null         | sed 's/\040/ /g'         | grep -E '^/var/www/hyper-host-(ftp|sites)/'         | grep -E '/(common|sites|bots|site)(/|$)'         | sort -r || true
    )
    [[ ${#_hh_bad_mounts[@]} -eq 0 ]] && break
    for mp in "${_hh_bad_mounts[@]}"; do
      case "$mp" in
        "/"|"/var"|"/var/www"|"$SITES_DIR"|"$BOTS_DIR"|"$FTP_DIR") continue ;;
      esac
      umount -lf "$mp" 2>/dev/null || true
    done
  done
  if [[ -f /etc/fstab ]]; then
    sed -i.bak -E '/hyper-host-ftp|hyper-host-sites\/.*\/(common|sites|bots|site)|public_html\/(common|sites|bots|site)/d' /etc/fstab 2>/dev/null || true
  fi
}

safe_chown_tree() {
  local owner="$1" path="$2"
  [[ -e "$path" ]] || return 0
  cleanup_hyper_host_mounts
  find "$path" -xdev -exec chown -h "$owner" {} + 2>/dev/null || true
}

safe_chmod_tree() {
  local mode="$1" path="$2"
  [[ -e "$path" ]] || return 0
  cleanup_hyper_host_mounts
  find "$path" -xdev -exec chmod "$mode" {} + 2>/dev/null || true
}
fix_web_permissions() {
  local path="$1" user="${2:-}"
  [[ -e "$path" ]] || return 0
  cleanup_hyper_host_mounts
  find "$path" -xdev -exec chgrp www-data {} + 2>/dev/null || true
  find "$path" -xdev -exec chmod u+rwX,g+rwX,o+rX {} + 2>/dev/null || true
  find "$path" -xdev -type d -exec chmod g+s {} + 2>/dev/null || true
  if command -v setfacl >/dev/null 2>&1; then
    setfacl -R -m u:www-data:rwx,g:www-data:rwx "$path" 2>/dev/null || true
    setfacl -R -d -m u:www-data:rwx,g:www-data:rwx "$path" 2>/dev/null || true
    if [[ -n "$user" ]]; then
      setfacl -R -m u:"$user":rwx "$path" 2>/dev/null || true
      setfacl -R -d -m u:"$user":rwx "$path" 2>/dev/null || true
    fi
  fi
}

php_index_template_file() {
  local title="$1" file="$2"
  mkdir -p "$(dirname "$file")"
  cat > "$file" <<EOPHP
<?php http_response_code(200); ?>
<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1">
  <title>${title} — HYPER-HOST</title>
  <style>:root{color-scheme:dark}*{box-sizing:border-box}body{margin:0;min-height:100vh;display:grid;place-items:center;background:radial-gradient(circle at 20% 20%,#2563eb44,transparent 32%),radial-gradient(circle at 90% 10%,#9333ea44,transparent 30%),linear-gradient(135deg,#070a14,#101827);color:#fff;font-family:Inter,Arial,sans-serif}.box{width:min(860px,92vw);padding:44px;border:1px solid rgba(255,255,255,.14);border-radius:32px;background:rgba(15,23,42,.78);box-shadow:0 40px 120px rgba(0,0,0,.55);backdrop-filter:blur(18px)}.logo{display:inline-flex;gap:10px;align-items:center;padding:10px 14px;border:1px solid rgba(255,255,255,.14);border-radius:999px;background:rgba(255,255,255,.06);color:#93c5fd}h1{margin:18px 0 12px;font-size:clamp(36px,6vw,64px);letter-spacing:-.05em}.muted{color:#b7c2d8;font-size:18px;line-height:1.65}.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin-top:26px}.item{padding:16px;border-radius:18px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1)}code{color:#a7f3d0}.powered{margin-top:24px;color:#a78bfa}</style>
</head>
<body><main class="box"><div class="logo">🚀 HYPER-HOST</div><h1>${title}</h1><p class="muted">Сайт/папка создана. Загрузи файлы через FTP или файловый менеджер и замени этот стартовый экран.</p><div class="grid"><div class="item">Корень: <code>public_html</code></div><div class="item">PHP: <code>работает</code></div><div class="item">Панель: <code>HYPER-HOST</code></div></div><div class="powered">powered by memes4u1337</div></main></body></html>
EOPHP
}

php_sock_for_version() {
  local version="$1"
  if [[ -n "$version" && -S "/run/php/php${version}-fpm.sock" ]]; then echo "/run/php/php${version}-fpm.sock"; return; fi
  echo "$PHP_FPM_SOCK"
}

cmd_create_folder() {
  ensure_dirs
  local name="${1:-}"; [[ -n "$name" ]] || err "Folder name required"; valid_folder "$name" || err "Invalid folder name: $name"
  local root="$SITES_DIR/$name/public_html"
  mkdir -p "$root" "$SITES_DIR/$name/logs"
  [[ -f "$root/index.php" || -f "$root/index.html" ]] || php_index_template_file "$name" "$root/index.php"
  chown -R www-data:www-data "$SITES_DIR/$name" 2>/dev/null || true
  fix_web_permissions "$SITES_DIR/$name"
  log "Folder created: $name -> $root"
}
cmd_delete_folder() { local name="${1:-}"; [[ -n "$name" ]] || err "Folder name required"; valid_folder "$name" || err "Invalid folder name"; rm -rf "$SITES_DIR/$name"; log "Folder deleted: $name"; }

cmd_add_site() {
  ensure_dirs
  local domain="${1:-}" aliases="${2:-}" phpv="${3:-}"
  [[ -n "$domain" ]] || err "Domain required"; valid_domain "$domain" || err "Invalid domain: $domain"
  if [[ -n "$PANEL_DOMAIN" && "$PANEL_DOMAIN" != "_" && "$domain" == "$PANEL_DOMAIN" ]]; then
    err "Этот домен закреплён за панелью: $domain. Используй другой домен для сайта или сначала смени panel-domain."
  fi
  local root="$SITES_DIR/$domain/public_html" sock; sock="$(php_sock_for_version "$phpv")"
  mkdir -p "$root" "$SITES_DIR/$domain/logs"
  [[ -f "$root/index.php" || -f "$root/index.html" ]] || php_index_template_file "$domain работает" "$root/index.php"
  chown -R www-data:www-data "$SITES_DIR/$domain" 2>/dev/null || true
  fix_web_permissions "$SITES_DIR/$domain"
  local server_names="$domain"
  if [[ -n "$aliases" ]]; then
    IFS=',' read -ra arr <<< "$aliases"
    for a in "${arr[@]}"; do a="$(echo "$a" | xargs)"; [[ -z "$a" ]] && continue; valid_domain "$a" || err "Invalid alias: $a"; server_names="$server_names $a"; done
  fi
  cat > "$NGINX_AVAILABLE/hyper-host-site-$domain.conf" <<EONGINX
server {
    listen 80;
    listen [::]:80;
    server_name ${server_names};
    root ${root};
    index index.php index.html index.htm;
    client_max_body_size 1024M;
    access_log ${SITES_DIR}/${domain}/logs/access.log;
    error_log ${SITES_DIR}/${domain}/logs/error.log;
    location / { try_files \$uri \$uri/ /index.php?\$query_string; }
    # HYPER-HOST ACME CHALLENGE
    location ^~ /.well-known/acme-challenge/ {
        root ${root};
        default_type "text/plain";
        try_files \$uri =404;
        allow all;
    }
    location ~ \.php$ { include snippets/fastcgi-php.conf; fastcgi_pass unix:${sock}; }
    location ~ /\. { deny all; }
}
EONGINX
  ln -sf "$NGINX_AVAILABLE/hyper-host-site-$domain.conf" "$NGINX_ENABLED/hyper-host-site-$domain.conf"
  nginx_reload
  log "Site created: $domain -> $root"
}
cmd_delete_site() { local domain="${1:-}" mode="${2:---keep-files}"; [[ -n "$domain" ]] || err "Domain required"; valid_domain "$domain" || err "Invalid domain"; rm -f "$NGINX_ENABLED/hyper-host-site-$domain.conf" "$NGINX_AVAILABLE/hyper-host-site-$domain.conf"; nginx_reload; [[ "$mode" == "--delete-files" ]] && rm -rf "$SITES_DIR/$domain"; log "Site deleted: $domain / $mode"; }
is_private_ipv4() {
  local ip="$1"
  [[ "$ip" =~ ^10\. ]] && return 0
  [[ "$ip" =~ ^192\.168\. ]] && return 0
  [[ "$ip" =~ ^172\.(1[6-9]|2[0-9]|3[0-1])\. ]] && return 0
  [[ "$ip" =~ ^127\. ]] && return 0
  return 1
}

outbound_public_ip() {
  curl -4 -fsS --max-time 4 https://api.ipify.org 2>/dev/null || \
  curl -4 -fsS --max-time 4 https://ifconfig.me 2>/dev/null || \
  echo ""
}

configured_public_ip() {
  local ip="${PUBLIC_IP:-}"
  [[ -z "$ip" && -f /etc/hyper-host/public_ip ]] && ip="$(tr -d '[:space:]' </etc/hyper-host/public_ip 2>/dev/null || true)"
  [[ -z "$ip" ]] && ip="${SERVER_PUBLIC_IP:-}"
  echo "$ip"
}

public_ip() {
  # Это IP, который панель будет рекомендовать для DNS.
  # Важно: если сервер стоит за роутером/NAT, исходящий IP через ifconfig.me может быть не тем,
  # на который у тебя смотрит домен. Поэтому есть ручная настройка PUBLIC_IP.
  local cfg out
  cfg="$(configured_public_ip)"
  if [[ -n "$cfg" ]]; then echo "$cfg"; return; fi
  if [[ -n "$SERVER_IP" ]] && ! is_private_ipv4 "$SERVER_IP"; then echo "$SERVER_IP"; return; fi
  out="$(outbound_public_ip)"
  [[ -n "$out" ]] && { echo "$out"; return; }
  echo "$SERVER_IP"
}

resolve_domain_ips_public() {
  # HYPER-HOST v16: проверяем DNS через публичные резолверы, а не через локальный bind/hosts.
  # Иначе сервер может сам себе отдавать 192.168.x.x и SSL/панель думают, что DNS неправильный.
  local domain="$1" ns
  for ns in 1.1.1.1 8.8.8.8 9.9.9.9; do
    { dig +time=2 +tries=1 +short @"$ns" A "$domain" 2>/dev/null; dig +time=2 +tries=1 +short @"$ns" AAAA "$domain" 2>/dev/null; }
  done | sed '/^$/d' | sort -u
}

resolve_domain_a_public() {
  local domain="$1" ns
  for ns in 1.1.1.1 8.8.8.8 9.9.9.9; do
    dig +time=2 +tries=1 +short @"$ns" A "$domain" 2>/dev/null
  done | sed '/^$/d' | sort -u
}

resolve_domain_ips() {
  local domain="$1"
  # Важно: для SSL/DNS нельзя брать локальный bind/resolv.conf, иначе панель видит 192.168.x.x.
  # Проверяем только публичные резолверы. Локальная зона показывается отдельно в dns-status.
  resolve_domain_ips_public "$domain"
}

resolve_domain_a() {
  local domain="$1"
  # Только публичный DNS. Без fallback на локальный resolver.
  resolve_domain_a_public "$domain"
}

resolve_domain_a_local() {
  local domain="$1"
  dig +time=1 +tries=1 +short @127.0.0.1 A "$domain" 2>/dev/null | sed '/^$/d' | sort -u || true
}

choose_ssl_expected_ip() {
  local domain="$1" cfg arec first_a out
  cfg="$(configured_public_ip)"
  [[ -n "$cfg" ]] && { echo "$cfg"; return; }
  arec="$(resolve_domain_a "$domain")"
  first_a="$(printf '%s\n' "$arec" | head -n1)"
  # Если сервер за NAT и DNS уже смотрит на публичный IP роутера — считаем его ожидаемым.
  if [[ -n "$first_a" && -n "$SERVER_IP" ]] && is_private_ipv4 "$SERVER_IP"; then echo "$first_a"; return; fi
  if [[ -n "$SERVER_IP" ]] && ! is_private_ipv4 "$SERVER_IP"; then echo "$SERVER_IP"; return; fi
  out="$(outbound_public_ip)"
  [[ -n "$out" ]] && { echo "$out"; return; }
  echo "$SERVER_IP"
}

dns_points_here() {
  local domain="$1" expected ips
  expected="$(choose_ssl_expected_ip "$domain")"
  ips="$(resolve_domain_ips "$domain")"
  [[ -n "$ips" ]] || return 2
  if [[ -n "$expected" ]] && echo "$ips" | grep -qxF "$expected"; then return 0; fi
  # Для локального сервера за NAT разрешаем A-запись на публичный IP роутера,
  # даже если outbound IP отличается. Главное — чтобы порты 80/443 были проброшены.
  if [[ -z "$(configured_public_ip)" && -n "$SERVER_IP" ]] && is_private_ipv4 "$SERVER_IP" && [[ -n "$(resolve_domain_a "$domain")" ]]; then return 0; fi
  [[ -n "$SERVER_IP" ]] && echo "$ips" | grep -qxF "$SERVER_IP" && return 0
  return 1
}

site_root_for_domain() {
  local domain="$1" conf="$NGINX_AVAILABLE/hyper-host-site-$domain.conf" root=""
  if [[ -f "$conf" ]]; then
    root="$(awk '/^[[:space:]]*root[[:space:]]+/ {gsub(";", "", $2); print $2; exit}' "$conf" 2>/dev/null || true)"
  fi
  [[ -n "$root" ]] || root="$SITES_DIR/$domain/public_html"
  echo "$root"
}

nginx_domains_for_site() {
  local domain="$1" conf="$NGINX_AVAILABLE/hyper-host-site-$domain.conf"
  if [[ -f "$conf" ]]; then
    awk '/^[[:space:]]*server_name[[:space:]]+/ {for(i=2;i<=NF;i++){gsub(";", "", $i); print $i}}' "$conf" 2>/dev/null | sort -u
  else
    echo "$domain"
  fi
}

local_http_challenge_check() {
  local domain="$1" root="$2" token body url
  [[ -d "$root" ]] || return 2
  ensure_acme_location_for_domain "$domain" "$root"
  nginx -t >/dev/null 2>&1 && systemctl reload nginx >/dev/null 2>&1 || true
  mkdir -p "$root/.well-known/acme-challenge"
  token="hyper-host-ssl-test-$(date +%s)-$$"
  printf 'ok-%s' "$token" > "$root/.well-known/acme-challenge/$token"
  chmod -R a+rX "$root/.well-known" 2>/dev/null || true
  for url in "http://127.0.0.1/.well-known/acme-challenge/$token" "http://${SERVER_IP}/.well-known/acme-challenge/$token"; do
    body="$(curl -fsS --connect-timeout 1 --max-time 2 -H "Host: $domain" "$url" 2>/dev/null || true)"
    [[ "$body" == "ok-$token" ]] && { rm -f "$root/.well-known/acme-challenge/$token" 2>/dev/null || true; return 0; }
  done
  rm -f "$root/.well-known/acme-challenge/$token" 2>/dev/null || true
  return 1
}

ssl_preflight_json() {
  local domain="$1" root pub configured outbound expected arec aaaarec ips dns_status nginx_ok http_ok has_site certbot_ready problem required_a nat_mode warning
  root="$(site_root_for_domain "$domain")"
  configured="$(configured_public_ip)"
  outbound="$(outbound_public_ip)"
  expected="$(choose_ssl_expected_ip "$domain")"
  pub="$expected"
  arec="$(resolve_domain_a_public "$domain")"
  aaaarec="$(for ns in 1.1.1.1 8.8.8.8 9.9.9.9; do dig +time=2 +tries=1 +short @"$ns" AAAA "$domain" 2>/dev/null; done | sed '/^$/d' | sort -u || true)"
  ips="$(printf '%s\n%s\n' "$arec" "$aaaarec" | sed '/^$/d' | sort -u)"
  dns_status="bad"
  nat_mode=0
  [[ -n "$SERVER_IP" ]] && is_private_ipv4 "$SERVER_IP" && nat_mode=1
  if [[ -z "$ips" ]]; then
    dns_status="missing"
  elif dns_points_here "$domain"; then
    dns_status="ok"
  else
    dns_status="wrong_ip"
  fi
  nginx_ok=0; nginx -t >/dev/null 2>&1 && nginx_ok=1
  has_site=0; [[ -f "$NGINX_AVAILABLE/hyper-host-site-$domain.conf" || -d "$root" ]] && has_site=1
  http_ok=0; [[ "$nginx_ok" == 1 ]] && local_http_challenge_check "$domain" "$root" && http_ok=1
  certbot_ready=0; [[ "$dns_status" == ok && "$nginx_ok" == 1 && "$http_ok" == 1 && "$has_site" == 1 ]] && certbot_ready=1
  problem=""; warning=""
  required_a="A    $domain    $expected"
  if [[ "$nat_mode" == 1 ]]; then warning=""; fi
  if [[ "$dns_status" == missing ]]; then problem="У домена нет публичных A/AAAA записей. Добавь запись: $required_a"; fi
  if [[ "$dns_status" == wrong_ip ]]; then problem="DNS домена указывает не на нужный IP. Сейчас: ${ips//$'\n'/, }. Нужно: $required_a"; fi
  if [[ "$nginx_ok" != 1 ]]; then problem="Nginx config не проходит проверку: sudo nginx -t"; fi
  if [[ "$has_site" != 1 ]]; then problem="Сайт не найден в HYPER-HOST. Сначала создай сайт: $domain"; fi
  if [[ "$http_ok" != 1 && "$dns_status" == ok && "$nginx_ok" == 1 ]]; then problem="Nginx локально не отдаёт /.well-known/acme-challenge для Host: $domain. Проверь root сайта и конфиг."; fi
  DOMAIN="$domain" ROOT="$root" PUBLIC_IP="$pub" CONFIGURED_PUBLIC_IP="$configured" OUTBOUND_PUBLIC_IP="$outbound" EXPECTED_PUBLIC_IP="$expected" SERVER_IP="$SERVER_IP" A_RECORDS="$arec" AAAA_RECORDS="$aaaarec" DNS_STATUS="$dns_status" NGINX_OK="$nginx_ok" HTTP_OK="$http_ok" HAS_SITE="$has_site" CERTBOT_READY="$certbot_ready" PROBLEM="$problem" WARNING="$warning" REQUIRED_A="$required_a" NAT_MODE="$nat_mode" python3 - <<'PYSSL'
import os,json
split=lambda s:[x for x in s.splitlines() if x.strip()]
print(json.dumps({
 'domain':os.environ['DOMAIN'],
 'root':os.environ['ROOT'],
 'server_ip':os.environ.get('SERVER_IP',''),
 'public_ip':os.environ.get('PUBLIC_IP',''),
 'expected_public_ip':os.environ.get('EXPECTED_PUBLIC_IP',''),
 'configured_public_ip':os.environ.get('CONFIGURED_PUBLIC_IP',''),
 'outbound_public_ip':os.environ.get('OUTBOUND_PUBLIC_IP',''),
 'nat_mode':os.environ.get('NAT_MODE')=='1',
 'a':split(os.environ.get('A_RECORDS','')),
 'aaaa':split(os.environ.get('AAAA_RECORDS','')),
 'dns_status':os.environ.get('DNS_STATUS'),
 'points_here':os.environ.get('DNS_STATUS')=='ok',
 'nginx_ok':os.environ.get('NGINX_OK')=='1',
 'http_challenge_ok':os.environ.get('HTTP_OK')=='1',
 'site_exists':os.environ.get('HAS_SITE')=='1',
 'certbot_ready':os.environ.get('CERTBOT_READY')=='1',
 'required_a':os.environ.get('REQUIRED_A',''),
 'problem':os.environ.get('PROBLEM',''),
 'warning':os.environ.get('WARNING',''),
}, ensure_ascii=False))
PYSSL
}

cmd_ssl_check_json() {
  local domain="${1:-}"
  [[ -n "$domain" ]] || err "Domain required"
  valid_domain "$domain" || err "Invalid domain"
  ssl_preflight_json "$domain"
}

cmd_public_ip() {
  local action="${1:-get}" ip="${2:-}"
  mkdir -p /etc/hyper-host
  case "$action" in
    get)
      echo "$(public_ip)"
      ;;
    set)
      [[ -n "$ip" ]] || err "Public IP required"
      [[ "$ip" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]] || err "Invalid IPv4: $ip"
      echo "$ip" > /etc/hyper-host/public_ip
      if [[ -f "$CONF" ]]; then
        if grep -q '^PUBLIC_IP=' "$CONF"; then sed -i "s#^PUBLIC_IP=.*#PUBLIC_IP=\"$ip\"#" "$CONF"; else echo "PUBLIC_IP=\"$ip\"" >> "$CONF"; fi
      fi
      log "Public IP saved: $ip"
      ;;
    clear)
      rm -f /etc/hyper-host/public_ip
      [[ -f "$CONF" ]] && sed -i '/^PUBLIC_IP=/d' "$CONF" || true
      log "Public IP override cleared"
      ;;
    *) err "Use: public-ip get|set IP|clear" ;;
  esac
}

cmd_ssl_ip_selfsigned() {
  local ip="${1:-$SERVER_IP}"
  [[ "$ip" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]] || err "Invalid IP: $ip"
  local dir="/etc/ssl/hyper-host-ip-$ip" key="$dir/privkey.pem" crt="$dir/fullchain.pem" conf="$dir/openssl.cnf" nginx_conf="/etc/nginx/sites-available/hyper-host-ip-$ip.conf"
  mkdir -p "$dir" "$PANEL_DIR/public"
  cat > "$conf" <<EOFIP
[req]
default_bits = 2048
prompt = no
default_md = sha256
distinguished_name = dn
x509_extensions = v3_req
[dn]
CN = $ip
[v3_req]
subjectAltName = @alt_names
[alt_names]
IP.1 = $ip
EOFIP
  openssl req -x509 -nodes -days 825 -newkey rsa:2048 -keyout "$key" -out "$crt" -config "$conf" >/dev/null 2>&1
  chmod 0600 "$key"; chmod 0644 "$crt"
  cat > "$nginx_conf" <<EOFIPNGINX
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name $ip;

    ssl_certificate $crt;
    ssl_certificate_key $key;

    root ${PANEL_DIR}/public;
    index index.php index.html;
    client_max_body_size 256M;

    access_log /var/log/nginx/hyper-host-ip-$ip.access.log;
    error_log /var/log/nginx/hyper-host-ip-$ip.error.log;

    location / { try_files \$uri \$uri/ /index.php?\$query_string; }

    location /phpmyadmin {
        alias /usr/share/phpmyadmin/;
        index index.php index.html;
    }

    location ~ ^/phpmyadmin/(.+\.php)$ {
        alias /usr/share/phpmyadmin/\$1;
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME /usr/share/phpmyadmin/\$1;
        fastcgi_pass unix:${PHP_FPM_SOCK};
    }

    location ~ \.php$ {
        include snippets/fastcgi-php.conf;
        fastcgi_pass unix:${PHP_FPM_SOCK};
    }
}
EOFIPNGINX
  ln -sf "$nginx_conf" "/etc/nginx/sites-enabled/hyper-host-ip-$ip.conf"
  ufw allow 443/tcp >/dev/null 2>&1 || true
  nginx -t >/dev/null && systemctl reload nginx || nginx -t
  log "Self-signed IP SSL enabled: https://$ip -> HYPER-HOST panel"
  echo "WARNING: это self-signed сертификат для IP. Браузер будет предупреждать о недоверенном сертификате. Для нормального зелёного SSL используй домен panel.hyper-host.pw."
}




cmd_ssl_fix_site() {
  local domain="${1:-}"
  [[ -n "$domain" ]] || err "Domain required"
  valid_domain "$domain" || err "Invalid domain"
  local root="$(site_root_for_domain "$domain")"
  ensure_acme_location_for_domain "$domain" "$root"
  mkdir -p "$root/.well-known/acme-challenge"
  chown -R www-data:www-data "$root/.well-known" 2>/dev/null || true
  chmod -R a+rX "$root/.well-known" 2>/dev/null || true
  nginx_reload
  log "SSL ACME location fixed for $domain -> $root"
}

cmd_ssl_site() {
  local domain="${1:-}" email="${2:-}"
  [[ -n "$domain" && -n "$email" ]] || err "Domain and email required"
  valid_domain "$domain" || err "Invalid domain"
  cleanup_hyper_host_mounts
  ensure_dirs
  ufw allow 80/tcp >/dev/null 2>&1 || true
  ufw allow 443/tcp >/dev/null 2>&1 || true

  local check ready problem root log_file d candidates=() cert_domains=() args=()
  root="$(site_root_for_domain "$domain")"
  ensure_acme_location_for_domain "$domain" "$root"
  nginx_reload >/dev/null 2>&1 || true
  check="$(ssl_preflight_json "$domain")"
  ready="$(printf '%s' "$check" | python3 -c 'import sys,json; print(1 if json.load(sys.stdin).get("certbot_ready") else 0)' 2>/dev/null || echo 0)"
  if [[ "$ready" != 1 ]]; then
    problem="$(printf '%s' "$check" | python3 -c 'import sys,json; print(json.load(sys.stdin).get("problem","SSL preflight failed"))' 2>/dev/null || echo "SSL preflight failed")"
    echo "$check" >&2
    err "SSL не выпущен: $problem"
  fi

  root="$(site_root_for_domain "$domain")"
  while read -r d; do
    [[ -z "$d" ]] && continue
    valid_domain "$d" || continue
    if dns_points_here "$d" && local_http_challenge_check "$d" "$root"; then
      candidates+=("$d")
    fi
  done < <(nginx_domains_for_site "$domain")
  candidates+=("$domain")
  mapfile -t cert_domains < <(printf '%s\n' "${candidates[@]}" | sed '/^$/d' | sort -u)
  [[ ${#cert_domains[@]} -gt 0 ]] || cert_domains=("$domain")

  log_file="/var/log/letsencrypt/hyper-host-${domain}-$(date +%F-%H%M%S).log"
  mkdir -p /var/log/letsencrypt
  args=(certbot --nginx --non-interactive --agree-tos --email "$email" --no-eff-email --keep-until-expiring --expand --redirect --preferred-challenges http --cert-name "$domain")
  for d in "${cert_domains[@]}"; do args+=(-d "$d"); done

  log "SSL preflight OK: ${cert_domains[*]} -> $root"
  if ! "${args[@]}" >"$log_file" 2>&1; then
    tail -n 120 "$log_file" >&2 || true
    err "SSL не выпущен: Certbot вернул ошибку. Лог: $log_file. Проверь DNS, 80/443 порты и что домен доступен из интернета."
  fi
  nginx_reload
  log "SSL issued for ${cert_domains[*]} / log: $log_file"
}

cmd_site_php() {
  local domain="${1:-}" version="${2:-}"; [[ -n "$domain" && -n "$version" ]] || err "Domain and PHP version required"; valid_domain "$domain" || err "Invalid domain"
  local conf="$NGINX_AVAILABLE/hyper-host-site-$domain.conf" sock; [[ -f "$conf" ]] || err "Nginx config not found: $conf"; sock="$(php_sock_for_version "$version")"; [[ -S "$sock" ]] || err "PHP-FPM socket not found: $sock"
  sed -i -E "s#fastcgi_pass unix:[^;]+;#fastcgi_pass unix:${sock};#" "$conf"
  nginx_reload; log "PHP version for $domain -> $version"
}

ftp_shell_path() {
  if [[ -x /usr/sbin/nologin ]]; then echo /usr/sbin/nologin; else echo /bin/false; fi
}

ftp_alias_for() {
  local username="${1:-}"
  if [[ "$username" == hhftp_* ]]; then
    printf '%s' "${username#hhftp_}"
  else
    printf 'hhftp_%s' "$username"
  fi
}

ftp_user_variants() {
  local username="${1:-}" alias_user lower lower_alias seen="" u
  alias_user="$(ftp_alias_for "$username")"
  lower="$(printf '%s' "$username" | tr '[:upper:]' '[:lower:]')"
  lower_alias="$(ftp_alias_for "$lower")"
  for u in "$username" "$alias_user" "$lower" "$lower_alias"; do
    [[ -n "$u" ]] || continue
    [[ "$seen" == *"|$u|"* ]] && continue
    valid_name "$u" || continue
    printf '%s
' "$u"
    seen="$seen|$u|"
  done
}

write_ftp_user_conf() {
  local username="${1:-}" common="${2:-}"
  [[ -n "$username" && -n "$common" ]] || return 0
  mkdir -p /etc/vsftpd.user_conf
  cat > "/etc/vsftpd.user_conf/$username" <<EOFUSERCONF
local_root=$common
write_enable=YES
EOFUSERCONF
}

ensure_single_ftp_os_user() {
  local username="${1:-}" password="${2:-}" home="${3:-}" shell tmp
  [[ -n "$username" && -n "$password" && -n "$home" ]] || return 1
  valid_name "$username" || return 1
  shell="$(ftp_shell_path)"
  if id "$username" >/dev/null 2>&1; then
    usermod -d "$home" -s "$shell" "$username" 2>/dev/null || true
  else
    tmp="$(mktemp)"
    if ! useradd -M -d "$home" -s "$shell" -g www-data "$username" 2>"$tmp"; then
      # Ubuntu/Debian могут ругаться на заглавные буквы. Для FTP панели это нормально,
      # поэтому повторяем с --badname, а дополнительно создаём lowercase-алиасы.
      useradd --badname -M -d "$home" -s "$shell" -g www-data "$username" 2>>"$tmp" || { cat "$tmp" >&2; rm -f "$tmp"; return 1; }
    fi
    rm -f "$tmp"
  fi
  usermod -aG www-data "$username" 2>/dev/null || true
  echo "$username:$password" | chpasswd || return 1
  chage -E -1 "$username" 2>/dev/null || true
  passwd -u "$username" >/dev/null 2>&1 || true
  return 0
}

cmd_create_ftp() {
  ensure_dirs
  ensure_nologin_shell
  cleanup_hyper_host_mounts
  local username="${1:-}" password="${2:-}" mode="${3:-common}" variants=() u owner="" alias_note=""
  [[ -n "$username" && -n "$password" ]] || err "Username and password required"
  valid_name "$username" || err "Invalid ftp username"

  # v37: FileZilla/Ubuntu-safe. Создаём точный логин + hhftp_алиас + lowercase варианты.
  # Это чинит кейсы вида hhftp_Danz, когда клиент вводит логин с заглавной буквой,
  # а Linux/панель раньше могли создать другой вариант имени.
  mapfile -t variants < <(ftp_user_variants "$username")
  [[ ${#variants[@]} -gt 0 ]] || err "Invalid ftp username"

  local home="$FTP_DIR/$username" common="$home/common" sites="$common/sites" bots="$common/bots"

  # Chroot-home не должен быть writable пользователем. Рабочая папка — common/.
  mkdir -p "$home" "$common" "$sites" "$bots" "$SITES_DIR" "$BOTS_DIR"
  for u in "${variants[@]}"; do
    if ensure_single_ftp_os_user "$u" "$password" "$home"; then
      [[ -z "$owner" ]] && owner="$u"
      write_ftp_user_conf "$u" "$common"
    fi
  done
  [[ -n "$owner" ]] || err "Не удалось создать FTP Linux-пользователя"

  chown root:root "$home"
  chmod 0755 "$home"
  chown -R "$owner":www-data "$common"
  chmod -R u+rwX,g+rwX,o+rX "$common"
  find "$common" -type d -exec chmod 2775 {} + 2>/dev/null || true

  # В FTP пользователь сразу попадает в common/, внутри common/sites и common/bots — реальные папки панели.
  for pair in "$SITES_DIR:$sites" "$BOTS_DIR:$bots"; do
    local src dst
    src="${pair%%:*}"; dst="${pair#*:}"
    mkdir -p "$src" "$dst"
    if ! mountpoint -q "$dst"; then mount --bind "$src" "$dst" 2>/dev/null || true; fi
    if mountpoint -q "$dst" && ! grep -qs " $dst " /etc/fstab; then echo "$src $dst none bind 0 0" >> /etc/fstab; fi
  done

  for u in "${variants[@]}"; do
    id "$u" >/dev/null 2>&1 || continue
    fix_web_permissions "$SITES_DIR" "$u"
    fix_web_permissions "$BOTS_DIR" "$u"
    fix_web_permissions "$common" "$u"
  done
  ensure_vsftpd_external_access
  systemctl is-active vsftpd >/dev/null 2>&1 || err "vsftpd не запустился. Проверь: systemctl status vsftpd"
  alias_note="$(printf '%s ' "${variants[@]}" | sed 's/[[:space:]]*$//')"
  log "FTP user ready: $username -> $common (aliases: $alias_note, 0.0.0.0:21, passive 40000-40100)"
}
cmd_delete_ftp() {
  local username="${1:-}" tmp variants=() u
  [[ -n "$username" ]] || err "Username required"
  valid_name "$username" || err "Invalid username"
  mapfile -t variants < <(ftp_user_variants "$username")
  local home
  home="$(getent passwd "$username" | cut -d: -f6 || true)"
  [[ -n "$home" && "$home" == "$FTP_DIR"/* ]] || home="$FTP_DIR/$username"
  for d in "$home/common/sites" "$home/common/bots" "$home/sites" "$home/bots" "$home/site"; do mountpoint -q "$d" && umount -lf "$d" || true; done
  if [[ -f /etc/fstab ]]; then
    tmp="$(mktemp)"
    grep -vF " $home/common/sites " /etc/fstab | grep -vF " $home/common/bots " | grep -vF " $home/sites " | grep -vF " $home/bots " | grep -vF " $home/site " > "$tmp" || true
    cat "$tmp" > /etc/fstab; rm -f "$tmp"
  fi
  for u in "${variants[@]}"; do
    if id "$u" >/dev/null 2>&1; then
      local uh
      uh="$(getent passwd "$u" | cut -d: -f6)"
      [[ "$uh" == "$home" ]] && userdel "$u" || true
    fi
    rm -f "/etc/vsftpd.user_conf/$u" 2>/dev/null || true
  done
  rm -rf "$home"
  systemctl restart vsftpd || true
  log "FTP user deleted: $username"
}
cmd_ftp_password() {
  local username="${1:-}" password="${2:-}" variants=() u owner="" home="" common=""
  [[ -n "$username" && -n "$password" ]] || err "Username and password required"
  valid_name "$username" || err "Invalid username"
  mapfile -t variants < <(ftp_user_variants "$username")
  [[ ${#variants[@]} -gt 0 ]] || err "Invalid ftp username"
  home="$(getent passwd "$username" | cut -d: -f6 || true)"
  [[ -n "$home" && "$home" == "$FTP_DIR"/* ]] || home="$FTP_DIR/$username"
  common="$home/common"
  mkdir -p "$common" "$common/sites" "$common/bots"
  for u in "${variants[@]}"; do
    if ensure_single_ftp_os_user "$u" "$password" "$home"; then
      [[ -z "$owner" ]] && owner="$u"
      write_ftp_user_conf "$u" "$common"
    fi
  done
  [[ -n "$owner" ]] || err "Не удалось восстановить FTP Linux-пользователя"
  chown root:root "$home" 2>/dev/null || true
  chmod 0755 "$home" 2>/dev/null || true
  chown -R "$owner":www-data "$common" 2>/dev/null || true
  chmod -R u+rwX,g+rwX,o+rX "$common" 2>/dev/null || true
  find "$common" -type d -exec chmod 2775 {} + 2>/dev/null || true
  for pair in "$SITES_DIR:$common/sites" "$BOTS_DIR:$common/bots"; do
    local src dst
    src="${pair%%:*}"; dst="${pair#*:}"
    mkdir -p "$src" "$dst"
    mountpoint -q "$dst" || mount --bind "$src" "$dst" 2>/dev/null || true
    mountpoint -q "$dst" && grep -qs " $dst " /etc/fstab || echo "$src $dst none bind 0 0" >> /etc/fstab
  done
  for u in "${variants[@]}"; do
    id "$u" >/dev/null 2>&1 || continue
    fix_web_permissions "$SITES_DIR" "$u"
    fix_web_permissions "$BOTS_DIR" "$u"
    fix_web_permissions "$common" "$u"
  done
  ensure_vsftpd_external_access
  log "FTP password/login repaired: $username (aliases: $(printf '%s ' "${variants[@]}" | sed 's/[[:space:]]*$//'))"
}

cmd_ftp_test_login() {
  local username="${1:-}" password="${2:-}" host="${3:-127.0.0.1}"
  [[ -n "$username" && -n "$password" ]] || err "Используй: sudo hyper ftp test LOGIN PASSWORD [HOST]"
  python3 - "$host" "$username" "$password" <<'PYFTPTEST'
import ftplib, sys
host,user,pw=sys.argv[1],sys.argv[2],sys.argv[3]
try:
    ftp=ftplib.FTP()
    ftp.connect(host,21,timeout=8)
    banner=getattr(ftp,'welcome','')
    ftp.login(user,pw)
    ftp.set_pasv(True)
    items=ftp.nlst()
    ftp.quit()
    print('OK: FTP login works')
    print('host:', host)
    print('user:', user)
    print('banner:', banner)
    print('items:', ', '.join(items[:20]) if items else '(empty)')
except Exception as e:
    print('ERROR:', type(e).__name__, str(e))
    sys.exit(1)
PYFTPTEST
}

cmd_create_db() {
  local db="${1:-}" user="${2:-}" pass="${3:-}" remote="${4:-0}" host_pattern="${5:-}"
  [[ -n "$db" && -n "$user" && -n "$pass" ]] || err "DB, user and password required"
  valid_db_name "$db" || err "Invalid db name"
  valid_db_name "$user" || err "Invalid db user"
  local epass; epass="$(sql_escape "$pass")"
  [[ -z "$host_pattern" ]] && { [[ "$remote" == "1" ]] && host_pattern="%" || host_pattern="localhost"; }
  validate_mysql_host_pattern "$host_pattern"
  mysql <<SQL
CREATE DATABASE IF NOT EXISTS \`${db}\` CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
CREATE USER IF NOT EXISTS '${user}'@'localhost' IDENTIFIED BY '${epass}';
ALTER USER '${user}'@'localhost' IDENTIFIED BY '${epass}';
GRANT ALL PRIVILEGES ON \`${db}\`.* TO '${user}'@'localhost';
SQL
  if [[ "$remote" == "1" ]]; then mysql <<SQL
CREATE USER IF NOT EXISTS '${user}'@'${host_pattern}' IDENTIFIED BY '${epass}';
ALTER USER '${user}'@'${host_pattern}' IDENTIFIED BY '${epass}';
GRANT ALL PRIVILEGES ON \`${db}\`.* TO '${user}'@'${host_pattern}';
SQL
  fi
  mysql -e "FLUSH PRIVILEGES;"
  log "Database created: $db / $user / remote=$remote host=$host_pattern"
}

cmd_delete_db() {
  local db="${1:-}" user="${2:-}"
  [[ -n "$db" && -n "$user" ]] || err "DB and user required"
  valid_db_name "$db" || err "Invalid db"
  valid_db_name "$user" || err "Invalid user"
  mysql -e "DROP DATABASE IF EXISTS \`${db}\`; DROP USER IF EXISTS '${user}'@'localhost'; DROP USER IF EXISTS '${user}'@'%'; FLUSH PRIVILEGES;"
  mysql -N -B -e "SELECT Host FROM mysql.user WHERE User='$(sql_escape "$user")'" 2>/dev/null | while read -r h; do [[ -n "$h" ]] && mysql -e "DROP USER IF EXISTS '${user}'@'${h}';" || true; done
  mysql -e "FLUSH PRIVILEGES;"
  log "Database deleted: $db / $user"
}

validate_mysql_host_pattern() {
  local h="${1:-}"
  [[ "$h" == "localhost" || "$h" == "%" ]] && return 0
  [[ "$h" =~ ^[0-9]{1,3}(\.[0-9]{1,3}){3}$ ]] && return 0
  [[ "$h" =~ ^[A-Za-z0-9._%-]{1,128}$ ]] && return 0
  err "Invalid MySQL host pattern: $h"
}

cmd_create_mysql_account() {
  local user="${1:-}" pass="${2:-}" host="${3:-localhost}" db="${4:-}" priv="${5:-ALL}"
  [[ -n "$user" && -n "$pass" ]] || err "User and password required"
  valid_db_name "$user" || err "Invalid MySQL user"
  validate_mysql_host_pattern "$host"
  [[ -z "$db" || "$db" == "*" || "$db" == "*.*" || "$db" =~ ^[A-Za-z0-9_]{2,48}$ ]] || err "Invalid db name"
  [[ "$priv" =~ ^(ALL|SELECT|READ)$ ]] || priv="ALL"
  local epass; epass="$(sql_escape "$pass")"
  mysql <<SQL
CREATE USER IF NOT EXISTS '${user}'@'${host}' IDENTIFIED BY '${epass}';
ALTER USER '${user}'@'${host}' IDENTIFIED BY '${epass}';
SQL
  if [[ -n "$db" && "$db" != "*" && "$db" != "*.*" ]]; then
    mysql -e "CREATE DATABASE IF NOT EXISTS \`${db}\` CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;"
    if [[ "$priv" == "SELECT" || "$priv" == "READ" ]]; then
      mysql -e "GRANT SELECT, SHOW VIEW ON \`${db}\`.* TO '${user}'@'${host}';"
    else
      mysql -e "GRANT ALL PRIVILEGES ON \`${db}\`.* TO '${user}'@'${host}';"
    fi
  elif [[ "$db" == "*" || "$db" == "*.*" ]]; then
    mysql -e "GRANT ALL PRIVILEGES ON *.* TO '${user}'@'${host}' WITH GRANT OPTION;"
  else
    mysql -e "GRANT USAGE ON *.* TO '${user}'@'${host}';"
  fi
  mysql -e "FLUSH PRIVILEGES;"
  log "MySQL/phpMyAdmin account ready: ${user}@${host} db=${db:-usage}"
}

cmd_delete_mysql_account() {
  local user="${1:-}" host="${2:-localhost}"
  [[ -n "$user" ]] || err "User required"
  valid_db_name "$user" || err "Invalid MySQL user"
  validate_mysql_host_pattern "$host"
  mysql -e "DROP USER IF EXISTS '${user}'@'${host}'; FLUSH PRIVILEGES;"
  log "MySQL account deleted: ${user}@${host}"
}

cmd_mysql_external() {
  local state="${1:-}"
  [[ "$state" == enable || "$state" == disable ]] || err "Use enable or disable"
  local file="/etc/mysql/mariadb.conf.d/50-server.cnf"
  [[ -f "$file" ]] || file="/etc/mysql/my.cnf"
  cp "$file" "$file.backup.$(date +%s)" || true
  local value="127.0.0.1"
  [[ "$state" == enable ]] && value="0.0.0.0"
  python3 - "$file" "$value" <<'PYSET'
from pathlib import Path
import sys,re
path=Path(sys.argv[1]); value=sys.argv[2]
text=path.read_text(errors='ignore') if path.exists() else ''
if '[mysqld]' not in text:
    text='[mysqld]\n'+text
# выключаем skip-networking, если было
text=re.sub(r'^\s*skip-networking\s*$', '# skip-networking disabled by HYPER-HOST', text, flags=re.M)
if re.search(r'^\s*bind-address\s*=', text, re.M):
    text=re.sub(r'^\s*bind-address\s*=.*$', f'bind-address = {value}', text, flags=re.M)
else:
    text=text.replace('[mysqld]', '[mysqld]\nbind-address = '+value, 1)
path.write_text(text)
PYSET
  if [[ "$state" == enable ]]; then
    iptables -C INPUT -p tcp --dport 3306 -j ACCEPT 2>/dev/null || iptables -I INPUT -p tcp --dport 3306 -j ACCEPT || true
    ufw allow 3306/tcp >/dev/null 2>&1 || true
  else
    ufw delete allow 3306/tcp >/dev/null 2>&1 || true
  fi
  systemctl restart mariadb || systemctl restart mysql || true
  sleep 1
  log "MySQL external access: $state (bind-address=$value, external host=${PANEL_DOMAIN:-$PUBLIC_IP})"
}

cmd_mysql_status_json() {
  python3 - <<'PYIN'
import json, subprocess, re, os, socket

def sh(cmd):
    try: return subprocess.check_output(cmd, shell=True, text=True, stderr=subprocess.DEVNULL).strip()
    except Exception: return ''

bind=''
for f in ['/etc/mysql/mariadb.conf.d/50-server.cnf','/etc/mysql/my.cnf']:
    if os.path.exists(f):
        txt=open(f,errors='ignore').read()
        m=re.findall(r'^\s*bind-address\s*=\s*(\S+)', txt, re.M)
        if m: bind=m[-1]
listen=':3306' in sh("ss -lntp | grep ':3306' || true")
service=sh('systemctl is-active mariadb || systemctl is-active mysql || true')
panel=os.environ.get('PANEL_DOMAIN','')
public=os.environ.get('PUBLIC_IP','')
server=os.environ.get('SERVER_IP','')
external = panel if panel and panel != '_' else public
users=[]
raw=sh("mysql -N -B -e \"SELECT User,Host FROM mysql.user WHERE User NOT IN ('root','mariadb.sys','mysql','debian-sys-maint') ORDER BY User,Host\" 2>/dev/null || true")
for line in raw.splitlines():
    p=line.split('\t')
    if len(p)>=2: users.append({'user':p[0], 'host':p[1]})
print(json.dumps({
  'bind_address': bind or 'default',
  'listen_3306': listen,
  'service': service,
  'external_host': external,
  'public_ip': public,
  'lan_host': server,
  'internal_host': '127.0.0.1',
  'panel_domain': panel,
  'port': '3306',
  'users': users,
}, ensure_ascii=False))
PYIN
}

cmd_mysql_doctor_json() {
  python3 - <<'PYDOC'
import json, os, socket, subprocess

def sh(cmd):
    try: return subprocess.check_output(cmd, shell=True, text=True, stderr=subprocess.DEVNULL).strip()
    except Exception as e: return ''

def tcp(host, port, timeout=2):
    try:
        s=socket.create_connection((host,int(port)), timeout=timeout); s.close(); return True
    except Exception: return False
panel=os.environ.get('PANEL_DOMAIN','')
public=os.environ.get('PUBLIC_IP','')
server=os.environ.get('SERVER_IP','')
listen=':3306' in sh("ss -lntp | grep ':3306' || true")
local_tcp=tcp('127.0.0.1',3306)
lan_tcp=tcp(server,3306) if server else False
external_host=panel if panel and panel!='_' else public
# Внешний host с самого сервера может не работать из-за NAT loopback, поэтому это warning, не fail.
external_tcp=tcp(external_host,3306) if external_host else False
bind=''
for f in ['/etc/mysql/mariadb.conf.d/50-server.cnf','/etc/mysql/my.cnf']:
    if os.path.exists(f):
        import re
        txt=open(f,errors='ignore').read(); m=re.findall(r'^\s*bind-address\s*=\s*(\S+)', txt, re.M)
        if m: bind=m[-1]
problem=''
if not listen or not local_tcp:
    problem='MariaDB не слушает 3306 на сервере. Выполни: sudo hyper db external enable'
elif bind not in ('0.0.0.0','::','default','') and bind.startswith('127.'):
    problem='MariaDB привязана к 127.0.0.1. Для внешнего входа выполни: sudo hyper db external enable'
print(json.dumps({
  'service': sh('systemctl is-active mariadb || systemctl is-active mysql || true'),
  'bind_address': bind or 'default',
  'listen_3306': listen,
  'local_127_0_0_1': local_tcp,
  'lan_host': server,
  'lan_3306': lan_tcp,
  'external_host': external_host,
  'external_3306_from_server': external_tcp,
  'note': 'Если бот на ПК в этой же Wi-Fi сети — используй MYSQL_HOST=%s. Если бот вне сети — используй MYSQL_HOST=%s и проброс TCP 3306 на роутере.' % (server or '192.168.x.x', external_host or 'PUBLIC_IP'),
  'problem': problem,
}, ensure_ascii=False))
PYDOC
}

cmd_mysql_test() {
  local host="${1:-127.0.0.1}" user="${2:-}" pass="${3:-}" db="${4:-}"
  [[ -n "$user" && -n "$pass" ]] || err "Use: mysql-test HOST USER PASSWORD [DB]"
  local opt_db=(); [[ -n "$db" ]] && opt_db=("$db")
  MYSQL_PWD="$pass" mysql -h "$host" -P 3306 -u "$user" -e "SELECT 'ok' AS hyper_host_mysql_test, USER() AS mysql_user, CURRENT_USER() AS grants_user, VERSION() AS version;" "${opt_db[@]}"
}


configure_phpmyadmin_label() {
  mkdir -p /etc/phpmyadmin/conf.d
  local pma_host="${PANEL_DOMAIN:-}"
  [[ -z "$pma_host" || "$pma_host" == "_" ]] && pma_host="${PUBLIC_IP:-${SERVER_IP:-127.0.0.1}}"
  cat > /etc/phpmyadmin/conf.d/hyper-host-server.php <<EOPMA
<?php
// HYPER-HOST: показываем понятный SQL host в phpMyAdmin.
if (isset(\$i)) {
    \$cfg['Servers'][\$i]['verbose'] = '${pma_host}:3306';
    \$cfg['Servers'][\$i]['host'] = '127.0.0.1';
    \$cfg['Servers'][\$i]['port'] = '3306';
}
EOPMA
  chmod 0644 /etc/phpmyadmin/conf.d/hyper-host-server.php || true
}

cmd_phpmyadmin_fix() {
  configure_phpmyadmin_label
  log "phpMyAdmin label fixed: ${PANEL_DOMAIN:-${PUBLIC_IP:-${SERVER_IP:-127.0.0.1}}}:3306"
}

ensure_bot_user() {
  id "$BOT_USER" >/dev/null 2>&1 || useradd --system --home "$BOTS_DIR" --shell /usr/sbin/nologin "$BOT_USER"
  usermod -d "$BOTS_DIR" -s /usr/sbin/nologin "$BOT_USER" 2>/dev/null || true
  usermod -aG www-data "$BOT_USER" 2>/dev/null || true
  mkdir -p "$BOTS_DIR" "$PM2_HOME_DIR"
  # Не делаем chown -R по всем ботам на каждом открытии вкладки — это сильно тормозит панель.
  chown "$BOT_USER":www-data "$BOTS_DIR" "$PM2_HOME_DIR" 2>/dev/null || true
  find "$PM2_HOME_DIR" -xdev -maxdepth 2 -exec chown -h "$BOT_USER":www-data {} + 2>/dev/null || true
  chmod 2775 "$BOTS_DIR" "$PM2_HOME_DIR" 2>/dev/null || true
}
node_major() { node -v 2>/dev/null | sed 's/^v//' | cut -d. -f1 | grep -E '^[0-9]+$' || echo 0; }
ensure_node_runtime() {
  apt-get update -y >/dev/null 2>&1 || true
  apt-get install -y curl ca-certificates gnupg >/dev/null 2>&1 || true
  dpkg --configure -a >/tmp/hyper-host-dpkg-configure.log 2>&1 || true
  apt-get -f install -y >/tmp/hyper-host-apt-fix.log 2>&1 || true
  local major; major="$(node_major)"
  if [[ "$major" -lt "$NODE_MAJOR_MIN" ]]; then
    log "Node.js слишком старый или сломан: $(node -v 2>/dev/null || echo none). Чищу старые node/npm/libnode-dev и ставлю Node.js 20.x."
    apt-get remove -y npm nodejs libnode-dev node-gyp nodejs-doc >/tmp/hyper-host-node-remove.log 2>&1 || true
    apt-get autoremove -y >/tmp/hyper-host-node-autoremove.log 2>&1 || true
    rm -f /etc/apt/sources.list.d/nodesource*.list /etc/apt/keyrings/nodesource.gpg 2>/dev/null || true
    curl -fsSL https://deb.nodesource.com/setup_20.x | bash - >/tmp/hyper-host-nodesource.log 2>&1 || true
    apt-get update -y >/dev/null 2>&1 || true
    apt-get install -y nodejs >/tmp/hyper-host-node-install.log 2>&1 || apt-get install -y nodejs npm || true
  fi
  command -v npm >/dev/null 2>&1 || apt-get install -y npm || true
}
ensure_pm2() {
  command -v python3 >/dev/null 2>&1 || apt-get install -y python3
  command -v pip3 >/dev/null 2>&1 || apt-get install -y python3-pip
  python3 -m venv --help >/dev/null 2>&1 || apt-get install -y python3-venv
  ensure_node_runtime
  if ! command -v pm2 >/dev/null 2>&1; then npm install -g pm2@latest; fi
  ensure_bot_user
  pm2_as_bot ping >/dev/null 2>&1 || true
  pm2_as_bot save --force >/dev/null 2>&1 || pm2_as_bot save >/dev/null 2>&1 || true
  install_hyperbot_pm2_service
}
pm2_as_bot() {
  sudo -u "$BOT_USER" -H env HOME="$BOTS_DIR" PM2_HOME="$PM2_HOME_DIR" PATH="/usr/local/bin:/usr/bin:/bin" pm2 "$@"
}
run_as_bot() {
  sudo -u "$BOT_USER" -H env HOME="$BOTS_DIR" PM2_HOME="$PM2_HOME_DIR" PATH="/usr/local/bin:/usr/bin:/bin" "$@"
}

install_hyperbot_pm2_service() {
  # HYPER-HOST v13: боты должны жить 24/7 независимо от открытой консоли/панели.
  # Поэтому PM2 запускается как systemd-сервис от пользователя hyperbot и поднимает сохранённый dump.pm2 после reboot.
  ensure_bot_user
  local pm2_bin
  pm2_bin="$(command -v pm2 || true)"
  [[ -n "$pm2_bin" ]] || return 0
  mkdir -p "$PM2_HOME_DIR"
  chown "$BOT_USER":www-data "$BOTS_DIR" "$PM2_HOME_DIR" 2>/dev/null || true
  chmod 2775 "$BOTS_DIR" "$PM2_HOME_DIR" 2>/dev/null || true
  cat > /etc/systemd/system/hyperbot-pm2.service <<EOSVC
[Unit]
Description=HYPER-HOST PM2 24/7 bots runtime
Documentation=https://github.com/memes4u1337/hyper-hosting-panel
After=network-online.target
Wants=network-online.target

[Service]
Type=forking
User=${BOT_USER}
LimitNOFILE=infinity
LimitNPROC=infinity
LimitCORE=infinity
Environment=HOME=${BOTS_DIR}
Environment=PM2_HOME=${PM2_HOME_DIR}
Environment=PATH=/usr/local/bin:/usr/bin:/bin
PIDFile=${PM2_HOME_DIR}/pm2.pid
ExecStart=/bin/bash -lc '${pm2_bin} resurrect || ${pm2_bin} ping'
ExecReload=/bin/bash -lc '${pm2_bin} reload all || true'
ExecStop=/bin/bash -lc '${pm2_bin} save --force || ${pm2_bin} save || true'
ExecStop=/bin/bash -lc '${pm2_bin} kill || true'
Restart=on-failure
RestartSec=5
TimeoutStartSec=120
TimeoutStopSec=60
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
EOSVC
  systemctl daemon-reload >/dev/null 2>&1 || true
  systemctl enable hyperbot-pm2.service >/dev/null 2>&1 || true
  systemctl start hyperbot-pm2.service >/dev/null 2>&1 || true
}

pm2_persist() {
  # Сохраняем текущий список PM2 и включаем автоподъём через systemd.
  ensure_bot_user
  mkdir -p "$PM2_HOME_DIR"
  chown "$BOT_USER":www-data "$BOTS_DIR" "$PM2_HOME_DIR" 2>/dev/null || true
  pm2_as_bot save --force >/dev/null 2>&1 || pm2_as_bot save >/dev/null 2>&1 || true
  install_hyperbot_pm2_service
}

cmd_pm2_persist() {
  ensure_pm2
  pm2_persist
  log "PM2 24/7 autostart enabled for $BOT_USER. Боты продолжат работать после закрытия панели/SSH и поднимутся после перезагрузки."
}
make_bot_start_script() {
  local name="$1" runtime="$2" main_file="$3" path="$BOTS_DIR/$name" mem="${4:-0}"
  mkdir -p "$path"
  main_file="$(basename "$main_file")"

  # HYPER-HOST v24: раньше .hyper-start.sh мог получить пустой interpreter и падал:
  #   .hyper-start.sh: line 4: : No such file or directory
  # Теперь стартовый файл сам находит interpreter внутри папки бота и пишет понятную ошибку.
  cat > "$path/.hyper-start.sh" <<EOS
#!/usr/bin/env bash
set -Eeuo pipefail
cd "\$(cd "\$(dirname "\${BASH_SOURCE[0]}")" && pwd)"
LOCK=".hyper-bot.lock"
exec 9>"\$LOCK"
if ! flock -n 9; then
  echo "HYPER-HOST: bot ${name} уже запущен, дубль остановлен"
  exit 0
fi
if [[ -f .env ]]; then
  set -a
  # shellcheck disable=SC1091
  source .env
  set +a
fi
MAIN_FILE="${main_file}"
if [[ ! -f "\$MAIN_FILE" ]]; then
  echo "HYPER-HOST ERROR: главный файл не найден: \$(pwd)/\$MAIN_FILE"
  echo "Проверь поле 'Главный файл' в панели и загруженные файлы бота."
  exit 127
fi
case "${runtime}" in
  python)
    if [[ -x ./venv/bin/python ]]; then exec ./venv/bin/python "\$MAIN_FILE"; fi
    if command -v python3 >/dev/null 2>&1; then exec python3 "\$MAIN_FILE"; fi
    if command -v python >/dev/null 2>&1; then exec python "\$MAIN_FILE"; fi
    echo "HYPER-HOST ERROR: python3 не найден. Выполни: sudo apt install -y python3 python3-venv python3-pip"
    exit 127
    ;;
  node)
    if command -v node >/dev/null 2>&1; then exec node "\$MAIN_FILE"; fi
    echo "HYPER-HOST ERROR: node не найден. Выполни: sudo apt install -y nodejs npm"
    exit 127
    ;;
  php)
    if command -v php >/dev/null 2>&1; then exec php "\$MAIN_FILE"; fi
    echo "HYPER-HOST ERROR: php-cli не найден. Выполни: sudo apt install -y php-cli"
    exit 127
    ;;
  custom)
    exec bash -lc "./\$MAIN_FILE"
    ;;
  *)
    echo "HYPER-HOST ERROR: неизвестный runtime: ${runtime}"
    exit 2
    ;;
esac
EOS
  chmod +x "$path/.hyper-start.sh"
  chown "$BOT_USER":www-data "$path/.hyper-start.sh" 2>/dev/null || true
}
bot_install_deps_internal() {
  local name="$1" runtime="${2:-python}" path="$BOTS_DIR/$name"
  [[ -d "$path" ]] || err "Bot folder not found"
  ensure_bot_user
  chown -R "$BOT_USER":www-data "$path" 2>/dev/null || true
  fix_web_permissions "$path" "$BOT_USER"
  if [[ "$runtime" == "python" && -f "$path/requirements.txt" ]]; then
    run_as_bot python3 -m venv "$path/venv"
    run_as_bot "$path/venv/bin/python" -m pip install --upgrade pip wheel setuptools
    run_as_bot "$path/venv/bin/pip" install -r "$path/requirements.txt"
    log "Python requirements installed in venv for $name"
  elif [[ "$runtime" == "node" && -f "$path/package.json" ]]; then
    (cd "$path" && run_as_bot npm install)
    log "Node packages installed for $name"
  elif [[ "$runtime" == "php" && -f "$path/composer.json" ]]; then
    if command -v composer >/dev/null 2>&1; then (cd "$path" && run_as_bot composer install --no-interaction); fi
    log "PHP dependencies checked for $name"
  else
    log "No dependency file found for $name"
  fi
  fix_web_permissions "$path" "$BOT_USER"
}
bot_token_from_path() {
  local path="$1"
  [[ -d "$path" ]] || return 0
  grep -RhoE '[0-9]{8,12}:[A-Za-z0-9_-]{25,}' "$path" 2>/dev/null | head -n1 || true
}

telegram_delete_webhook_for_token() {
  local token="$1"
  [[ -n "$token" ]] || return 0
  curl -fsS --max-time 6 "https://api.telegram.org/bot${token}/deleteWebhook?drop_pending_updates=true" >/dev/null 2>&1 || true
}

bot_stop_same_token_local() {
  local name="$1" path="$2" token other other_name
  token="$(bot_token_from_path "$path")"
  [[ -n "$token" ]] || return 0
  telegram_delete_webhook_for_token "$token"
  shopt -s nullglob
  for other in "$BOTS_DIR"/*; do
    [[ -d "$other" ]] || continue
    [[ "$other" == "$path" ]] && continue
    if grep -RqsF "$token" "$other" 2>/dev/null; then
      other_name="$(basename "$other")"
      pm2_as_bot stop "$other_name" >/dev/null 2>&1 || true
      pm2_as_bot delete "$other_name" >/dev/null 2>&1 || true
      pm2 stop "$other_name" >/dev/null 2>&1 || true
      pm2 delete "$other_name" >/dev/null 2>&1 || true
      pkill -f "$other" >/dev/null 2>&1 || true
    fi
  done
  shopt -u nullglob
}

bot_stop_duplicates() {
  local name="$1" path="$BOTS_DIR/$name"
  # TelegramConflictError возникает, когда один и тот же токен запущен в двух процессах.
  # Перед стартом нового бота гасим старые локальные копии с таким же именем/папкой в PM2 root и PM2 hyperbot.
  pm2_as_bot stop "$name" >/dev/null 2>&1 || true
  pm2_as_bot delete "$name" >/dev/null 2>&1 || true
  if command -v pm2 >/dev/null 2>&1; then
    PM2_HOME=/root/.pm2 pm2 stop "$name" >/dev/null 2>&1 || true
    PM2_HOME=/root/.pm2 pm2 delete "$name" >/dev/null 2>&1 || true
    pm2 stop "$name" >/dev/null 2>&1 || true
    pm2 delete "$name" >/dev/null 2>&1 || true
  fi
  systemctl stop "hyperbot-$name.service" >/dev/null 2>&1 || true
  systemctl disable "hyperbot-$name.service" >/dev/null 2>&1 || true
  # Убиваем только процессы, которые запущены из папки конкретного бота.
  if [[ -d "$path" ]]; then
    pkill -f "$path/.*(bot\.py|main\.py|index\.py|\.hyper-start\.sh)" >/dev/null 2>&1 || true
  fi
}

bot_start_pm2() {
  local name="$1" runtime="$2" main_file="$3" mem="${4:-0}" path="$BOTS_DIR/$name"
  ensure_pm2
  [[ -f "$path/$main_file" ]] || err "Главный файл не найден: $path/$main_file"
  bot_stop_duplicates "$name"
  make_bot_start_script "$name" "$runtime" "$main_file" "$mem"
  local mem_arg=(); [[ "$mem" =~ ^[0-9]+$ && "$mem" -gt 0 ]] && mem_arg+=(--max-memory-restart "${mem}M")
  (cd "$path" && pm2_as_bot start ./.hyper-start.sh --name "$name" --interpreter bash "${mem_arg[@]}")
  pm2_persist
  log "PM2 started: $name (user=$BOT_USER, PM2_HOME=$PM2_HOME_DIR, autostart=systemd)"
}
normalize_main_file() {
  local runtime="$1" main_file="${2:-}"
  if [[ -z "$main_file" ]]; then
    case "$runtime" in python) main_file="bot.py";; node) main_file="index.js";; php) main_file="bot.php";; custom) main_file="start.sh";; esac
  fi
  main_file="${main_file#python3 }"; main_file="${main_file#python }"; main_file="${main_file#node }"; main_file="${main_file#php }"; basename "$main_file"
}
cmd_bot_create() {
  ensure_dirs; ensure_pm2
  local name="${1:-}" runtime="${2:-python}" main_file="${3:-}" mem="${4:-0}" proc_limit="${5:-0}"
  [[ -n "$name" ]] || err "Bot name required"; valid_name "$name" || err "Invalid bot name"; [[ "$runtime" =~ ^(python|node|php|custom)$ ]] || err "Invalid runtime"
  main_file="$(normalize_main_file "$runtime" "$main_file")"
  local path="$BOTS_DIR/$name"; mkdir -p "$path"
  [[ -f "$path/.env" ]] || echo '# BOT_TOKEN=put_token_here' > "$path/.env"
  if [[ "$runtime" == python && ! -f "$path/$main_file" ]]; then cat > "$path/$main_file" <<'PYBOT'
import time
print('HYPER-HOST bot template started', flush=True)
while True:
    time.sleep(60)
PYBOT
  fi
  if [[ "$runtime" == node && ! -f "$path/$main_file" ]]; then echo "setInterval(()=>console.log('HYPER-HOST node bot'),60000);" > "$path/$main_file"; fi
  if [[ "$runtime" == php && ! -f "$path/$main_file" ]]; then echo "<?php while(true){ echo 'HYPER-HOST php bot'.PHP_EOL; sleep(60); }" > "$path/$main_file"; fi
  chown -R "$BOT_USER":www-data "$path" 2>/dev/null || true
  fix_web_permissions "$path" "$BOT_USER"
  bot_install_deps_internal "$name" "$runtime"
  bot_start_pm2 "$name" "$runtime" "$main_file" "$mem"
  fix_web_permissions "$path" "$BOT_USER"
  log "PM2 bot created: $name / main=$main_file"
}
cmd_bot_deploy() {
  ensure_dirs; ensure_pm2
  local name="${1:-}" runtime="${2:-python}" main_file="${3:-bot.py}" bot_tmp="${4:-}" env_tmp="${5:-}" req_tmp="${6:-}" mem="${7:-0}"
  [[ -n "$name" ]] || err "Bot name required"; valid_name "$name" || err "Invalid bot name"; [[ "$runtime" =~ ^(python|node|php|custom)$ ]] || err "Invalid runtime"
  main_file="$(normalize_main_file "$runtime" "$main_file")"
  local path="$BOTS_DIR/$name"; mkdir -p "$path"
  if [[ -n "$bot_tmp" && -f "$bot_tmp" ]]; then cp "$bot_tmp" "$path/$main_file"; fi
  if [[ -n "$env_tmp" && -f "$env_tmp" ]]; then cp "$env_tmp" "$path/.env"; elif [[ ! -f "$path/.env" ]]; then echo '# BOT_TOKEN=put_token_here' > "$path/.env"; fi
  if [[ -n "$req_tmp" && -f "$req_tmp" ]]; then
    if [[ "$runtime" == "node" ]]; then cp "$req_tmp" "$path/package.json"; else cp "$req_tmp" "$path/requirements.txt"; fi
  fi
  [[ -f "$path/$main_file" ]] || err "Главный файл бота не найден: $main_file. Загрузи bot.py / index.js / bot.php."
  chown -R "$BOT_USER":www-data "$path" 2>/dev/null || true
  fix_web_permissions "$path" "$BOT_USER"
  bot_install_deps_internal "$name" "$runtime"
  bot_start_pm2 "$name" "$runtime" "$main_file" "$mem"
  fix_web_permissions "$path" "$BOT_USER"
  log "Bot deployed and started: $name / main=$main_file"
}
cmd_bot_install_requirements() { local name="${1:-}"; [[ -n "$name" ]] || err "Bot name required"; valid_name "$name" || err "Invalid bot"; local runtime="${2:-python}"; ensure_pm2; bot_install_deps_internal "$name" "$runtime"; fix_web_permissions "$BOTS_DIR/$name" "$BOT_USER"; }
cmd_bot_delete() {
  local name="${1:-}" mode="${2:---keep-files}"
  [[ -n "$name" ]] || err "Bot name required"; valid_name "$name" || err "Invalid bot"
  ensure_pm2
  pm2_as_bot stop "$name" >/dev/null 2>&1 || true
  pm2_as_bot delete "$name" >/dev/null 2>&1 || true
  pm2_persist
  if [[ "$mode" == "--delete-files" || "$mode" == "--purge" ]]; then
    local bot_path="$BOTS_DIR/$name"
    if [[ -d "$bot_path" && "$bot_path" == "$BOTS_DIR/"* ]]; then
      rm -rf --one-file-system "$bot_path"
    fi
    log "Bot deleted: $name / files removed"
  else
    log "Bot deleted from PM2 only: $name / files kept"
  fi
}
cmd_bot_action() {
  local action="${1:-}" name="${2:-}"
  [[ "$action" =~ ^(start|stop|restart|status|logs|kill-conflicts)$ ]] || err "Invalid bot action"
  [[ -n "$name" ]] || err "Bot name required"; valid_name "$name" || err "Invalid bot"
  ensure_pm2
  case "$action" in
    start|restart)
      # HYPER-HOST v24: всегда пересобираем .hyper-start.sh перед стартом,
      # чтобы старые битые start-файлы с пустым interpreter не ломали запуск.
      local bot_dir="$BOTS_DIR/$name" runtime="python" main_file=""
      [[ -d "$bot_dir" ]] || err "Папка бота не найдена: $bot_dir"
      if [[ -f "$bot_dir/bot.py" ]]; then runtime="python"; main_file="bot.py";
      elif [[ -f "$bot_dir/main.py" ]]; then runtime="python"; main_file="main.py";
      elif [[ -f "$bot_dir/index.py" ]]; then runtime="python"; main_file="index.py";
      elif [[ -f "$bot_dir/index.js" ]]; then runtime="node"; main_file="index.js";
      elif [[ -f "$bot_dir/bot.php" ]]; then runtime="php"; main_file="bot.php";
      elif [[ -f "$bot_dir/start.sh" ]]; then runtime="custom"; main_file="start.sh";
      else
        err "Не найден главный файл бота. Нужен bot.py, main.py, index.py, index.js, bot.php или start.sh в $bot_dir"
      fi
      make_bot_start_script "$name" "$runtime" "$main_file" 0
      bot_stop_duplicates "$name"
      (cd "$bot_dir" && pm2_as_bot start ./.hyper-start.sh --name "$name" --interpreter bash)
      pm2_persist
      ;;
    stop)
      pm2_as_bot stop "$name" || true
      pm2_persist
      ;;
    kill-conflicts)
      bot_stop_duplicates "$name"
      pm2_persist
      log "Local duplicate bot processes killed: $name"
      ;;
    status)
      BOTNAME="$name" pm2_as_bot jlist | BOTNAME="$name" python3 -c 'import sys,json,os; data=json.load(sys.stdin); name=os.environ.get("BOTNAME",""); print(next((p.get("pm2_env",{}).get("status","") for p in data if p.get("name")==name), "not_found"))'
      ;;
    logs)
      pm2_as_bot logs "$name" --lines 250 --nostream || true
      ;;
  esac
}
cmd_bot_list_json() {
  ensure_pm2
  pm2_as_bot jlist 2>/dev/null | python3 -c 'import sys,json,os,time
try:
    data=json.load(sys.stdin)
except Exception:
    data=[]

def rss_from_pid(pid):
    try:
        pid=int(pid or 0)
        if pid <= 0: return 0
        with open(f"/proc/{pid}/status", encoding="utf-8", errors="ignore") as f:
            for line in f:
                if line.startswith("VmRSS:"):
                    return int(line.split()[1]) * 1024
    except Exception:
        pass
    return 0

def uptime_text(ms):
    try:
        sec=max(0, int((time.time()*1000 - int(ms or 0)) / 1000))
        d,sec=divmod(sec,86400); h,sec=divmod(sec,3600); m,_=divmod(sec,60)
        return f"{d}д {h}ч {m}м" if d else (f"{h}ч {m}м" if h else f"{m}м")
    except Exception:
        return "—"

out=[]
for p in data:
    env=p.get("pm2_env",{}) or {}
    cwd=env.get("pm_cwd","") or ""
    files=[]
    if cwd and os.path.isdir(cwd):
        for n in ("bot.py","main.py","index.py","index.js","bot.php",".env","requirements.txt","package.json",".hyper-start.sh"):
            if os.path.exists(os.path.join(cwd,n)): files.append(n)
    pid=p.get("pid") or env.get("pid") or 0
    memory=int((p.get("monit",{}) or {}).get("memory",0) or 0)
    if memory <= 0:
        memory = rss_from_pid(pid)
    cpu=float((p.get("monit",{}) or {}).get("cpu",0) or 0)
    status=env.get("status","") or "unknown"
    created=env.get("pm_uptime") or 0
    out.append({"name":p.get("name","") or "","pm_id":env.get("pm_id", p.get("pm_id", "")),"pid":pid,"status":status,"restarts":int(env.get("restart_time",0) or 0),"unstable_restarts":int(env.get("unstable_restarts",0) or 0),"memory":memory,"memory_mb":round(memory/1024/1024,1),"cpu":cpu,"cpu_percent":round(cpu,1),"cwd":cwd,"files":files,"uptime":uptime_text(created),"pm_uptime":created,"updated_at":int(time.time()),"pm2_home":os.environ.get("PM2_HOME","")})
print(json.dumps(out, ensure_ascii=False))'
}

