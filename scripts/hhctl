import glob,os,json,re
items=[]
for sock in glob.glob('/run/php/php*-fpm.sock'):
    m=re.search(r'php([0-9.]+)-fpm\.sock', sock)
    if m: items.append({'version':m.group(1),'sock':sock})
print(json.dumps(items, ensure_ascii=False))
PY
}

cmd_stats_json() { python3 - <<'PY'
import os,json,subprocess,shutil
def run(cmd):
    try: return subprocess.check_output(cmd,shell=True,text=True,stderr=subprocess.DEVNULL).strip()
    except Exception: return ''
def service(name): return run(f'systemctl is-active {name}') or 'inactive'
def meminfo():
    data={}
    try:
        for line in open('/proc/meminfo'):
            k,v=line.split(':',1); data[k]=int(v.strip().split()[0])*1024
    except Exception: pass
    t=data.get('MemTotal',0); a=data.get('MemAvailable',0); return t,max(0,t-a),a
def cpu():
    try:
        for l in open('/proc/cpuinfo',encoding='utf-8',errors='ignore'):
            if l.lower().startswith('model name'): return l.split(':',1)[1].strip()
    except Exception: pass
    return run('uname -m') or 'unknown'
def upt():
    try:
        s=int(float(open('/proc/uptime').read().split()[0])); d,s=divmod(s,86400); h,s=divmod(s,3600); m,_=divmod(s,60); return f'{d}д {h}ч {m}м' if d else f'{h}ч {m}м'
    except Exception: return 'unknown'
du=shutil.disk_usage('/'); mt,mu,ma=meminfo(); load=os.getloadavg() if hasattr(os,'getloadavg') else (0,0,0)
php=run("systemctl list-units --type=service --state=running --no-legend 'php*-fpm.service' | awk '{print $1}' | head -n1") or 'php-fpm'
pm2=run('command -v pm2 >/dev/null 2>&1 && pm2 -v || true')
print(json.dumps({'server_ip':os.environ.get('SERVER_IP',''),'panel_domain':os.environ.get('PANEL_DOMAIN',''),'cpu_model':cpu(),'cpu_cores':os.cpu_count() or 0,'load1':load[0],'load5':load[1],'load15':load[2],'uptime':upt(),'disk_total':du.total,'disk_used':du.used,'disk_free':du.free,'mem_total':mt,'mem_used':mu,'mem_available':ma,'pm2_version':pm2,'services':{'nginx':service('nginx'),'mariadb':service('mariadb'),'vsftpd':service('vsftpd'),'php_fpm':service(php),'bind9':service('bind9')},'paths':{'panel':os.environ.get('PANEL_DIR',''),'sites':os.environ.get('SITES_DIR',''),'bots':os.environ.get('BOTS_DIR',''),'ftp':os.environ.get('FTP_DIR',''),'backups':os.environ.get('BACKUP_DIR',''),'phpmyadmin':os.environ.get('PHPMYADMIN_PATH','/usr/share/phpmyadmin')}},ensure_ascii=False))
PY
}

cmd_sync_json() { python3 - <<'PY'
import os,json,glob,pwd,re,subprocess
SITES_DIR=os.environ.get('SITES_DIR','/var/www/hyper-host-sites'); BOTS_DIR=os.environ.get('BOTS_DIR','/var/www/hyper-host-bots'); FTP_DIR=os.environ.get('FTP_DIR','/var/www/hyper-host-ftp'); NGINX_AVAILABLE='/etc/nginx/sites-available'
sites=[]; folders=[]
for public_html in sorted(glob.glob(os.path.join(SITES_DIR,'*','public_html'))):
    name=os.path.basename(os.path.dirname(public_html)); conf=os.path.join(NGINX_AVAILABLE,f'hyper-host-site-{name}.conf')
    if os.path.exists(conf) and re.match(r'^([A-Za-z0-9]([A-Za-z0-9-]{0,61}[A-Za-z0-9])?\.)+[A-Za-z]{2,63}$', name):
        text=open(conf,encoding='utf-8',errors='ignore').read(); aliases=[]; m=re.search(r'server_name\s+([^;]+);', text)
        if m:
            names=[x.strip() for x in m.group(1).split() if x.strip()]; aliases=[x for x in names if x != name]
        ssl=1 if os.path.exists(f'/etc/letsencrypt/live/{name}/fullchain.pem') else 0
        phpm=re.search(r'/run/php/php([0-9.]+)-fpm\.sock', text); phpv=phpm.group(1) if phpm else ''
        sites.append({'domain':name,'aliases':','.join(aliases),'root_path':public_html,'ssl_enabled':ssl,'php_version':phpv})
    else: folders.append({'name':name,'path':public_html})
ftp=[]
for u in pwd.getpwall():
    if u.pw_name.startswith('hhftp_'):
        ftp.append({'username':u.pw_name,'target_path':u.pw_dir,'host':os.environ.get('PANEL_DOMAIN') if os.environ.get('PANEL_DOMAIN','_')!='_' else os.environ.get('SERVER_IP','')})
bots=[]
try:
    data=json.loads(subprocess.check_output('pm2 jlist',shell=True,text=True,stderr=subprocess.DEVNULL))
except Exception: data=[]
for p in data:
    name=p.get('name','')
    if not re.match(r'^[A-Za-z0-9_][A-Za-z0-9_-]{1,63}$', name): continue
    env=p.get('pm2_env',{}); path=env.get('pm_cwd') or os.path.join(BOTS_DIR,name); script=env.get('pm_exec_path',''); interp=env.get('exec_interpreter','') or ''
    runtime='custom'; cmd=os.path.basename(script) if script else ''
    if 'python' in interp or script.endswith('.py'): runtime='python'; cmd='python3 '+cmd
    elif script.endswith('.js') or 'node' in interp: runtime='node'; cmd='node '+cmd
    elif script.endswith('.php') or 'php' in interp: runtime='php'; cmd='php '+cmd
    bots.append({'name':name,'runtime':runtime,'path':path,'start_command':cmd,'memory_limit_mb':0})
databases=[]
try:
    out=subprocess.check_output("mysql -N -B -e \"SELECT Db, User, MAX(Host <> 'localhost') AS remote FROM mysql.db WHERE Db NOT IN ('mysql','performance_schema','information_schema','sys') GROUP BY Db, User ORDER BY Db\"",shell=True,text=True,stderr=subprocess.DEVNULL)
    for line in out.splitlines():
        parts=line.split('\t')
        if len(parts)>=3 and parts[0] and parts[1] and not parts[0].startswith('phpmyadmin'):
            databases.append({'db_name':parts[0],'db_user':parts[1],'remote_allowed':1 if parts[2] in ('1','true','TRUE') else 0})
except Exception: pass
print(json.dumps({'sites':sites,'folders':folders,'ftp':ftp,'databases':databases,'bots':bots},ensure_ascii=False))
PY
}



# -----------------------------
# HYPER-HOST v15: network + DNS
# -----------------------------
write_bind_authoritative_defaults() {
  mkdir -p /etc/bind/hyper-host-zones
  cat > /etc/bind/named.conf.options <<'EOBINDOPT'
options {
    directory "/var/cache/bind";
    listen-on { any; };
    listen-on-v6 { any; };
    allow-query { any; };
    recursion no;
    dnssec-validation auto;
    auth-nxdomain no;
};
EOBINDOPT
  touch /etc/bind/named.conf.local
}


extract_ipv4() {
  printf '%s' "${1:-}" | grep -Eo '([0-9]{1,3}\.){3}[0-9]{1,3}' | head -n1 || true
}

listen_port_tcp() {
  local port="$1"
  # Надёжная проверка локального прослушивания порта. Старый awk иногда брал не ту колонку ss.
  ss -H -ltn 2>/dev/null | awk -v p=":$port" '{print $4}' | grep -Eq "(^|[:\]])${port}$|:${port}$" && return 0
  ss -H -ltn "sport = :$port" 2>/dev/null | grep -q .
}

listen_port_udp() {
  local port="$1"
  ss -H -lun 2>/dev/null | awk -v p=":$port" '{print $5}' | grep -Eq "(^|[:\]])${port}$|:${port}$" && return 0
  ss -H -lun "sport = :$port" 2>/dev/null | grep -q .
}

open_server_ports() {
  # Открываем именно Ubuntu firewall. Роутер всё равно нужно пробросить вручную.
  ufw allow 80/tcp >/dev/null 2>&1 || true
  ufw allow 443/tcp >/dev/null 2>&1 || true
  ufw allow 53/tcp >/dev/null 2>&1 || true
  ufw allow 53/udp >/dev/null 2>&1 || true
  ufw allow 21/tcp >/dev/null 2>&1 || true
  ufw allow 40000:40100/tcp >/dev/null 2>&1 || true
  if command -v iptables >/dev/null 2>&1; then
    for p in 80 443 53 21; do iptables -C INPUT -p tcp --dport "$p" -j ACCEPT 2>/dev/null || iptables -I INPUT -p tcp --dport "$p" -j ACCEPT 2>/dev/null || true; done
    iptables -C INPUT -p udp --dport 53 -j ACCEPT 2>/dev/null || iptables -I INPUT -p udp --dport 53 -j ACCEPT 2>/dev/null || true
    iptables -C INPUT -p tcp --dport 40000:40100 -j ACCEPT 2>/dev/null || iptables -I INPUT -p tcp --dport 40000:40100 -j ACCEPT 2>/dev/null || true
  fi
}

ensure_nginx_public_listen() {
  systemctl enable nginx >/dev/null 2>&1 || true
  nginx_force_listen_all
  nginx -t >/dev/null 2>&1 || nginx -t
  systemctl restart nginx 2>/dev/null || systemctl reload nginx 2>/dev/null || true
}

nginx_force_listen_all() {
  # HYPER-HOST не должен биндиться на 90.x.x.x, если сервер за роутером.
  # Внешний IP находится на роутере, а nginx на Ubuntu должен слушать 0.0.0.0:80/443.
  local conf
  shopt -s nullglob
  for conf in /etc/nginx/sites-available/hyper-host-*.conf; do
    python3 - "$conf" <<'PYNGINXALL'
import sys,re,pathlib
p=pathlib.Path(sys.argv[1])
text=p.read_text(encoding='utf-8', errors='ignore')
text=re.sub(r'listen\s+\d+\.\d+\.\d+\.\d+:80\s*;', 'listen 80;', text)
text=re.sub(r'listen\s+\d+\.\d+\.\d+\.\d+:443\s+ssl([^;]*);', r'listen 443 ssl\1;', text)
text=re.sub(r'listen\s+\d+\.\d+\.\d+\.\d+:443\s*;', 'listen 443 ssl;', text)
p.write_text(text, encoding='utf-8')
PYNGINXALL
  done
  shopt -u nullglob
}

cmd_network_fix() {
  local domain="${1:-}" pub="${2:-}" zonefile=""
  pub="$(extract_ipv4 "$pub")"
  [[ -n "$pub" ]] || pub="$(extract_ipv4 "$(configured_public_ip)")"
  [[ -n "$pub" ]] || pub="$(extract_ipv4 "$(choose_ssl_expected_ip "${domain:-example.com}")")"
  [[ -n "$pub" ]] || err "Не смог определить публичный IP. Используй: sudo hyper network fix DOMAIN 90.189.208.25"
  [[ -z "$domain" || "$domain" == "_" ]] || valid_domain "$domain" || err "Invalid domain: $domain"

  cmd_public_ip set "$pub" >/dev/null 2>&1 || true
  open_server_ports
  ensure_acme_locations_all
  ensure_nginx_public_listen

  if [[ -n "$domain" && "$domain" != "_" ]]; then
    local root; root="$(site_root_for_domain "$domain")"
    ensure_acme_location_for_domain "$domain" "$root"
    # Если домен уже обслуживается нашим bind9, принудительно обновляем зону на публичный IP.
    zonefile="$DNS_DIR/db.$domain"
    if [[ -f "$zonefile" ]] || grep -Fq "zone \"$domain\"" /etc/bind/named.conf.local 2>/dev/null; then
      cmd_dns_wizard "$domain" "$pub" panel >/dev/null 2>&1 || true
    fi
  fi

  write_bind_authoritative_defaults
  systemctl enable bind9 >/dev/null 2>&1 || true
  systemctl restart bind9 2>/dev/null || true
  nginx -t >/dev/null && systemctl reload nginx || nginx -t
  log "Network fixed: nginx=0.0.0.0, server ports 80/443/53 opened, public_ip=$pub"
  echo "OK: серверная часть открыта. Если с телефона всё равно не грузит — на роутере пробрось TCP 80/443 -> $SERVER_IP и проверь, что у домена A=$pub."
}

cmd_network_doctor_json() {
  local domain="${1:-}" pub cfg out server nginx_ok bind_ok ufw_status l80 l443 l53 dns_a dns_a_local dns_status local_http local_acme root problem hint
  server="$SERVER_IP"; cfg="$(configured_public_ip)"; pub="$(public_ip)"; out="$(outbound_public_ip)"
  nginx_ok=0; nginx -t >/dev/null 2>&1 && nginx_ok=1
  bind_ok=0; systemctl is-active bind9 >/dev/null 2>&1 && bind_ok=1
  ufw_status="$(ufw status 2>/dev/null | head -n1 | sed 's/^Status: //')"
  l80=0; listen_port_tcp 80 && l80=1
  l443=0; listen_port_tcp 443 && l443=1
  l53=0; listen_port_udp 53 && l53=1
  dns_a=""; dns_a_local=""; dns_status="not_checked"; local_http=0; local_acme=0; problem=""; hint=""
  if [[ -n "$domain" ]]; then
    valid_domain "$domain" || err "Invalid domain"
    dns_a="$(resolve_domain_a_public "$domain")"
    dns_a_local="$(resolve_domain_a_local "$domain")"
    dns_status="bad"
    if [[ -z "$dns_a" ]]; then
      dns_status="missing"
      problem="Публичная DNS A-запись не найдена. У регистратора/в DNS должно быть: A $domain $pub"
    elif printf '%s\n' "$dns_a" | grep -qxF "$pub"; then
      dns_status="ok"
    else
      problem="Публичная DNS A-запись смотрит не туда. Сейчас: ${dns_a//$'\n'/, }. Нужно: $pub"
    fi
    curl -fsS --connect-timeout 1 --max-time 2 -H "Host: $domain" "http://127.0.0.1/" >/dev/null 2>&1 && local_http=1 || true
    root="$(site_root_for_domain "$domain")"
    local_http_challenge_check "$domain" "$root" && local_acme=1 || true
    if [[ "$l80" != 1 || "$l443" != 1 ]]; then problem="На Ubuntu nginx не слушает 80/443. Выполни отдельной строкой: sudo hyper network fix $domain $pub"; fi
    if [[ "$local_acme" != 1 ]]; then problem="Локально не проходит ACME challenge. Выполни отдельной строкой: sudo hyper ssl fix $domain"; fi
  fi
  if [[ -n "$server" ]] && is_private_ipv4 "$server"; then
    hint="Сервер за роутером/NAT. На Ubuntu порты открывает sudo hyper network fix, а на роутере вручную пробрось TCP 80/443 на $server. Если из Wi‑Fi внешний IP не открывается — это NAT Loopback, проверяй через мобильный интернет."
  fi
  DOMAIN="$domain" SERVER_IP="$server" PUBLIC_IP="$pub" CONFIGURED_PUBLIC_IP="$cfg" OUTBOUND_PUBLIC_IP="$out" DNS_A="$dns_a" DNS_A_LOCAL="$dns_a_local" DNS_STATUS="$dns_status" NGINX_OK="$nginx_ok" BIND_OK="$bind_ok" UFW_STATUS="$ufw_status" L80="$l80" L443="$l443" L53="$l53" LOCAL_HTTP="$local_http" LOCAL_ACME="$local_acme" PROBLEM="$problem" HINT="$hint" python3 - <<'PYNET'
import os,json
lines=lambda x:[i for i in x.splitlines() if i.strip()]
print(json.dumps({
 'domain': os.environ.get('DOMAIN',''),
 'server_ip': os.environ.get('SERVER_IP',''),
 'public_ip': os.environ.get('PUBLIC_IP',''),
 'configured_public_ip': os.environ.get('CONFIGURED_PUBLIC_IP',''),
 'outbound_public_ip': os.environ.get('OUTBOUND_PUBLIC_IP',''),
 'nat_mode': os.environ.get('SERVER_IP','').startswith(('192.168.','10.','172.16.','172.17.','172.18.','172.19.','172.20.','172.21.','172.22.','172.23.','172.24.','172.25.','172.26.','172.27.','172.28.','172.29.','172.30.','172.31.')),
 'dns_a': lines(os.environ.get('DNS_A','')),
 'dns_a_local': lines(os.environ.get('DNS_A_LOCAL','')),
 'dns_status': os.environ.get('DNS_STATUS',''),
 'nginx_ok': os.environ.get('NGINX_OK') == '1',
 'bind9_ok': os.environ.get('BIND_OK') == '1',
 'ufw_status': os.environ.get('UFW_STATUS',''),
 'listen_80': os.environ.get('L80') == '1',
 'listen_443': os.environ.get('L443') == '1',
 'listen_dns_53': os.environ.get('L53') == '1',
 'local_http_ok': os.environ.get('LOCAL_HTTP') == '1',
 'local_acme_ok': os.environ.get('LOCAL_ACME') == '1',
 'server_ports_ok': os.environ.get('L80') == '1' and os.environ.get('L443') == '1',
 'dns_ready': os.environ.get('DNS_STATUS','') == 'ok',
 'problem': os.environ.get('PROBLEM',''),
 'hint': os.environ.get('HINT',''),
}, ensure_ascii=False))
PYNET
}
cmd_dns_wizard() {
  local domain="${1:-}" pub="${2:-}" panel_sub="${3:-panel}"
  [[ -n "$domain" ]] || err "Domain required"
  valid_domain "$domain" || err "Invalid domain: $domain"
  [[ -n "$pub" ]] || pub="$(public_ip)"
  [[ "$pub" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]] || err "Invalid public IPv4: $pub"
  mkdir -p "$DNS_DIR"
  write_bind_authoritative_defaults
  local ns1="ns1.$domain." ns2="ns2.$domain." admin="admin.$domain." records
  records="$(python3 - <<PYREC
import json
pub='$pub'; panel='$panel_sub'
records=[
 {'name':'@','type':'A','value':pub,'ttl':300},
 {'name':'www','type':'A','value':pub,'ttl':300},
 {'name':panel,'type':'A','value':pub,'ttl':300},
 {'name':'ns1','type':'A','value':pub,'ttl':300},
 {'name':'ns2','type':'A','value':pub,'ttl':300},
 {'name':'@','type':'MX','value':'10 mail','ttl':3600},
 {'name':'mail','type':'A','value':pub,'ttl':3600},
 {'name':'@','type':'TXT','value':'"v=spf1 a mx ip4:%s ~all"'%pub,'ttl':3600},
]
print(json.dumps(records, ensure_ascii=False))
PYREC
)"
  cmd_dns_apply "$domain" "$records" "$ns1" "$admin"
  ufw allow 53/tcp >/dev/null 2>&1 || true
  ufw allow 53/udp >/dev/null 2>&1 || true
  systemctl restart bind9 2>/dev/null || true
  cat <<EOF
DNS зона готова: $domain

У регистратора домена поставь NS:
  ns1.$domain
  ns2.$domain

Если регистратор просит glue/IP для NS:
  ns1.$domain -> $pub
  ns2.$domain -> $pub

Потом проверка:
  dig @$pub $domain A
  dig @$pub www.$domain A
  sudo hyper dns status $domain
EOF
}

cmd_dns_status_json() {
  local domain="${1:-}" pub zonefile nscheck a_local a_public bind_ok named_ok open53
  [[ -n "$domain" ]] || err "Domain required"
  valid_domain "$domain" || err "Invalid domain"
  pub="$(public_ip)"; zonefile="$DNS_DIR/db.$domain"
  bind_ok=0; systemctl is-active bind9 >/dev/null 2>&1 && bind_ok=1
  named_ok=0; [[ -f "$zonefile" ]] && named-checkzone "$domain" "$zonefile" >/dev/null 2>&1 && named_ok=1
  open53=0; ss -lun 2>/dev/null | awk '{print $5}' | grep -Eq '(:53$|0\.0\.0\.0:53|\[::\]:53)' && open53=1
  a_local="$(dig +short @127.0.0.1 "$domain" A 2>/dev/null | sed '/^$/d' | sort -u || true)"
  a_public="$(resolve_domain_a_public "$domain")"
  DOMAIN="$domain" PUBLIC_IP="$pub" ZONEFILE="$zonefile" BIND_OK="$bind_ok" NAMED_OK="$named_ok" OPEN53="$open53" A_LOCAL="$a_local" A_PUBLIC="$a_public" python3 - <<'PYDNS'
import os,json
lines=lambda x:[i for i in x.splitlines() if i.strip()]
print(json.dumps({
 'domain': os.environ['DOMAIN'],
 'public_ip': os.environ.get('PUBLIC_IP',''),
 'zonefile': os.environ.get('ZONEFILE',''),
 'zone_exists': os.path.exists(os.environ.get('ZONEFILE','')),
 'bind9_ok': os.environ.get('BIND_OK')=='1',
 'zone_ok': os.environ.get('NAMED_OK')=='1',
 'listen_53_udp': os.environ.get('OPEN53')=='1',
 'local_a': lines(os.environ.get('A_LOCAL','')),
 'public_a': lines(os.environ.get('A_PUBLIC','')),
 'registrar_ns_required': ['ns1.'+os.environ['DOMAIN'], 'ns2.'+os.environ['DOMAIN']],
 'glue_required': {'ns1.'+os.environ['DOMAIN']: os.environ.get('PUBLIC_IP',''), 'ns2.'+os.environ['DOMAIN']: os.environ.get('PUBLIC_IP','')},
}, ensure_ascii=False))
PYDNS
}

cmd_panel_domain() {
  local action="${1:-get}" domain="${2:-}"
  case "$action" in
    get) echo "$PANEL_DOMAIN" ;;
    set|bind)
      [[ -n "$domain" ]] || err "Domain required"
      valid_domain "$domain" || err "Invalid domain"
      mkdir -p /etc/hyper-host
      if [[ -f "$CONF" ]]; then
        if grep -q '^PANEL_DOMAIN=' "$CONF"; then sed -i "s#^PANEL_DOMAIN=.*#PANEL_DOMAIN="$domain"#" "$CONF"; else echo "PANEL_DOMAIN="$domain"" >> "$CONF"; fi
      fi
      PANEL_DOMAIN="$domain"
      panel_domain_conflict_cleanup "$domain"
      write_panel_nginx_conf "$domain"
      # Если зона обслуживается нашим DNS, добавляем/обновляем panel A на публичный IP.
      local apex="${domain#panel.}" pub="$(public_ip)"
      if [[ "$apex" != "$domain" && -f "$DNS_DIR/db.$apex" ]]; then
        cmd_dns_wizard "$apex" "$pub" panel >/dev/null 2>&1 || true
      fi
      nginx -t >/dev/null && systemctl reload nginx || nginx -t
      log "Panel domain bound: $domain -> $PANEL_DIR/public. Если раньше был сайт с таким доменом, он отключён только в nginx, файлы не удалены."
      ;;
    *) err "Use: panel-domain get|set DOMAIN" ;;
  esac
}

cmd_panel_ssl() {
  local domain="${1:-$PANEL_DOMAIN}" email="${2:-}"
  [[ -n "$domain" && "$domain" != "_" ]] || err "Panel domain required. Use: sudo hyper panel domain panel.example.com"
  [[ -n "$email" ]] || err "Email required"
  valid_domain "$domain" || err "Invalid domain"
  cmd_panel_domain set "$domain" >/dev/null
  ufw allow 80/tcp >/dev/null 2>&1 || true
  ufw allow 443/tcp >/dev/null 2>&1 || true
  local root="$PANEL_DIR/public" token body check_ip expected
  mkdir -p "$root/.well-known/acme-challenge"
  token="hyper-host-panel-ssl-test-$(date +%s)-$$"
  printf 'ok-%s' "$token" > "$root/.well-known/acme-challenge/$token"
  chmod -R a+rX "$root/.well-known" 2>/dev/null || true
  body="$(curl -fsS --connect-timeout 1 --max-time 2 -H "Host: $domain" "http://127.0.0.1/.well-known/acme-challenge/$token" 2>/dev/null || true)"
  rm -f "$root/.well-known/acme-challenge/$token" 2>/dev/null || true
  [[ "$body" == "ok-$token" ]] || err "Панель локально не отдаёт ACME для $domain. Выполни: sudo hyper panel domain $domain"
  expected="$(public_ip)"
  check_ip="$(resolve_domain_a_public "$domain" | head -n1)"
  if [[ -n "$expected" && "$check_ip" != "$expected" ]]; then
    err "DNS панели смотрит не туда: $domain -> ${check_ip:-нет A}. Нужно: A $domain $expected"
  fi
  local log_file="/var/log/letsencrypt/hyper-host-panel-${domain}-$(date +%F-%H%M%S).log"
  mkdir -p /var/log/letsencrypt
  log "Panel SSL preflight OK: $domain -> $root"
  if ! certbot --nginx --non-interactive --agree-tos --email "$email" --no-eff-email --keep-until-expiring --expand --redirect --preferred-challenges http --cert-name "hyper-host-panel-$domain" -d "$domain" >"$log_file" 2>&1; then
    tail -n 120 "$log_file" >&2 || true
    err "SSL панели не выпущен. Лог: $log_file. Проверь проброс TCP 80/443 на $SERVER_IP."
  fi
  nginx_reload
  log "Panel SSL issued: https://$domain / log: $log_file"
}


cmd_repair() {
  ensure_dirs; ensure_nologin_shell; ensure_bot_user; cleanup_hyper_host_mounts; ensure_acme_locations_all
  mkdir -p "$BASE_DIR/data" "$PANEL_DIR" "$SITES_DIR" "$BOTS_DIR" "$FTP_DIR" "$BACKUP_DIR" "$BASE_DIR/templates" /etc/hyper-host
  safe_chown_tree www-data:www-data "$PANEL_DIR"
  safe_chown_tree www-data:www-data "$BASE_DIR/data"
  chmod 0770 "$BASE_DIR/data" 2>/dev/null || true
  if [[ -f "$BASE_DIR/data/hyperhost.sqlite" ]]; then chown www-data:www-data "$BASE_DIR/data/hyperhost.sqlite" "$BASE_DIR/data/hyperhost.sqlite"-* 2>/dev/null || true; chmod 0660 "$BASE_DIR/data/hyperhost.sqlite" "$BASE_DIR/data/hyperhost.sqlite"-* 2>/dev/null || true; fi
  fix_web_permissions "$SITES_DIR"; fix_web_permissions "$BOTS_DIR" "$BOT_USER"; chmod 0755 "$FTP_DIR" "$BACKUP_DIR" 2>/dev/null || true

  # Убираем старые сломанные bind-mount'ы, которые могли попасть в public_html или старые FTP homes.
  mapfile -t bad_mounts < <(awk '{print $5}' /proc/self/mountinfo | sed 's/\\040/ /g' | grep -E '^/var/www/hyper-host-(ftp|sites)/' | grep -E '/(common|sites|bots|site)(/|$)' | sort -r || true)
  for mp in "${bad_mounts[@]}"; do umount -lf "$mp" 2>/dev/null || true; done
  if [[ -f /etc/fstab ]]; then
    sed -i.bak -E '/hyper-host-ftp|hyper-host-sites\/.*\/(common|sites|bots|site)|public_html\/(common|sites|bots|site)/d' /etc/fstab || true
  fi

  while IFS=: read -r user _ uid gid gecos old_home shell; do
    [[ "$user" == hhftp_* ]] || continue
    home="$FTP_DIR/$user"; common="$home/common"; sites="$common/sites"; bots="$common/bots"
    mkdir -p "$common" "$sites" "$bots"
    usermod -d "$home" -s /usr/sbin/nologin "$user" 2>/dev/null || true
    chown root:root "$home" 2>/dev/null || true; chmod 0755 "$home" 2>/dev/null || true
    chown -R "$user":www-data "$common" 2>/dev/null || true; chmod -R u+rwX,g+rwX,o+rX "$common" 2>/dev/null || true
    mountpoint -q "$sites" || mount --bind "$SITES_DIR" "$sites" 2>/dev/null || true
    mountpoint -q "$bots" || mount --bind "$BOTS_DIR" "$bots" 2>/dev/null || true
    fix_web_permissions "$SITES_DIR" "$user"; fix_web_permissions "$BOTS_DIR" "$user"; fix_web_permissions "$common" "$user"
  done < /etc/passwd

  if command -v pm2 >/dev/null 2>&1; then
    pm2_persist
  fi

  cat > /etc/sudoers.d/hyper-host <<EOSUDO
www-data ALL=(root) NOPASSWD: /usr/local/sbin/hyper-host-ctl *
EOSUDO
  chmod 0440 /etc/sudoers.d/hyper-host; visudo -cf /etc/sudoers.d/hyper-host >/dev/null
  open_server_ports
  ensure_nginx_public_listen
  systemctl restart vsftpd 2>/dev/null || true; systemctl reload nginx 2>/dev/null || systemctl restart nginx 2>/dev/null || true
  log "Repair finished: permissions, ACL, FTP safe homes, PM2 hyperbot and services checked"
}

case "${1:-}" in
  create-folder) shift; cmd_create_folder "$@" ;;
  delete-folder) shift; cmd_delete_folder "$@" ;;
  add-site) shift; cmd_add_site "$@" ;;
  delete-site) shift; cmd_delete_site "$@" ;;
  ssl-site) shift; cmd_ssl_site "$@" ;;
  ssl-fix-site) shift; cmd_ssl_fix_site "$@" ;;
  ssl-ip-selfsigned) shift; cmd_ssl_ip_selfsigned "$@" ;;
  public-ip) shift; cmd_public_ip "$@" ;;
  site-php) shift; cmd_site_php "$@" ;;
  create-ftp) shift; cmd_create_ftp "$@" ;;
  delete-ftp) shift; cmd_delete_ftp "$@" ;;
  ftp-password) shift; cmd_ftp_password "$@" ;;
  create-db) shift; cmd_create_db "$@" ;;
  delete-db) shift; cmd_delete_db "$@" ;;
  mysql-external) shift; cmd_mysql_external "$@" ;;
  bot-create) shift; cmd_bot_create "$@" ;;
  bot-deploy) shift; cmd_bot_deploy "$@" ;;
  bot-install-requirements) shift; cmd_bot_install_requirements "$@" ;;
  bot-delete) shift; cmd_bot_delete "$@" ;;
  bot) shift; cmd_bot_action "$@" ;;
  bot-list-json) shift; cmd_bot_list_json "$@" ;;
  bot-doctor) shift; cmd_bot_doctor "$@" ;;
