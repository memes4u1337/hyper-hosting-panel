#!/usr/bin/env bash
set -Eeo pipefail

CTL="/usr/local/sbin/hyper-host-ctl"
REPO_URL="https://github.com/memes4u1337/hyper-hosting-panel.git"
REPO_DIR="/root/hyper-hosting-panel"
DEV_HANDLE="@memes4u1337"
PANEL="HYPER-HOST"

[[ -x "$CTL" ]] || { echo "[hyper] Не найден $CTL. Сначала установи HYPER-HOST: sudo bash install.sh" >&2; exit 2; }

say() { printf '\033[1;36m%s\033[0m\n' "$*"; }
warn() { printf '\033[1;33m%s\033[0m\n' "$*"; }
err() { printf '\033[1;31m%s\033[0m\n' "$*" >&2; exit 1; }

json_pretty() {
  python3 -m json.tool 2>/dev/null || cat
}

human_bytes_py='''
import sys
n=float(sys.argv[1]) if len(sys.argv)>1 and sys.argv[1] else 0
for u in ["B","KB","MB","GB","TB"]:
    if n < 1024 or u == "TB":
        print((f"{n:.0f} {u}" if u=="B" else f"{n:.1f} {u}")); break
    n/=1024
'''
hbytes() { python3 -c "$human_bytes_py" "${1:-0}" 2>/dev/null || echo "${1:-0} B"; }

cmd_dev() {
  cat <<EOF
🚀 $PANEL
Разработчик: $DEV_HANDLE
Powered by: memes4u1337
GitHub: $REPO_URL
Команда помощи: sudo hyper help
EOF
}

cmd_stats() {
  local json
  json="$($CTL stats-json 2>/dev/null || echo '{}')"
  JSON="$json" python3 - <<'PY'
import os,json
j=json.loads(os.environ.get('JSON','{}') or '{}')
def hb(n):
    try: n=float(n)
    except Exception: n=0
    for u in ['B','KB','MB','GB','TB']:
        if n < 1024 or u == 'TB':
            return (f'{n:.0f} {u}' if u=='B' else f'{n:.1f} {u}')
        n/=1024
svc=j.get('services',{}) or {}; p=j.get('paths',{}) or {}
print('🚀 HYPER-HOST — SERVER STATS')
print('────────────────────────────')
print(f"IP панели:       {j.get('server_ip','')}")
print(f"Домен панели:    {j.get('panel_domain','')}")
print(f"CPU:             {j.get('cpu_model','unknown')}")
print(f"Ядер:            {j.get('cpu_cores',0)}")
print(f"Load:            {j.get('load1',0):.2f} / {j.get('load5',0):.2f} / {j.get('load15',0):.2f}")
print(f"Uptime:          {j.get('uptime','unknown')}")
print(f"RAM:             {hb(j.get('mem_used',0))} / {hb(j.get('mem_total',0))} свободно {hb(j.get('mem_available',0))}")
print(f"Disk:            {hb(j.get('disk_used',0))} / {hb(j.get('disk_total',0))} свободно {hb(j.get('disk_free',0))}")
print(f"PM2:             {j.get('pm2_version','') or 'not installed'}")
print('')
print('Сервисы:')
for k in ['nginx','mariadb','php_fpm','vsftpd','bind9']:
    print(f"  {k:<10} {svc.get(k,'unknown')}")
print('')
print('Пути:')
for k in ['panel','sites','bots','ftp','backups','phpmyadmin']:
    if p.get(k): print(f"  {k:<10} {p.get(k)}")
PY
}

cmd_bots() {
  local json
  json="$($CTL bot-list-json 2>/dev/null || echo '[]')"
  JSON="$json" python3 - <<'PY'
import os,json
try: data=json.loads(os.environ.get('JSON','[]') or '[]')
except Exception: data=[]
def hb(n):
    try: n=float(n)
    except Exception: n=0
    for u in ['B','KB','MB','GB','TB']:
        if n < 1024 or u == 'TB': return f'{n:.1f} {u}' if u!='B' else f'{n:.0f} {u}'
        n/=1024
print('🤖 HYPER-HOST — BOTS')
print('────────────────────')
if not data:
    print('Ботов в PM2 пока нет.')
    raise SystemExit
print(f"{'NAME':<24} {'STATUS':<12} {'CPU':<7} {'RAM':<12} {'RESTARTS':<8} PATH")
for b in data:
    print(f"{b.get('name',''):<24} {b.get('status',''):<12} {str(b.get('cpu',0)):<7} {hb(b.get('memory',0)):<12} {str(b.get('restarts',0)):<8} {b.get('cwd','')}")
PY
}

cmd_sites() {
  local json
  json="$($CTL sync-json 2>/dev/null || echo '{}')"
  JSON="$json" python3 - <<'PY'
import os,json
j=json.loads(os.environ.get('JSON','{}') or '{}')
sites=j.get('sites',[]) or []; folders=j.get('folders',[]) or []
print('🌐 HYPER-HOST — SITES')
print('─────────────────────')
if not sites and not folders:
    print('Сайтов/папок пока нет.'); raise SystemExit
if sites:
    print(f"{'DOMAIN':<32} {'SSL':<8} ROOT")
    for s in sites:
        print(f"{s.get('domain',''):<32} {('yes' if s.get('ssl_enabled') else 'no'):<8} {s.get('root_path','')}")
if folders:
    print('\nПапки без nginx-домена:')
    for f in folders: print(f"  {f.get('name','')} -> {f.get('path','')}")
PY
}

cmd_ftp() {
  local sub="${1:-list}"
  if [[ "$sub" == "fix" ]]; then $CTL ftp-fix; return; fi
  if [[ "$sub" == "doctor" || "$sub" == "status" ]]; then $CTL ftp-doctor-json | json_pretty; return; fi
  local json
  json="$($CTL sync-json 2>/dev/null || echo '{}')"
  JSON="$json" python3 - <<'PY'
import os,json
j=json.loads(os.environ.get('JSON','{}') or '{}')
items=j.get('ftp',[]) or []
print('📁 HYPER-HOST — FTP')
print('──────────────────')
if not items:
    print('FTP-пользователей пока нет.'); raise SystemExit
print(f"{'USER':<28} {'HOST':<18} HOME")
for x in items:
    print(f"{x.get('username',''):<28} {x.get('host',''):<18} {x.get('target_path','')}")
PY
}

cmd_dbs() {
  local sub="${1:-list}"; shift || true
  case "$sub" in
    list|status)
      local json mjson
      json="$($CTL sync-json 2>/dev/null || echo '{}')"
      mjson="$($CTL mysql-status-json 2>/dev/null || echo '{}')"
      JSON="$json" MYSQL="$mjson" python3 - <<'PY'
import os,json
j=json.loads(os.environ.get('JSON','{}') or '{}')
m=json.loads(os.environ.get('MYSQL','{}') or '{}')
items=j.get('databases',[]) or []
print('🗄️ HYPER-HOST — DATABASES')
print('────────────────────────')
print(f"MariaDB: {m.get('service','unknown')} | bind: {m.get('bind_address','unknown')} | 3306: {'listen' if m.get('listen_3306') else 'closed/local'}")
print(f"Для бота на сервере: MYSQL_HOST=127.0.0.1 MYSQL_PORT=3306")
print(f"Для бота на ПК в той же сети: MYSQL_HOST={m.get('lan_host','')} MYSQL_PORT=3306")
print(f"SQL host для внешнего подключения: {m.get('external_host','')}:3306")
print(f"SQL host внутри сети: {m.get('lan_host','')}:3306")
if not items:
    print('Баз данных панели пока нет.'); raise SystemExit
print(f"{'DB':<32} {'USER':<32} REMOTE")
for x in items:
    print(f"{x.get('db_name',''):<32} {x.get('db_user',''):<32} {('yes' if x.get('remote_allowed') else 'no')}")
PY
      ;;
    external) [[ "${1:-}" == enable || "${1:-}" == disable ]] || err "Используй: sudo hyper db external enable|disable"; $CTL mysql-external "$1"; $CTL mysql-status-json | json_pretty ;;
    doctor) $CTL mysql-doctor-json | json_pretty ;;
    pma-fix) $CTL phpmyadmin-fix ;;
    test) shift || true; [[ -n "${1:-}" && -n "${2:-}" && -n "${3:-}" ]] || err "Используй: sudo hyper db test HOST USER PASS [DB]"; $CTL mysql-test "$@" ;;
    user) [[ -n "${1:-}" && -n "${2:-}" ]] || err "Используй: sudo hyper db user USER PASS [DB] [HOST]"; $CTL create-mysql-account "$1" "$2" "${4:-%}" "${3:-}" ALL ;;
    *) err "Используй: sudo hyper db list | doctor | pma-fix | external enable|disable | user USER PASS [DB] [%|IP] | test HOST USER PASS [DB]" ;;
  esac
}

cmd_ssl() {
  local sub="${1:-status}"; shift || true
  case "$sub" in
    status|list)
      local json
      json="$($CTL ssl-status-json 2>/dev/null || echo '[]')"
      JSON="$json" python3 - <<'PY'
import os,json
try: data=json.loads(os.environ.get('JSON','[]') or '[]')
except Exception: data=[]
print('🔐 HYPER-HOST — SSL')
print('──────────────────')
if not data:
    print('Сертификатов пока нет.'); raise SystemExit
print(f"{'DOMAIN':<36} {'DAYS':<8} STATUS")
for x in data:
    print(f"{x.get('domain',''):<36} {str(x.get('days_left','')):<8} {x.get('status','')}")
PY
      ;;
    check) [[ -n "${1:-}" ]] || err "Используй: sudo hyper ssl check DOMAIN"; $CTL ssl-check-json "$1" | json_pretty ;;
    fix) [[ -n "${1:-}" ]] || err "Используй: sudo hyper ssl fix DOMAIN"; $CTL ssl-fix-site "$1" ;;
    issue|create) [[ -n "${1:-}" && -n "${2:-}" ]] || err "Используй: sudo hyper ssl issue DOMAIN EMAIL"; $CTL ssl-site "$1" "$2" ;;
    panel) [[ -n "${1:-}" && -n "${2:-}" ]] || err "Используй: sudo hyper ssl panel panel.example.com EMAIL"; $CTL panel-ssl "$1" "$2" ;;
    ip|local-ip) $CTL ssl-ip-selfsigned "${1:-}" ;;
    renew) $CTL ssl-renew-all ;;
    *) err "SSL команды: sudo hyper ssl status | check DOMAIN | fix DOMAIN | issue DOMAIN EMAIL | panel PANEL_DOMAIN EMAIL | ip [192.168.0.179] | renew" ;;
  esac
}

cmd_bot() {
  local sub="${1:-}"; shift || true
  case "$sub" in
    list|status|'') cmd_bots ;;
    start|stop|restart|logs|kill-conflicts|fix|status-one)
      [[ -n "${1:-}" ]] || err "Используй: sudo hyper bot $sub NAME"
      local action="$sub"; [[ "$action" == "fix" ]] && action="kill-conflicts"; [[ "$action" == "status-one" ]] && action="status"
      $CTL bot "$action" "$1"
      ;;
    delete)
      [[ -n "${1:-}" ]] || err "Используй: sudo hyper bot delete NAME [--delete-files]"
      if [[ "${2:-}" == "--delete-files" ]]; then $CTL bot-delete "$1" --delete-files; else $CTL bot-delete "$1" --keep-files; fi
      ;;
    create)
      [[ -n "${1:-}" && -n "${2:-}" && -n "${3:-}" ]] || err "Используй: sudo hyper bot create NAME python|node|php|custom MAIN_FILE [MEM_MB]"
      $CTL bot-create "$@"
      ;;
    doctor) $CTL bot-doctor ;;
    persist|24) $CTL pm2-persist ;;
    *) err "Bot команды: list, start NAME, stop NAME, restart NAME, logs NAME, fix NAME, delete NAME [--delete-files], create NAME runtime main, doctor, persist" ;;
  esac
}

cmd_panel() {
  local sub="${1:-status}"; shift || true
  case "$sub" in
    status) echo "Панель: $($CTL panel-domain get 2>/dev/null || echo '_')" ;;
    domain|bind) [[ -n "${1:-}" ]] || err "Используй: sudo hyper panel domain panel.hyper-host.pw"; $CTL panel-domain set "$1" ;;
    ssl) [[ -n "${1:-}" && -n "${2:-}" ]] || err "Используй: sudo hyper panel ssl panel.hyper-host.pw EMAIL"; $CTL panel-ssl "$1" "$2" ;;
    *) err "Panel команды: sudo hyper panel domain DOMAIN | sudo hyper panel ssl DOMAIN EMAIL | sudo hyper panel status" ;;
  esac
}

cmd_status() {
  cmd_dev
  echo
  cmd_stats
  echo
  cmd_bots
}

cmd_update() {
  [[ "${EUID}" -eq 0 ]] || err "Запусти: sudo hyper update"
  cd /root
  if [[ ! -d "$REPO_DIR/.git" ]]; then
    git clone "$REPO_URL" "$REPO_DIR"
  fi
  cd "$REPO_DIR"
  git fetch origin main
  git checkout main
  git reset --hard origin/main
  git clean -fd
  chmod +x install.sh uninstall.sh scripts/hhctl scripts/hyper 2>/dev/null || true
  bash install.sh
  $CTL repair
  $CTL pm2-persist
  $CTL sync-json >/dev/null 2>&1 || true
  nginx -t
  systemctl reload nginx
  systemctl restart vsftpd 2>/dev/null || true
  say "Обновление HYPER-HOST из GitHub завершено."
}


cmd_network() {
  local sub="${1:-doctor}"; shift || true
  case "$sub" in
    doctor|check)
      $CTL network-doctor-json "${1:-}" | json_pretty
      ;;
    fix|open)
      $CTL network-fix "${1:-}" "${2:-}"
      ;;
    public-ip)
      local act="${1:-get}"; shift || true
      $CTL public-ip "$act" "$@"
      ;;
    panel-domain)
      local act="${1:-get}"; shift || true
      $CTL panel-domain "$act" "$@"
      ;;
    *) err "Network команды: sudo hyper network doctor [DOMAIN] | fix DOMAIN PUBLIC_IP | open DOMAIN PUBLIC_IP | public-ip set IP | panel-domain set DOMAIN" ;;
  esac
}

cmd_dns() {
  local sub="${1:-status}"; shift || true
  case "$sub" in
    wizard|setup)
      [[ -n "${1:-}" ]] || err "Используй: sudo hyper dns wizard DOMAIN [PUBLIC_IP] [panel]"
      $CTL dns-wizard "$@"
      ;;
    status|check)
      [[ -n "${1:-}" ]] || err "Используй: sudo hyper dns status DOMAIN"
      $CTL dns-status-json "$1" | json_pretty
      ;;
    apply)
      [[ -n "${1:-}" && -n "${2:-}" ]] || err "Используй: sudo hyper dns apply DOMAIN RECORDS_JSON"
      $CTL dns-apply "$@"
      ;;
    delete)
      [[ -n "${1:-}" ]] || err "Используй: sudo hyper dns delete DOMAIN"
      $CTL dns-delete "$1"
      ;;
    guide)
      cat <<'EODNSGUIDE'
DNS перенос домена на HYPER-HOST:

1) На сервере:
   sudo hyper network fix hyper-host.pw 90.189.208.25
   sudo hyper dns wizard hyper-host.pw 90.189.208.25 panel

2) У регистратора домена укажи NS:
   ns1.hyper-host.pw
   ns2.hyper-host.pw

3) Если регистратор просит Glue/IP:
   ns1.hyper-host.pw -> 90.189.208.25
   ns2.hyper-host.pw -> 90.189.208.25

4) На роутере пробросить:
   TCP 80  -> 192.168.0.179:80
   TCP 443 -> 192.168.0.179:443
   TCP/UDP 53 -> 192.168.0.179:53

5) Проверка:
   sudo hyper dns status hyper-host.pw
   sudo hyper network doctor hyper-host.pw
   sudo hyper ssl check hyper-host.pw
EODNSGUIDE
      ;;
    *) err "DNS команды: sudo hyper dns wizard DOMAIN [IP] | status DOMAIN | guide | delete DOMAIN" ;;
  esac
}

cmd_backup() {
  local sub="${1:-list}"; shift || true
  case "$sub" in
    list) $CTL backup-list-json | json_pretty ;;
    run) $CTL backup-run "${1:-all}" ;;
    schedule) [[ -n "${1:-}" && -n "${2:-}" ]] || err "Используй: sudo hyper backup schedule NAME '0 3 * * *' [all|sites|bots|db|panel]"; $CTL backup-schedule "$1" "$2" "${3:-all}" ;;
    delete-schedule) [[ -n "${1:-}" ]] || err "Используй: sudo hyper backup delete-schedule NAME"; $CTL backup-delete-schedule "$1" ;;
    *) err "Backup команды: list, run [target], schedule NAME 'cron' [target], delete-schedule NAME" ;;
  esac
}

cmd_php() { $CTL php-list-json | json_pretty; }
cmd_repair() { $CTL repair; }
cmd_doctor() { $CTL bot-doctor; }
cmd_sync() { $CTL sync-json | json_pretty; }
cmd_raw() { $CTL "$@"; }

cmd_help() {
  cat <<'EOF'
🚀 HYPER-HOST CLI
Разработчик: @memes4u1337

Основные команды:
  sudo hyper dev                     кто разработчик
  sudo hyper stats                   вся информация о сервере
  sudo hyper status                  dev + stats + bots
  sudo hyper bots                    список ботов и статус
  sudo hyper sites                   список сайтов
  sudo hyper ssl status              список SSL сертификатов
  sudo hyper panel domain DOMAIN      привязать домен именно к панели
  sudo hyper panel ssl DOMAIN EMAIL   выпустить SSL для панели
  sudo hyper ftp                     FTP-пользователи
  sudo hyper ftp doctor              диагностика FTP/vsftpd/passive
  sudo hyper ftp fix                 починить FTP для FileZilla
  sudo hyper access guide            гайд по подключению с любого ПК/интернета
  sudo hyper access doctor           диагностика портов SSH/FTP/HTTP/MySQL
  sudo hyper access fix              открыть доступ с другого ПК на Ubuntu
  sudo hyper disk guide              гайд по расширению диска
  sudo hyper disk doctor             диагностика LVM/размера root
  sudo hyper disk expand             расширить root LVM на весь диск
  sudo hyper dbs
  sudo hyper db status
  sudo hyper db doctor
  sudo hyper db external enable
  sudo hyper db user USER PASS DB %
  sudo hyper db test HOST USER PASS DB                     базы данных
  sudo hyper db external enable      открыть MySQL 3306 наружу
  sudo hyper db pma-fix              показать правильный SQL host в phpMyAdmin
  sudo hyper db user USER PASS DB %    создать пользователя для внешнего входа
  sudo hyper db user USER PASS DB    создать MySQL/phpMyAdmin аккаунт
  sudo hyper php                     PHP-FPM версии
  sudo hyper repair                  починить права/FTP/PM2/Nginx
  sudo hyper update                  обновить панель из GitHub
  sudo hyper network doctor DOMAIN   проверить внешний/внутренний доступ
  sudo hyper network fix DOMAIN IP   починить nginx/ufw/public-ip
  sudo hyper dns wizard DOMAIN IP    создать DNS-зону для переноса домена
  sudo hyper dns status DOMAIN       проверить нашу DNS-зону
  sudo hyper help                    помощь

Боты:
  sudo hyper bot list
  sudo hyper bot create NAME python bot.py 512
  sudo hyper bot start NAME
  sudo hyper bot stop NAME
  sudo hyper bot restart NAME
  sudo hyper bot logs NAME
  sudo hyper bot fix NAME            убрать локальные дубли / TelegramConflict
  sudo hyper bot delete NAME
  sudo hyper bot delete NAME --delete-files
  sudo hyper bot persist             включить 24/7 автозапуск через systemd
  sudo hyper bot doctor

SSL:
  sudo hyper network doctor DOMAIN
  sudo hyper network fix DOMAIN 90.189.208.25
  sudo hyper ssl check DOMAIN
  sudo hyper ssl fix DOMAIN
  sudo hyper ssl issue DOMAIN EMAIL
  sudo hyper ssl panel panel.hyper-host.pw EMAIL
  sudo hyper ssl ip 192.168.0.179
  sudo hyper ssl renew

DNS:
  sudo hyper dns wizard hyper-host.pw 90.189.208.25 panel
  sudo hyper dns status hyper-host.pw
  sudo hyper dns guide

Доступ с другого ПК/интернета:
  sudo hyper access guide
  sudo hyper access fix
  sudo hyper access doctor

Диск 1ТБ вместо 98ГБ:
  sudo hyper disk guide
  sudo hyper disk doctor
  sudo hyper disk expand

Сайты/низкий уровень:
  sudo hyper raw add-site DOMAIN [ALIASES]
  sudo hyper raw delete-site DOMAIN [--delete-files]
  sudo hyper raw create-ftp USER PASS
  sudo hyper raw create-db DB USER PASS [0|1]
  sudo hyper raw create-mysql-account USER PASS localhost DB ALL
  sudo hyper raw mysql-external enable|disable
  sudo hyper raw site-logs DOMAIN error 200

EOF
}



cmd_access() {
  local sub="${1:-guide}"; shift || true
  case "$sub" in
    guide|help) $CTL access-guide ;;
    doctor|status|check) $CTL access-doctor-json | json_pretty ;;
    fix|open) $CTL access-fix ;;
    *) err "Access команды: sudo hyper access guide | doctor | fix" ;;
  esac
}

cmd_disk() {
  local sub="${1:-guide}"; shift || true
  case "$sub" in
    guide|help) $CTL disk-guide ;;
    doctor|status|check) $CTL disk-doctor-json | json_pretty ;;
    expand|resize) $CTL disk-expand ;;
    *) err "Disk команды: sudo hyper disk guide | doctor | expand" ;;
  esac
}

cmd_db_status() {
  say "🛢 HYPER-HOST — DATABASES"
  $CTL mysql-status-json | json_pretty
}
cmd_db_doctor() {
  say "🧪 HYPER-HOST — MYSQL DOCTOR"
  $CTL mysql-doctor-json | json_pretty
}
cmd_db_external() {
  local state="${1:-status}"
  case "$state" in
    enable|on) $CTL mysql-external enable ;;
    disable|off) $CTL mysql-external disable ;;
    status) cmd_db_status ;;
    *) err "Используй: sudo hyper db external enable|disable" ;;
  esac
}
cmd_db_user() {
  local user="${1:-}" pass="${2:-}" db="${3:-}" host="${4:-%}"
  [[ -n "$user" && -n "$pass" ]] || err "Используй: sudo hyper db user USER PASS [DB] [HOST]"
  $CTL create-mysql-account "$user" "$pass" "$host" "$db" ALL
  say "Готово. Для внешнего бота host=${host}. В .env используй MYSQL_HOST=panel.hyper-host.pw или 192.168.0.179 если бот в локальной сети."
}
cmd_db_test() {
  local host="${1:-127.0.0.1}" user="${2:-}" pass="${3:-}" db="${4:-}"
  $CTL mysql-test "$host" "$user" "$pass" "$db"
}

case "${1:-help}" in
  dev) shift; cmd_dev "$@" ;;
  stats) shift; cmd_stats "$@" ;;
  status) shift; cmd_status "$@" ;;
  bots) shift; cmd_bots "$@" ;;
  bot) shift; cmd_bot "$@" ;;
  sites) shift; cmd_sites "$@" ;;
  ftp) shift; cmd_ftp "$@" ;;
  access) shift; cmd_access "$@" ;;
  disk) shift; cmd_disk "$@" ;;
  db|dbs|databases) shift; cmd_dbs "$@" ;;
  ssl) shift; cmd_ssl "$@" ;;
  panel) shift; cmd_panel "$@" ;;
  network|net) shift; cmd_network "$@" ;;
  dns) shift; cmd_dns "$@" ;;
  backup|backups) shift; cmd_backup "$@" ;;
  php) shift; cmd_php "$@" ;;
  repair) shift; cmd_repair "$@" ;;
  doctor) shift; cmd_doctor "$@" ;;
  sync) shift; cmd_sync "$@" ;;
  update) shift; cmd_update "$@" ;;
  raw) shift; cmd_raw "$@" ;;
  help|-h|--help|'') cmd_help ;;
  *) err "Неизвестная команда: $1. Помощь: sudo hyper help" ;;
esac
